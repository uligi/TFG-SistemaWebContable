@{
    ViewBag.Title = "Períodos Contables";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h4 class="font-weight-bold py-3 mb-0">Gestionar Períodos Contables</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Períodos Contables</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de períodos contables</h6>

        <div>
            <button type="button" class="btn btn-outline-info btn-sm mr-2" data-toggle="modal" data-target="#ModalAyudaPeriodo">
                ¿Cómo funciona?
            </button>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nuevo período
            </button>
        </div>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar por año, mes o estado...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaPeriodosContables">
                <thead>
                    <tr>
                        <th>Año</th>
                        <th>Mes</th>
                        <th>Fecha inicio</th>
                        <th>Fecha fin</th>
                        <th>Estado</th>
                        <th>Activo</th>
                        <th style="width:230px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo período contable</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdPeriodoContable" value="0" />

                <div class="form-row">

                    <div class="form-group col-md-6">
                        <label for="txtAnio">Año</label>
                        <input type="number" id="txtAnio" class="form-control" min="2000" max="2100" step="1" />
                    </div>

                    <div class="form-group col-md-6">
                        <label for="cboMes">Mes</label>
                        <select id="cboMes" class="form-control">
                            <option value="0">Seleccione un mes</option>
                            <option value="1">Enero</option>
                            <option value="2">Febrero</option>
                            <option value="3">Marzo</option>
                            <option value="4">Abril</option>
                            <option value="5">Mayo</option>
                            <option value="6">Junio</option>
                            <option value="7">Julio</option>
                            <option value="8">Agosto</option>
                            <option value="9">Septiembre</option>
                            <option value="10">Octubre</option>
                            <option value="11">Noviembre</option>
                            <option value="12">Diciembre</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-6">
                        <label for="txtFechaInicio">Fecha inicio</label>
                        <input type="date" id="txtFechaInicio" class="form-control" />
                    </div>

                    <div class="form-group col-md-6">
                        <label for="txtFechaFin">Fecha fin</label>
                        <input type="date" id="txtFechaFin" class="form-control" />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-6">
                        <label for="cboEstado">Estado</label>
                        <select id="cboEstado" class="form-control">
                            <option value="Abierto">Abierto</option>
                            <option value="Cerrado">Cerrado</option>
                        </select>
                    </div>

                    <div class="form-group col-md-6">
                        <label for="cboActivo">Activo</label>
                        <select id="cboActivo" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="alert alert-info">
                    Solo puede existir un período contable abierto a la vez.
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarPeriodoContable()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>
<div class="modal fade" id="ModalAyudaPeriodo" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Guía rápida de períodos contables</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <p class="mb-2">
                    Esta pantalla permite controlar los meses contables en los que se registrarán movimientos del sistema.
                </p>

                <ul class="mb-3">
                    <li>Cree un período por cada mes contable.</li>
                    <li>Solo puede existir un período abierto a la vez.</li>
                    <li>Un período abierto permite registrar movimientos contables.</li>
                    <li>Un período cerrado ya no debería recibir nuevos movimientos.</li>
                    <li>Use <strong>Cerrar</strong> cuando termine de registrar las operaciones del mes.</li>
                    <li>Use <strong>Inactivar</strong> solo si el período fue creado por error y ya está cerrado.</li>
                </ul>

                <div class="alert alert-light border mb-0">
                    <strong>Nota:</strong> al seleccionar el año y el mes, el sistema genera automáticamente la fecha de inicio y la fecha final.
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>
@section scripts {
    <script>
        var listaPeriodosContables = [];

        $(document).ready(function () {
            cargarPeriodosContables();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });

            $("#txtAnio, #cboMes").on("change", function () {
                generarFechasPeriodo();
            });
        });

        function cargarPeriodosContables() {
            $.ajax({
                url: '@Url.Action("ListarPeriodosContables", "GestionarPeriodoContable")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaPeriodosContables = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los períodos contables.");
                }
            });
        }

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaPeriodosContables tbody");

            tbody.empty();

            if (listaPeriodosContables.length === 0) {
                tbody.append(`
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No hay períodos contables registrados.
                        </td>
                    </tr>
                `);
                return;
            }

            $.each(listaPeriodosContables, function (i, item) {
                var anio = item.Anio || "";
                var mes = obtenerNombreMes(item.Mes);
                var estadoTexto = item.Estado || "";

                var texto = (anio + " " + mes + " " + estadoTexto).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = estadoTexto === "Abierto"
                    ? '<span class="badge badge-success">Abierto</span>'
                    : '<span class="badge badge-secondary">Cerrado</span>';

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-light">No</span>';

                var botonCerrar = "";

                if (item.Estado === "Abierto" && item.Activo) {
                    botonCerrar = `
                        <button type="button" class="btn btn-sm btn-outline-warning" onclick="cerrarPeriodoContable(${item.IdPeriodoContable})">
                            Cerrar
                        </button>
                    `;
                }

                var fila = `
                    <tr>
                        <td>${anio}</td>
                        <td>${mes}</td>
                        <td>${formatearFecha(item.FechaInicio)}</td>
                        <td>${formatearFecha(item.FechaFin)}</td>
                        <td>${estado}</td>
                        <td>${activo}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            ${botonCerrar}
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarPeriodoContable(${item.IdPeriodoContable})">
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtIdPeriodoContable").val(0);
            $("#txtAnio").val(new Date().getFullYear());
            $("#cboMes").val(new Date().getMonth() + 1);
            $("#cboEstado").val("Abierto");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo período contable");

            generarFechasPeriodo();

            if (json != null) {
                $("#txtIdPeriodoContable").val(json.IdPeriodoContable);
                $("#txtAnio").val(json.Anio);
                $("#cboMes").val(json.Mes);
                $("#txtFechaInicio").val(convertirFechaInput(json.FechaInicio));
                $("#txtFechaFin").val(convertirFechaInput(json.FechaFin));
                $("#cboEstado").val(json.Estado);
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar período contable");
            }

            $("#FormModal").modal("show");
        }

        function guardarPeriodoContable() {
            var obj = {
                IdPeriodoContable: parseInt($("#txtIdPeriodoContable").val()),
                Anio: parseInt($("#txtAnio").val()),
                Mes: parseInt($("#cboMes").val()),
                FechaInicio: $("#txtFechaInicio").val(),
                FechaFin: $("#txtFechaFin").val(),
                Estado: $("#cboEstado").val(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.Anio) || obj.Anio < 2000 || obj.Anio > 2100) {
                $("#mensajeError").text("Debe ingresar un año válido.").show();
                return;
            }

            if (isNaN(obj.Mes) || obj.Mes < 1 || obj.Mes > 12) {
                $("#mensajeError").text("Debe seleccionar un mes válido.").show();
                return;
            }

            if (obj.FechaInicio === "") {
                $("#mensajeError").text("Debe ingresar la fecha de inicio.").show();
                return;
            }

            if (obj.FechaFin === "") {
                $("#mensajeError").text("Debe ingresar la fecha final.").show();
                return;
            }

            if (new Date(obj.FechaInicio) > new Date(obj.FechaFin)) {
                $("#mensajeError").text("La fecha de inicio no puede ser mayor que la fecha final.").show();
                return;
            }

            if (obj.Estado !== "Abierto" && obj.Estado !== "Cerrado") {
                $("#mensajeError").text("Debe seleccionar un estado válido.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarPeriodoContable", "GestionarPeriodoContable")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#FormModal").modal("hide");
                        cargarPeriodosContables();
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el período contable.").show();
                }
            });
        }

        function cerrarPeriodoContable(idPeriodoContable) {
            if (!confirm("¿Desea cerrar este período contable? Después de cerrarlo no debería registrar movimientos en él.")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("CerrarPeriodoContable", "GestionarPeriodoContable")',
                type: "POST",
                data: JSON.stringify({ idPeriodoContable: idPeriodoContable }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarPeriodosContables();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al cerrar el período contable.");
                }
            });
        }

        function inactivarPeriodoContable(idPeriodoContable) {
            if (!confirm("¿Desea inactivar este período contable?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarPeriodoContable", "GestionarPeriodoContable")',
                type: "POST",
                data: JSON.stringify({ idPeriodoContable: idPeriodoContable }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarPeriodosContables();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el período contable.");
                }
            });
        }

        function generarFechasPeriodo() {
            var anio = parseInt($("#txtAnio").val());
            var mes = parseInt($("#cboMes").val());

            if (isNaN(anio) || isNaN(mes) || mes < 1 || mes > 12) {
                return;
            }

            var fechaInicio = new Date(anio, mes - 1, 1);
            var fechaFin = new Date(anio, mes, 0);

            $("#txtFechaInicio").val(convertirDateAInput(fechaInicio));
            $("#txtFechaFin").val(convertirDateAInput(fechaFin));
        }

        function obtenerNombreMes(mes) {
            switch (parseInt(mes)) {
                case 1: return "Enero";
                case 2: return "Febrero";
                case 3: return "Marzo";
                case 4: return "Abril";
                case 5: return "Mayo";
                case 6: return "Junio";
                case 7: return "Julio";
                case 8: return "Agosto";
                case 9: return "Septiembre";
                case 10: return "Octubre";
                case 11: return "Noviembre";
                case 12: return "Diciembre";
                default: return "";
            }
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }
    </script>
}