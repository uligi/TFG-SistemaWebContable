
@{
    ViewBag.Title = "Distrito";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}



<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Distritos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Ubicación</li>
        <li class="breadcrumb-item active">Distritos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de distritos</h6>

        <div>
            <input type="file" id="archivoCsvDistrito" accept=".csv" style="display:none;" />

            <button type="button" class="btn btn-secondary btn-sm" onclick="$('#archivoCsvDistrito').click();">
                Cargar CSV
            </button>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nuevo distrito
            </button>
        </div>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar distrito, cantón o provincia...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaDistritos">
                <thead>
                    <tr>
                        <th>Distrito</th>
                        <th>Cantón</th>
                        <th>Provincia</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo distrito</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdDistrito" value="0" />

                <div class="form-group">
                    <label for="cboProvincia">Provincia</label>
                    <select id="cboProvincia" class="form-control">
                        <option value="0">Seleccione una provincia</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="cboCanton">Cantón</label>
                    <select id="cboCanton" class="form-control">
                        <option value="0">Seleccione un cantón</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="txtNombre">Nombre del distrito</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarDistrito()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaDistritos = [];

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarDistritos();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });

            $("#cboProvincia").on("change", function () {
                var idProvincia = parseInt($(this).val());
                cargarCantonesPorProvincia(idProvincia, 0);
            });
            $("#archivoCsvDistrito").on("change", function () {
                cargarCsvDistrito();
            });
        });

        function cargarDistritos() {
            $.ajax({
                url: '@Url.Action("ListarDistritos", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaDistritos = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los distritos.");
                }
            });
        }
        function cargarCsvDistrito() {
    var archivo = $("#archivoCsvDistrito")[0].files[0];

    if (archivo == null) {
        alert("Debe seleccionar un archivo CSV.");
        return;
    }

    var formData = new FormData();
    formData.append("archivo", archivo);

    $.ajax({
        url: '@Url.Action("CargarCsvDistritos", "Ubicacion")',
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function (respuesta) {
            if (respuesta.resultado) {
                alert("Insertados: " + respuesta.data.insertados + "\nErrores: " + respuesta.data.errores);
                cargarDistritos();
            } else {
                alert(respuesta.mensaje);
            }

            $("#archivoCsvDistrito").val("");
        },
        error: function () {
            alert("Error al cargar el archivo CSV.");
            $("#archivoCsvDistrito").val("");
        }
    });
}

        function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data, function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>", {
                                value: item.IdProvincia,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar las provincias.");
                }
            });
        }

        function cargarCantonesPorProvincia(idProvincia, idCantonSeleccionado) {
            $("#cboCanton").empty();
            $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

            if (idProvincia === 0) {
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarCantonesActivosPorProvincia", "Ubicacion")',
                type: "GET",
                data: { idProvincia: idProvincia },
                dataType: "json",
                success: function (respuesta) {
                    $.each(respuesta.data, function (i, item) {
                        $("#cboCanton").append(
                            $("<option>", {
                                value: item.IdCanton,
                                text: item.Nombre
                            })
                        );
                    });

                    if (idCantonSeleccionado !== 0) {
                        $("#cboCanton").val(idCantonSeleccionado);
                    }
                },
                error: function () {
                    alert("Error al cargar los cantones.");
                }
            });
        }

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaDistritos tbody");

            tbody.empty();

            $.each(listaDistritos, function (i, item) {
                var texto = (item.Nombre + " " + item.CantonNombre + " " + item.ProvinciaNombre).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var fila = `
                    <tr>
                        <td>${item.Nombre}</td>
                        <td>${item.CantonNombre}</td>
                        <td>${item.ProvinciaNombre}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarDistrito(${item.IdDistrito})">
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtIdDistrito").val(0);
            $("#cboProvincia").val(0);
            $("#cboCanton").empty().append('<option value="0">Seleccione un cantón</option>');
            $("#txtNombre").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo distrito");

            if (json != null) {
                $("#txtIdDistrito").val(json.IdDistrito);
                $("#cboProvincia").val(json.IdProvincia);
                $("#txtNombre").val(json.Nombre);
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar distrito");

                cargarCantonesPorProvincia(json.IdProvincia, json.IdCanton);
            }

            $("#FormModal").modal("show");
        }

        function guardarDistrito() {
            var obj = {
                IdDistrito: parseInt($("#txtIdDistrito").val()),
                IdCanton: parseInt($("#cboCanton").val()),
                Nombre: $("#txtNombre").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (parseInt($("#cboProvincia").val()) === 0) {
                $("#mensajeError").text("Debe seleccionar una provincia.").show();
                return;
            }

            if (obj.IdCanton === 0) {
                $("#mensajeError").text("Debe seleccionar un cantón.").show();
                return;
            }

            if (obj.Nombre === "") {
                $("#mensajeError").text("Debe ingresar el nombre del distrito.").show();
                return;
            }

            if (obj.Nombre.length > 45) {
                $("#mensajeError").text("El nombre no puede superar los 45 caracteres.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarDistrito", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {

                    if (obj.IdDistrito === 0) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarDistritos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarDistritos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el distrito.").show();
                }
            });
        }

        function inactivarDistrito(id) {
            if (!confirm("¿Desea inactivar este distrito?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarDistrito", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarDistritos();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el distrito.");
                }
            });
        }
    </script>
}

