@{
    ViewBag.Title = "Distritos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-ubicacion {
        font-family: Consolas, monospace;
        font-weight: bold;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Distritos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Ubicación</li>
        <li class="breadcrumb-item active">Distritos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de distritos</h6>

        <div>
            <button type="button" class="btn btn-outline-secondary btn-sm mr-1" onclick="abrirModalCsv()">
                <i class="fas fa-file-csv mr-1"></i> Cargar CSV
            </button>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nuevo distrito
            </button>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaDistritos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Distrito</th>
                        <th>Cantón</th>
                        <th>Provincia</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Distrito -->
<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo distrito</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label for="txtCodigoDistrito">Código de distrito</label>
                    <input type="number" id="txtCodigoDistrito" class="form-control" min="1" autocomplete="off" />
                    <small class="form-text text-muted">
                        Este código será la llave primaria del distrito.
                    </small>
                </div>

                <div class="form-group">
                    <label for="cboProvincia">Provincia</label>
                    <select id="cboProvincia" class="form-control">
                        <option value="0">Seleccione una provincia</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="cboCanton">Cantón</label>
                    <select id="cboCanton" class="form-control">
                        <option value="0">Seleccione un cantón</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="txtNombre">Nombre del distrito</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group" id="grupoActivo">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarDistrito()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- Modal CSV -->
<div class="modal fade" id="ModalCsv" tabindex="-1" role="dialog" aria-labelledby="tituloModalCsv" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title" id="tituloModalCsv">Cargar distritos desde CSV</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="alert alert-danger" id="mensajeErrorCsv" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoCsv" style="display:none;"></div>

                <div class="form-group">
                    <label for="archivoCsvDistrito">Archivo CSV</label>
                    <input type="file" id="archivoCsvDistrito" class="form-control-file" accept=".csv" />

                    <small class="form-text text-muted">
                        El archivo debe tener las columnas: CodigoDistrito, Nombre, CodigoCanton.
                    </small>

                    <div class="mt-2">
                        <button type="button" class="btn btn-outline-info btn-sm" onclick="descargarPlantillaDistrito()">
                            <i class="fas fa-download mr-1"></i> Descargar plantilla CSV
                        </button>
                    </div>
                </div>

                <div class="bg-light border rounded p-3">
                    <strong>Ejemplo:</strong>
                    <pre class="mb-0 mt-2">CodigoDistrito,Nombre,CodigoCanton
                        10101,Carmen,101
                        10102,Merced,101
                        10103,Hospital,101
                        10201,Escazú,102
                        10301,Desamparados,103
                        10401,Santiago,104
                        10501,San Marcos,105
                        10601,Aserrí,106
                        10701,Colón,107
                        10801,Guadalupe,108
                    </pre>

                <div id="detalleCsv" class="mt-3" style="display:none;">
                    <strong>Detalle de errores:</strong>
                    <ul id="listaErroresCsv" class="mb-0 mt-2 text-danger"></ul>
                </div>

            </div>

            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn btn-primary" onclick="cargarCsvDistrito()">
                    <i class="fas fa-upload mr-1"></i> Cargar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaDistritos = [];
        var tablaDistritos = null;

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarDistritos();

            $("#cboProvincia").on("change", function () {
                var codigoProvincia = parseInt($(this).val());

                $("#cboCanton").empty();
                $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

                if (!isNaN(codigoProvincia) && codigoProvincia > 0) {
                    cargarCantonesPorProvincia(codigoProvincia, null);
                }
            });

            $("#txtCodigoDistrito").on("input", function () {
                var valor = $(this).val();
                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 8) {
                    valor = valor.substring(0, 8);
                }

                $(this).val(valor);
            });

            $("#txtNombre").on("input", function () {
                limpiarTextoUbicacion("txtNombre", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtNombre", "El nombre del distrito no puede superar los 45 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtCodigoDistrito");
                ocultarAyudaCampo("txtNombre");
                ocultarAyudaCampo("cboProvincia");
                ocultarAyudaCampo("cboCanton");
            });
        });

        function cargarDistritos() {
            $.ajax({
                url: '@Url.Action("ListarDistritos", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaDistritos = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los distritos.", "error");
                }
            });
        }

        function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>", {
                                value: item.CodigoProvincia,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las provincias.", "error");
                }
            });
        }

        function cargarCantonesPorProvincia(codigoProvincia, callback) {
            $.ajax({
                url: '@Url.Action("ListarCantonesActivosPorProvincia", "Ubicacion")',
                type: "GET",
                data: { codigoProvincia: codigoProvincia },
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCanton").empty();
                    $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboCanton").append(
                            $("<option>", {
                                value: item.CodigoCanton,
                                text: item.Nombre
                            })
                        );
                    });

                    if (callback != null) {
                        callback();
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los cantones.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaDistritos != null) {
                tablaDistritos.clear().destroy();
                tablaDistritos = null;
            }

            var tbody = $("#tablaDistritos tbody");
            tbody.empty();

            $.each(listaDistritos, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var codigo = item.CodigoDistrito || 0;
                var nombre = item.Nombre || "";
                var canton = item.CantonNombre || "";
                var provincia = item.ProvinciaNombre || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarDistrito(item.CodigoDistrito);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-ubicacion", text: codigo }));
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").text(canton));
                fila.append($("<td>").text(provincia));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaDistritos = $("#tablaDistritos").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtCodigoDistrito");
            ocultarAyudaCampo("txtNombre");
            ocultarAyudaCampo("cboProvincia");
            ocultarAyudaCampo("cboCanton");

            $("#txtCodigoDistrito").val("");
            $("#txtCodigoDistrito").prop("disabled", false);

            $("#cboProvincia").val(0);
            $("#cboCanton").empty();
            $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

            $("#txtNombre").val("");
            $("#cboActivo").val("true");

            aplicarVisibilidadActivoDistrito();

            $("#tituloModal").text("Nuevo distrito");

            if (json != null) {
                $("#txtCodigoDistrito").val(json.CodigoDistrito);
                $("#txtCodigoDistrito").prop("disabled", true);

                $("#cboProvincia").val(json.CodigoProvincia);

                cargarCantonesPorProvincia(json.CodigoProvincia, function () {
                    $("#cboCanton").val(json.CodigoCanton);
                });

                $("#txtNombre").val(json.Nombre || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                aplicarVisibilidadActivoDistrito();

                $("#tituloModal").text("Editar distrito");
            }

            $("#FormModal").modal("show");
        }

        function aplicarVisibilidadActivoDistrito() {
            if (window.esAdministradorSistema === true) {
                $("#grupoActivo").show();
            } else {
                $("#grupoActivo").hide();
                $("#cboActivo").val("true");
            }
        }

        function guardarDistrito() {
            $("#mensajeError").hide().text("");

            var obj = {
                CodigoDistrito: parseInt($("#txtCodigoDistrito").val()),
                CodigoCanton: parseInt($("#cboCanton").val()),
                Nombre: $("#txtNombre").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            var codigoProvincia = parseInt($("#cboProvincia").val());

            if (window.esAdministradorSistema !== true) {
                obj.Activo = true;
            }

            if (isNaN(obj.CodigoDistrito) || obj.CodigoDistrito <= 0) {
                mostrarError("Debe ingresar un código de distrito válido.", "txtCodigoDistrito");
                return;
            }

            if (isNaN(codigoProvincia) || codigoProvincia <= 0) {
                mostrarError("Debe seleccionar una provincia.", "cboProvincia");
                return;
            }

            if (isNaN(obj.CodigoCanton) || obj.CodigoCanton <= 0) {
                mostrarError("Debe seleccionar un cantón.", "cboCanton");
                return;
            }

            if (obj.Nombre === "") {
                mostrarError("Debe ingresar el nombre del distrito.", "txtNombre");
                return;
            }

            if (!validarTextoUbicacion(obj.Nombre)) {
                mostrarError("El nombre del distrito solo puede contener letras, números, espacios y caracteres básicos.", "txtNombre");
                return;
            }

            if (obj.Nombre.length > 45) {
                mostrarError("El nombre del distrito no puede superar los 45 caracteres.", "txtNombre");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarDistrito", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarDistritos();
                        mostrarMensajeSistema("Distrito guardado correctamente.", "exito");
                    } else {
                        $("#mensajeError").text(respuesta.mensaje || "No se pudo guardar el distrito.").show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el distrito.").show();
                }
            });
        }

        function inactivarDistrito(codigoDistrito) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este distrito"),
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarDistrito", "Ubicacion")',
                        type: "POST",
                        data: JSON.stringify({ codigoDistrito: codigoDistrito }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                cargarDistritos();
                                mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Distrito"), "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el distrito.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al procesar el distrito.", "error");
                        }
                    });
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function abrirModalCsv() {
            $("#archivoCsvDistrito").val("");
            $("#mensajeErrorCsv").hide().text("");
            $("#mensajeExitoCsv").hide().text("");
            $("#detalleCsv").hide();
            $("#listaErroresCsv").empty();

            $("#ModalCsv").modal("show");
        }

        function cargarCsvDistrito() {
            $("#mensajeErrorCsv").hide().text("");
            $("#mensajeExitoCsv").hide().text("");
            $("#detalleCsv").hide();
            $("#listaErroresCsv").empty();

            var archivo = $("#archivoCsvDistrito")[0].files[0];

            if (archivo == null) {
                $("#mensajeErrorCsv").text("Debe seleccionar un archivo CSV.").show();
                return;
            }

            var extension = archivo.name.split(".").pop().toLowerCase();

            if (extension !== "csv") {
                $("#mensajeErrorCsv").text("El archivo debe tener formato CSV.").show();
                return;
            }

            var formData = new FormData();
            formData.append("archivo", archivo);

            $.ajax({
                url: '@Url.Action("CargarCsvDistritos", "Ubicacion")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        var data = respuesta.data || {};
                        var insertados = data.insertados || 0;
                        var actualizados = data.actualizados || 0;
                        var errores = data.errores || 0;
                        var detalleErrores = data.detalleErrores || [];

                        $("#mensajeExitoCsv")
                            .text("Carga finalizada. Insertados: " + insertados + ". Actualizados: " + actualizados + ". Errores: " + errores + ".")
                            .show();

                        if (detalleErrores.length > 0) {
                            $.each(detalleErrores, function (i, error) {
                                $("#listaErroresCsv").append($("<li>").text(error));
                            });

                            $("#detalleCsv").show();
                        }

                        cargarDistritos();
                    } else {
                        $("#mensajeErrorCsv").text(respuesta.mensaje || "No se pudo cargar el archivo CSV.").show();
                    }

                    $("#archivoCsvDistrito").val("");
                },
                error: function () {
                    $("#mensajeErrorCsv").text("Error al cargar el archivo CSV.").show();
                    $("#archivoCsvDistrito").val("");
                }
            });
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoUbicacion(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoUbicacion(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function descargarArchivoCsv(nombreArchivo, contenido) {
            var blob = new Blob([contenido], { type: "text/csv;charset=utf-8;" });
            var url = URL.createObjectURL(blob);

            var enlace = document.createElement("a");
            enlace.href = url;
            enlace.download = nombreArchivo;

            document.body.appendChild(enlace);
            enlace.click();
            document.body.removeChild(enlace);

            URL.revokeObjectURL(url);
        }

        function descargarPlantillaDistrito() {
            var contenido = "\uFEFFCodigoDistrito,Nombre,CodigoCanton\n" +
                "10101,Carmen,101\n" +
                "10102,Merced,101\n" +
                "10103,Hospital,101\n" +
                "10201,Escazú,102\n" +
                "10301,Desamparados,103\n" +
                "10401,Santiago,104\n" +
                "10501,San Marcos,105\n" +
                "10601,Aserrí,106\n" +
                "10701,Colón,107\n" +
                "10801,Guadalupe,108\n";

            descargarArchivoCsv("plantilla_distritos.csv", contenido);
        }
    </script>
}