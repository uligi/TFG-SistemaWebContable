@{
    ViewBag.Title = "Cantones";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-ubicacion {
        font-family: Consolas, monospace;
        font-weight: bold;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Cantones</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Ubicación</li>
        <li class="breadcrumb-item active">Cantones</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de cantones</h6>

        <div>
            <button type="button" class="btn btn-outline-secondary btn-sm mr-1" onclick="abrirModalCsv()">
                <i class="fas fa-file-csv mr-1"></i> Cargar CSV
            </button>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nuevo cantón
            </button>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaCantones" style="width:100%;">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Cantón</th>
                        <th>Provincia</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Cantón -->
<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo cantón</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label for="txtCodigoCanton">Código de cantón</label>
                    <input type="number" id="txtCodigoCanton" class="form-control" min="1" autocomplete="off" />
                    <small class="form-text text-muted">
                        Este código será la llave primaria del cantón.
                    </small>
                </div>

                <div class="form-group">
                    <label for="cboProvincia">Provincia</label>
                    <select id="cboProvincia" class="form-control">
                        <option value="0">Seleccione una provincia</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="txtNombre">Nombre del cantón</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group" id="grupoActivo">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarCanton()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- Modal CSV -->
<div class="modal fade" id="ModalCsv" tabindex="-1" role="dialog" aria-labelledby="tituloModalCsv" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title" id="tituloModalCsv">Cargar cantones desde CSV</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="alert alert-danger" id="mensajeErrorCsv" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoCsv" style="display:none;"></div>

                <div class="form-group">
                    <label for="archivoCsvCanton">Archivo CSV</label>
                    <input type="file" id="archivoCsvCanton" class="form-control-file" accept=".csv" />

                    <small class="form-text text-muted">
                        El archivo debe tener las columnas: CodigoCanton, CodigoProvincia, Nombre.
                    </small>

                    <div class="mt-2">
                        <button type="button" class="btn btn-outline-info btn-sm" onclick="descargarPlantillaCanton()">
                            <i class="fas fa-download mr-1"></i> Descargar plantilla CSV
                        </button>
                    </div>
                </div>

                <div class="bg-light border rounded p-3">
                    <strong>Ejemplo:</strong>
                    <pre class="mb-0 mt-2">CodigoCanton,CodigoProvincia,Nombre
1,1,San José
2,1,Escazú
3,1,Desamparados
1,2,Alajuela
2,2,San Ramón</pre>
                </div>

                <div id="detalleCsv" class="mt-3" style="display:none;">
                    <strong>Detalle de errores:</strong>
                    <ul id="listaErroresCsv" class="mb-0 mt-2 text-danger"></ul>
                </div>

            </div>

            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn btn-primary" onclick="cargarCsvCanton()">
                    <i class="fas fa-upload mr-1"></i> Cargar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaCantones = [];
        var tablaCantones = null;

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarCantones();

            $("#txtCodigoCanton").on("input", function () {
                var valor = $(this).val();
                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 5) {
                    valor = valor.substring(0, 5);
                }

                $(this).val(valor);
            });

            $("#txtNombre").on("input", function () {
                limpiarTextoUbicacion("txtNombre", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtNombre", "El nombre del cantón no puede superar los 45 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtCodigoCanton");
                ocultarAyudaCampo("txtNombre");
                ocultarAyudaCampo("cboProvincia");
            });
        });

        function cargarCantones() {
            $.ajax({
                url: '@Url.Action("ListarCantones", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCantones = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los cantones.", "error");
                }
            });
        }

        function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>", {
                                value: item.CodigoProvincia,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las provincias.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaCantones != null) {
                tablaCantones.clear().destroy();
                tablaCantones = null;
            }

            var tbody = $("#tablaCantones tbody");
            tbody.empty();

            $.each(listaCantones, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var codigo = item.CodigoCanton || 0;
                var nombre = item.Nombre || "";
                var provincia = item.ProvinciaNombre || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarCanton(item.CodigoCanton);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-ubicacion", text: codigo }));
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").text(provincia));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaCantones = $("#tablaCantones").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtCodigoCanton");
            ocultarAyudaCampo("txtNombre");
            ocultarAyudaCampo("cboProvincia");

            $("#txtCodigoCanton").val("");
            $("#txtCodigoCanton").prop("disabled", false);

            $("#cboProvincia").val(0);
            $("#txtNombre").val("");
            $("#cboActivo").val("true");

            aplicarVisibilidadActivoCanton();

            $("#tituloModal").text("Nuevo cantón");

            if (json != null) {
                $("#txtCodigoCanton").val(json.CodigoCanton);
                $("#txtCodigoCanton").prop("disabled", true);

                $("#cboProvincia").val(json.CodigoProvincia);
                $("#txtNombre").val(json.Nombre || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                aplicarVisibilidadActivoCanton();

                $("#tituloModal").text("Editar cantón");
            }

            $("#FormModal").modal("show");
        }

        function aplicarVisibilidadActivoCanton() {
            if (window.esAdministradorSistema === true) {
                $("#grupoActivo").show();
            } else {
                $("#grupoActivo").hide();
                $("#cboActivo").val("true");
            }
        }

        function guardarCanton() {
            $("#mensajeError").hide().text("");

            var obj = {
                CodigoCanton: parseInt($("#txtCodigoCanton").val()),
                CodigoProvincia: parseInt($("#cboProvincia").val()),
                Nombre: $("#txtNombre").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (window.esAdministradorSistema !== true) {
                obj.Activo = true;
            }

            if (isNaN(obj.CodigoCanton) || obj.CodigoCanton <= 0) {
                mostrarError("Debe ingresar un código de cantón válido.", "txtCodigoCanton");
                return;
            }

            if (obj.CodigoProvincia === 0 || isNaN(obj.CodigoProvincia)) {
                mostrarError("Debe seleccionar una provincia.", "cboProvincia");
                return;
            }

            if (obj.Nombre === "") {
                mostrarError("Debe ingresar el nombre del cantón.", "txtNombre");
                return;
            }

            if (!validarTextoUbicacion(obj.Nombre)) {
                mostrarError("El nombre del cantón solo puede contener letras, números, espacios y caracteres básicos.", "txtNombre");
                return;
            }

            if (obj.Nombre.length > 45) {
                mostrarError("El nombre del cantón no puede superar los 45 caracteres.", "txtNombre");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCanton", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarCantones();
                        mostrarMensajeSistema("Cantón guardado correctamente.", "exito");
                    } else {
                        $("#mensajeError").text(respuesta.mensaje || "No se pudo guardar el cantón.").show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el cantón.").show();
                }
            });
        }

        function inactivarCanton(codigoCanton) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este cantón"),
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarCanton", "Ubicacion")',
                        type: "POST",
                        data: JSON.stringify({ codigoCanton: codigoCanton }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                cargarCantones();
                                mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Cantón"), "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el cantón.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al procesar el cantón.", "error");
                        }
                    });
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function abrirModalCsv() {
            $("#archivoCsvCanton").val("");
            $("#mensajeErrorCsv").hide().text("");
            $("#mensajeExitoCsv").hide().text("");
            $("#detalleCsv").hide();
            $("#listaErroresCsv").empty();

            $("#ModalCsv").modal("show");
        }

        function cargarCsvCanton() {
            $("#mensajeErrorCsv").hide().text("");
            $("#mensajeExitoCsv").hide().text("");
            $("#detalleCsv").hide();
            $("#listaErroresCsv").empty();

            var archivo = $("#archivoCsvCanton")[0].files[0];

            if (archivo == null) {
                $("#mensajeErrorCsv").text("Debe seleccionar un archivo CSV.").show();
                return;
            }

            var extension = archivo.name.split(".").pop().toLowerCase();

            if (extension !== "csv") {
                $("#mensajeErrorCsv").text("El archivo debe tener formato CSV.").show();
                return;
            }

            var formData = new FormData();
            formData.append("archivo", archivo);

            $.ajax({
                url: '@Url.Action("CargarCsvCantones", "Ubicacion")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        var data = respuesta.data || {};
                        var insertados = data.insertados || 0;
                        var errores = data.errores || 0;
                        var detalleErrores = data.detalleErrores || [];

                        $("#mensajeExitoCsv")
                            .text("Carga finalizada. Insertados: " + insertados + ". Errores: " + errores + ".")
                            .show();

                        if (detalleErrores.length > 0) {
                            $.each(detalleErrores, function (i, error) {
                                $("#listaErroresCsv").append($("<li>").text(error));
                            });

                            $("#detalleCsv").show();
                        }

                        cargarCantones();
                    } else {
                        $("#mensajeErrorCsv").text(respuesta.mensaje || "No se pudo cargar el archivo CSV.").show();
                    }

                    $("#archivoCsvCanton").val("");
                },
                error: function () {
                    $("#mensajeErrorCsv").text("Error al cargar el archivo CSV.").show();
                    $("#archivoCsvCanton").val("");
                }
            });
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoUbicacion(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoUbicacion(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function descargarArchivoCsv(nombreArchivo, contenido) {
            var blob = new Blob([contenido], { type: "text/csv;charset=utf-8;" });
            var url = URL.createObjectURL(blob);

            var enlace = document.createElement("a");
            enlace.href = url;
            enlace.download = nombreArchivo;

            document.body.appendChild(enlace);
            enlace.click();
            document.body.removeChild(enlace);

            URL.revokeObjectURL(url);
        }

        function descargarPlantillaCanton() {
            var contenido = "CodigoCanton,CodigoProvincia,Nombre\n" +
                "1,1,San José\n" +
                "2,1,Escazú\n" +
                "3,1,Desamparados\n" +
                "1,2,Alajuela\n" +
                "2,2,San Ramón\n";

            descargarArchivoCsv("plantilla_cantones.csv", contenido);
        }
    </script>
}