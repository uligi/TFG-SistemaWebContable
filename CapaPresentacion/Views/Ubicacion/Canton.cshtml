
@{
    ViewBag.Title = "Canton";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Cantones</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Ubicación</li>
        <li class="breadcrumb-item active">Cantones</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de cantones</h6>

        <div>
            <input type="file" id="archivoCsvCanton" accept=".csv" style="display:none;" />

            <button type="button" class="btn btn-secondary btn-sm" onclick="$('#archivoCsvCanton').click();">
                Cargar CSV
            </button>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nuevo cantón
            </button>
        </div>
    </div>

    <div class="card-body">



        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaCantones" style="width:100%;">
                <thead>
                    <tr>
                        <th>Cantón</th>
                        <th>Provincia</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo cantón</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdCanton" value="0" />

                <div class="form-group">
                    <label for="cboProvincia">Provincia</label>
                    <select id="cboProvincia" class="form-control">
                        <option value="0">Seleccione una provincia</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="txtNombre">Nombre del cantón</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarCanton()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaCantones = [];
        var tablaCantones = null;

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarCantones();

            $("#archivoCsvCanton").on("change", function () {
                cargarCsvCanton();
            });

            $("#txtNombre").on("input", function () {
                limpiarTextoUbicacion("txtNombre", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtNombre", "El nombre del cantón no puede superar los 45 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtNombre");
                ocultarAyudaCampo("cboProvincia");
            });
        });

        function cargarCantones() {
            $.ajax({
                url: '@Url.Action("ListarCantones", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCantones = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los cantones.");
                }
            });
        }

        function cargarCsvCanton() {
            var archivo = $("#archivoCsvCanton")[0].files[0];

            if (archivo == null) {
                alert("Debe seleccionar un archivo CSV.");
                return;
            }

            var formData = new FormData();
            formData.append("archivo", archivo);

            $.ajax({
                url: '@Url.Action("CargarCsvCantones", "Ubicacion")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        alert("Insertados: " + respuesta.data.insertados + "\nErrores: " + respuesta.data.errores);
                        cargarCantones();
                    } else {
                        alert(respuesta.mensaje);
                    }

                    $("#archivoCsvCanton").val("");
                },
                error: function () {
                    alert("Error al cargar el archivo CSV.");
                    $("#archivoCsvCanton").val("");
                }
            });
        }

        function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>", {
                                value: item.IdProvincia,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar las provincias.");
                }
            });
        }

        function pintarTabla() {
            if (tablaCantones != null) {
                tablaCantones.clear().destroy();
                tablaCantones = null;
            }

            var tbody = $("#tablaCantones tbody");
            tbody.empty();

            $.each(listaCantones, function (i, item) {
                var nombre = item.Nombre || "";
                var provincia = item.ProvinciaNombre || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarCanton(item.IdCanton);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonInactivar);

                var fila = $("<tr>");
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").text(provincia));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaCantones = $("#tablaCantones").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[1, "asc"], [0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtNombre");
            ocultarAyudaCampo("cboProvincia");

            $("#txtIdCanton").val(0);
            $("#cboProvincia").val(0);
            $("#txtNombre").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo cantón");

            if (json != null) {
                $("#txtIdCanton").val(json.IdCanton);
                $("#cboProvincia").val(json.IdProvincia);
                $("#txtNombre").val(json.Nombre || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar cantón");
            }

            $("#FormModal").modal("show");
        }

        function guardarCanton() {
            $("#mensajeError").hide().text("");

            var obj = {
                IdCanton: parseInt($("#txtIdCanton").val()),
                IdProvincia: parseInt($("#cboProvincia").val()),
                Nombre: $("#txtNombre").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdCanton)) {
                obj.IdCanton = 0;
            }

            if (obj.IdProvincia === 0 || isNaN(obj.IdProvincia)) {
                mostrarError("Debe seleccionar una provincia.", "cboProvincia");
                return;
            }

            if (obj.Nombre === "") {
                mostrarError("Debe ingresar el nombre del cantón.", "txtNombre");
                return;
            }

            if (!validarTextoUbicacion(obj.Nombre)) {
                mostrarError("El nombre del cantón solo puede contener letras, números, espacios y caracteres básicos.", "txtNombre");
                return;
            }

            if (obj.Nombre.length > 45) {
                mostrarError("El nombre del cantón no puede superar los 45 caracteres.", "txtNombre");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCanton", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (obj.IdCanton === 0) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarCantones();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarCantones();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el cantón.").show();
                }
            });
        }

        function inactivarCanton(id) {
            if (!confirm("¿Desea inactivar este cantón?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarCanton", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarCantones();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el cantón.");
                }
            });
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoUbicacion(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoUbicacion(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }
    </script>
}
