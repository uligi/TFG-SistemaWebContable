@{
    ViewBag.Title = "Provincias";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<div class="container-fluid">

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-bottom">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0">
                        <i class="fas fa-map-marked-alt mr-2"></i>Provincias
                    </h4>
                    <small class="text-muted">
                        Mantenimiento de provincias registradas en el sistema.
                    </small>
                </div>

                <div>
                    <button type="button" class="btn btn-outline-secondary mr-2" onclick="abrirModalCsv()">
                        <i class="fas fa-file-csv mr-1"></i> Cargar CSV
                    </button>

                    <button type="button" class="btn btn-primary" onclick="abrirModal(null)">
                        <i class="fas fa-plus mr-1"></i> Nueva provincia
                    </button>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table id="tablaProvincias" class="table table-hover table-bordered w-100">
                    <thead class="thead-light">
                        <tr>
                            <th>Código</th>
                            <th>Provincia</th>
                            <th>Estado</th>
                            <th style="width: 160px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Provincia -->
<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-labelledby="tituloModal" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="tituloModal">Nueva provincia</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="alert alert-danger" id="mensajeError" style="display:none;"></div>

                <div class="form-group">
                    <label for="txtCodigoProvincia">Código de provincia</label>
                    <input type="number"
                           id="txtCodigoProvincia"
                           class="form-control"
                           min="1"
                           autocomplete="off"
                           placeholder="Ejemplo: 2" />
                    <small class="form-text text-muted">
                        Este código será la llave primaria de la provincia.
                    </small>
                    <small class="text-danger ayuda-campo" id="ayuda_txtCodigoProvincia" style="display:none;"></small>
                </div>

                <div class="form-group">
                    <label for="txtNombre">Nombre de la provincia</label>
                    <input type="text"
                           id="txtNombre"
                           class="form-control"
                           maxlength="45"
                           autocomplete="off"
                           placeholder="Ejemplo: Cartago" />
                    <small class="text-danger ayuda-campo" id="ayuda_txtNombre" style="display:none;"></small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

            </div>

            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarProvincia()">
                    <i class="fas fa-save mr-1"></i> Guardar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- Modal CSV -->
<div class="modal fade" id="ModalCsv" tabindex="-1" role="dialog" aria-labelledby="tituloModalCsv" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title" id="tituloModalCsv">Cargar provincias desde CSV</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="alert alert-danger" id="mensajeErrorCsv" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoCsv" style="display:none;"></div>

                <div class="form-group">
                    <label for="archivoCsv">Archivo CSV</label>
                    <input type="file" id="archivoCsv" class="form-control-file" accept=".csv" />
                    <small class="form-text text-muted">
                        El archivo debe tener las columnas: CodigoProvincia, Nombre.
                    </small>

                    <div class="mt-2">
                        <button type="button" class="btn btn-outline-info btn-sm" onclick="descargarPlantillaProvincia()">
                            <i class="fas fa-download mr-1"></i> Descargar plantilla CSV
                        </button>
                    </div>
                </div>

                <div class="bg-light border rounded p-3">
                    <strong>Ejemplo:</strong>
                    <pre class="mb-0 mt-2">CodigoProvincia,Nombre
2,San José
3,Alajuela
4,Cartago
5,Heredia
6,Guanacaste
7,Puntarenas
8,Limón</pre>
                </div>

                <div id="detalleCsv" class="mt-3" style="display:none;">
                    <strong>Detalle de errores:</strong>
                    <ul id="listaErroresCsv" class="mb-0 mt-2 text-danger"></ul>
                </div>

            </div>

            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn btn-primary" onclick="cargarCsvProvincias()">
                    <i class="fas fa-upload mr-1"></i> Cargar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts{
    <script>

        var tablaProvincias;
        var listaProvincias = [];

        $(document).ready(function () {
            cargarProvincias();

            $("#txtCodigoProvincia").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 5) {
                    valor = valor.substring(0, 5);
                }

                $(this).val(valor);
            });

            $("#txtNombre").on("input", function () {
                ocultarAyudaCampo("txtNombre");
                $("#mensajeError").hide().text("");
            });

            $("#txtCodigoProvincia").on("input", function () {
                ocultarAyudaCampo("txtCodigoProvincia");
                $("#mensajeError").hide().text("");
            });
        });

        function cargarProvincias() {
            $.ajax({
                url: '@Url.Action("ListarProvincias", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaProvincias = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las provincias.", "error");
                }
            });
        }

        function pintarTabla() {

            if ($.fn.DataTable.isDataTable("#tablaProvincias")) {
                tablaProvincias.destroy();
            }

            var tbody = $("#tablaProvincias tbody");
            tbody.empty();

            $.each(listaProvincias, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var codigo = item.CodigoProvincia || 0;
                var nombre = item.Nombre || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarProvincia(item.CodigoProvincia);
                });

                var acciones = $("<td class='text-center'>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(codigo));
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaProvincias = $("#tablaProvincias").DataTable({
                responsive: true,
                ordering: true,
                order: [[0, "asc"]],
                pageLength: 10,
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            $(".ayuda-campo").hide().text("");

            $("#txtCodigoProvincia").val("");
            $("#txtCodigoProvincia").prop("disabled", false);

            $("#txtNombre").val("");
            $("#cboActivo").val("true");
            aplicarVisibilidadActivoProvincia();

            $("#tituloModal").text("Nueva provincia");

            if (json != null) {
                $("#txtCodigoProvincia").val(json.CodigoProvincia);
                $("#txtCodigoProvincia").prop("disabled", true);

                $("#txtNombre").val(json.Nombre || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                aplicarVisibilidadActivoProvincia();

                $("#tituloModal").text("Editar provincia");
            }

            $("#FormModal").modal("show");
        }

        function aplicarVisibilidadActivoProvincia() {
            if (window.esAdministradorSistema === true) {
                $("#cboActivo").closest(".form-group").show();
            } else {
                $("#cboActivo").closest(".form-group").hide();
                $("#cboActivo").val("true");
            }
        }

        function guardarProvincia() {
            $("#mensajeError").hide().text("");
            $(".ayuda-campo").hide().text("");

            var obj = {
                CodigoProvincia: parseInt($("#txtCodigoProvincia").val()),
                Nombre: $("#txtNombre").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (window.esAdministradorSistema !== true) {
                obj.Activo = true;
            }

            if (isNaN(obj.CodigoProvincia) || obj.CodigoProvincia <= 0) {
                mostrarError("Debe ingresar un código de provincia válido.", "txtCodigoProvincia");
                return;
            }

            if (obj.Nombre === "") {
                mostrarError("Debe ingresar el nombre de la provincia.", "txtNombre");
                return;
            }

            if (!validarTextoUbicacion(obj.Nombre)) {
                mostrarError("El nombre de la provincia solo puede contener letras, números, espacios y caracteres básicos.", "txtNombre");
                return;
            }

            if (obj.Nombre.length > 45) {
                mostrarError("El nombre de la provincia no puede superar los 45 caracteres.", "txtNombre");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarProvincia", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarProvincias();
                        mostrarMensajeSistema("Provincia guardada correctamente.", "exito");

                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar la provincia.").show();
                }
            });
        }

        function inactivarProvincia(codigoProvincia) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "esta provincia"),
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarProvincia", "Ubicacion")',
                        type: "POST",
                        data: JSON.stringify({ codigoProvincia: codigoProvincia }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                cargarProvincias();
                                mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Provincia"), "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar la provincia.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al procesar la provincia.", "error");
                        }
                    });
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function abrirModalCsv() {
            $("#archivoCsv").val("");
            $("#mensajeErrorCsv").hide().text("");
            $("#mensajeExitoCsv").hide().text("");
            $("#detalleCsv").hide();
            $("#listaErroresCsv").empty();

            $("#ModalCsv").modal("show");
        }

        function cargarCsvProvincias() {
            $("#mensajeErrorCsv").hide().text("");
            $("#mensajeExitoCsv").hide().text("");
            $("#detalleCsv").hide();
            $("#listaErroresCsv").empty();

            var archivo = $("#archivoCsv")[0].files[0];

            if (archivo == null) {
                $("#mensajeErrorCsv").text("Debe seleccionar un archivo CSV.").show();
                return;
            }

            var extension = archivo.name.split(".").pop().toLowerCase();

            if (extension !== "csv") {
                $("#mensajeErrorCsv").text("El archivo debe tener formato CSV.").show();
                return;
            }

            var formData = new FormData();
            formData.append("archivo", archivo);

            $.ajax({
                url: '@Url.Action("CargarCsvProvincias", "Ubicacion")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (respuesta) {

                    if (respuesta.resultado) {

                        var data = respuesta.data || {};
                        var insertados = data.insertados || 0;
                        var errores = data.errores || 0;
                        var detalleErrores = data.detalleErrores || [];

                        $("#mensajeExitoCsv")
                            .text("Carga finalizada. Insertados: " + insertados + ". Errores: " + errores + ".")
                            .show();

                        if (detalleErrores.length > 0) {
                            $.each(detalleErrores, function (i, error) {
                                $("#listaErroresCsv").append($("<li>").text(error));
                            });

                            $("#detalleCsv").show();
                        }

                        cargarProvincias();

                    } else {
                        $("#mensajeErrorCsv").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorCsv").text("Error al cargar el archivo CSV.").show();
                }
            });
        }

        function mostrarError(mensaje, campo) {
            $("#mensajeError").text(mensaje).show();

            if (campo != null && campo !== "") {
                $("#ayuda_" + campo).text(mensaje).show();
                $("#" + campo).focus();
            }
        }

        function ocultarAyudaCampo(campo) {
            $("#ayuda_" + campo).hide().text("");
        }

        function validarTextoUbicacion(texto) {
            var regex = /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s\.\-]+$/;
            return regex.test(texto);
        }

        function descargarArchivoCsv(nombreArchivo, contenido) {
            var blob = new Blob([contenido], { type: "text/csv;charset=utf-8;" });
            var url = URL.createObjectURL(blob);

            var enlace = document.createElement("a");
            enlace.href = url;
            enlace.download = nombreArchivo;

            document.body.appendChild(enlace);
            enlace.click();
            document.body.removeChild(enlace);

            URL.revokeObjectURL(url);
        }

        function descargarPlantillaProvincia() {
            var contenido = "CodigoProvincia,Nombre\n" +
                "1,San José\n" +
                "2,Alajuela\n" +
                "3,Cartago\n" +
                "4,Heredia\n" +
                "5,Guanacaste\n" +
                "6,Puntarenas\n" +
                "7,Limón\n";

            descargarArchivoCsv("plantilla_provincias.csv", contenido);
        }

    </script>
}