
@{
    ViewBag.Title = "Provincia";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}


<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Provincias</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Ubicación</li>
        <li class="breadcrumb-item active">Provincias</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de provincias</h6>

        <div>
            <input type="file" id="archivoCsvProvincia" accept=".csv" style="display:none;" />

            <button type="button" class="btn btn-secondary btn-sm" onclick="$('#archivoCsvProvincia').click();">
                Cargar CSV
            </button>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nueva provincia
            </button>
        </div>
    </div>


    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-4">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar provincia...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaProvincias">
                <thead>
                    <tr>
                        <th>Provincia</th>
                        <th>Estado</th>
                        <th style="width:160px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nueva provincia</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdProvincia" value="0" />

                <div class="form-group">
                    <label for="txtNombre">Nombre de la provincia</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarProvincia()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaProvincias = [];

        $(document).ready(function () {
            cargarProvincias();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });
            $("#archivoCsvProvincia").on("change", function () {
                cargarCsvProvincia();
            });
        });

        function cargarProvincias() {
            $.ajax({
                url: '@Url.Action("ListarProvincias", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaProvincias = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar las provincias.");
                }
            });
        }
        function cargarCsvProvincia() {
    var archivo = $("#archivoCsvProvincia")[0].files[0];

    if (archivo == null) {
        alert("Debe seleccionar un archivo CSV.");
        return;
    }

    var formData = new FormData();
    formData.append("archivo", archivo);

    $.ajax({
        url: '@Url.Action("CargarCsvProvincias", "Ubicacion")',
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function (respuesta) {
            if (respuesta.resultado) {
                alert("Insertados: " + respuesta.data.insertados + "\nErrores: " + respuesta.data.errores);
                cargarProvincias();
            } else {
                alert(respuesta.mensaje);
            }

            $("#archivoCsvProvincia").val("");
        },
        error: function () {
            alert("Error al cargar el archivo CSV.");
            $("#archivoCsvProvincia").val("");
        }
    });
}
        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaProvincias tbody");

            tbody.empty();

            $.each(listaProvincias, function (i, item) {
                var texto = item.Nombre.toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var fila = `
                    <tr>
                        <td>${item.Nombre}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarProvincia(${item.IdProvincia})">
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            $("#txtIdProvincia").val(0);
            $("#txtNombre").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nueva provincia");

            if (json != null) {
                $("#txtIdProvincia").val(json.IdProvincia);
                $("#txtNombre").val(json.Nombre);
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar provincia");
            }

            $("#FormModal").modal("show");
        }

        function guardarProvincia() {
            var obj = {
                IdProvincia: parseInt($("#txtIdProvincia").val()),
                Nombre: $("#txtNombre").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (obj.Nombre === "") {
                $("#mensajeError").text("Debe ingresar el nombre de la provincia.").show();
                return;
            }

            if (obj.Nombre.length > 45) {
                $("#mensajeError").text("El nombre no puede superar los 45 caracteres.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarProvincia", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (obj.IdProvincia === 0) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarProvincias();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarProvincias();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar la provincia.").show();
                }
            });
        }

        function inactivarProvincia(id) {
            if (!confirm("¿Desea inactivar esta provincia?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarProvincia", "Ubicacion")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarProvincias();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar la provincia.");
                }
            });
        }
    </script>
}

