@{
    ViewBag.Title = "Cuentas por Pagar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-documento {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .texto-vencido {
        color: #dc3545;
        font-weight: bold;
    }

    .texto-por-vencer {
        color: #856404;
        font-weight: bold;
    }

    .texto-pagado {
        color: #28a745;
        font-weight: bold;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Cuentas por Pagar</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Cuentas</li>
        <li class="breadcrumb-item active">Cuentas por pagar</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de cuentas por pagar</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalCuenta(null)">
            Nueva cuenta
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-4">
                <input type="text" id="txtBuscarCuenta" class="form-control" placeholder="Buscar por proveedor, documento, concepto o estado..." />
            </div>

            <div class="col-md-3">
                <select id="cboFiltroEstado" class="form-control">
                    <option value="">Todos los estados de cuenta</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Parcial">Parcial</option>
                    <option value="Pagada">Pagada</option>
                    <option value="Anulada">Anulada</option>
                </select>
            </div>

            <div class="col-md-3">
                <select id="cboFiltroEstadoCredito" class="form-control">
                    <option value="">Todos los estados de crédito</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Por vencer">Por vencer</option>
                    <option value="Vencida">Vencida</option>
                    <option value="Pagada">Pagada</option>
                    <option value="Anulada">Anulada</option>
                    <option value="Inactiva">Inactiva</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary btn-block" onclick="cargarCuentasPorPagar()">
                    Actualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaCuentasPorPagar">
                <thead>
                    <tr>
                        <th>Proveedor</th>
                        <th>Documento</th>
                        <th>Concepto</th>
                        <th>Fecha emisión</th>
                        <th>Vencimiento</th>
                        <th>Días</th>
                        <th>Monto original</th>
                        <th>Saldo actual</th>
                        <th>Estado cuenta</th>
                        <th>Estado crédito</th>
                        <th>Activo</th>
                        <th style="width:260px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModalCuenta" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalCuenta">Nueva cuenta por pagar</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdentificacionProveedor" value="" />
                <input type="hidden" id="txtDiasCreditoProveedor" value="0" />

                <div class="alert alert-danger" id="mensajeErrorCuenta" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoCuenta" style="display:none;"></div>

                <h6 class="font-weight-bold">Datos de la cuenta</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtProveedorVisible">Proveedor</label>
                        <input type="text" id="txtProveedorVisible" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtBuscarProveedor">Buscar proveedor</label>
                        <div class="input-group">
                            <input type="text" id="txtBuscarProveedor" class="form-control" placeholder="Identificación, razón social o nombre comercial..." />

                            <div class="input-group-append">
                                <button type="button" class="btn btn-outline-primary" onclick="buscarProveedores()">
                                    Buscar
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="form-group col-md-2">
                        <label>Días crédito</label>
                        <input type="text" id="txtDiasCreditoVisible" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-2">
                        <label>&nbsp;</label>
                        <button type="button" class="btn btn-outline-secondary btn-block" onclick="limpiarSeleccionProveedor()">
                            Limpiar
                        </button>
                    </div>

                </div>

                <div class="table-responsive mb-3" id="contenedorResultadosProveedor" style="display:none;">
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Identificación</th>
                                <th>Razón social</th>
                                <th>Contacto</th>
                                <th>Días crédito</th>
                                <th style="width:110px;">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyResultadosProveedor"></tbody>
                    </table>
                </div>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtNumeroDocumento">Número documento</label>
                        <input type="text" id="txtNumeroDocumento" class="form-control" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaEmision">Fecha emisión</label>
                        <input type="date" id="txtFechaEmision" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaVencimiento">Fecha vencimiento</label>
                        <input type="date" id="txtFechaVencimiento" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboEstadoCuenta">Estado</label>
                        <select id="cboEstadoCuenta" class="form-control">
                            <option value="Pendiente">Pendiente</option>
                            <option value="Parcial">Parcial</option>
                            <option value="Pagada">Pagada</option>
                            <option value="Anulada">Anulada</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-6">
                        <label for="txtConcepto">Concepto</label>
                        <input type="text" id="txtConcepto" class="form-control" maxlength="100" placeholder="Factura de proveedor, mercadería, servicio, etc." />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtMontoOriginal">Monto original</label>
                        <input type="text" id="txtMontoOriginal" class="form-control" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtSaldoActual">Saldo actual</label>
                        <input type="text" id="txtSaldoActual" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboActivoCuenta">Activo</label>
                        <select id="cboActivoCuenta" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label>Estado crédito</label>
                        <div class="form-control bg-light" id="lblEstadoCreditoModal">
                            Pendiente
                        </div>
                    </div>

                    <div class="form-group col-md-8 d-flex align-items-end justify-content-end">
                        <button type="button" class="btn btn-primary" onclick="guardarCuentaPorPagar()">
                            Guardar cuenta
                        </button>
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="font-weight-bold mb-0">Abonos de la cuenta</h6>

                    <div>
                        <span class="badge badge-info mr-2" id="lblMontoOriginal">Monto original: 0.00</span>
                        <span class="badge badge-warning mr-2" id="lblMontoPagado">Pagado: 0.00</span>
                        <span class="badge badge-success" id="lblSaldoActual">Saldo: 0.00</span>
                    </div>
                </div>

                <small class="form-text text-muted mb-3" id="textoAyudaAbono">
                    Para registrar abonos, primero guarde o seleccione una cuenta por pagar.
                </small>

                <input type="hidden" id="txtNumeroAbono" value="0" />

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtFechaAbono">Fecha abono</label>
                        <input type="date" id="txtFechaAbono" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMontoAbono">Monto abono</label>
                        <input type="text" id="txtMontoAbono" class="form-control" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtObservacion">Observación</label>
                        <input type="text" id="txtObservacion" class="form-control" maxlength="150" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboActivoAbono">Activo</label>
                        <select id="cboActivoAbono" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="text-right mb-3">
                    <button type="button" class="btn btn-secondary" onclick="limpiarAbono()">
                        Limpiar abono
                    </button>

                    <button type="button" class="btn btn-primary" onclick="guardarAbonoCuentaPorPagar()">
                        Guardar abono
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaAbonos">
                        <thead>
                            <tr>
                                <th># Abono</th>
                                <th>Fecha</th>
                                <th>Monto</th>
                                <th>Observación</th>
                                <th>Activo</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-primary" onclick="recalcularSaldoCuenta()">
                    Recalcular saldo
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaCuentas = [];
        var listaAbonos = [];
        var listaProveedores = [];

        $(document).ready(function () {
            cargarCuentasPorPagar();

            if (window.esAdministradorSistema !== true) {
                $("#cboFiltroEstado option[value='Anulada']").remove();
                $("#cboFiltroEstadoCredito option[value='Anulada']").remove();
                $("#cboFiltroEstadoCredito option[value='Inactiva']").remove();
            }

            $("#txtBuscarCuenta, #cboFiltroEstado, #cboFiltroEstadoCredito").on("keyup change", function () {
                pintarTablaCuentas();
            });

            $("#txtBuscarProveedor").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarProveedores();
                }
            });

            $("#txtBuscarProveedor").on("input", function () {
                limpiarTextoGeneral("txtBuscarProveedor", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtNumeroDocumento").on("input", function () {
                limpiarCodigoDocumento("txtNumeroDocumento", "Solo se permiten letras, números, puntos, guiones y guion bajo.");
            });

            $("#txtConcepto").on("input", function () {
                limpiarTextoGeneral("txtConcepto", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 100) {
                    $(this).val($(this).val().substring(0, 100));
                    mostrarAyudaCampo("txtConcepto", "El concepto no puede superar los 100 caracteres.");
                }
            });

            $("#txtMontoOriginal, #txtMontoAbono").on("input", function () {
                limpiarDecimal(this.id, "Solo se permiten números y punto decimal.");
            });

            $("#txtMontoOriginal").on("keyup change", function () {
                if ($("#txtSaldoActual").val() === "" || $("#txtSaldoActual").val() === "0.00") {
                    $("#txtSaldoActual").val($("#txtMontoOriginal").val());
                }

                actualizarResumenCuenta();
            });

            $("#txtFechaEmision").on("change", function () {
                calcularFechaVencimientoPorDiasCredito();
            });

            $("#txtObservacion").on("input", function () {
                limpiarTextoGeneral("txtObservacion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtObservacion", "La observación no puede superar los 150 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorCuenta").is(":visible")) {
                    $("#mensajeErrorCuenta").fadeOut(150);
                }

                if ($("#mensajeExitoCuenta").is(":visible")) {
                    $("#mensajeExitoCuenta").fadeOut(150);
                }
            });
        });

        function cargarCuentasPorPagar() {
            $.ajax({
                url: '@Url.Action("ListarCuentasPorPagar", "GestionarCuentasPorPagar")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCuentas = respuesta.data || [];
                    pintarTablaCuentas();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las cuentas por pagar.", "error");
                }
            });
        }

        function pintarTablaCuentas() {
            var filtro = $("#txtBuscarCuenta").val().toLowerCase();
            var estadoFiltro = $("#cboFiltroEstado").val();
            var estadoCreditoFiltro = $("#cboFiltroEstadoCredito").val();
            var tbody = $("#tablaCuentasPorPagar tbody");

            tbody.empty();

            if (listaCuentas.length === 0) {
                tbody.append('<tr><td colspan="12" class="text-center text-muted">No hay cuentas por pagar registradas.</td></tr>');
                return;
            }

            $.each(listaCuentas, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var proveedor = item.ProveedorNombre || "";
                var identificacion = item.IdentificacionProveedor || "";
                var numeroDocumento = item.NumeroDocumento || "";
                var concepto = item.Concepto || "";
                var estado = item.Estado || "";
                var estadoCredito = item.EstadoCredito || "";

                var texto = (proveedor + " " + identificacion + " " + numeroDocumento + " " + concepto + " " + estado + " " + estadoCredito).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                if (estadoFiltro !== "" && estado !== estadoFiltro) {
                    return;
                }

                if (estadoCreditoFiltro !== "" && estadoCredito !== estadoCreditoFiltro) {
                    return;
                }

                var badgeEstado = obtenerBadgeEstadoCuenta(estado);
                var badgeEstadoCredito = obtenerBadgeEstadoCredito(estadoCredito, item.DiasRestantes);
                var diasTexto = obtenerTextoDiasRestantes(item.DiasRestantes, estadoCredito);

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModalCuenta(item);
                });

                var botonAbono = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-success mr-1",
                    text: "Abonar"
                }).on("click", function () {
                    abrirModalCuenta(item);
                });

                var botonEstado = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarCuentaPorPagar(item.IdentificacionProveedor, item.NumeroDocumento);
                });

                var fila = $("<tr>");
                fila.append($("<td>").html(
                    '<div>' + identificacion + ' - ' + proveedor + '</div>' +
                    '<div class="texto-tabla-secundario">Días crédito: ' + (item.DiasCredito || 0) + '</div>'
                ));
                fila.append($("<td>", { class: "codigo-documento", text: numeroDocumento }));
                fila.append($("<td>").text(concepto));
                fila.append($("<td>").text(formatearFecha(item.FechaEmision)));
                fila.append($("<td>").text(formatearFecha(item.FechaVencimiento)));
                fila.append($("<td>").html(diasTexto));
                fila.append($("<td>").text(formatearNumero(item.MontoOriginal)));
                fila.append($("<td>").text(formatearNumero(item.SaldoActual)));
                fila.append($("<td>").html(badgeEstado));
                fila.append($("<td>").html(badgeEstadoCredito));
                fila.append($("<td>").html(activo));

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo && parseFloat(item.SaldoActual || 0) > 0 && estado !== "Anulada") {
                    acciones.append(botonAbono);
                }

                if (item.Activo && estado !== "Pagada") {
                    acciones.append(botonEstado);
                }

                fila.append(acciones);
                tbody.append(fila);
            });
        }

        function abrirModalCuenta(json) {
            limpiarErrores();
            limpiarSeleccionProveedor();
            limpiarAbono();

            listaAbonos = [];
            pintarTablaAbonos();
            bloquearAbonos(true);

            $("#tituloModalCuenta").text("Nueva cuenta por pagar");
            $("#txtFechaEmision").val(convertirDateAInput(new Date()));
            $("#txtFechaVencimiento").val(convertirDateAInput(new Date()));
            $("#txtNumeroDocumento").val("");
            $("#txtConcepto").val("");
            $("#txtMontoOriginal").val("");
            $("#txtSaldoActual").val("");
            $("#cboEstadoCuenta").val("Pendiente");
            $("#cboActivoCuenta").val("true");
            $("#lblEstadoCreditoModal").html(obtenerBadgeEstadoCredito("Pendiente", 30));

            $("#txtNumeroDocumento").prop("readonly", false);
            $("#txtSaldoActual").prop("readonly", true);

            if (json != null) {
                $("#tituloModalCuenta").text("Editar cuenta por pagar");

                $("#txtIdentificacionProveedor").val(json.IdentificacionProveedor || "");
                $("#txtDiasCreditoProveedor").val(json.DiasCredito || 0);

                $("#txtProveedorVisible").val((json.IdentificacionProveedor || "") + " - " + (json.ProveedorNombre || ""));
                $("#txtDiasCreditoVisible").val((json.DiasCredito || 0) + " día(s)");

                $("#txtNumeroDocumento").val(json.NumeroDocumento || "");
                $("#txtNumeroDocumento").prop("readonly", true);

                $("#txtFechaEmision").val(convertirFechaInput(json.FechaEmision));
                $("#txtFechaVencimiento").val(convertirFechaInput(json.FechaVencimiento));
                $("#txtConcepto").val(json.Concepto || "");
                $("#txtMontoOriginal").val(formatearNumero(json.MontoOriginal));
                $("#txtSaldoActual").val(formatearNumero(json.SaldoActual));
                $("#cboEstadoCuenta").val(json.Estado || "Pendiente");
                $("#cboActivoCuenta").val(json.Activo ? "true" : "false");

                $("#lblEstadoCreditoModal").html(obtenerBadgeEstadoCredito(json.EstadoCredito || "", json.DiasRestantes));

                bloquearAbonos(false);
                cargarAbonosCuenta(json.IdentificacionProveedor, json.NumeroDocumento);
            }

            $("#FormModalCuenta").modal("show");
        }

        function buscarProveedores() {
            var filtro = $("#txtBuscarProveedor").val().trim();

            if (filtro.length < 2) {
                mostrarErrorCuenta("Digite al menos 2 caracteres para buscar el proveedor.", "txtBuscarProveedor");
                return;
            }

            $.ajax({
                url: '@Url.Action("BuscarProveedoresCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "GET",
                data: { filtro: filtro },
                dataType: "json",
                success: function (respuesta) {
                    listaProveedores = respuesta.data || [];
                    pintarResultadosProveedor();
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al buscar proveedores.").show();
                }
            });
        }

        function pintarResultadosProveedor() {
            var tbody = $("#tbodyResultadosProveedor");
            tbody.empty();

            if (listaProveedores.length === 0) {
                tbody.append('<tr><td colspan="5" class="text-center text-muted">No se encontraron proveedores.</td></tr>');
                $("#contenedorResultadosProveedor").show();
                return;
            }

            $.each(listaProveedores, function (i, item) {
                var identificacion = item.IdentificacionProveedor || "";
                var razonSocial = item.RazonSocial || "";
                var nombreContacto = item.NombreContacto || "";
                var diasCredito = parseInt(item.DiasCredito || 0);

                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarProveedorCuenta(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text(identificacion));
                fila.append($("<td>").text(razonSocial));
                fila.append($("<td>").text(nombreContacto));
                fila.append($("<td>").text(diasCredito + " día(s)"));
                fila.append($("<td>").append(boton));

                tbody.append(fila);
            });

            $("#contenedorResultadosProveedor").show();
        }

        function seleccionarProveedorCuenta(item) {
            var identificacion = item.IdentificacionProveedor || "";
            var razonSocial = item.RazonSocial || "";
            var diasCredito = parseInt(item.DiasCredito || 0);

            if (isNaN(diasCredito)) {
                diasCredito = 0;
            }

            $("#txtIdentificacionProveedor").val(identificacion);
            $("#txtDiasCreditoProveedor").val(diasCredito);

            $("#txtProveedorVisible").val(identificacion + " - " + razonSocial);
            $("#txtDiasCreditoVisible").val(diasCredito + " día(s)");

            $("#txtBuscarProveedor").val("");
            $("#contenedorResultadosProveedor").hide();

            calcularFechaVencimientoPorDiasCredito();
        }

        function limpiarSeleccionProveedor() {
            $("#txtIdentificacionProveedor").val("");
            $("#txtDiasCreditoProveedor").val("0");
            $("#txtProveedorVisible").val("");
            $("#txtDiasCreditoVisible").val("");
            $("#txtBuscarProveedor").val("");
            $("#contenedorResultadosProveedor").hide();
            $("#tbodyResultadosProveedor").empty();
        }

        function calcularFechaVencimientoPorDiasCredito() {
            var fechaEmisionTexto = $("#txtFechaEmision").val();
            var diasCredito = parseInt($("#txtDiasCreditoProveedor").val());

            if (isNaN(diasCredito)) {
                diasCredito = 0;
            }

            if (fechaEmisionTexto === "") {
                return;
            }

            var fechaEmision = new Date(fechaEmisionTexto + "T00:00:00");
            var fechaVencimiento = sumarDias(fechaEmision, diasCredito);

            $("#txtFechaVencimiento").val(convertirDateAInput(fechaVencimiento));
        }

        function guardarCuentaPorPagar() {
            $("#mensajeErrorCuenta").hide().text("");
            $("#mensajeExitoCuenta").hide().text("");

            var obj = {
                IdentificacionProveedor: $("#txtIdentificacionProveedor").val().trim(),
                NumeroDocumento: $("#txtNumeroDocumento").val().trim(),
                FechaEmision: $("#txtFechaEmision").val(),
                FechaVencimiento: $("#txtFechaVencimiento").val(),
                Concepto: $("#txtConcepto").val().trim(),
                MontoOriginal: parseFloat($("#txtMontoOriginal").val()),
                SaldoActual: parseFloat($("#txtSaldoActual").val()),
                Estado: $("#cboEstadoCuenta").val(),
                Activo: $("#cboActivoCuenta").val() === "true"
            };

            if (isNaN(obj.MontoOriginal)) obj.MontoOriginal = 0;
            if (isNaN(obj.SaldoActual)) obj.SaldoActual = obj.MontoOriginal;

            if (obj.IdentificacionProveedor === "") {
                mostrarErrorCuenta("Debe seleccionar un proveedor.", "txtBuscarProveedor");
                return;
            }



            if (obj.FechaEmision === "") {
                mostrarErrorCuenta("Debe ingresar la fecha de emisión.", "txtFechaEmision");
                return;
            }

            if (obj.FechaVencimiento === "") {
                mostrarErrorCuenta("Debe ingresar la fecha de vencimiento.", "txtFechaVencimiento");
                return;
            }

            if (new Date(obj.FechaVencimiento + "T00:00:00") < new Date(obj.FechaEmision + "T00:00:00")) {
                mostrarErrorCuenta("La fecha de vencimiento no puede ser menor que la fecha de emisión.", "txtFechaVencimiento");
                return;
            }

            if (obj.Concepto === "") {
                mostrarErrorCuenta("Debe ingresar el concepto.", "txtConcepto");
                return;
            }

            if (obj.MontoOriginal <= 0) {
                mostrarErrorCuenta("El monto original debe ser mayor a cero.", "txtMontoOriginal");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        var numeroDocumento = respuesta.numeroDocumento || obj.NumeroDocumento;

                        $("#txtNumeroDocumento").val(numeroDocumento);

                        $("#mensajeErrorCuenta").hide().text("");

                        cargarCuentasPorPagar();

                        mostrarMensajeSistema(respuesta.mensaje || "Cuenta por pagar guardada correctamente.", "exito");
                    } else {
                        $("#mensajeErrorCuenta").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al guardar la cuenta por pagar.").show();
                }
            });
        }

        function cargarAbonosCuenta(identificacionProveedor, numeroDocumento) {
            $.ajax({
                url: '@Url.Action("ListarAbonosCuentaPorPagarPorCuenta", "GestionarCuentasPorPagar")',
                type: "GET",
                data: {
                    identificacionProveedor: identificacionProveedor,
                    numeroDocumento: numeroDocumento
                },
                dataType: "json",
                success: function (respuesta) {
                    listaAbonos = respuesta.data || [];
                    pintarTablaAbonos();
                    actualizarResumenCuenta();
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al cargar los abonos.").show();
                }
            });
        }

        function pintarTablaAbonos() {
            var tbody = $("#tablaAbonos tbody");
            tbody.empty();

            if (listaAbonos.length === 0) {
                tbody.append('<tr><td colspan="6" class="text-center text-muted">No hay abonos registrados.</td></tr>');
                actualizarResumenCuenta();
                return;
            }

            $.each(listaAbonos, function (i, item) {
                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    editarAbono(item);
                });

                var botonEstado = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarAbono(item.IdentificacionProveedor, item.NumeroDocumento, item.NumeroAbono);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonEstado);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroAbono));
                fila.append($("<td>").text(formatearFecha(item.FechaAbono)));
                fila.append($("<td>").text(formatearNumero(item.MontoAbono)));
                fila.append($("<td>").text(item.Observacion || ""));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function actualizarResumenCuenta() {
            var montoOriginal = parseFloat($("#txtMontoOriginal").val() || 0);
            var saldoActual = parseFloat($("#txtSaldoActual").val() || 0);

            var montoPagado = montoOriginal - saldoActual;

            if (isNaN(montoPagado) || montoPagado < 0) {
                montoPagado = 0;
            }

            $("#lblMontoOriginal").text("Monto original: " + formatearNumero(montoOriginal));
            $("#lblMontoPagado").text("Pagado: " + formatearNumero(montoPagado));
            $("#lblSaldoActual").text("Saldo: " + formatearNumero(saldoActual));
        }

        function guardarAbonoCuentaPorPagar() {
            $("#mensajeErrorCuenta").hide().text("");
            $("#mensajeExitoCuenta").hide().text("");

            var obj = {
                IdentificacionProveedor: $("#txtIdentificacionProveedor").val().trim(),
                NumeroDocumento: $("#txtNumeroDocumento").val().trim(),
                NumeroAbono: parseInt($("#txtNumeroAbono").val()),
                FechaAbono: $("#txtFechaAbono").val(),
                MontoAbono: parseFloat($("#txtMontoAbono").val()),
                Observacion: $("#txtObservacion").val().trim(),
                Activo: $("#cboActivoAbono").val() === "true"
            };

            if (isNaN(obj.NumeroAbono)) obj.NumeroAbono = 0;
            if (isNaN(obj.MontoAbono)) obj.MontoAbono = 0;

            if (obj.IdentificacionProveedor === "" || obj.NumeroDocumento === "") {
                mostrarErrorCuenta("Primero debe seleccionar o guardar una cuenta por pagar.", "txtNumeroDocumento");
                return;
            }

            if (obj.FechaAbono === "") {
                mostrarErrorCuenta("Debe ingresar la fecha del abono.", "txtFechaAbono");
                return;
            }

            if (obj.MontoAbono <= 0) {
                mostrarErrorCuenta("El monto del abono debe ser mayor a cero.", "txtMontoAbono");
                return;
            }

            if (obj.Observacion.length > 150) {
                mostrarErrorCuenta("La observación no puede superar los 150 caracteres.", "txtObservacion");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarAbonoCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#mensajeExitoCuenta").text(respuesta.mensaje || "Abono guardado correctamente.").show();

                        limpiarAbono();
                        cargarCuentasPorPagar();
                        refrescarCuentaActual(obj.IdentificacionProveedor, obj.NumeroDocumento);
                    } else {
                        $("#mensajeErrorCuenta").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al guardar el abono.").show();
                }
            });
        }

        function refrescarCuentaActual(identificacionProveedor, numeroDocumento) {
            $.ajax({
                url: '@Url.Action("ObtenerCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "GET",
                data: {
                    identificacionProveedor: identificacionProveedor,
                    numeroDocumento: numeroDocumento
                },
                dataType: "json",
                success: function (respuesta) {
                    var item = respuesta.data;

                    if (item != null) {
                        $("#txtMontoOriginal").val(formatearNumero(item.MontoOriginal));
                        $("#txtSaldoActual").val(formatearNumero(item.SaldoActual));
                        $("#cboEstadoCuenta").val(item.Estado);
                        $("#cboActivoCuenta").val(item.Activo ? "true" : "false");
                        $("#lblEstadoCreditoModal").html(obtenerBadgeEstadoCredito(item.EstadoCredito || "", item.DiasRestantes));

                        cargarAbonosCuenta(identificacionProveedor, numeroDocumento);
                    }
                }
            });
        }

        function editarAbono(item) {
            $("#txtNumeroAbono").val(item.NumeroAbono);
            $("#txtFechaAbono").val(convertirFechaInput(item.FechaAbono));
            $("#txtMontoAbono").val(formatearNumero(item.MontoAbono));
            $("#txtObservacion").val(item.Observacion || "");
            $("#cboActivoAbono").val(item.Activo ? "true" : "false");
        }

        function limpiarAbono() {
            $("#txtNumeroAbono").val("0");
            $("#txtFechaAbono").val(convertirDateAInput(new Date()));
            $("#txtMontoAbono").val("");
            $("#txtObservacion").val("");
            $("#cboActivoAbono").val("true");
        }

        function bloquearAbonos(bloquear) {
            $("#txtFechaAbono").prop("disabled", bloquear);
            $("#txtMontoAbono").prop("disabled", bloquear);
            $("#txtObservacion").prop("disabled", bloquear);
            $("#cboActivoAbono").prop("disabled", bloquear);

            if (bloquear) {
                $("#textoAyudaAbono").text("Para registrar abonos, primero guarde o seleccione una cuenta por pagar.");
            } else {
                $("#textoAyudaAbono").text("Registre los abonos realizados al proveedor.");
            }
        }

        function inactivarAbono(identificacionProveedor, numeroDocumento, numeroAbono) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este abono"),
                function () {
                    ejecutarInactivarAbono(identificacionProveedor, numeroDocumento, numeroAbono);
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function ejecutarInactivarAbono(identificacionProveedor, numeroDocumento, numeroAbono) {
            $.ajax({
                url: '@Url.Action("InactivarAbonoCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "POST",
                data: JSON.stringify({
                    identificacionProveedor: identificacionProveedor,
                    numeroDocumento: numeroDocumento,
                    numeroAbono: numeroAbono
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        limpiarAbono();
                        cargarCuentasPorPagar();
                        refrescarCuentaActual(identificacionProveedor, numeroDocumento);
                        mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Abono"), "exito");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el abono.", "error");
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al procesar el abono.", "error");
                }
            });
        }

        function recalcularSaldoCuenta() {
            var identificacionProveedor = $("#txtIdentificacionProveedor").val().trim();
            var numeroDocumento = $("#txtNumeroDocumento").val().trim();

            if (identificacionProveedor === "" || numeroDocumento === "") {
                mostrarErrorCuenta("Debe seleccionar una cuenta por pagar.", "txtNumeroDocumento");
                return;
            }

            $.ajax({
                url: '@Url.Action("RecalcularSaldoCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "POST",
                data: JSON.stringify({
                    identificacionProveedor: identificacionProveedor,
                    numeroDocumento: numeroDocumento
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#mensajeExitoCuenta").text(respuesta.mensaje).show();
                        cargarCuentasPorPagar();
                        refrescarCuentaActual(identificacionProveedor, numeroDocumento);
                    } else {
                        $("#mensajeErrorCuenta").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al recalcular el saldo.").show();
                }
            });
        }

        function inactivarCuentaPorPagar(identificacionProveedor, numeroDocumento) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "esta cuenta por pagar"),
                function () {
                    ejecutarInactivarCuentaPorPagar(identificacionProveedor, numeroDocumento);
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function ejecutarInactivarCuentaPorPagar(identificacionProveedor, numeroDocumento) {
            $.ajax({
                url: '@Url.Action("InactivarCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "POST",
                data: JSON.stringify({
                    identificacionProveedor: identificacionProveedor,
                    numeroDocumento: numeroDocumento
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarCuentasPorPagar();
                        mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Cuenta por pagar"), "exito");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar la cuenta por pagar.", "error");
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al procesar la cuenta por pagar.", "error");
                }
            });
        }
        function obtenerBadgeEstadoCuenta(estado) {
            if (estado === "Pagada") {
                return '<span class="badge badge-success">Pagada</span>';
            }

            if (estado === "Parcial") {
                return '<span class="badge badge-warning">Parcial</span>';
            }

            if (estado === "Anulada") {
                return '<span class="badge badge-danger">Anulada</span>';
            }

            return '<span class="badge badge-info">' + estado + '</span>';
        }

        function obtenerBadgeEstadoCredito(estadoCredito, diasRestantes) {
            diasRestantes = parseInt(diasRestantes);

            if (isNaN(diasRestantes)) {
                diasRestantes = 0;
            }

            if (estadoCredito === "Pagada") {
                return '<span class="badge badge-success">Pagada</span>';
            }

            if (estadoCredito === "Vencida") {
                return '<span class="badge badge-danger">Vencida</span>';
            }

            if (estadoCredito === "Por vencer") {
                return '<span class="badge badge-warning">Por vencer</span>';
            }

            if (estadoCredito === "Anulada") {
                return '<span class="badge badge-danger">Anulada</span>';
            }

            if (estadoCredito === "Inactiva") {
                return '<span class="badge badge-secondary">Inactiva</span>';
            }

            return '<span class="badge badge-info">Pendiente</span>';
        }

        function obtenerTextoDiasRestantes(diasRestantes, estadoCredito) {
            diasRestantes = parseInt(diasRestantes);

            if (isNaN(diasRestantes)) {
                diasRestantes = 0;
            }

            if (estadoCredito === "Pagada") {
                return '<span class="texto-pagado">Pagada</span>';
            }

            if (estadoCredito === "Vencida") {
                return '<span class="texto-vencido">' + Math.abs(diasRestantes) + ' día(s) vencida</span>';
            }

            if (estadoCredito === "Por vencer") {
                if (diasRestantes === 0) {
                    return '<span class="texto-por-vencer">Vence hoy</span>';
                }

                return '<span class="texto-por-vencer">' + diasRestantes + ' día(s)</span>';
            }

            if (diasRestantes === 0) {
                return '<span class="texto-por-vencer">Vence hoy</span>';
            }

            return diasRestantes + ' día(s)';
        }

        function mostrarErrorCuenta(mensaje, idCampo) {
            $("#mensajeErrorCuenta").text(mensaje).show();

            if (idCampo && $("#" + idCampo).length > 0) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function limpiarErrores() {
            $("#mensajeErrorCuenta").hide().text("");
            $("#mensajeExitoCuenta").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarCodigoDocumento(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9A-Za-z.\-_]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            return formatearFecha(valor);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }

        function sumarDias(fecha, dias) {
            var nuevaFecha = new Date(fecha);
            nuevaFecha.setDate(nuevaFecha.getDate() + dias);
            return nuevaFecha;
        }
    </script>
}