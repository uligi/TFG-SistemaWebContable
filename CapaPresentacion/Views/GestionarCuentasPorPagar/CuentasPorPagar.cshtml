@{
    ViewBag.Title = "Cuentas por Pagar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestionar Cuentas por Pagar</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Cuentas</li>
        <li class="breadcrumb-item active">Cuentas por Pagar</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de cuentas por pagar</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalCuenta(null)">
            Nueva cuenta por pagar
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaCuentasPorPagar" style="width:100%;">
                <thead>
                    <tr>
                        <th>Documento</th>
                        <th>Proveedor</th>
                        <th>Emisión</th>
                        <th>Vencimiento</th>
                        <th>Concepto</th>
                        <th>Monto original</th>
                        <th>Saldo actual</th>
                        <th>Estado</th>
                        <th>Activo</th>
                        <th style="width:230px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL CUENTA POR PAGAR -->
<div class="modal fade" id="ModalCuenta" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalCuenta">Nueva cuenta por pagar</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdCuentaPorPagar" value="0" />
                <input type="hidden" id="txtIdentificacionProveedor" value="" />

                <div class="form-row">

                    <div class="form-group col-md-5">
                        <label>Proveedor</label>

                        <div class="input-group">
                            <input type="text" id="txtBuscarProveedor" class="form-control" placeholder="Buscar proveedor por identificación o nombre..." />
                            <div class="input-group-append">
                                <button type="button" class="btn btn-outline-primary" onclick="buscarProveedores()">
                                    Buscar
                                </button>
                            </div>
                        </div>

                        <small class="form-text text-muted" id="lblProveedorSeleccionado">
                            Ningún proveedor seleccionado.
                        </small>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtProveedorNombre">Proveedor seleccionado</label>
                        <input type="text" id="txtProveedorNombre" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtNumeroDocumento">Número documento</label>
                        <input type="text" id="txtNumeroDocumento" class="form-control" readonly placeholder="Se genera automáticamente" /> </div>

                </div>

                <div class="table-responsive mb-3" id="contenedorResultadosProveedor" style="display:none;">
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Identificación</th>
                                <th>Proveedor</th>
                                <th style="width:100px;">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyResultadosProveedor"></tbody>
                    </table>
                </div>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtFechaEmision">Fecha emisión</label>
                        <input type="date" id="txtFechaEmision" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaVencimiento">Fecha vencimiento</label>
                        <input type="date" id="txtFechaVencimiento" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMontoOriginal">Monto original</label>
                        <input type="number" id="txtMontoOriginal" class="form-control" min="0" step="0.01" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtSaldoActual">Saldo actual</label>
                        <input type="number" id="txtSaldoActual" class="form-control" readonly />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-6">
                        <label for="txtConcepto">Concepto</label>
                        <input type="text" id="txtConcepto" class="form-control" maxlength="45" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboEstado">Estado</label>
                        <select id="cboEstado" class="form-control">
                            <option value="Pendiente">Pendiente</option>
                            <option value="Parcial">Parcial</option>
                            <option value="Pagada">Pagada</option>
                            <option value="Vencida">Vencida</option>
                            <option value="Anulada">Anulada</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboActivo">Activo</label>
                        <select id="cboActivo" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="alert alert-danger mt-2" id="mensajeErrorCuenta" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarCuentaPorPagar()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- MODAL ABONOS -->
<div class="modal fade" id="ModalAbonos" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Abonos de cuenta por pagar</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdCuentaAbono" value="0" />
                <input type="hidden" id="txtIdAbonoCuentaPorPagar" value="0" />

                <div class="alert alert-info">
                    <strong>Documento:</strong> <span id="lblAbonoDocumento"></span> |
                    <strong>Proveedor:</strong> <span id="lblAbonoProveedor"></span> |
                    <strong>Saldo actual:</strong> ₡<span id="lblAbonoSaldo"></span>
                </div>

                <h6 class="font-weight-bold">Registrar abono</h6>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtFechaAbono">Fecha abono</label>
                        <input type="date" id="txtFechaAbono" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMontoAbono">Monto abono</label>
                        <input type="number" id="txtMontoAbono" class="form-control" min="0" step="0.01" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtObservacion">Observación</label>
                        <input type="text" id="txtObservacion" class="form-control" maxlength="150" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboActivoAbono">Activo</label>
                        <select id="cboActivoAbono" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="text-right mb-3">
                    <button type="button" class="btn btn-secondary" onclick="limpiarAbono()">
                        Limpiar
                    </button>
                    <button type="button" class="btn btn-primary" onclick="guardarAbonoCuentaPorPagar()">
                        Guardar abono
                    </button>
                </div>

                <div class="alert alert-danger mt-2" id="mensajeErrorAbono" style="display:none;"></div>

                <hr />

                <div class="table-responsive">
                    <table class="table table-striped table-bordered" id="tablaAbonos" style="width:100%;">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Monto</th>
                                <th>Observación</th>
                                <th>Activo</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var tablaCuentas = null;
        var tablaAbonos = null;

        var listaCuentas = [];
        var listaProveedores = [];
        var listaAbonos = [];

        $(document).ready(function () {
            cargarCuentasPorPagar();

            $("#txtBuscarProveedor").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarProveedores();
                }
            });

            $("#ModalCuenta").on("hidden.bs.modal", function () {
                $("#mensajeErrorCuenta").hide().text("");
            });

            $("#ModalAbonos").on("hidden.bs.modal", function () {
                limpiarAbono();
                $("#mensajeErrorAbono").hide().text("");
            });

            $("#txtBuscarProveedor").on("input", function () {
                limpiarTextoBusqueda("txtBuscarProveedor", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtConcepto").on("input", function () {
                limpiarTextoCuenta("txtConcepto", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtConcepto", "El concepto no puede superar los 45 caracteres.");
                }
            });

            $("#txtMontoOriginal").on("input", function () {
                limpiarNoDecimal("txtMontoOriginal", "Solo se permiten números y punto decimal en el monto original.");
            });

            $("#txtMontoAbono").on("input", function () {
                limpiarNoDecimal("txtMontoAbono", "Solo se permiten números y punto decimal en el monto del abono.");
            });

            $("#txtObservacion").on("input", function () {
                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtObservacion", "La observación no puede superar los 150 caracteres.");
                } else {
                    ocultarAyudaCampo("txtObservacion");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorCuenta").is(":visible")) {
                    $("#mensajeErrorCuenta").fadeOut(150);
                }

                if ($("#mensajeErrorAbono").is(":visible")) {
                    $("#mensajeErrorAbono").fadeOut(150);
                }
            });
        });

        function cargarCuentasPorPagar() {
            $.ajax({
                url: '@Url.Action("ListarCuentasPorPagar", "GestionarCuentasPorPagar")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCuentas = respuesta.data || [];
                    pintarTablaCuentas();
                },
                error: function () {
                    alert("Error al cargar las cuentas por pagar.");
                }
            });
        }

        function pintarTablaCuentas() {
            if (tablaCuentas != null) {
                tablaCuentas.clear().destroy();
                tablaCuentas = null;
            }

            var tbody = $("#tablaCuentasPorPagar tbody");
            tbody.empty();

            $.each(listaCuentas, function (i, item) {
                var estado = obtenerBadgeEstado(item.Estado);

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModalCuenta(item);
                });

                var botonAbonos = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-success mr-1",
                    text: "Abonos"
                }).on("click", function () {
                    abrirModalAbonos(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarCuentaPorPagar(item.IdCuentaPorPagar);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonAbonos);
                acciones.append(botonInactivar);

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroDocumento || ""));
                fila.append($("<td>").text((item.IdentificacionProveedor || "") + " - " + (item.ProveedorNombre || "")));
                fila.append($("<td>").text(formatearFecha(item.FechaEmision)));
                fila.append($("<td>").text(formatearFecha(item.FechaVencimiento)));
                fila.append($("<td>").text(item.Concepto || ""));
                fila.append($("<td>").text("₡" + parseFloat(item.MontoOriginal || 0).toFixed(2)));
                fila.append($("<td>").text("₡" + parseFloat(item.SaldoActual || 0).toFixed(2)));
                fila.append($("<td>").html(estado));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaCuentas = $("#tablaCuentasPorPagar").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[2, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModalCuenta(json) {
            $("#mensajeErrorCuenta").hide().text("");

            $("#txtIdCuentaPorPagar").val(0);
            $("#txtIdentificacionProveedor").val("");

            $("#txtBuscarProveedor").val("");
            $("#lblProveedorSeleccionado").text("Ningún proveedor seleccionado.");
            $("#contenedorResultadosProveedor").hide();
            $("#tbodyResultadosProveedor").empty();

            $("#txtProveedorNombre").val("");
            $("#txtNumeroDocumento").val("");

            $("#txtFechaEmision").val(convertirDateAInput(new Date()));

            var fechaVencimiento = new Date();
            fechaVencimiento.setDate(fechaVencimiento.getDate() + 30);
            $("#txtFechaVencimiento").val(convertirDateAInput(fechaVencimiento));

            $("#txtConcepto").val("");
            $("#txtMontoOriginal").val("0.00");
            $("#txtSaldoActual").val("0.00");
            $("#cboEstado").val("Pendiente");
            $("#cboActivo").val("true");

            $("#txtBuscarProveedor").prop("disabled", false);
            $("#txtMontoOriginal").prop("readonly", false);

            $("#tituloModalCuenta").text("Nueva cuenta por pagar");

            if (json != null) {
                $("#txtIdCuentaPorPagar").val(json.IdCuentaPorPagar);
                $("#txtIdentificacionProveedor").val(json.IdentificacionProveedor);

                $("#txtBuscarProveedor").val(json.IdentificacionProveedor + " - " + (json.ProveedorNombre || ""));
                $("#lblProveedorSeleccionado").text("Proveedor seleccionado: " + json.IdentificacionProveedor + " - " + (json.ProveedorNombre || ""));
                $("#txtProveedorNombre").val(json.IdentificacionProveedor + " - " + (json.ProveedorNombre || ""));

                $("#txtNumeroDocumento").val(json.NumeroDocumento || "");
                $("#txtFechaEmision").val(convertirFechaInput(json.FechaEmision));
                $("#txtFechaVencimiento").val(convertirFechaInput(json.FechaVencimiento));
                $("#txtConcepto").val(json.Concepto || "");
                $("#txtMontoOriginal").val(parseFloat(json.MontoOriginal || 0).toFixed(2));
                $("#txtSaldoActual").val(parseFloat(json.SaldoActual || 0).toFixed(2));
                $("#cboEstado").val(json.Estado || "Pendiente");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#txtBuscarProveedor").prop("disabled", true);

                $("#tituloModalCuenta").text("Editar cuenta por pagar");
            }

            $("#ModalCuenta").modal("show");
        }

        function buscarProveedores() {
            var filtro = $("#txtBuscarProveedor").val().trim().toLowerCase();

            if (filtro.length < 2) {
                mostrarErrorCuenta("Digite al menos 2 caracteres para buscar el proveedor.", "txtBuscarProveedor");
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarProveedores", "Proveedor")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaProveedores = (respuesta.data || []).filter(function (x) {
                        var identificacion = x.IdentificacionProveedor || x.Identificacion || "";
                        var nombre = x.RazonSocial || x.ProveedorNombre || x.Nombre || "";

                        var texto = (identificacion + " " + nombre).toLowerCase();

                        return x.Activo === true && texto.indexOf(filtro) !== -1;
                    });

                    pintarResultadosProveedores();
                    $("#mensajeErrorCuenta").hide().text("");
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al buscar proveedores.").show();
                }
            });
        }

        function pintarResultadosProveedores() {
            var tbody = $("#tbodyResultadosProveedor");
            tbody.empty();

            if (listaProveedores.length === 0) {
                tbody.append(
                    '<tr>' +
                        '<td colspan="3" class="text-center text-muted">' +
                            'No se encontraron proveedores.' +
                        '</td>' +
                    '</tr>'
                );

                $("#contenedorResultadosProveedor").show();
                return;
            }

            $.each(listaProveedores, function (i, item) {
                var identificacion = item.IdentificacionProveedor || item.Identificacion || "";
                var nombre = item.RazonSocial || item.ProveedorNombre || item.Nombre || "";

                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarProveedor(identificacion, nombre);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text(identificacion));
                fila.append($("<td>").text(nombre));

                var acciones = $("<td>");
                acciones.append(boton);

                fila.append(acciones);
                tbody.append(fila);
            });

            $("#contenedorResultadosProveedor").show();
        }

        function seleccionarProveedor(identificacion, nombre) {
            $("#txtIdentificacionProveedor").val(identificacion);
            $("#txtBuscarProveedor").val(identificacion + " - " + nombre);
            $("#txtProveedorNombre").val(identificacion + " - " + nombre);
            $("#lblProveedorSeleccionado").text("Proveedor seleccionado: " + identificacion + " - " + nombre);
            $("#contenedorResultadosProveedor").hide();
        }

       function guardarCuentaPorPagar() {
    $("#mensajeErrorCuenta").hide().text("");

    var montoTexto = $("#txtMontoOriginal").val().trim();

    var obj = {
        IdCuentaPorPagar: parseInt($("#txtIdCuentaPorPagar").val()),
        IdentificacionProveedor: $("#txtIdentificacionProveedor").val(),
        NumeroDocumento: $("#txtNumeroDocumento").val().trim(),
        FechaEmision: $("#txtFechaEmision").val(),
        FechaVencimiento: $("#txtFechaVencimiento").val(),
        Concepto: $("#txtConcepto").val().trim(),
        MontoOriginal: montoTexto === "" ? 0 : parseFloat(montoTexto),
        Estado: $("#cboEstado").val(),
        Activo: $("#cboActivo").val() === "true"
    };

    if (isNaN(obj.IdCuentaPorPagar)) {
        obj.IdCuentaPorPagar = 0;
    }

    if (obj.IdentificacionProveedor === "") {
        mostrarErrorCuenta("Debe seleccionar un proveedor.", "txtBuscarProveedor");
        return;
    }

    if (obj.NumeroDocumento === "" && obj.IdCuentaPorPagar !== 0) {
        mostrarErrorCuenta("El número de documento no puede estar vacío.", "txtNumeroDocumento");
        return;
    }

    if (obj.FechaEmision === "") {
        mostrarErrorCuenta("Debe ingresar la fecha de emisión.", "txtFechaEmision");
        return;
    }

    var mensajeFechaEmision = validarFechaNoFutura(obj.FechaEmision, "La fecha de emisión no puede ser futura.");
    if (mensajeFechaEmision !== "") {
        mostrarErrorCuenta(mensajeFechaEmision, "txtFechaEmision");
        return;
    }

    if (obj.FechaVencimiento === "") {
        mostrarErrorCuenta("Debe ingresar la fecha de vencimiento.", "txtFechaVencimiento");
        return;
    }

    var mensajeFechas = validarFechaVencimiento(obj.FechaEmision, obj.FechaVencimiento);
    if (mensajeFechas !== "") {
        mostrarErrorCuenta(mensajeFechas, "txtFechaVencimiento");
        return;
    }

    if (obj.Concepto === "") {
        mostrarErrorCuenta("Debe ingresar el concepto.", "txtConcepto");
        return;
    }

    if (!validarTextoCuenta(obj.Concepto)) {
        mostrarErrorCuenta("El concepto solo puede contener letras, números, espacios y caracteres básicos.", "txtConcepto");
        return;
    }

    if (obj.Concepto.length > 45) {
        mostrarErrorCuenta("El concepto no puede superar los 45 caracteres.", "txtConcepto");
        return;
    }

    var mensajeMonto = validarDecimalMayorCero(montoTexto, "el monto original");
    if (mensajeMonto !== "") {
        mostrarErrorCuenta(mensajeMonto, "txtMontoOriginal");
        return;
    }

    if (obj.Estado === "" || obj.Estado === null) {
        mostrarErrorCuenta("Debe seleccionar un estado.", "cboEstado");
        return;
    }

    $.ajax({
        url: '@Url.Action("GuardarCuentaPorPagar", "GestionarCuentasPorPagar")',
        type: "POST",
        data: JSON.stringify({ obj: obj }),
        dataType: "json",
        contentType: "application/json; charset=utf-8",
        success: function (respuesta) {
            if (respuesta.resultado) {
                $("#ModalCuenta").modal("hide");
                cargarCuentasPorPagar();
            } else {
                $("#mensajeErrorCuenta").text(respuesta.mensaje).show();
            }
        },
        error: function () {
            $("#mensajeErrorCuenta").text("Error al guardar la cuenta por pagar.").show();
        }
    });
}

        function inactivarCuentaPorPagar(idCuentaPorPagar) {
            if (!confirm("¿Desea inactivar esta cuenta por pagar?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "POST",
                data: JSON.stringify({ idCuentaPorPagar: idCuentaPorPagar }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarCuentasPorPagar();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar la cuenta por pagar.");
                }
            });
        }

        function abrirModalAbonos(item) {
            $("#txtIdCuentaAbono").val(item.IdCuentaPorPagar);
            $("#lblAbonoDocumento").text(item.NumeroDocumento || "");
            $("#lblAbonoProveedor").text((item.IdentificacionProveedor || "") + " - " + (item.ProveedorNombre || ""));
            $("#lblAbonoSaldo").text(parseFloat(item.SaldoActual || 0).toFixed(2));

            limpiarAbono();
            cargarAbonosCuentaPorPagar(item.IdCuentaPorPagar);

            $("#ModalAbonos").modal("show");
        }

        function cargarAbonosCuentaPorPagar(idCuentaPorPagar) {
            $.ajax({
                url: '@Url.Action("ListarAbonosCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "GET",
                data: { idCuentaPorPagar: idCuentaPorPagar },
                dataType: "json",
                success: function (respuesta) {
                    listaAbonos = respuesta.data || [];
                    pintarTablaAbonos();
                },
                error: function () {
                    alert("Error al cargar los abonos.");
                }
            });
        }

        function pintarTablaAbonos() {
            if (tablaAbonos != null) {
                tablaAbonos.clear().destroy();
                tablaAbonos = null;
            }

            var tbody = $("#tablaAbonos tbody");
            tbody.empty();

            $.each(listaAbonos, function (i, item) {
                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    editarAbono(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarAbonoCuentaPorPagar(item.IdAbonoCuentaPorPagar);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonInactivar);

                var fila = $("<tr>");
                fila.append($("<td>").text(formatearFecha(item.FechaAbono)));
                fila.append($("<td>").text("₡" + parseFloat(item.MontoAbono || 0).toFixed(2)));
                fila.append($("<td>").text(item.Observacion || ""));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaAbonos = $("#tablaAbonos").DataTable({
                responsive: true,
                pageLength: 5,
                destroy: true,
                order: [[0, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function limpiarAbono() {
            $("#txtIdAbonoCuentaPorPagar").val(0);
            $("#txtFechaAbono").val(convertirDateAInput(new Date()));
            $("#txtMontoAbono").val("");
            $("#txtObservacion").val("");
            $("#cboActivoAbono").val("true");
            $("#mensajeErrorAbono").hide().text("");
        }

        function editarAbono(item) {
            $("#txtIdAbonoCuentaPorPagar").val(item.IdAbonoCuentaPorPagar);
            $("#txtFechaAbono").val(convertirFechaInput(item.FechaAbono));
            $("#txtMontoAbono").val(parseFloat(item.MontoAbono || 0).toFixed(2));
            $("#txtObservacion").val(item.Observacion || "");
            $("#cboActivoAbono").val(item.Activo ? "true" : "false");
        }

       function guardarAbonoCuentaPorPagar() {
    $("#mensajeErrorAbono").hide().text("");

    var idCuentaPorPagar = parseInt($("#txtIdCuentaAbono").val());
    var montoTexto = $("#txtMontoAbono").val().trim();

    var obj = {
        IdAbonoCuentaPorPagar: parseInt($("#txtIdAbonoCuentaPorPagar").val()),
        IdCuentaPorPagar: idCuentaPorPagar,
        FechaAbono: $("#txtFechaAbono").val(),
        MontoAbono: montoTexto === "" ? 0 : parseFloat(montoTexto),
        Observacion: $("#txtObservacion").val().trim(),
        Activo: $("#cboActivoAbono").val() === "true"
    };

    if (isNaN(obj.IdAbonoCuentaPorPagar)) {
        obj.IdAbonoCuentaPorPagar = 0;
    }

    if (obj.IdCuentaPorPagar === 0 || isNaN(obj.IdCuentaPorPagar)) {
        mostrarErrorAbono("Debe seleccionar una cuenta por pagar.", "txtIdCuentaAbono");
        return;
    }

    if (obj.FechaAbono === "") {
        mostrarErrorAbono("Debe ingresar la fecha del abono.", "txtFechaAbono");
        return;
    }

    var mensajeFecha = validarFechaNoFutura(obj.FechaAbono, "La fecha del abono no puede ser futura.");
    if (mensajeFecha !== "") {
        mostrarErrorAbono(mensajeFecha, "txtFechaAbono");
        return;
    }

    var mensajeMonto = validarDecimalMayorCero(montoTexto, "el monto del abono");
    if (mensajeMonto !== "") {
        mostrarErrorAbono(mensajeMonto, "txtMontoAbono");
        return;
    }

    if (obj.Observacion.length > 150) {
        mostrarErrorAbono("La observación no puede superar los 150 caracteres.", "txtObservacion");
        return;
    }

    $.ajax({
        url: '@Url.Action("GuardarAbonoCuentaPorPagar", "GestionarCuentasPorPagar")',
        type: "POST",
        data: JSON.stringify({ obj: obj }),
        dataType: "json",
        contentType: "application/json; charset=utf-8",
        success: function (respuesta) {
            if (respuesta.resultado) {
                limpiarAbono();
                cargarAbonosCuentaPorPagar(idCuentaPorPagar);
                cargarCuentasPorPagar();
            } else {
                $("#mensajeErrorAbono").text(respuesta.mensaje).show();
            }
        },
        error: function () {
            $("#mensajeErrorAbono").text("Error al guardar el abono.").show();
        }
    });
}

        function inactivarAbonoCuentaPorPagar(idAbonoCuentaPorPagar) {
            var idCuentaPorPagar = parseInt($("#txtIdCuentaAbono").val());

            if (!confirm("¿Desea inactivar este abono?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarAbonoCuentaPorPagar", "GestionarCuentasPorPagar")',
                type: "POST",
                data: JSON.stringify({ idAbonoCuentaPorPagar: idAbonoCuentaPorPagar }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        limpiarAbono();
                        cargarAbonosCuentaPorPagar(idCuentaPorPagar);
                        cargarCuentasPorPagar();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el abono.");
                }
            });
        }

        function obtenerBadgeEstado(estado) {
            if (estado === "Pagada") {
                return '<span class="badge badge-success">Pagada</span>';
            }

            if (estado === "Parcial") {
                return '<span class="badge badge-info">Parcial</span>';
            }

            if (estado === "Vencida") {
                return '<span class="badge badge-danger">Vencida</span>';
            }

            if (estado === "Anulada") {
                return '<span class="badge badge-secondary">Anulada</span>';
            }

            return '<span class="badge badge-warning">' + (estado || "Pendiente") + '</span>';
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }

        function mostrarErrorCuenta(mensaje, idCampo) {
            $("#mensajeErrorCuenta").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarErrorAbono(mensaje, idCampo) {
            $("#mensajeErrorAbono").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarNoDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoBusqueda(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoCuenta(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoCuenta(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function validarDecimalMayorCero(texto, nombreCampo) {
            if (texto === "") {
                return "Debe ingresar " + nombreCampo + ".";
            }

            if (!/^[0-9]+(\.[0-9]+)?$/.test(texto)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            var numero = parseFloat(texto);

            if (isNaN(numero)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            if (numero <= 0) {
                return nombreCampo + " debe ser mayor a cero.";
            }

            return "";
        }

        function validarFechaNoFutura(fechaTexto, mensaje) {
            if (fechaTexto === "") {
                return "";
            }

            var fecha = new Date(fechaTexto + "T00:00:00");
            var hoy = new Date();

            if (isNaN(fecha.getTime())) {
                return "Debe ingresar una fecha válida.";
            }

            hoy.setHours(0, 0, 0, 0);

            if (fecha > hoy) {
                return mensaje;
            }

            return "";
        }

        function validarFechaVencimiento(fechaEmisionTexto, fechaVencimientoTexto) {
            var fechaEmision = new Date(fechaEmisionTexto + "T00:00:00");
            var fechaVencimiento = new Date(fechaVencimientoTexto + "T00:00:00");

            if (isNaN(fechaEmision.getTime()) || isNaN(fechaVencimiento.getTime())) {
                return "Debe ingresar fechas válidas.";
            }

            if (fechaVencimiento < fechaEmision) {
                return "La fecha de vencimiento no puede ser menor que la fecha de emisión.";
            }

            return "";
        }
    </script>
}