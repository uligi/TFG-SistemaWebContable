@{
    ViewBag.Title = "Cuentas por Cobrar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-factura {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .texto-vencido {
        color: #dc3545;
        font-weight: bold;
    }

    .texto-por-vencer {
        color: #856404;
        font-weight: bold;
    }

    .texto-pagado {
        color: #28a745;
        font-weight: bold;
    }

    .mensaje-operacion {
        display: none;
        border-radius: 8px;
        padding: 12px 15px;
        margin-bottom: 15px;
        font-size: 14px;
        font-weight: 600;
        border-left: 5px solid transparent;
    }

        .mensaje-operacion.exito {
            display: block;
            background: #eaf7ee;
            color: #1f7a3f;
            border-left-color: #28a745;
        }

        .mensaje-operacion.error {
            display: block;
            background: #fdecea;
            color: #b02a37;
            border-left-color: #dc3545;
        }

        .mensaje-operacion.advertencia {
            display: block;
            background: #fff8e1;
            color: #8a6d1d;
            border-left-color: #ffc107;
        }

</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Cuentas por Cobrar</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Cuentas</li>
        <li class="breadcrumb-item active">Cuentas por cobrar</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de cuentas por cobrar</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalCuenta(null)">
            Nueva cuenta
        </button>
    </div>

    <div class="card-body">
        <div id="mensajeOperacion" class="mensaje-operacion"></div>


        <div class="form-row mb-3">
            <div class="col-md-4">
                <input type="text" id="txtBuscarCuenta" class="form-control" placeholder="Buscar por cliente, factura o estado..." />
            </div>

            <div class="col-md-3">
                <select id="cboFiltroEstado" class="form-control">
                    <option value="">Todos los estados de cuenta</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Parcial">Parcial</option>
                    <option value="Pagada">Pagada</option>
                    <option value="Anulada">Anulada</option>
                </select>
            </div>

            <div class="col-md-3">
                <select id="cboFiltroEstadoCredito" class="form-control">
                    <option value="">Todos los estados de crédito</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Por vencer">Por vencer</option>
                    <option value="Vencida">Vencida</option>
                    <option value="Pagada">Pagada</option>
                    <option value="Anulada">Anulada</option>
                    <option value="Inactiva">Inactiva</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary btn-block" onclick="cargarCuentasPorCobrar()">
                    Actualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaCuentasPorCobrar">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Factura</th>
                        <th>Fecha emisión</th>
                        <th>Vencimiento</th>
                        <th>Días</th>
                        <th>Monto original</th>
                        <th>Saldo actual</th>
                        <th>Estado cuenta</th>
                        <th>Estado crédito</th>
                        <th>Activo</th>
                        <th style="width:260px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModalCuenta" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalCuenta">Nueva cuenta por cobrar</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdentificacionCliente" value="" />
                <input type="hidden" id="txtNumeroFactura" value="" />
                <input type="hidden" id="txtEsEdicionCuenta" value="false" />

                <div class="alert alert-danger" id="mensajeErrorCuenta" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoCuenta" style="display:none;"></div>

                <h6 class="font-weight-bold">Datos de la cuenta</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtClienteVisible">Cliente</label>
                        <input type="text" id="txtClienteVisible" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtNumeroFacturaVisible">Factura</label>
                        <input type="text" id="txtNumeroFacturaVisible" class="form-control codigo-factura" readonly />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtBuscarFactura">Buscar factura</label>
                        <div class="input-group">
                            <input type="text" id="txtBuscarFactura" class="form-control" placeholder="Número o cliente..." />

                            <div class="input-group-append">
                                <button type="button" class="btn btn-outline-primary" onclick="buscarFacturas()">
                                    Buscar
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="form-group col-md-2">
                        <label>&nbsp;</label>
                        <button type="button" class="btn btn-outline-secondary btn-block" onclick="limpiarSeleccionFactura()">
                            Limpiar
                        </button>
                    </div>

                </div>

                <div class="table-responsive mb-3" id="contenedorResultadosFactura" style="display:none;">
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Factura</th>
                                <th>Cliente</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th style="width:110px;">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyResultadosFactura"></tbody>
                    </table>
                </div>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtFechaEmision">Fecha emisión</label>
                        <input type="date" id="txtFechaEmision" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaVencimiento">Fecha vencimiento</label>
                        <input type="date" id="txtFechaVencimiento" class="form-control" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtMontoOriginal">Monto original</label>
                        <input type="text" id="txtMontoOriginal" class="form-control" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtSaldoActual">Saldo actual</label>
                        <input type="text" id="txtSaldoActual" class="form-control" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboEstadoCuenta">Estado</label>
                        <select id="cboEstadoCuenta" class="form-control">
                            <option value="Pendiente">Pendiente</option>
                            <option value="Parcial">Parcial</option>
                            <option value="Pagada">Pagada</option>
                            <option value="Anulada">Anulada</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-2">
                        <label for="cboActivoCuenta">Activo</label>
                        <select id="cboActivoCuenta" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label>Estado crédito</label>
                        <div class="form-control bg-light" id="lblEstadoCreditoModal">
                            Pendiente
                        </div>
                    </div>

                    <div class="form-group col-md-6 d-flex align-items-end justify-content-end">
                        <button type="button" class="btn btn-primary" onclick="guardarCuentaPorCobrar()">
                            Guardar cuenta
                        </button>
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="font-weight-bold mb-0">Abonos de la cuenta</h6>

                    <div>
                        <span class="badge badge-info mr-2" id="lblMontoOriginal">Monto original: 0.00</span>
                        <span class="badge badge-warning mr-2" id="lblMontoPagado">Pagado: 0.00</span>
                        <span class="badge badge-success" id="lblSaldoActual">Saldo: 0.00</span>
                    </div>
                </div>

                <small class="form-text text-muted mb-3" id="textoAyudaAbono">
                    Para registrar abonos, primero guarde o seleccione una cuenta por cobrar.
                </small>

                <input type="hidden" id="txtNumeroAbono" value="0" />

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtFechaAbono">Fecha abono</label>
                        <input type="date" id="txtFechaAbono" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMontoAbono">Monto abono</label>
                        <input type="text" id="txtMontoAbono" class="form-control" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtObservacion">Observación</label>
                        <input type="text" id="txtObservacion" class="form-control" maxlength="150" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboActivoAbono">Activo</label>
                        <select id="cboActivoAbono" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="text-right mb-3">
                    <button type="button" class="btn btn-secondary" onclick="limpiarAbono()">
                        Limpiar abono
                    </button>

                    <button type="button" class="btn btn-primary" onclick="guardarAbonoCuentaPorCobrar()">
                        Guardar abono
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaAbonos">
                        <thead>
                            <tr>
                                <th># Abono</th>
                                <th>Fecha</th>
                                <th>Monto</th>
                                <th>Observación</th>
                                <th>Activo</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-primary" onclick="recalcularSaldoCuenta()">
                    Recalcular saldo
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaCuentas = [];
        var listaAbonos = [];
        var listaFacturas = [];

        $(document).ready(function () {
            cargarCuentasPorCobrar();

            if (window.esAdministradorSistema !== true) {
                $("#cboFiltroEstado option[value='Anulada']").remove();
                $("#cboFiltroEstadoCredito option[value='Anulada']").remove();
                $("#cboFiltroEstadoCredito option[value='Inactiva']").remove();
            }


            $("#txtBuscarCuenta, #cboFiltroEstado, #cboFiltroEstadoCredito").on("keyup change", function () {
                pintarTablaCuentas();
            });

            $("#txtBuscarFactura").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarFacturas();
                }
            });

            $("#txtBuscarFactura").on("input", function () {
                limpiarTextoGeneral("txtBuscarFactura", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtMontoOriginal, #txtSaldoActual, #txtMontoAbono").on("input", function () {
                limpiarDecimal(this.id, "Solo se permiten números y punto decimal.");
            });

            $("#txtObservacion").on("input", function () {
                limpiarTextoGeneral("txtObservacion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtObservacion", "La observación no puede superar los 150 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorCuenta").is(":visible")) {
                    $("#mensajeErrorCuenta").fadeOut(150);
                }

                if ($("#mensajeExitoCuenta").is(":visible")) {
                    $("#mensajeExitoCuenta").fadeOut(150);
                }
            });
        });

        function cargarCuentasPorCobrar() {
            $.ajax({
                url: '@Url.Action("ListarCuentasPorCobrar", "GestionarCuentasPorCobrar")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCuentas = respuesta.data || [];
                    pintarTablaCuentas();
                },
                error: function () {
                    mostrarMensajeOperacion("error", "Error al cargar las cuentas por cobrar.");
                }
            });
        }

        function pintarTablaCuentas() {
            var filtro = $("#txtBuscarCuenta").val().toLowerCase();
            var estadoFiltro = $("#cboFiltroEstado").val();
            var estadoCreditoFiltro = $("#cboFiltroEstadoCredito").val();
            var tbody = $("#tablaCuentasPorCobrar tbody");

            tbody.empty();

            if (listaCuentas.length === 0) {
                tbody.append('<tr><td colspan="11" class="text-center text-muted">No hay cuentas por cobrar registradas.</td></tr>');
                return;
            }

            $.each(listaCuentas, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var cliente = item.ClienteNombre || "";
                var identificacion = item.IdentificacionCliente || "";
                var numeroFactura = item.NumeroFactura || "";
                var estado = item.Estado || "";
                var estadoCredito = item.EstadoCredito || "";

                var texto = (cliente + " " + identificacion + " " + numeroFactura + " " + estado + " " + estadoCredito).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                if (estadoFiltro !== "" && estado !== estadoFiltro) {
                    return;
                }

                if (estadoCreditoFiltro !== "" && estadoCredito !== estadoCreditoFiltro) {
                    return;
                }

                var badgeEstado = obtenerBadgeEstadoCuenta(estado);
                var badgeEstadoCredito = obtenerBadgeEstadoCredito(estadoCredito, item.DiasRestantes);
                var diasTexto = obtenerTextoDiasRestantes(item.DiasRestantes, estadoCredito);

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModalCuenta(item);
                });

                var botonAbono = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-success mr-1",
                    text: "Abonar"
                }).on("click", function () {
                    abrirModalCuenta(item);
                });

                var botonEstado = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarCuentaPorCobrar(item.IdentificacionCliente, item.NumeroFactura);
                });

                var fila = $("<tr>");
                fila.append($("<td>").html(
                    '<div>' + identificacion + ' - ' + cliente + '</div>' +
                    '<div class="texto-tabla-secundario">Factura: ' + numeroFactura + '</div>'
                ));
                fila.append($("<td>", { class: "codigo-factura", text: numeroFactura }));
                fila.append($("<td>").text(formatearFecha(item.FechaEmision)));
                fila.append($("<td>").text(formatearFecha(item.FechaVencimiento)));
                fila.append($("<td>").html(diasTexto));
                fila.append($("<td>").text(formatearNumero(item.MontoOriginal)));
                fila.append($("<td>").text(formatearNumero(item.SaldoActual)));
                fila.append($("<td>").html(badgeEstado));
                fila.append($("<td>").html(badgeEstadoCredito));
                fila.append($("<td>").html(activo));

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo && parseFloat(item.SaldoActual || 0) > 0 && estado !== "Anulada") {
                    acciones.append(botonAbono);
                }

                if (item.Activo && estado !== "Pagada") {
                    acciones.append(botonEstado);
                }

                fila.append(acciones);
                tbody.append(fila);
            });
        }

        function abrirModalCuenta(json) {
            limpiarErrores();
            ocultarMensajeOperacion();
            limpiarSeleccionFactura();
            limpiarAbono();

            $("#txtEsEdicionCuenta").val("false");

            listaAbonos = [];
            pintarTablaAbonos();
            bloquearAbonos(true);

            $("#tituloModalCuenta").text("Nueva cuenta por cobrar");
            $("#txtFechaEmision").val(convertirDateAInput(new Date()));
            $("#txtFechaVencimiento").val(convertirDateAInput(sumarDias(new Date(), 30)));
            $("#txtMontoOriginal").val("");
            $("#txtSaldoActual").val("");
            $("#cboEstadoCuenta").val("Pendiente");
            $("#cboActivoCuenta").val("true");
            $("#lblEstadoCreditoModal").html(obtenerBadgeEstadoCredito("Pendiente", 30));

            $("#txtSaldoActual").prop("readonly", true);

            if (json != null) {

                $("#txtEsEdicionCuenta").val("true");


                $("#tituloModalCuenta").text("Editar cuenta por cobrar");

                $("#txtIdentificacionCliente").val(json.IdentificacionCliente || "");
                $("#txtNumeroFactura").val(json.NumeroFactura || "");

                $("#txtClienteVisible").val((json.IdentificacionCliente || "") + " - " + (json.ClienteNombre || ""));
                $("#txtNumeroFacturaVisible").val(json.NumeroFactura || "");

                $("#txtFechaEmision").val(convertirFechaInput(json.FechaEmision));
                $("#txtFechaVencimiento").val(convertirFechaInput(json.FechaVencimiento));
                $("#txtMontoOriginal").val(formatearNumero(json.MontoOriginal));
                $("#txtSaldoActual").val(formatearNumero(json.SaldoActual));
                $("#cboEstadoCuenta").val(json.Estado || "Pendiente");
                $("#cboActivoCuenta").val(json.Activo ? "true" : "false");

                $("#lblEstadoCreditoModal").html(obtenerBadgeEstadoCredito(json.EstadoCredito || "", json.DiasRestantes));

                bloquearAbonos(false);
                cargarAbonosCuenta(json.IdentificacionCliente, json.NumeroFactura);
            }

            $("#FormModalCuenta").modal("show");
        }

        function buscarFacturas() {
            var filtro = $("#txtBuscarFactura").val().trim().toLowerCase();

            $.ajax({
                url: '@Url.Action("ListarFacturas", "Facturacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaFacturas = respuesta.data || [];
                    pintarResultadosFactura(filtro);
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al buscar facturas.").show();
                }
            });
        }

        function pintarResultadosFactura(filtro) {
            var tbody = $("#tbodyResultadosFactura");
            tbody.empty();

            var encontrados = 0;

            $.each(listaFacturas, function (i, item) {
                var numeroFactura = item.NumeroFactura || "";
                var clienteNombre = item.ClienteNombre || "";
                var identificacionCliente = item.IdentificacionCliente || "";
                var estadoFactura = item.Estado || "";
                var totalFactura = parseFloat(item.TotalFactura || 0);

                var texto = (numeroFactura + " " + clienteNombre + " " + identificacionCliente).toLowerCase();

                if (filtro !== "" && texto.indexOf(filtro) === -1) {
                    return;
                }

                if (item.Activo !== true || estadoFactura !== "Emitida") {
                    return;
                }

                encontrados++;

                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarFacturaCuenta(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-factura", text: numeroFactura }));
                fila.append($("<td>").text(identificacionCliente + " - " + clienteNombre));
                fila.append($("<td>").text(formatearFecha(item.FechaFactura)));
                fila.append($("<td>").text(formatearNumero(totalFactura)));
                fila.append($("<td>").text(estadoFactura));
                fila.append($("<td>").append(boton));

                tbody.append(fila);
            });

            if (encontrados === 0) {
                tbody.append('<tr><td colspan="6" class="text-center text-muted">No se encontraron facturas emitidas disponibles.</td></tr>');
            }

            $("#contenedorResultadosFactura").show();
        }

        function seleccionarFacturaCuenta(item) {
            var totalFactura = parseFloat(item.TotalFactura || 0);

            $("#txtIdentificacionCliente").val(item.IdentificacionCliente || "");
            $("#txtNumeroFactura").val(item.NumeroFactura || "");

            $("#txtClienteVisible").val((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || ""));
            $("#txtNumeroFacturaVisible").val(item.NumeroFactura || "");

            $("#txtMontoOriginal").val(formatearNumero(totalFactura));
            $("#txtSaldoActual").val(formatearNumero(totalFactura));

            $("#contenedorResultadosFactura").hide();
            $("#txtBuscarFactura").val("");
        }

        function limpiarSeleccionFactura() {
            $("#txtIdentificacionCliente").val("");
            $("#txtNumeroFactura").val("");
            $("#txtClienteVisible").val("");
            $("#txtNumeroFacturaVisible").val("");
            $("#txtBuscarFactura").val("");
            $("#contenedorResultadosFactura").hide();
            $("#tbodyResultadosFactura").empty();
        }

        function guardarCuentaPorCobrar() {
            $("#mensajeErrorCuenta").hide().text("");
            $("#mensajeExitoCuenta").hide().text("");

            var obj = {
                IdentificacionCliente: $("#txtIdentificacionCliente").val().trim(),
                NumeroFactura: $("#txtNumeroFactura").val().trim(),
                FechaEmision: $("#txtFechaEmision").val(),
                FechaVencimiento: $("#txtFechaVencimiento").val(),
                MontoOriginal: parseFloat($("#txtMontoOriginal").val()),
                SaldoActual: parseFloat($("#txtSaldoActual").val()),
                Estado: $("#cboEstadoCuenta").val(),
                Activo: $("#cboActivoCuenta").val() === "true"
            };

            if (isNaN(obj.MontoOriginal)) obj.MontoOriginal = 0;
            if (isNaN(obj.SaldoActual)) obj.SaldoActual = obj.MontoOriginal;

            if (obj.IdentificacionCliente === "") {
                mostrarErrorCuenta("Debe seleccionar un cliente/factura.", "txtBuscarFactura");
                return;
            }

            if (obj.NumeroFactura === "") {
                mostrarErrorCuenta("Debe seleccionar una factura.", "txtBuscarFactura");
                return;
            }

            if (obj.FechaEmision === "") {
                mostrarErrorCuenta("Debe ingresar la fecha de emisión.", "txtFechaEmision");
                return;
            }

            if (obj.FechaVencimiento === "") {
                mostrarErrorCuenta("Debe ingresar la fecha de vencimiento.", "txtFechaVencimiento");
                return;
            }

            if (new Date(obj.FechaVencimiento + "T00:00:00") < new Date(obj.FechaEmision + "T00:00:00")) {
                mostrarErrorCuenta("La fecha de vencimiento no puede ser menor que la fecha de emisión.", "txtFechaVencimiento");
                return;
            }

            if (obj.MontoOriginal <= 0) {
                mostrarErrorCuenta("El monto original debe ser mayor a cero.", "txtMontoOriginal");
                return;
            }
            var esEdicion = $("#txtEsEdicionCuenta").val() === "true";

            $.ajax({
                url: '@Url.Action("GuardarCuentaPorCobrar", "GestionarCuentasPorCobrar")',
                type: "POST",
                data: JSON.stringify({
                    obj: obj,
                    esEdicion: esEdicion
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {

                        bloquearAbonos(false);
                        cargarCuentasPorCobrar();
                        cargarAbonosCuenta(obj.IdentificacionCliente, obj.NumeroFactura);

                        if (esEdicion) {
                            mostrarMensajeModal("exito", "Cuenta por cobrar actualizada correctamente.");
                            mostrarMensajeOperacion("exito", "Cuenta por cobrar actualizada correctamente.");
                        } else {
                            $("#txtEsEdicionCuenta").val("true");
                            mostrarMensajeModal("exito", "Cuenta por cobrar registrada correctamente.");
                            mostrarMensajeOperacion("exito", "Cuenta por cobrar registrada correctamente.");
                        }

                    } else {
                        mostrarMensajeModal("error", respuesta.mensaje || "No se pudo guardar la cuenta por cobrar.");
                    }
                },
                error: function () {
                    mostrarMensajeModal("error", "Error al guardar la cuenta por cobrar.");
                }
            });
        }

        function cargarAbonosCuenta(identificacionCliente, numeroFactura) {
            $.ajax({
                url: '@Url.Action("ListarAbonosCuentaPorCobrarPorCuenta", "GestionarCuentasPorCobrar")',
                type: "GET",
                data: {
                    identificacionCliente: identificacionCliente,
                    numeroFactura: numeroFactura
                },
                dataType: "json",
                success: function (respuesta) {
                    listaAbonos = respuesta.data || [];
                    pintarTablaAbonos();
                    actualizarResumenCuenta();
                },
                error: function () {
                    $("#mensajeErrorCuenta").text("Error al cargar los abonos.").show();
                }
            });
        }

        function pintarTablaAbonos() {
            var tbody = $("#tablaAbonos tbody");
            tbody.empty();

            if (listaAbonos.length === 0) {
                tbody.append('<tr><td colspan="6" class="text-center text-muted">No hay abonos registrados.</td></tr>');
                actualizarResumenCuenta();
                return;
            }

            $.each(listaAbonos, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    editarAbono(item);
                });

                var botonEstado = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarAbono(item.IdentificacionCliente, item.NumeroFactura, item.NumeroAbono);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonEstado);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroAbono));
                fila.append($("<td>").text(formatearFecha(item.FechaAbono)));
                fila.append($("<td>").text(formatearNumero(item.MontoAbono)));
                fila.append($("<td>").text(item.Observacion || ""));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function actualizarResumenCuenta() {
            var montoOriginal = parseFloat($("#txtMontoOriginal").val() || 0);
            var saldoActual = parseFloat($("#txtSaldoActual").val() || 0);

            var montoPagado = montoOriginal - saldoActual;

            if (isNaN(montoPagado) || montoPagado < 0) {
                montoPagado = 0;
            }

            $("#lblMontoOriginal").text("Monto original: " + formatearNumero(montoOriginal));
            $("#lblMontoPagado").text("Pagado: " + formatearNumero(montoPagado));
            $("#lblSaldoActual").text("Saldo: " + formatearNumero(saldoActual));
        }

        function guardarAbonoCuentaPorCobrar() {
            $("#mensajeErrorCuenta").hide().text("");
            $("#mensajeExitoCuenta").hide().text("");

            var obj = {
                IdentificacionCliente: $("#txtIdentificacionCliente").val().trim(),
                NumeroFactura: $("#txtNumeroFactura").val().trim(),
                NumeroAbono: parseInt($("#txtNumeroAbono").val()),
                FechaAbono: $("#txtFechaAbono").val(),
                MontoAbono: parseFloat($("#txtMontoAbono").val()),
                Observacion: $("#txtObservacion").val().trim(),
                Activo: $("#cboActivoAbono").val() === "true"
            };

            if (isNaN(obj.NumeroAbono)) obj.NumeroAbono = 0;
            if (isNaN(obj.MontoAbono)) obj.MontoAbono = 0;

            if (obj.IdentificacionCliente === "" || obj.NumeroFactura === "") {
                mostrarErrorCuenta("Primero debe seleccionar o guardar una cuenta por cobrar.", "txtNumeroFacturaVisible");
                return;
            }

            if (obj.FechaAbono === "") {
                mostrarErrorCuenta("Debe ingresar la fecha del abono.", "txtFechaAbono");
                return;
            }

            if (obj.MontoAbono <= 0) {
                mostrarErrorCuenta("El monto del abono debe ser mayor a cero.", "txtMontoAbono");
                return;
            }

            if (obj.Observacion.length > 150) {
                mostrarErrorCuenta("La observación no puede superar los 150 caracteres.", "txtObservacion");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarAbonoCuentaPorCobrar", "GestionarCuentasPorCobrar")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        var esEdicionAbono = obj.NumeroAbono > 0;

                        limpiarAbono();
                        cargarCuentasPorCobrar();
                        refrescarCuentaActual(obj.IdentificacionCliente, obj.NumeroFactura);

                        if (esEdicionAbono) {
                            mostrarMensajeModal("exito", "Abono actualizado correctamente.");
                            mostrarMensajeOperacion("exito", "Abono actualizado correctamente.");
                        } else {
                            mostrarMensajeModal("exito", "Abono registrado correctamente.");
                            mostrarMensajeOperacion("exito", "Abono registrado correctamente.");
                        }
                    } else {
                        mostrarMensajeModal("error", respuesta.mensaje || "No se pudo guardar el abono.");
                    }
                },
                error: function () {
                    mostrarMensajeModal("error", "Error al guardar el abono.");
                }
            });
        }

        function refrescarCuentaActual(identificacionCliente, numeroFactura) {
            $.ajax({
                url: '@Url.Action("ObtenerCuentaPorCobrar", "GestionarCuentasPorCobrar")',
                type: "GET",
                data: {
                    identificacionCliente: identificacionCliente,
                    numeroFactura: numeroFactura
                },
                dataType: "json",
                success: function (respuesta) {
                    var item = respuesta.data;

                    if (item != null) {
                        $("#txtMontoOriginal").val(formatearNumero(item.MontoOriginal));
                        $("#txtSaldoActual").val(formatearNumero(item.SaldoActual));
                        $("#cboEstadoCuenta").val(item.Estado);
                        $("#cboActivoCuenta").val(item.Activo ? "true" : "false");
                        $("#lblEstadoCreditoModal").html(obtenerBadgeEstadoCredito(item.EstadoCredito || "", item.DiasRestantes));

                        cargarAbonosCuenta(identificacionCliente, numeroFactura);
                    }
                }
            });
        }

        function editarAbono(item) {
            $("#txtNumeroAbono").val(item.NumeroAbono);
            $("#txtFechaAbono").val(convertirFechaInput(item.FechaAbono));
            $("#txtMontoAbono").val(formatearNumero(item.MontoAbono));
            $("#txtObservacion").val(item.Observacion || "");
            $("#cboActivoAbono").val(item.Activo ? "true" : "false");
        }

        function limpiarAbono() {
            $("#txtNumeroAbono").val("0");
            $("#txtFechaAbono").val(convertirDateAInput(new Date()));
            $("#txtMontoAbono").val("");
            $("#txtObservacion").val("");
            $("#cboActivoAbono").val("true");
        }

        function bloquearAbonos(bloquear) {
            $("#txtFechaAbono").prop("disabled", bloquear);
            $("#txtMontoAbono").prop("disabled", bloquear);
            $("#txtObservacion").prop("disabled", bloquear);
            $("#cboActivoAbono").prop("disabled", bloquear);

            if (bloquear) {
                $("#textoAyudaAbono").text("Para registrar abonos, primero guarde o seleccione una cuenta por cobrar.");
            } else {
                $("#textoAyudaAbono").text("Registre los abonos realizados por el cliente.");
            }
        }

        function inactivarAbono(identificacionCliente, numeroFactura, numeroAbono) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este abono"),
                function () {
                    ejecutarInactivarAbono(identificacionCliente, numeroFactura, numeroAbono);
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function ejecutarInactivarAbono(identificacionCliente, numeroFactura, numeroAbono) {
            $.ajax({
                url: '@Url.Action("InactivarAbonoCuentaPorCobrar", "GestionarCuentasPorCobrar")',
                type: "POST",
                data: JSON.stringify({
                    identificacionCliente: identificacionCliente,
                    numeroFactura: numeroFactura,
                    numeroAbono: numeroAbono
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        limpiarAbono();
                        cargarCuentasPorCobrar();
                        refrescarCuentaActual(identificacionCliente, numeroFactura);

                        mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Abono"), "exito", "#mensajeOperacion");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el abono.", "error", "#mensajeOperacion");
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al procesar el abono.", "error", "#mensajeOperacion");
                }
            });
        }

        function recalcularSaldoCuenta() {
            var identificacionCliente = $("#txtIdentificacionCliente").val().trim();
            var numeroFactura = $("#txtNumeroFactura").val().trim();

            if (identificacionCliente === "" || numeroFactura === "") {
                mostrarErrorCuenta("Debe seleccionar una cuenta por cobrar.", "txtNumeroFacturaVisible");
                return;
            }

            $.ajax({
                url: '@Url.Action("RecalcularSaldoCuentaPorCobrar", "GestionarCuentasPorCobrar")',
                type: "POST",
                data: JSON.stringify({
                    identificacionCliente: identificacionCliente,
                    numeroFactura: numeroFactura
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarCuentasPorCobrar();
                        refrescarCuentaActual(identificacionCliente, numeroFactura);

                        mostrarMensajeModal("exito", respuesta.mensaje || "Saldo recalculado correctamente.");
                        mostrarMensajeOperacion("exito", "Saldo recalculado correctamente.");
                    } else {
                        mostrarMensajeModal("error", respuesta.mensaje || "No se pudo recalcular el saldo.");
                    }
                },
                error: function () {
                    mostrarMensajeModal("error", "Error al recalcular el saldo.");
                }
            });
        }

        function inactivarCuentaPorCobrar(identificacionCliente, numeroFactura) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "esta cuenta por cobrar"),
                function () {
                    ejecutarInactivarCuentaPorCobrar(identificacionCliente, numeroFactura);
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function ejecutarInactivarCuentaPorCobrar(identificacionCliente, numeroFactura) {
            $.ajax({
                url: '@Url.Action("InactivarCuentaPorCobrar", "GestionarCuentasPorCobrar")',
                type: "POST",
                data: JSON.stringify({
                    identificacionCliente: identificacionCliente,
                    numeroFactura: numeroFactura
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarCuentasPorCobrar();
                        mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Cuenta por cobrar"), "exito", "#mensajeOperacion");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar la cuenta por cobrar.", "error", "#mensajeOperacion");
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al procesar la cuenta por cobrar.", "error", "#mensajeOperacion");
                }
            });
        }
        function obtenerBadgeEstadoCuenta(estado) {
            if (estado === "Pagada") {
                return '<span class="badge badge-success">Pagada</span>';
            }

            if (estado === "Parcial") {
                return '<span class="badge badge-warning">Parcial</span>';
            }

            if (estado === "Anulada") {
                return '<span class="badge badge-danger">Anulada</span>';
            }

            return '<span class="badge badge-info">' + estado + '</span>';
        }

        function obtenerBadgeEstadoCredito(estadoCredito, diasRestantes) {
            diasRestantes = parseInt(diasRestantes);

            if (isNaN(diasRestantes)) {
                diasRestantes = 0;
            }

            if (estadoCredito === "Pagada") {
                return '<span class="badge badge-success">Pagada</span>';
            }

            if (estadoCredito === "Vencida") {
                return '<span class="badge badge-danger">Vencida</span>';
            }

            if (estadoCredito === "Por vencer") {
                return '<span class="badge badge-warning">Por vencer</span>';
            }

            if (estadoCredito === "Anulada") {
                return '<span class="badge badge-danger">Anulada</span>';
            }

            if (estadoCredito === "Inactiva") {
                return '<span class="badge badge-secondary">Inactiva</span>';
            }

            return '<span class="badge badge-info">Pendiente</span>';
        }

        function obtenerTextoDiasRestantes(diasRestantes, estadoCredito) {
            diasRestantes = parseInt(diasRestantes);

            if (isNaN(diasRestantes)) {
                diasRestantes = 0;
            }

            if (estadoCredito === "Pagada") {
                return '<span class="texto-pagado">Pagada</span>';
            }

            if (estadoCredito === "Vencida") {
                return '<span class="texto-vencido">' + Math.abs(diasRestantes) + ' día(s) vencida</span>';
            }

            if (estadoCredito === "Por vencer") {
                if (diasRestantes === 0) {
                    return '<span class="texto-por-vencer">Vence hoy</span>';
                }

                return '<span class="texto-por-vencer">' + diasRestantes + ' día(s)</span>';
            }

            if (diasRestantes === 0) {
                return '<span class="texto-por-vencer">Vence hoy</span>';
            }

            return diasRestantes + ' día(s)';
        }

        function mostrarMensajeOperacion(tipo, mensaje) {
            var contenedor = $("#mensajeOperacion");

            contenedor
                .removeClass("exito error advertencia")
                .addClass(tipo)
                .html(mensaje)
                .fadeIn(150);

            setTimeout(function () {
                contenedor.fadeOut(300);
            }, 5000);
        }

        function ocultarMensajeOperacion() {
            $("#mensajeOperacion")
                .removeClass("exito error advertencia")
                .hide()
                .html("");
        }

        function mostrarMensajeModal(tipo, mensaje) {
            $("#mensajeErrorCuenta").hide().text("");
            $("#mensajeExitoCuenta").hide().text("");

            if (tipo === "exito") {
                $("#mensajeExitoCuenta").text(mensaje).show();
            } else {
                $("#mensajeErrorCuenta").text(mensaje).show();
            }
        }


        function mostrarErrorCuenta(mensaje, idCampo) {
            $("#mensajeErrorCuenta").text(mensaje).show();

            if (idCampo && $("#" + idCampo).length > 0) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function limpiarErrores() {
            $("#mensajeErrorCuenta").hide().text("");
            $("#mensajeExitoCuenta").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            return formatearFecha(valor);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }

        function sumarDias(fecha, dias) {
            var nuevaFecha = new Date(fecha);
            nuevaFecha.setDate(nuevaFecha.getDate() + dias);
            return nuevaFecha;
        }
    </script>
}