@{
    ViewBag.Title = "Notas de Crédito";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-nota,
    .codigo-factura {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Notas de Crédito</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Facturación</li>
        <li class="breadcrumb-item active">Notas de crédito</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de notas de crédito</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalNota(null)">
            Nueva nota de crédito
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscarNota" class="form-control" placeholder="Buscar por nota, factura, cliente, empleado o estado..." />
            </div>

            <div class="col-md-3">
                <select id="cboFiltroEstado" class="form-control">
                    <option value="">Todos los estados</option>
                    <option value="Aplicada">Aplicada</option>
                    <option value="Anulada">Anulada</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary btn-block" onclick="cargarNotasCredito()">
                    Actualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaNotasCredito">
                <thead>
                    <tr>
                        <th>Nota crédito</th>
                        <th>Factura</th>
                        <th>Cliente</th>
                        <th>Empleado</th>
                        <th>Fecha</th>
                        <th>Total factura</th>
                        <th>Total nota</th>
                        <th>Estado</th>
                        <th>Activo</th>
                        <th style="width:220px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModalNota" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalNota">Nueva nota de crédito</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtNumeroNotaCreditoInterno" value="" />
                <input type="hidden" id="txtNumeroFacturaInterno" value="" />

                <div class="alert alert-danger" id="mensajeErrorNota" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoNota" style="display:none;"></div>

                <h6 class="font-weight-bold">Datos de la nota de crédito</h6>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtNumeroNotaCredito">Número nota crédito</label>
                        <input type="text" id="txtNumeroNotaCredito" class="form-control codigo-nota" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtNumeroFacturaVisible">Factura asociada</label>
                        <input type="text" id="txtNumeroFacturaVisible" class="form-control codigo-factura" readonly />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtBuscarCliente">Buscar cliente</label>

                        <input type="hidden" id="txtIdentificacionCliente" value="" />

                        <div class="input-group">
                            <input type="text"
                                   id="txtBuscarCliente"
                                   class="form-control"
                                   placeholder="Buscar cliente por cédula o nombre..." />

                            <div class="input-group-append">
                                <button type="button" class="btn btn-outline-primary" onclick="buscarClientesNotaCredito()">
                                    Buscar
                                </button>
                            </div>
                        </div>

                        <small class="form-text text-muted" id="lblClienteSeleccionado">
                            Ningún cliente seleccionado.
                        </small>
                    </div>

                    <div class="table-responsive mb-3" id="contenedorResultadosCliente" style="display:none;">
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Identificación</th>
                                    <th>Cliente</th>
                                    <th style="width:110px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyResultadosCliente"></tbody>
                        </table>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <label for="txtBuscarFactura">Factura del cliente seleccionado</label>

                            <div class="input-group">
                                <input type="text"
                                       id="txtBuscarFactura"
                                       class="form-control"
                                       placeholder="Filtrar facturas por número..." />

                                <div class="input-group-append">
                                    <button type="button" class="btn btn-outline-primary" onclick="buscarFacturasNotaCredito()">
                                        Buscar facturas
                                    </button>
                                </div>
                            </div>

                            <small class="form-text text-muted">
                                Primero seleccione un cliente para mostrar sus facturas disponibles.
                            </small>
                        </div>
                    </div>

                    <div class="form-group col-md-2">
                        <label>&nbsp;</label>
                        <button type="button" class="btn btn-outline-secondary btn-block" onclick="limpiarFacturaSeleccionada()">
                            Limpiar
                        </button>
                    </div>

                </div>

                <div class="table-responsive mb-3" id="contenedorResultadosFactura" style="display:none;">
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Factura</th>
                                <th>Cliente</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th style="width:110px;">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyResultadosFactura"></tbody>
                    </table>
                </div>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtClienteVisible">Cliente</label>
                        <input type="text" id="txtClienteVisible" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboEmpleado">Empleado que registra</label>
                        <select id="cboEmpleado" class="form-control">
                            <option value="">Seleccione un empleado</option>
                        </select>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtFechaNotaCredito">Fecha nota</label>
                        <input type="date" id="txtFechaNotaCredito" class="form-control" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboEstadoNota">Estado</label>
                        <select id="cboEstadoNota" class="form-control">
                            <option value="Aplicada">Aplicada</option>
                            <option value="Anulada">Anulada</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtTotalFactura">Total factura</label>
                        <input type="text" id="txtTotalFactura" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtSubtotal">Subtotal nota</label>
                        <input type="text" id="txtSubtotal" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtTotalImpuesto">Total impuesto</label>
                        <input type="text" id="txtTotalImpuesto" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtTotalNotaCredito">Total nota crédito</label>
                        <input type="text" id="txtTotalNotaCredito" class="form-control" />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-10">
                        <label for="txtMotivo">Motivo</label>
                        <input type="text" id="txtMotivo" class="form-control" maxlength="250" placeholder="Motivo de la nota de crédito..." />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboActivoNota">Activo</label>
                        <select id="cboActivoNota" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="text-right">
                    <button type="button" class="btn btn-secondary" onclick="limpiarFormularioNota()">
                        Limpiar
                    </button>

                    <button type="button" class="btn btn-primary" onclick="guardarNotaCredito()">
                        Guardar nota
                    </button>
                </div>

            </div>

            <div class="modal-footer">
                <small class="text-muted mr-auto">
                    Al registrar una nota de crédito, si la factura tiene cuenta por cobrar activa, el saldo se reduce automáticamente.
                </small>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaNotasCredito = [];
        var listaFacturas = [];

        $(document).ready(function () {
            cargarNotasCredito();
            cargarEmpleados();

            $("#txtBuscarNota, #cboFiltroEstado").on("keyup change", function () {
                pintarTablaNotasCredito();
            });

            $("#txtBuscarCliente").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarClientesNotaCredito();
                }
            });

            $("#txtBuscarCliente").on("input", function () {
                limpiarTextoGeneral("txtBuscarCliente", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtBuscarFactura").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarFacturasNotaCredito();
                }
            });

            $("#txtBuscarFactura").on("input", function () {
                limpiarTextoGeneral("txtBuscarFactura", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtMotivo").on("input", function () {
                limpiarTextoGeneral("txtMotivo", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 250) {
                    $(this).val($(this).val().substring(0, 250));
                    mostrarAyudaCampo("txtMotivo", "El motivo no puede superar los 250 caracteres.");
                }
            });

            $("#txtSubtotal, #txtTotalImpuesto, #txtTotalNotaCredito").on("input", function () {
                limpiarDecimal(this.id, "Solo se permiten números y punto decimal.");
            });

            $("#txtSubtotal, #txtTotalImpuesto").on("keyup change", function () {
                calcularTotalNota();
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorNota").is(":visible")) {
                    $("#mensajeErrorNota").fadeOut(150);
                }

                if ($("#mensajeExitoNota").is(":visible")) {
                    $("#mensajeExitoNota").fadeOut(150);
                }
            });
        });
        function buscarClientesNotaCredito() {
    var filtro = $("#txtBuscarCliente").val().trim();

    if (filtro.length < 2) {
        mostrarErrorNota("Digite al menos 2 caracteres para buscar el cliente.", "txtBuscarCliente");
        return;
    }

    $.ajax({
        url: '@Url.Action("BuscarClientesFactura", "Facturacion")',
        type: "GET",
        data: { filtro: filtro },
        dataType: "json",
        success: function (respuesta) {
            var tbody = $("#tbodyResultadosCliente");
            tbody.empty();

            if (!respuesta.data || respuesta.data.length === 0) {
                tbody.append(
                    '<tr>' +
                        '<td colspan="3" class="text-center text-muted">' +
                            'No se encontraron clientes.' +
                        '</td>' +
                    '</tr>'
                );

                $("#contenedorResultadosCliente").show();
                return;
            }

            $.each(respuesta.data, function (i, item) {
                var identificacion = item.Identificacion || "";

                var nombre = (
                    (item.Nombre || "") + " " +
                    (item.PrimerApellido || "") + " " +
                    (item.SegundoApellido || "")
                ).trim();

                if (nombre === "") {
                    nombre = item.NombreCompleto || item.ClienteNombre || "Cliente sin nombre";
                }

                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarClienteNotaCredito(identificacion, nombre);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text(identificacion));
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").append(boton));

                tbody.append(fila);
            });

            $("#contenedorResultadosCliente").show();
        },
        error: function () {
            $("#mensajeErrorNota").text("Error al buscar clientes.").show();
        }
    });
}

function seleccionarClienteNotaCredito(identificacion, nombre) {
    $("#txtIdentificacionCliente").val(identificacion);
    $("#txtBuscarCliente").val(identificacion + " - " + nombre);
    $("#lblClienteSeleccionado").text("Cliente seleccionado: " + identificacion + " - " + nombre);
    $("#txtClienteVisible").val(identificacion + " - " + nombre);

    $("#contenedorResultadosCliente").hide();

    limpiarFacturaSeleccionada();
    $("#txtIdentificacionCliente").val(identificacion);
    $("#txtClienteVisible").val(identificacion + " - " + nombre);

    buscarFacturasNotaCredito();
}
        function cargarNotasCredito() {
            $.ajax({
                url: '@Url.Action("ListarNotasCredito", "Facturacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaNotasCredito = respuesta.data || [];
                    pintarTablaNotasCredito();
                },
                error: function () {
                    alert("Error al cargar las notas de crédito.");
                }
            });
        }

        function cargarEmpleados() {
            $.ajax({
                url: '@Url.Action("BuscarEmpleadosFactura", "Facturacion")',
                type: "GET",
                data: { filtro: "" },
                dataType: "json",
                success: function (respuesta) {
                    $("#cboEmpleado").empty().append('<option value="">Seleccione un empleado</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        var nombre = item.NombreCompleto
                            || item.EmpleadoNombre
                            || ((item.Nombre || "") + " " + (item.PrimerApellido || "") + " " + (item.SegundoApellido || "")).trim()
                            || item.Identificacion;

                        $("#cboEmpleado").append(
                            $("<option>", {
                                value: item.Identificacion,
                                text: item.Identificacion + " - " + nombre
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar los empleados.");
                }
            });
        }

        function pintarTablaNotasCredito() {
            var filtro = $("#txtBuscarNota").val().toLowerCase();
            var estadoFiltro = $("#cboFiltroEstado").val();
            var tbody = $("#tablaNotasCredito tbody");

            tbody.empty();

            if (listaNotasCredito.length === 0) {
                tbody.append('<tr><td colspan="10" class="text-center text-muted">No hay notas de crédito registradas.</td></tr>');
                return;
            }

            $.each(listaNotasCredito, function (i, item) {
                var numeroNota = item.NumeroNotaCredito || "";
                var numeroFactura = item.NumeroFactura || "";
                var cliente = item.ClienteNombre || "";
                var empleado = item.EmpleadoNombre || "";
                var estado = item.Estado || "";

                var texto = (numeroNota + " " + numeroFactura + " " + cliente + " " + empleado + " " + estado).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                if (estadoFiltro !== "" && estado !== estadoFiltro) {
                    return;
                }

                var badgeEstado = estado === "Aplicada"
                    ? '<span class="badge badge-success">Aplicada</span>'
                    : estado === "Anulada"
                        ? '<span class="badge badge-danger">Anulada</span>'
                        : '<span class="badge badge-warning">' + estado + '</span>';

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModalNota(item);
                });

                var botonAnular = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Anular"
                }).on("click", function () {
                    inactivarNotaCredito(item.NumeroNotaCredito);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo && estado !== "Anulada") {
                    acciones.append(botonAnular);
                }

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-nota", text: numeroNota }));
                fila.append($("<td>", { class: "codigo-factura", text: numeroFactura }));
                fila.append($("<td>").text(cliente));
                fila.append($("<td>").text(empleado));
                fila.append($("<td>").text(formatearFecha(item.FechaNotaCredito)));
                fila.append($("<td>").text(formatearNumero(item.TotalFactura)));
                fila.append($("<td>").text(formatearNumero(item.TotalNotaCredito)));
                fila.append($("<td>").html(badgeEstado));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function abrirModalNota(json) {
            limpiarErrores();
            limpiarFormularioNota();

            $("#tituloModalNota").text("Nueva nota de crédito");
            $("#txtFechaNotaCredito").val(convertirDateAInput(new Date()));
            $("#cboEstadoNota").val("Aplicada");
            $("#cboActivoNota").val("true");
            $("#txtNumeroNotaCredito").val("Se generará automáticamente");

            $("#txtSubtotal").prop("readonly", false);
            $("#txtTotalImpuesto").prop("readonly", false);
            $("#txtTotalNotaCredito").prop("readonly", false);
            $("#txtBuscarFactura").prop("disabled", false);

            if (json != null) {
                $("#tituloModalNota").text("Editar nota de crédito");

                $("#txtNumeroNotaCreditoInterno").val(json.NumeroNotaCredito || "");
                $("#txtNumeroNotaCredito").val(json.NumeroNotaCredito || "");

                $("#txtNumeroFacturaInterno").val(json.NumeroFactura || "");
                $("#txtNumeroFacturaVisible").val(json.NumeroFactura || "");

                $("#txtClienteVisible").val((json.IdentificacionCliente || "") + " - " + (json.ClienteNombre || ""));
                $("#cboEmpleado").val(json.IdentificacionEmpleado || "");

                $("#txtFechaNotaCredito").val(convertirFechaInput(json.FechaNotaCredito));
                $("#txtSubtotal").val(formatearNumero(json.Subtotal));
                $("#txtTotalImpuesto").val(formatearNumero(json.TotalImpuesto));
                $("#txtTotalNotaCredito").val(formatearNumero(json.TotalNotaCredito));
                $("#txtTotalFactura").val(formatearNumero(json.TotalFactura));

                $("#txtMotivo").val(json.Motivo || "");
                $("#cboEstadoNota").val(json.Estado || "Aplicada");
                $("#cboActivoNota").val(json.Activo ? "true" : "false");

                $("#txtSubtotal").prop("readonly", true);
                $("#txtTotalImpuesto").prop("readonly", true);
                $("#txtTotalNotaCredito").prop("readonly", true);
                $("#txtBuscarFactura").prop("disabled", true);
            }

            $("#FormModalNota").modal("show");
        }

       function buscarFacturasNotaCredito() {
    var identificacionCliente = $("#txtIdentificacionCliente").val().trim();
    var filtro = $("#txtBuscarFactura").val().trim().toLowerCase();

    if (identificacionCliente === "") {
        mostrarErrorNota("Primero debe seleccionar un cliente.", "txtBuscarCliente");
        return;
    }

    $.ajax({
        url: '@Url.Action("ListarFacturasPorCliente", "Facturacion")',
        type: "GET",
        data: { identificacionCliente: identificacionCliente },
        dataType: "json",
        success: function (respuesta) {
            listaFacturas = respuesta.data || [];

            if (filtro !== "") {
                listaFacturas = listaFacturas.filter(function (item) {
                    var numeroFactura = item.NumeroFactura || "";
                    var estado = item.Estado || "";

                    var texto = (numeroFactura + " " + estado).toLowerCase();

                    return texto.indexOf(filtro) !== -1;
                });
            }

            listaFacturas = listaFacturas.filter(function (item) {
                return item.Activo === true &&
                    item.Estado === "Emitida" &&
                    parseFloat(item.TotalFactura || 0) > 0;
            });

            pintarResultadosFactura();
        },
        error: function () {
            $("#mensajeErrorNota").text("Error al buscar facturas del cliente.").show();
        }
    });
}

        function pintarResultadosFactura() {
            var tbody = $("#tbodyResultadosFactura");
            tbody.empty();

            if (listaFacturas.length === 0) {
                tbody.append('<tr><td colspan="6" class="text-center text-muted">No se encontraron facturas disponibles.</td></tr>');
                $("#contenedorResultadosFactura").show();
                return;
            }

            $.each(listaFacturas, function (i, item) {
                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarFacturaNota(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-factura", text: item.NumeroFactura || "" }));
                fila.append($("<td>").text((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")));
                fila.append($("<td>").text(formatearFecha(item.FechaFactura)));
                fila.append($("<td>").text(formatearNumero(item.TotalFactura)));
                fila.append($("<td>").text(item.Estado || ""));
                fila.append($("<td>").append(boton));

                tbody.append(fila);
            });

            $("#contenedorResultadosFactura").show();
        }

        function seleccionarFacturaNota(item) {
            $("#txtNumeroFacturaInterno").val(item.NumeroFactura || "");
            $("#txtNumeroFacturaVisible").val(item.NumeroFactura || "");

            $("#txtClienteVisible").val((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || ""));
            $("#txtTotalFactura").val(formatearNumero(item.TotalFactura));

            $("#txtBuscarFactura").val("");
            $("#contenedorResultadosFactura").hide();

            $("#txtSubtotal").val(formatearNumero(item.TotalFactura));
            $("#txtTotalImpuesto").val("0.00");
            $("#txtTotalNotaCredito").val(formatearNumero(item.TotalFactura));
        }

        function guardarNotaCredito() {
            $("#mensajeErrorNota").hide().text("");
            $("#mensajeExitoNota").hide().text("");

            var obj = {
                NumeroNotaCredito: $("#txtNumeroNotaCreditoInterno").val().trim(),
                NumeroFactura: $("#txtNumeroFacturaInterno").val().trim(),
                IdentificacionEmpleado: $("#cboEmpleado").val(),
                FechaNotaCredito: $("#txtFechaNotaCredito").val(),
                Motivo: $("#txtMotivo").val().trim(),
                Subtotal: parseFloat($("#txtSubtotal").val()),
                TotalImpuesto: parseFloat($("#txtTotalImpuesto").val()),
                TotalNotaCredito: parseFloat($("#txtTotalNotaCredito").val()),
                Estado: $("#cboEstadoNota").val(),
                Activo: $("#cboActivoNota").val() === "true"
            };

            if (isNaN(obj.Subtotal)) obj.Subtotal = 0;
            if (isNaN(obj.TotalImpuesto)) obj.TotalImpuesto = 0;
            if (isNaN(obj.TotalNotaCredito)) obj.TotalNotaCredito = 0;

            if (obj.NumeroNotaCredito === "" && obj.NumeroFactura === "") {
                mostrarErrorNota("Debe seleccionar una factura.", "txtBuscarFactura");
                return;
            }

            if (obj.IdentificacionEmpleado === "") {
                mostrarErrorNota("Debe seleccionar un empleado.", "cboEmpleado");
                return;
            }

            if (obj.FechaNotaCredito === "") {
                mostrarErrorNota("Debe ingresar la fecha de la nota de crédito.", "txtFechaNotaCredito");
                return;
            }

            var mensajeFecha = validarFechaNoFutura(obj.FechaNotaCredito, "La fecha de la nota de crédito no puede ser futura.");
            if (mensajeFecha !== "") {
                mostrarErrorNota(mensajeFecha, "txtFechaNotaCredito");
                return;
            }

            if (obj.Motivo === "") {
                mostrarErrorNota("Debe ingresar el motivo de la nota de crédito.", "txtMotivo");
                return;
            }

            if (obj.Motivo.length > 250) {
                mostrarErrorNota("El motivo no puede superar los 250 caracteres.", "txtMotivo");
                return;
            }

            if (obj.NumeroNotaCredito === "") {
                if (obj.TotalNotaCredito <= 0) {
                    mostrarErrorNota("El total de la nota de crédito debe ser mayor a cero.", "txtTotalNotaCredito");
                    return;
                }

                var totalFactura = parseFloat($("#txtTotalFactura").val());

                if (!isNaN(totalFactura) && obj.TotalNotaCredito > totalFactura) {
                    mostrarErrorNota("El total de la nota de crédito no puede superar el total de la factura.", "txtTotalNotaCredito");
                    return;
                }
            }

            $.ajax({
                url: '@Url.Action("GuardarNotaCredito", "Facturacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        var numeroNotaCredito = respuesta.numeroNotaCredito || obj.NumeroNotaCredito;

                        $("#txtNumeroNotaCreditoInterno").val(numeroNotaCredito);
                        $("#txtNumeroNotaCredito").val(numeroNotaCredito);

                        $("#mensajeExitoNota").text(respuesta.mensaje || "Nota de crédito guardada correctamente.").show();

                        cargarNotasCredito();
                    } else {
                        $("#mensajeErrorNota").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorNota").text("Error al guardar la nota de crédito.").show();
                }
            });
        }

        function inactivarNotaCredito(numeroNotaCredito) {
            if (!confirm("¿Desea anular esta nota de crédito? Si afectó una cuenta por cobrar, el saldo será revertido.")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarNotaCredito", "Facturacion")',
                type: "POST",
                data: JSON.stringify({ numeroNotaCredito: numeroNotaCredito }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarNotasCredito();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al anular la nota de crédito.");
                }
            });
        }

        function limpiarFormularioNota() {
            $("#txtNumeroNotaCreditoInterno").val("");
            $("#txtNumeroNotaCredito").val("");
            $("#txtNumeroFacturaInterno").val("");
            $("#txtNumeroFacturaVisible").val("");
            $("#txtBuscarFactura").val("");
            $("#txtClienteVisible").val("");
            $("#txtTotalFactura").val("");

            $("#cboEmpleado").val("");
            $("#txtFechaNotaCredito").val(convertirDateAInput(new Date()));
            $("#txtSubtotal").val("");
            $("#txtTotalImpuesto").val("");
            $("#txtTotalNotaCredito").val("");
            $("#txtMotivo").val("");

            $("#cboEstadoNota").val("Aplicada");
            $("#cboActivoNota").val("true");

            $("#contenedorResultadosFactura").hide();
            $("#tbodyResultadosFactura").empty();

            $("#txtIdentificacionCliente").val("");
            $("#txtBuscarCliente").val("");
            $("#lblClienteSeleccionado").text("Ningún cliente seleccionado.");
            $("#contenedorResultadosCliente").hide();
            $("#tbodyResultadosCliente").empty();

            $("#txtSubtotal").prop("readonly", false);
            $("#txtTotalImpuesto").prop("readonly", false);
            $("#txtTotalNotaCredito").prop("readonly", false);
            $("#txtBuscarFactura").prop("disabled", false);
        }

        function limpiarFacturaSeleccionada() {
            $("#txtNumeroFacturaInterno").val("");
            $("#txtNumeroFacturaVisible").val("");
            $("#txtBuscarFactura").val("");
            $("#txtTotalFactura").val("");

            $("#txtSubtotal").val("");
            $("#txtTotalImpuesto").val("");
            $("#txtTotalNotaCredito").val("");

            $("#contenedorResultadosFactura").hide();
            $("#tbodyResultadosFactura").empty();
        }

        function calcularTotalNota() {
            var subtotal = parseFloat($("#txtSubtotal").val());
            var impuesto = parseFloat($("#txtTotalImpuesto").val());

            if (isNaN(subtotal)) subtotal = 0;
            if (isNaN(impuesto)) impuesto = 0;

            var total = subtotal + impuesto;

            $("#txtTotalNotaCredito").val(total.toFixed(2));
        }

        function mostrarErrorNota(mensaje, idCampo) {
            $("#mensajeErrorNota").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function limpiarErrores() {
            $("#mensajeErrorNota").hide().text("");
            $("#mensajeExitoNota").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            return formatearFecha(valor);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }

        function validarFechaNoFutura(fechaTexto, mensaje) {
            if (fechaTexto === "") {
                return "";
            }

            var fecha = new Date(fechaTexto + "T00:00:00");
            var hoy = new Date();

            if (isNaN(fecha.getTime())) {
                return "Debe ingresar una fecha válida.";
            }

            hoy.setHours(0, 0, 0, 0);

            if (fecha > hoy) {
                return mensaje;
            }

            return "";
        }
    </script>
}