        function ejecutarAjaxCaja(url, datos) {
            return $.ajax({
                url: url,
                type: "POST",
                data: JSON.stringify(datos),
                dataType: "json",
                contentType: "application/json; charset=utf-8"
            });
        }

        function obtenerFechaActualCaja() {
            var fecha = new Date();
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }

        function formatearNumeroCaja(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toLocaleString("es-CR", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        function validarCorreo(valor) {
            if (valor == null) {
                return false;
            }

            valor = valor.trim().toLowerCase();

            var arroba = String.fromCharCode(64);
            var patron = "^[^\\s" + arroba + "]+"
                + arroba
                + "[^\\s" + arroba + "]+\\.[^\\s" + arroba + "]+$";

            var regexCorreo = new RegExp(patron);
            return regexCorreo.test(valor);
        }

        function cargarContactoClienteCaja(identificacion) {
    if (!identificacion || identificacion === "" || identificacion === "000000000") {
        return;
    }

    $.ajax({
        url: '@Url.Action("ObtenerContactoClienteCaja", "Facturacion")',
        type: "GET",
        data: { identificacion: identificacion },
        dataType: "json",
        success: function (respuesta) {
            var correo = respuesta.correo || "";
            var telefono = respuesta.telefono || "";

            $("#txtCorreoClienteCaja").val(correo);
            $("#txtTelefonoClienteCaja").val(telefono);

            $("#lblContactoClienteCaja").text(
                "Correo: " + (correo === "" ? "No registrado" : correo) +
                " | Teléfono: " + (telefono === "" ? "No registrado" : telefono)
            );

            if (correo === "" || telefono === "") {
                $("#btnAgregarContactoClienteCaja").show();
            } else {
                $("#btnAgregarContactoClienteCaja").hide();
            }
        },
        error: function () {
            $("#txtCorreoClienteCaja").val("");
            $("#txtTelefonoClienteCaja").val("");
            $("#lblContactoClienteCaja").text("Correo: No registrado | Teléfono: No registrado");
            $("#btnAgregarContactoClienteCaja").show();
        }
    });
}

function abrirModalContactoClienteCaja() {
    var identificacion = $("#txtIdentificacionClienteCaja").val();

    if (!identificacion || identificacion === "" || identificacion === "000000000") {
        mostrarMensajeSistema("Debe seleccionar un cliente antes de agregar contacto.", "advertencia", "#mensajeOperacion");
        return;
    }

    $("#mensajeErrorContactoClienteCaja").hide().text("");

    $("#lblClienteContactoCaja").text($("#lblClienteSeleccionadoCaja").text().replace("Cliente seleccionado:", "").trim());

    $("#txtTelefonoContactoClienteCaja").val($("#txtTelefonoClienteCaja").val());
    $("#txtCorreoContactoClienteCaja").val($("#txtCorreoClienteCaja").val());

    $("#ModalContactoClienteCaja").modal("show");
}

function guardarContactoClienteCaja() {
    $("#mensajeErrorContactoClienteCaja").hide().text("");

    var identificacion = $("#txtIdentificacionClienteCaja").val();
    var telefono = $("#txtTelefonoContactoClienteCaja").val().trim();
    var correo = $("#txtCorreoContactoClienteCaja").val().trim();

    if (!identificacion || identificacion === "" || identificacion === "000000000") {
        $("#mensajeErrorContactoClienteCaja").text("Debe seleccionar un cliente válido.").show();
        return;
    }

    if (telefono === "" && correo === "") {
        $("#mensajeErrorContactoClienteCaja").text("Debe ingresar al menos un teléfono o un correo.").show();
        return;
    }

    if (telefono !== "" && !/^[0-9]{8}$/.test(telefono)) {
        $("#mensajeErrorContactoClienteCaja").text("El teléfono debe contener exactamente 8 dígitos.").show();
        return;
    }

    if (correo !== "" && !validarCorreo(correo)) {
        $("#mensajeErrorContactoClienteCaja").text("Debe ingresar un correo válido.").show();
        return;
    }

    $.ajax({
        url: '@Url.Action("RegistrarContactoClienteCaja", "Facturacion")',
        type: "POST",
        data: JSON.stringify({
            identificacion: identificacion,
            telefono: telefono,
            correo: correo
        }),
        dataType: "json",
        contentType: "application/json; charset=utf-8",
        success: function (respuesta) {
            if (respuesta.resultado) {
                $("#ModalContactoClienteCaja").modal("hide");

                $("#txtTelefonoClienteCaja").val(telefono);
                $("#txtCorreoClienteCaja").val(correo);

                $("#lblContactoClienteCaja").text(
                    "Correo: " + (correo === "" ? "No registrado" : correo) +
                    " | Teléfono: " + (telefono === "" ? "No registrado" : telefono)
                );

                if (correo === "" || telefono === "") {
                    $("#btnAgregarContactoClienteCaja").show();
                } else {
                    $("#btnAgregarContactoClienteCaja").hide();
                }

                mostrarMensajeSistema(respuesta.mensaje || "Contacto registrado correctamente.", "exito", "#mensajeOperacion");
            } else {
                $("#mensajeErrorContactoClienteCaja").text(respuesta.mensaje || "No se pudo registrar el contacto.").show();
            }
        },
        error: function () {
            $("#mensajeErrorContactoClienteCaja").text("Error al registrar el contacto.").show();
        }
    });
        }

        function enviarFacturaPorCorreoCaja() {
            if (ultimaFacturaCaja == null) {
                mostrarMensajeSistema("No hay factura para enviar.", "error", "#mensajeOperacion");
                return;
            }

            var factura = ultimaFacturaCaja;

            if (!factura.Correo || factura.Correo === "") {
                mostrarMensajeSistema("El cliente no tiene correo registrado.", "advertencia", "#mensajeOperacion");
                return;
            }

            var detalle = "";

            $.each(factura.Productos || [], function (i, item) {
                var cantidad = parseFloat(item.Cantidad || 0);
                var precio = parseFloat(item.PrecioUnitario || 0);
                var totalLinea = cantidad * precio;

                detalle += "- " + (item.NombreProducto || "") +
                    " | Cantidad: " + formatearNumeroCaja(cantidad) +
                    " | Precio: ₡" + formatearNumeroCaja(precio) +
                    " | Total: ₡" + formatearNumeroCaja(totalLinea) + "\n";
            });

            var asunto = "Factura " + factura.NumeroFactura + " - Abastecedor Las Graditas";

            var cuerpo =
                "Estimado cliente,\n\n" +
                "Se adjunta el detalle de su factura:\n\n" +
                "Número de factura: " + factura.NumeroFactura + "\n" +
                "Fecha: " + factura.Fecha + "\n" +
                "Cliente: " + factura.Cliente + "\n\n" +
                "Detalle:\n" +
                detalle + "\n" +
                "Subtotal: " + factura.Subtotal + "\n" +
                "IVA: " + factura.Impuesto + "\n" +
                "Descuento: " + factura.Descuento + "\n" +
                "Total: " + factura.Total + "\n\n" +
                "Gracias por su compra.";

            var url =
                "mailto:" + encodeURIComponent(factura.Correo) +
                "?subject=" + encodeURIComponent(asunto) +
                "&body=" + encodeURIComponent(cuerpo);

            window.location.href = url;
        }
    </script>
}