
@{
    ViewBag.Title = "Gestionar Facturación";
    Layout = "~/Views/Shared/_Layout.cshtml";


}

<h4 class="font-weight-bold py-3 mb-0">Gestionar Facturación</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Operación</li>
        <li class="breadcrumb-item active">Facturación</li>
    </ol>
</div>

<div class="card mb-4">
    <h6 class="card-header">Registro de factura</h6>

    <div class="card-body">

        <form>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Número de factura</label>
                    <input type="text"
                           class="form-control"
                           name="NumeroFactura"
                           placeholder="Ejemplo: FAC-0001" />
                    <div class="clearfix"></div>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Cliente</label>
                    <select class="custom-select" name="IdentificacionCliente">
                        <option value="">Seleccione un cliente</option>
                        <option value="101110111">Cliente ejemplo 1</option>
                        <option value="202220222">Cliente ejemplo 2</option>
                        <option value="303330333">Cliente ejemplo 3</option>
                    </select>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Fecha de emisión</label>
                    <input type="date"
                           class="form-control"
                           name="FechaEmision" />
                    <div class="clearfix"></div>
                </div>

            </div>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Producto</label>
                    <select class="custom-select" name="IdProducto">
                        <option value="">Seleccione un producto</option>
                        <option value="1">Producto ejemplo 1</option>
                        <option value="2">Producto ejemplo 2</option>
                        <option value="3">Producto ejemplo 3</option>
                    </select>
                </div>

                <div class="form-group col-md-2">
                    <label class="form-label">Cantidad</label>
                    <input type="number"
                           class="form-control"
                           name="Cantidad"
                           placeholder="0"
                           min="1" />
                    <div class="clearfix"></div>
                </div>

                <div class="form-group col-md-3">
                    <label class="form-label">Precio unitario</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="PrecioUnitario"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

                <div class="form-group col-md-3">
                    <label class="form-label">Subtotal del producto</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="SubtotalProducto"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

            </div>

            <div class="form-row">

                <div class="form-group col-md-3">
                    <label class="form-label">Impuesto</label>
                    <div class="input-group">
                        <input type="number"
                               class="form-control"
                               name="Impuesto"
                               placeholder="0"
                               step="0.01" />
                        <div class="input-group-append">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>

                <div class="form-group col-md-3">
                    <label class="form-label">Descuento</label>
                    <div class="input-group">
                        <input type="number"
                               class="form-control"
                               name="Descuento"
                               placeholder="0"
                               step="0.01" />
                        <div class="input-group-append">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>

                <div class="form-group col-md-3">
                    <label class="form-label">Tipo de pago</label>
                    <select class="custom-select" name="TipoPago">
                        <option value="">Seleccione el tipo de pago</option>
                        <option value="Contado">Contado</option>
                        <option value="Credito">Crédito</option>
                        <option value="Mixto">Mixto</option>
                    </select>
                </div>

                <div class="form-group col-md-3">
                    <label class="form-label">Método de pago</label>
                    <select class="custom-select" name="MetodoPago">
                        <option value="">Seleccione el método</option>
                        <option value="Efectivo">Efectivo</option>
                        <option value="Tarjeta">Tarjeta</option>
                        <option value="Transferencia">Transferencia</option>
                        <option value="SinpeMovil">SINPE Móvil</option>
                    </select>
                </div>

            </div>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Subtotal</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="SubtotalFactura"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Monto de impuesto</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="MontoImpuesto"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Total de factura</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="TotalFactura"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

            </div>

            <div class="form-group">
                <label class="form-label">Observación</label>
                <textarea class="form-control"
                          name="Observacion"
                          rows="3"
                          placeholder="Ingrese una observación sobre la factura"></textarea>
            </div>

            <div class="form-group mt-4">
                <button type="button" class="btn btn-primary">
                    Guardar
                </button>

                <button type="button" class="btn btn-secondary">
                    Modificar
                </button>

                <button type="button" class="btn btn-danger">
                    Eliminar
                </button>

                <button type="reset" class="btn btn-outline-secondary">
                    Limpiar
                </button>
            </div>

        </form>

    </div>
</div>

<div class="card mb-4">
    <h6 class="card-header">Detalle de productos facturados</h6>

    <div class="card-body">

        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio unitario</th>
                        <th>Impuesto</th>
                        <th>Descuento</th>
                        <th>Subtotal</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>Producto ejemplo 1</td>
