            $("#txtCodigoProducto").val(item.CodigoProducto);
            $("#txtIdImpuesto").val(item.IdImpuesto);

            $("#txtBuscarProducto").val((item.CodigoProducto || "") + " - " + (item.NombreProducto || ""));
