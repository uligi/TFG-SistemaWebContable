@{
    ViewBag.Title = "Facturas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .codigo-factura,
    .codigo-producto {
        font-family: Consolas, monospace;
        font-weight: bold;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestionar Facturas</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Facturación</li>
        <li class="breadcrumb-item active">Facturas</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de facturas</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nueva factura
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar por número, cliente, empleado o estado...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaFacturas">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Empleado</th>
                        <th>Tipo factura</th>
                        <th>Tipo pago</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Activo</th>
                        <th style="width:250px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nueva factura</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtNumeroFacturaInterno" value="" />

                <h6 class="font-weight-bold">Encabezado de factura</h6>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtNumeroFactura">Número de factura</label>
                        <input type="text" id="txtNumeroFactura" class="form-control codigo-factura" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaFactura">Fecha de factura</label>
                        <input type="date" id="txtFechaFactura" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoFactura">Tipo de factura</label>
                        <select id="cboTipoFactura" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoPago">Tipo de pago</label>
                        <select id="cboTipoPago" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtBuscarCliente">Cliente</label>

                        <input type="hidden" id="txtIdentificacionCliente" />

                        <div class="input-group">
                            <input type="text"
                                   id="txtBuscarCliente"
                                   class="form-control"
                                   placeholder="Buscar cliente por cédula o nombre..." />

                            <div class="input-group-append">
                                <button type="button" class="btn btn-outline-primary" onclick="buscarClientesFactura()">
                                    Buscar
                                </button>
                            </div>
                        </div>

                        <small class="form-text text-muted" id="lblClienteSeleccionado">
                            Ningún cliente seleccionado.
                        </small>

                        <div class="table-responsive mt-2" id="contenedorResultadosCliente" style="display:none;">
                            <table class="table table-sm table-bordered mb-0">
                                <thead>
                                    <tr>
                                        <th>Identificación</th>
                                        <th>Cliente</th>
                                        <th style="width:100px;">Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyResultadosCliente"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboEmpleado">Empleado</label>
                        <select id="cboEmpleado" class="form-control">
                            <option value="">Seleccione un empleado</option>
                        </select>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboEstado">Estado</label>
                        <select id="cboEstado" class="form-control">
                            <option value="Borrador">Borrador</option>
                            <option value="Emitida">Emitida</option>
                            <option value="Anulada">Anulada</option>
                        </select>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboActivo">Activo</label>
                        <select id="cboActivo" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>
                <div class="alert alert-success mt-2" id="mensajeExito" style="display:none;"></div>

                <div class="text-right mb-3">
                    <button type="button" class="btn btn-primary" onclick="guardarFactura()">
                        Guardar encabezado
                    </button>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="font-weight-bold mb-0">Detalle de factura</h6>

                    <div>
                        <span class="badge badge-info mr-2" id="lblSubtotal">Subtotal: 0.00</span>
                        <span class="badge badge-info mr-2" id="lblImpuesto">IVA: 0.00</span>
                        <span class="badge badge-info mr-2" id="lblDescuento">Descuento: 0.00</span>
                        <span class="badge badge-success" id="lblTotal">Total: 0.00</span>
                    </div>
                </div>

                <small class="form-text text-muted mb-3" id="textoAyudaDetalle">
                    Para agregar productos, primero guarde el encabezado de la factura.
                </small>

                <input type="hidden" id="txtCodigoProducto" value="" />
                <input type="hidden" id="txtIdImpuesto" value="0" />

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtBuscarProducto">Producto</label>

                        <div class="input-group">
                            <input type="text"
                                   id="txtBuscarProducto"
                                   class="form-control"
                                   placeholder="Buscar producto por código o nombre..." />

                            <div class="input-group-append">
                                <button type="button" class="btn btn-outline-primary" id="btnBuscarProducto" onclick="buscarProductosFactura()">
                                    Buscar
                                </button>
                            </div>
                        </div>

                        <small class="form-text text-muted" id="lblProductoSeleccionado">
                            Ningún producto seleccionado.
                        </small>

                        <div class="table-responsive mt-2" id="contenedorResultadosProducto" style="display:none;">
                            <table class="table table-sm table-bordered mb-0">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Producto</th>
                                        <th>Precio</th>
                                        <th>Stock</th>
                                        <th>IVA</th>
                                        <th style="width:100px;">Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyResultadosProducto"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtCantidad">Cantidad</label>
                        <input type="text" id="txtCantidad" class="form-control" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtPrecioUnitario">Precio unitario con IVA incluido</label><input type="text" id="txtPrecioUnitario" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="txtPorcentajeImpuesto">IVA %</label>
                        <input type="text" id="txtPorcentajeImpuesto" class="form-control" readonly />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboDescuento">Descuento</label>
                        <select id="cboDescuento" class="form-control">
                            <option value="0">Seleccione</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-8">
                        <label for="txtDescripcionItem">Descripción del ítem</label>
                        <input type="text" id="txtDescripcionItem" class="form-control" maxlength="150" />
                    </div>

                    <div class="form-group col-md-4">
                        <label>&nbsp;</label>
                        <div class="btn-group btn-block">
                            <button type="button" class="btn btn-secondary" id="btnLimpiarDetalle" onclick="limpiarDetalle()">
                                Limpiar
                            </button>
                            <button type="button" class="btn btn-primary" id="btnGuardarDetalle" onclick="guardarDetalleFactura()">
                                Guardar detalle
                            </button>
                        </div>
                    </div>

                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaDetalles">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th>Precio</th>
                                <th>IVA %</th>
                                <th>Descuento</th>
                                <th>Subtotal</th>
                                <th>Total línea</th>
                                <th>Estado</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-success" onclick="emitirFactura()">
                    Emitir factura
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalEnviarCorreoFactura" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Enviar factura por correo</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="alert alert-danger" id="mensajeErrorCorreoFactura" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoCorreoFactura" style="display:none;"></div>

                <input type="hidden" id="txtNumeroFacturaCorreo" />
                <input type="hidden" id="txtTelefonoFacturaCorreo" />

                <div class="form-row">
                    <div class="form-group col-md-4">
                        <label>Número de factura</label>
                        <input type="text" id="txtNumeroFacturaCorreoVisible" class="form-control codigo-factura" readonly />
                    </div>

                    <div class="form-group col-md-8">
                        <label>Cliente</label>
                        <input type="text" id="txtClienteFacturaCorreo" class="form-control" readonly />
                    </div>
                </div>

                <div class="form-group">
                    <label>Correo destino</label>
                    <input type="text"
                           id="txtCorreoDestinoFactura"
                           class="form-control"
                           maxlength="255"
                           placeholder="cliente@correo.com" />

                    <small class="form-text text-muted">
                        Si el cliente no tiene correo registrado, puede ingresar uno aquí y guardarlo como contacto del cliente.
                    </small>
                </div>

                <div class="alert alert-warning" id="mensajeSinCorreoFactura" style="display:none;">
                    El cliente no tiene correo registrado. Ingrese un correo para poder enviar la factura.
                </div>

                <hr />

                <h6 class="font-weight-bold">Detalle de factura</h6>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-right">Cantidad</th>
                                <th class="text-right">Precio</th>
                                <th class="text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyDetalleCorreoFactura"></tbody>
                    </table>
                </div>

                <div class="text-right">
                    <p class="mb-1">Subtotal: <strong id="lblSubtotalCorreoFactura">₡0.00</strong></p>
                    <p class="mb-1">IVA: <strong id="lblImpuestoCorreoFactura">₡0.00</strong></p>
                    <p class="mb-1">Descuento: <strong id="lblDescuentoCorreoFactura">₡0.00</strong></p>
                    <h5>Total: <strong id="lblTotalCorreoFactura">₡0.00</strong></h5>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" onclick="guardarCorreoClienteFactura()">
                    Guardar correo al cliente
                </button>

                <button type="button" class="btn btn-info" id="btnEnviarCorreoFacturaNormal" onclick="enviarCorreoFacturaNormal()">
                    Enviar factura
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaFacturas = [];
        var listaDetalles = [];
        var facturaCorreoActual = null;

        $(document).ready(function () {
            cargarFacturas();
            cargarEmpleados();
            cargarTiposFactura();
            cargarTiposPago();
            cargarDescuentos();

            $("#txtBuscar").on("keyup", function () {
                pintarTablaFacturas();
            });

            $("#txtBuscarCliente").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarClientesFactura();
                }
            });

            $("#txtBuscarProducto").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarProductosFactura();
                }
            });

            $("#txtBuscarCliente").on("input", function () {
                limpiarTextoBusqueda("txtBuscarCliente", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtBuscarProducto").on("input", function () {
                limpiarTextoBusqueda("txtBuscarProducto", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtCantidad").on("input", function () {
                limpiarNoDecimal("txtCantidad", "Solo se permiten números y punto decimal en la cantidad.");
            });

            $("#txtDescripcionItem").on("input", function () {
                limpiarTextoFactura("txtDescripcionItem", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcionItem", "La descripción del ítem no puede superar los 150 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }

                if ($("#mensajeExito").is(":visible")) {
                    $("#mensajeExito").fadeOut(150);
                }
            });
        });

        function cargarFacturas() {
            $.ajax({
                url: '@Url.Action("ListarFacturas", "Facturacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaFacturas = respuesta.data || [];
                    pintarTablaFacturas();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las facturas.", "error");
                }
            });
        }

        function cargarEmpleados() {
            $.ajax({
                url: '@Url.Action("BuscarEmpleadosFactura", "Facturacion")',
                type: "GET",
                data: { filtro: "" },
                dataType: "json",
                success: function (respuesta) {
                    $("#cboEmpleado").empty().append('<option value="">Seleccione un empleado</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        var nombre = item.NombreCompleto
                            || item.EmpleadoNombre
                            || ((item.Nombre || "") + " " + (item.PrimerApellido || "") + " " + (item.SegundoApellido || "")).trim()
                            || item.Identificacion;

                        $("#cboEmpleado").append(
                            $("<option>", {
                                value: item.Identificacion,
                                text: item.Identificacion + " - " + nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los empleados.", "error");
                }
            });
        }

        function cargarTiposFactura() {
            $.ajax({
                url: '@Url.Action("ListarTiposFacturaActivos", "Facturacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoFactura").empty().append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboTipoFactura").append(
                            $("<option>", {
                                value: item.IdTipoFactura,
                                text: item.TipoFactura || item.Tipo_Factura || item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de factura.", "error");
                }
            });
        }

        function cargarTiposPago() {
            $.ajax({
                url: '@Url.Action("ListarTiposPagoActivos", "Facturacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoPago").empty().append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboTipoPago").append(
                            $("<option>", {
                                value: item.IdTipoPago,
                                text: item.Nombre || item.TipoPago || item.Descripcion
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de pago.", "error");
                }
            });
        }

        function cargarDescuentos() {
            $.ajax({
                url: '@Url.Action("ListarDescuentosActivos", "Facturacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboDescuento").empty();
                    $("#cboDescuento").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboDescuento").append(
                            $("<option>", {
                                value: item.IdDescuento,
                                text: item.Nombre + " (" + parseFloat(item.Porcentaje || 0).toFixed(2) + "%)"
                            })
                            .attr("data-porcentaje", item.Porcentaje)
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los descuentos.", "error");
                }
            });
        }

        function pintarTablaFacturas() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaFacturas tbody");

            tbody.empty();

            if (listaFacturas.length === 0) {
                tbody.append('<tr><td colspan="10" class="text-center text-muted">No hay facturas registradas.</td></tr>');
                return;
            }

            $.each(listaFacturas, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var numero = item.NumeroFactura || "";
                var cliente = item.ClienteNombre || "";
                var empleado = item.EmpleadoNombre || "";
                var estadoTexto = item.Estado || "";

                var texto = (numero + " " + cliente + " " + empleado + " " + estadoTexto).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = estadoTexto === "Emitida"
                    ? '<span class="badge badge-success">Emitida</span>'
                    : estadoTexto === "Anulada"
                        ? '<span class="badge badge-danger">Anulada</span>'
                        : '<span class="badge badge-warning">' + estadoTexto + '</span>';

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonEmitir = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-success mr-1",
                    text: "Emitir"
                }).on("click", function () {
                    emitirFacturaDesdeTabla(item.NumeroFactura);
                });

                var botonAnular = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger mr-1",
                    text: "Anular"
                }).on("click", function () {
                    inactivarFactura(item.NumeroFactura);
                });

                var botonCorreo = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-info",
                    text: "Correo"
                }).on("click", function () {
                    abrirEnvioCorreoFactura(numero);
                });

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-factura", text: numero }));
                fila.append($("<td>").text(formatearFecha(item.FechaFactura)));
                fila.append($("<td>").text(cliente));
                fila.append($("<td>").text(empleado));
                fila.append($("<td>").text(item.TipoFacturaNombre || ""));
                fila.append($("<td>").text(item.TipoPagoNombre || ""));
                fila.append($("<td>").text(parseFloat(item.TotalFactura || 0).toFixed(2)));
                fila.append($("<td>").html(estado));
                fila.append($("<td>").html(activo));

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo && estadoTexto !== "Emitida" && estadoTexto !== "Anulada") {
                    acciones.append(botonEmitir);
                }

                if (item.Activo && estadoTexto !== "Anulada") {
                    acciones.append(botonAnular);
                }
                if (item.Activo && estadoTexto === "Emitida") {
                    acciones.append(botonCorreo);
                }

                fila.append(acciones);
                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            $("#mensajeExito").hide().text("");

            $("#txtNumeroFacturaInterno").val("");
            $("#txtNumeroFactura").val("");
            $("#txtFechaFactura").val(convertirDateAInput(new Date()));
            $("#cboTipoFactura").val(0);
            $("#cboTipoPago").val(0);

            $("#txtIdentificacionCliente").val("");
            $("#txtBuscarCliente").val("");
            $("#lblClienteSeleccionado").text("Ningún cliente seleccionado.");
            $("#contenedorResultadosCliente").hide();
            $("#tbodyResultadosCliente").empty();

            $("#cboEmpleado").val("");
            $("#cboEstado").val("Borrador");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nueva factura");

            limpiarDetalle();
            listaDetalles = [];
            pintarDetalles();
            bloquearDetalle(true);

            if (json != null) {
                $("#txtNumeroFacturaInterno").val(json.NumeroFactura || "");
                $("#txtNumeroFactura").val(json.NumeroFactura || "");
                $("#txtFechaFactura").val(convertirFechaInput(json.FechaFactura));
                $("#cboTipoFactura").val(json.IdTipoFactura);
                $("#cboTipoPago").val(json.IdTipoPago);

                $("#txtIdentificacionCliente").val(json.IdentificacionCliente);
                $("#txtBuscarCliente").val(json.IdentificacionCliente + " - " + (json.ClienteNombre || ""));
                $("#lblClienteSeleccionado").text("Cliente seleccionado: " + json.IdentificacionCliente + " - " + (json.ClienteNombre || ""));

                $("#cboEmpleado").val(json.IdentificacionEmpleado);
                $("#cboEstado").val(json.Estado);
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar factura");

                bloquearDetalle(false);
                cargarDetallesFactura(json.NumeroFactura);
            }

            $("#FormModal").modal("show");
        }

        function guardarFactura() {
            $("#mensajeError").hide().text("");
            $("#mensajeExito").hide().text("");

            var obj = {
                NumeroFactura: $("#txtNumeroFacturaInterno").val().trim(),
                IdentificacionCliente: $("#txtIdentificacionCliente").val(),
                IdentificacionEmpleado: $("#cboEmpleado").val(),
                IdTipoPago: parseInt($("#cboTipoPago").val()),
                IdTipoFactura: parseInt($("#cboTipoFactura").val()),
                FechaFactura: $("#txtFechaFactura").val(),
                Estado: $("#cboEstado").val(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoPago)) obj.IdTipoPago = 0;
            if (isNaN(obj.IdTipoFactura)) obj.IdTipoFactura = 0;

            if (obj.IdentificacionCliente === "") {
                mostrarError("Debe seleccionar un cliente.", "txtBuscarCliente");
                return;
            }

            if (obj.IdentificacionEmpleado === "") {
                mostrarError("Debe seleccionar un empleado.", "cboEmpleado");
                return;
            }

            if (obj.IdTipoPago === 0) {
                mostrarError("Debe seleccionar un tipo de pago.", "cboTipoPago");
                return;
            }

            if (obj.IdTipoFactura === 0) {
                mostrarError("Debe seleccionar un tipo de factura.", "cboTipoFactura");
                return;
            }

            if (obj.FechaFactura === "") {
                mostrarError("Debe ingresar la fecha de factura.", "txtFechaFactura");
                return;
            }

            var mensajeFecha = validarFechaNoFutura(obj.FechaFactura, "La fecha de factura no puede ser futura.");
            if (mensajeFecha !== "") {
                mostrarError(mensajeFecha, "txtFechaFactura");
                return;
            }

            if (obj.Estado === "" || obj.Estado === null) {
                mostrarError("Debe seleccionar un estado.", "cboEstado");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarFactura", "Facturacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        var numeroFactura = respuesta.numeroFactura || obj.NumeroFactura;

                        $("#txtNumeroFacturaInterno").val(numeroFactura);
                        $("#txtNumeroFactura").val(numeroFactura);

                        bloquearDetalle(false);
                        cargarFacturas();

                        $("#mensajeExito").text(respuesta.mensaje || "Encabezado guardado correctamente.").show();
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar la factura.").show();
                }
            });
        }

        function buscarClientesFactura() {
            var filtro = $("#txtBuscarCliente").val().trim();

            if (filtro.length < 2) {
                mostrarError("Digite al menos 2 caracteres para buscar el cliente.", "txtBuscarCliente");
                return;
            }

            $.ajax({
                url: '@Url.Action("BuscarClientesFactura", "Facturacion")',
                type: "GET",
                data: { filtro: filtro },
                dataType: "json",
                success: function (respuesta) {
                    var tbody = $("#tbodyResultadosCliente");
                    tbody.empty();

                    if (!respuesta.data || respuesta.data.length === 0) {
                        tbody.append('<tr><td colspan="3" class="text-center text-muted">No se encontraron clientes.</td></tr>');
                        $("#contenedorResultadosCliente").show();
                        return;
                    }

                    $.each(respuesta.data, function (i, item) {
                        var identificacion = item.Identificacion || "";

                        var nombre = (
                            (item.Nombre || "") + " " +
                            (item.PrimerApellido || "") + " " +
                            (item.SegundoApellido || "")
                        ).trim();

                        if (nombre === "") {
                            nombre = item.NombreCompleto || item.ClienteNombre || "Cliente sin nombre";
                        }

                        var boton = $("<button>", {
                            type: "button",
                            class: "btn btn-sm btn-primary",
                            text: "Seleccionar"
                        }).on("click", function () {
                            seleccionarClienteFactura(identificacion, nombre);
                        });

                        var fila = $("<tr>");
                        fila.append($("<td>").text(identificacion));
                        fila.append($("<td>").text(nombre));
                        fila.append($("<td>").append(boton));

                        tbody.append(fila);
                    });

                    $("#contenedorResultadosCliente").show();
                },
                error: function () {
                    $("#mensajeError").text("Error al buscar clientes.").show();
                }
            });
        }

        function seleccionarClienteFactura(identificacion, nombre) {
            $("#txtIdentificacionCliente").val(identificacion);
            $("#txtBuscarCliente").val(identificacion + " - " + nombre);
            $("#lblClienteSeleccionado").text("Cliente seleccionado: " + identificacion + " - " + nombre);
            $("#contenedorResultadosCliente").hide();
        }

        function buscarProductosFactura() {
