            $("#txtIdImpuesto").val("0");
            $("#txtBuscarProducto").val("");
            $("#lblProductoSeleccionado").text("Ningún producto seleccionado.");
            $("#contenedorResultadosProducto").hide();
            $("#tbodyResultadosProducto").empty();

            $("#txtCantidad").val("");
            $("#txtPrecioUnitario").val("");
