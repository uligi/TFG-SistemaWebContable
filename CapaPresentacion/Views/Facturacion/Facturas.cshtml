        function cargarDetallesFactura(numeroFactura) {
            $.ajax({
                url: '@Url.Action("ListarDetallesFactura", "Facturacion")',
                type: "GET",
                data: { numeroFactura: numeroFactura },
                dataType: "json",
                success: function (respuesta) {
                    listaDetalles = respuesta.data || [];
                    pintarDetalles();
                },
                error: function () {
                    alert("Error al cargar los detalles de la factura.");
                }
            });
        }

        function pintarDetalles() {
            var tbody = $("#tablaDetalles tbody");
            tbody.empty();

            var subtotal = 0;
            var impuesto = 0;
            var descuento = 0;
            var total = 0;

            if (listaDetalles.length === 0) {
                tbody.append('<tr><td colspan="9" class="text-center text-muted">No hay productos registrados.</td></tr>');
                actualizarTotales(0, 0, 0, 0);
                return;
            }

            $.each(listaDetalles, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var cantidad = parseFloat(item.Cantidad || 0);
                var precio = parseFloat(item.PrecioUnitario || 0);
                var porcentajeImpuesto = parseFloat(item.PorcentajeImpuesto || 0);
                var porcentajeDescuento = parseFloat(item.PorcentajeDescuento || 0);
                var subtotalLinea = parseFloat(item.SubtotalLinea || 0);
                var totalLinea = parseFloat(item.TotalLinea || 0);

                var montoDescuento = subtotalLinea * (porcentajeDescuento / 100);
                var totalDespuesDescuento = subtotalLinea - montoDescuento;

                var montoImpuesto = 0;

                if (porcentajeImpuesto > 0) {
                    montoImpuesto = totalDespuesDescuento - (totalDespuesDescuento / (1 + (porcentajeImpuesto / 100)));
                }

                if (item.Activo) {
                    subtotal += subtotalLinea;
                    impuesto += montoImpuesto;
                    descuento += montoDescuento;
                    total += totalLinea;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-info">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var producto = (item.CodigoProducto || "") + " - " + (item.NombreProducto || "");
                var descuentoTexto = (item.DescuentoNombre || "Sin descuento") + " (" + porcentajeDescuento.toFixed(2) + "%)";

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    editarDetalle(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarDetalleFactura(item.NumeroFactura, item.CodigoProducto);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text(producto));
                fila.append($("<td>").text(cantidad.toFixed(2)));
                fila.append($("<td>").text(precio.toFixed(2)));
                fila.append($("<td>").text(porcentajeImpuesto.toFixed(2) + "%"));
                fila.append($("<td>").text(descuentoTexto));
                fila.append($("<td>").text(subtotalLinea.toFixed(2)));
                fila.append($("<td>").text(totalLinea.toFixed(2)));
                fila.append($("<td>").html(estado));

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                fila.append(acciones);
                tbody.append(fila);
            });

            actualizarTotales(subtotal, impuesto, descuento, total);
        }

        function actualizarTotales(subtotal, impuesto, descuento, total) {
            $("#lblSubtotal").text("Subtotal: " + subtotal.toFixed(2));
            $("#lblImpuesto").text("IVA: " + impuesto.toFixed(2));
            $("#lblDescuento").text("Descuento: " + descuento.toFixed(2));
            $("#lblTotal").text("Total: " + total.toFixed(2));
        }

