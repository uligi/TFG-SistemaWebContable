            if (filtro.length < 2) {
                mostrarError("Digite al menos 2 caracteres para buscar el producto.", "txtBuscarProducto");
                return;
            }

            $.ajax({
                url: '@Url.Action("BuscarProductosFactura", "Facturacion")',
