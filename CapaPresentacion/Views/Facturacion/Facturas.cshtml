            $("#txtBuscarProducto").prop("disabled", bloquear);
            $("#btnBuscarProducto").prop("disabled", bloquear);
            $("#txtCantidad").prop("disabled", bloquear);
            $("#txtPrecioUnitario").prop("disabled", bloquear);
            $("#txtPorcentajeImpuesto").prop("disabled", bloquear);
            $("#cboDescuento").prop("disabled", bloquear);
            $("#txtDescripcionItem").prop("disabled", bloquear);
            $("#btnGuardarDetalle").prop("disabled", bloquear);
            $("#btnLimpiarDetalle").prop("disabled", bloquear);

            if (bloquear) {
                $("#textoAyudaDetalle").text("Para agregar productos, primero guarde el encabezado de la factura.");
            } else {
                $("#textoAyudaDetalle").text("Agregue productos al detalle de la factura.");
            }
        }

