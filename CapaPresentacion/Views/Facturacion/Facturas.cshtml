                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo anular la factura.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al anular la factura.", "error");
                        }
                    });
                },
                "Anular",
                "btn-danger"
            );
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarNoDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoBusqueda(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoFactura(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarDecimalMayorCero(texto, nombreCampo) {
            if (texto === "") {
                return "Debe ingresar " + nombreCampo + ".";
            }

            if (!/^[0-9]+(\.[0-9]+)?$/.test(texto)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            var numero = parseFloat(texto);

            if (isNaN(numero)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            if (numero <= 0) {
                return nombreCampo + " debe ser mayor a cero.";
            }

            return "";
        }

        function validarFechaNoFutura(fechaTexto, mensaje) {
            if (fechaTexto === "") {
                return "";
            }

            var fecha = new Date(fechaTexto + "T00:00:00");
            var hoy = new Date();

            if (isNaN(fecha.getTime())) {
                return "Debe ingresar una fecha válida.";
            }

            hoy.setHours(0, 0, 0, 0);

            if (fecha > hoy) {
                return mensaje;
            }

            return "";
        }

        function abrirEnvioCorreoFactura(numeroFactura) {
    $("#mensajeErrorCorreoFactura").hide().text("");
    $("#mensajeExitoCorreoFactura").hide().text("");
    $("#mensajeSinCorreoFactura").hide();

    facturaCorreoActual = null;

    $.when(
        $.ajax({
            url: '@Url.Action("ObtenerFactura", "Facturacion")',
            type: "GET",
            data: { numeroFactura: numeroFactura },
            dataType: "json"
        }),
        $.ajax({
            url: '@Url.Action("ListarDetallesFactura", "Facturacion")',
            type: "GET",
            data: { numeroFactura: numeroFactura },
            dataType: "json"
        })
    ).done(function (respuestaFactura, respuestaDetalle) {
        var factura = respuestaFactura[0].data;
        var detalles = respuestaDetalle[0].data || [];

        if (factura == null) {
            mostrarMensajeSistema("No se encontró la factura seleccionada.", "error");
            return;
        }

        cargarContactoCorreoFactura(factura, detalles);
    }).fail(function () {
        mostrarMensajeSistema("Error al cargar la información de la factura.", "error");
    });
}

function cargarContactoCorreoFactura(factura, detalles) {
    $.ajax({
        url: '@Url.Action("ObtenerContactoClienteCaja", "Facturacion")',
        type: "GET",
        data: { identificacion: factura.IdentificacionCliente },
        dataType: "json",
        success: function (contacto) {
            prepararModalCorreoFactura(factura, detalles, contacto || {});
        },
        error: function () {
            prepararModalCorreoFactura(factura, detalles, {});
        }
    });
}

        function prepararModalCorreoFactura(factura, detalles, contacto) {
            var productos = [];

            $.each(detalles || [], function (i, item) {
                if (item.Activo === false) {
                    return;
                }

                var cantidad = parseFloat(item.Cantidad || 0);
                var precio = parseFloat(item.PrecioUnitario || 0);
                var totalLinea = cantidad * precio;

                productos.push({
                    CodigoProducto: item.CodigoProducto || "",
                    NombreProducto: item.NombreProducto || "",
                    Cantidad: cantidad,
                    PrecioUnitario: precio,
                    TotalLinea: totalLinea
                });
            });

            facturaCorreoActual = {
                NumeroFactura: factura.NumeroFactura || "",
                Fecha: formatearFecha(factura.FechaFactura),
                IdentificacionCliente: factura.IdentificacionCliente || "",
                Cliente: ((factura.IdentificacionCliente || "") + " - " + (factura.ClienteNombre || "")).trim(),
                Correo: contacto.correo || "",
                Telefono: contacto.telefono || "",
                Cajero: ((factura.IdentificacionEmpleado || "") + " - " + (factura.EmpleadoNombre || "")).trim(),
                Productos: productos,
                Subtotal: "₡" + parseFloat(factura.Subtotal || 0).toFixed(2),
                Impuesto: "₡" + parseFloat(factura.TotalImpuesto || 0).toFixed(2),
                Descuento: "₡" + parseFloat(factura.TotalDescuento || 0).toFixed(2),
                Total: "₡" + parseFloat(factura.TotalFactura || 0).toFixed(2)
            };

            pintarModalCorreoFactura();
        }

        function pintarModalCorreoFactura() {
            if (facturaCorreoActual == null) {
                return;
            }

            $("#txtNumeroFacturaCorreo").val(facturaCorreoActual.NumeroFactura);
            $("#txtNumeroFacturaCorreoVisible").val(facturaCorreoActual.NumeroFactura);
            $("#txtClienteFacturaCorreo").val(facturaCorreoActual.Cliente);
            $("#txtCorreoDestinoFactura").val(facturaCorreoActual.Correo);
            $("#txtTelefonoFacturaCorreo").val(facturaCorreoActual.Telefono);

            if (facturaCorreoActual.Correo === "") {
                $("#mensajeSinCorreoFactura").show();
            } else {
                $("#mensajeSinCorreoFactura").hide();
            }

            var tbody = $("#tbodyDetalleCorreoFactura");
            tbody.empty();

            $.each(facturaCorreoActual.Productos || [], function (i, item) {
                var fila = $("<tr>");
                fila.append($("<td>").text((item.CodigoProducto || "") + " - " + (item.NombreProducto || "")));
                fila.append($("<td>", { class: "text-right", text: parseFloat(item.Cantidad || 0).toFixed(2) }));
                fila.append($("<td>", { class: "text-right", text: "₡" + parseFloat(item.PrecioUnitario || 0).toFixed(2) }));
                fila.append($("<td>", { class: "text-right", text: "₡" + parseFloat(item.TotalLinea || 0).toFixed(2) }));

                tbody.append(fila);
            });

            $("#lblSubtotalCorreoFactura").text(facturaCorreoActual.Subtotal);
            $("#lblImpuestoCorreoFactura").text(facturaCorreoActual.Impuesto);
            $("#lblDescuentoCorreoFactura").text(facturaCorreoActual.Descuento);
            $("#lblTotalCorreoFactura").text(facturaCorreoActual.Total);

            $("#ModalEnviarCorreoFactura").modal("show");
        }

        function guardarCorreoClienteFactura() {
            $("#mensajeErrorCorreoFactura").hide().text("");
            $("#mensajeExitoCorreoFactura").hide().text("");

            if (facturaCorreoActual == null) {
                $("#mensajeErrorCorreoFactura").text("No hay factura seleccionada.").show();
                return;
            }

            var correo = $("#txtCorreoDestinoFactura").val().trim();
            var telefono = $("#txtTelefonoFacturaCorreo").val().trim();

            if (correo === "") {
                $("#mensajeErrorCorreoFactura").text("Debe ingresar un correo.").show();
                return;
            }

            if (!validarCorreoFactura(correo)) {
                $("#mensajeErrorCorreoFactura").text("Debe ingresar un correo válido.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("RegistrarContactoClienteCaja", "Facturacion")',
                type: "POST",
                data: JSON.stringify({
                    identificacion: facturaCorreoActual.IdentificacionCliente,
                    telefono: "",
                    correo: correo
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        facturaCorreoActual.Correo = correo;

                        $("#mensajeSinCorreoFactura").hide();
                        $("#mensajeExitoCorreoFactura").text(respuesta.mensaje || "Correo guardado correctamente.").show();
                    } else {
                        $("#mensajeErrorCorreoFactura").text(respuesta.mensaje || "No se pudo guardar el correo.").show();
                    }
                },
                error: function () {
                    $("#mensajeErrorCorreoFactura").text("Error al guardar el correo del cliente.").show();
                }
            });
        }

        function enviarCorreoFacturaNormal() {
            $("#mensajeErrorCorreoFactura").hide().text("");
            $("#mensajeExitoCorreoFactura").hide().text("");

            if (facturaCorreoActual == null) {
                $("#mensajeErrorCorreoFactura").text("No hay factura seleccionada.").show();
                return;
            }

            var correo = $("#txtCorreoDestinoFactura").val().trim();

            if (correo === "") {
                $("#mensajeErrorCorreoFactura").text("Debe ingresar un correo destino.").show();
                return;
            }

            if (!validarCorreoFactura(correo)) {
                $("#mensajeErrorCorreoFactura").text("Debe ingresar un correo válido.").show();
                return;
            }

        facturaCorreoActual.Correo = correo;

        var detalles = [];

        $.each(facturaCorreoActual.Productos || [], function (i, item) {
            detalles.push({
                CodigoProducto: item.CodigoProducto || "",
                NombreProducto: item.NombreProducto || "",
                Cantidad: parseFloat(item.Cantidad || 0).toFixed(2),
                Precio: "₡" + parseFloat(item.PrecioUnitario || 0).toFixed(2),
                TotalLinea: "₡" + parseFloat(item.TotalLinea || 0).toFixed(2)
            });
        });

        var obj = {
            CorreoDestino: facturaCorreoActual.Correo,
            NumeroFactura: facturaCorreoActual.NumeroFactura,
            Cliente: facturaCorreoActual.Cliente,
            Fecha: facturaCorreoActual.Fecha,
            Cajero: facturaCorreoActual.Cajero,
            Subtotal: facturaCorreoActual.Subtotal,
            Impuesto: facturaCorreoActual.Impuesto,
            Descuento: facturaCorreoActual.Descuento,
            Total: facturaCorreoActual.Total,
            Detalles: detalles
        };

        $("#btnEnviarCorreoFacturaNormal").prop("disabled", true).text("Enviando...");

        $.ajax({
            url: '@Url.Action("EnviarFacturaCorreoCaja", "Facturacion")',
            type: "POST",
            data: JSON.stringify({ obj: obj }),
            dataType: "json",
            contentType: "application/json; charset=utf-8",
            success: function (respuesta) {
                if (respuesta.resultado) {
                    $("#mensajeExitoCorreoFactura").text(respuesta.mensaje || "Factura enviada correctamente.").show();
                    mostrarMensajeSistema(respuesta.mensaje || "Factura enviada correctamente.", "exito");
                } else {
                    $("#mensajeErrorCorreoFactura").text(respuesta.mensaje || "No se pudo enviar la factura.").show();
                }
            },
            error: function () {
                $("#mensajeErrorCorreoFactura").text("Error al enviar la factura por correo.").show();
            },
            complete: function () {
                $("#btnEnviarCorreoFacturaNormal").prop("disabled", false).text("Enviar factura");
            }
        });
        }

        function validarCorreoFactura(valor) {
            if (valor == null) {
                return false;
            }

            valor = valor.trim().toLowerCase();

            var arroba = String.fromCharCode(64);
            var patron = "^[^\\s" + arroba + "]+"
                + arroba
                + "[^\\s" + arroba + "]+\\.[^\\s" + arroba + "]+$";

            var regexCorreo = new RegExp(patron);
            return regexCorreo.test(valor);
        }

    </script>
}