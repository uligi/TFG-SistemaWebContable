        function guardarDetalleFactura() {
            $("#mensajeError").hide().text("");

            var numeroFactura = $("#txtNumeroFacturaInterno").val().trim();
            var idDescuento = parseInt($("#cboDescuento").val());
            var cantidadTexto = $("#txtCantidad").val().trim();
            var precioTexto = $("#txtPrecioUnitario").val().trim();
            var impuestoTexto = $("#txtPorcentajeImpuesto").val().trim();

            var obj = {
                NumeroFactura: numeroFactura,
                CodigoProducto: $("#txtCodigoProducto").val().trim(),
                IdImpuesto: parseInt($("#txtIdImpuesto").val()),
                IdDescuento: idDescuento,
                DescripcionItem: $("#txtDescripcionItem").val().trim(),
                Cantidad: cantidadTexto === "" ? 0 : parseFloat(cantidadTexto),
                PrecioUnitario: precioTexto === "" ? 0 : parseFloat(precioTexto),
                PorcentajeImpuesto: impuestoTexto === "" ? 0 : parseFloat(impuestoTexto),
                PorcentajeDescuento: parseFloat($("#cboDescuento option:selected").attr("data-porcentaje") || 0),
                Activo: true
            };

            if (numeroFactura === "") {
                mostrarError("Primero debe guardar el encabezado de la factura.", "txtNumeroFactura");
                return;
            }

            if (obj.CodigoProducto === "") {
                mostrarError("Debe seleccionar un producto.", "txtBuscarProducto");
                return;
            }

            if (isNaN(obj.IdImpuesto) || obj.IdImpuesto <= 0) {
                mostrarError("El producto seleccionado no tiene impuesto válido.", "txtBuscarProducto");
                return;
            }

            if (isNaN(obj.IdDescuento) || obj.IdDescuento <= 0) {
                mostrarError("Debe seleccionar un descuento. Si no aplica, seleccione el descuento Sin descuento.", "cboDescuento");
                return;
            }

            var mensajeCantidad = validarDecimalMayorCero(cantidadTexto, "la cantidad");
            if (mensajeCantidad !== "") {
                mostrarError(mensajeCantidad, "txtCantidad");
                return;
            }

            if (obj.PrecioUnitario < 0) {
                mostrarError("El precio unitario no puede ser negativo.", "txtPrecioUnitario");
                return;
            }

            if (obj.DescripcionItem.length > 150) {
                mostrarError("La descripción del ítem no puede superar los 150 caracteres.", "txtDescripcionItem");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarDetalleFactura", "Facturacion")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        limpiarDetalle();
                        cargarDetallesFactura(numeroFactura);
                        cargarFacturas();
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el detalle de factura.").show();
                }
            });
        }

        function inactivarDetalleFactura(numeroFactura, codigoProducto) {
            mostrarConfirmacionSistema(
                "Inactivar detalle",
                "¿Desea inactivar este detalle de factura?",
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarDetalleFactura", "Facturacion")',
                        type: "POST",
                        data: JSON.stringify({
                            numeroFactura: numeroFactura,
                            codigoProducto: codigoProducto
                        }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                limpiarDetalle();
                                cargarDetallesFactura(numeroFactura);
                                cargarFacturas();
                                mostrarMensajeSistema("Detalle de factura inactivado correctamente.", "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo inactivar el detalle de factura.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al inactivar el detalle de factura.", "error");
                        }
                    });
                },
                "Inactivar",
                "btn-danger"
            );
        }

        function emitirFactura() {
            var numeroFactura = $("#txtNumeroFacturaInterno").val().trim();

            if (numeroFactura === "") {
                mostrarError("Primero debe guardar la factura.", "txtNumeroFactura");
                return;
            }

            var detallesActivos = listaDetalles.filter(function (x) {
                return x.Activo === true;
            });

            if (detallesActivos.length === 0) {
                mostrarError("Debe agregar al menos un producto activo antes de emitir la factura.", "txtBuscarProducto");
                return;
            }

            emitirFacturaDesdeTabla(numeroFactura);
        }

        function emitirFacturaDesdeTabla(numeroFactura) {
            mostrarConfirmacionSistema(
                "Emitir factura",
                "¿Desea emitir esta factura?",
                function () {
                    $.ajax({
                        url: '@Url.Action("EmitirFactura", "Facturacion")',
                        type: "POST",
                        data: JSON.stringify({ numeroFactura: numeroFactura }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
