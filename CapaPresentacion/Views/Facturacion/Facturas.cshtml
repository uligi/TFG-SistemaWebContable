                                $("#FormModal").modal("hide");
                                cargarFacturas();
                                mostrarMensajeSistema(respuesta.mensaje || "Factura emitida correctamente.", "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo emitir la factura.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al emitir la factura.", "error");
                        }
                    });
                },
                "Emitir",
                "btn-success"
            );
        }

