@{
    ViewBag.Title = "Proveedores";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .bloque-contacto {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 12px;
        margin-bottom: 12px;
    }

    .tabla-contacto th,
    .tabla-contacto td {
        vertical-align: middle !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Proveedores</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Proveedores</li>
        <li class="breadcrumb-item active">Mantenimiento</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de proveedores</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo proveedor
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaProveedores" style="width:100%;">
                <thead>
                    <tr>
                        <th>Identificación</th>
                        <th>Razón social</th>
                        <th>Contacto</th>
                        <th>Ubicación</th>
                        <th>Días crédito</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo proveedor</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdentificacionProveedor" value="" />

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

                <h6 class="font-weight-bold mb-3">Datos del proveedor</h6>

                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label for="txtRazonSocial">Razón social</label>
                            <input type="text" id="txtRazonSocial" class="form-control" maxlength="200" autocomplete="off" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtDiasCredito">Días de crédito</label>
                            <input type="number" id="txtDiasCredito" class="form-control" min="0" step="1" autocomplete="off" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="txtNombreContacto">Nombre de contacto</label>
                    <input type="text" id="txtNombreContacto" class="form-control" maxlength="100" autocomplete="off" />
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Ubicación</h6>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboProvincia">Provincia</label>
                            <select id="cboProvincia" class="form-control">
                                <option value="0">Seleccione una provincia</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboCanton">Cantón</label>
                            <select id="cboCanton" class="form-control">
                                <option value="0">Seleccione un cantón</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboDistrito">Distrito</label>
                            <select id="cboDistrito" class="form-control">
                                <option value="0">Seleccione un distrito</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="txtDireccionExacta">Dirección exacta</label>
                    <textarea id="txtDireccionExacta" class="form-control" maxlength="250" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 250 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Teléfonos</h6>

                <div class="bloque-contacto">
                    <input type="hidden" id="txtTelefonoAnterior" value="" />

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="txtTelefono">Teléfono</label>
                                <input type="text" id="txtTelefono" class="form-control" maxlength="15" autocomplete="off" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="cboTipoTelefono">Tipo</label>
                                <select id="cboTipoTelefono" class="form-control">
                                    <option value="0">Seleccione</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboTelefonoPrincipal">Principal</label>
                                <select id="cboTelefonoPrincipal" class="form-control">
                                    <option value="false">No</option>
                                    <option value="true">Sí</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboTelefonoActivo">Estado</label>
                                <select id="cboTelefonoActivo" class="form-control">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-group mb-2 w-100">
                                <button type="button" class="btn btn-primary btn-block" onclick="guardarTelefonoProveedor()">
                                    Agregar
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-danger mt-2" id="mensajeErrorTelefono" style="display:none;"></div>

                    <div class="table-responsive mt-2">
                        <table class="table table-sm table-bordered tabla-contacto" id="tablaTelefonosProveedor" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Teléfono</th>
                                    <th>Tipo</th>
                                    <th>Principal</th>
                                    <th>Estado</th>
                                    <th style="width:160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <h6 class="font-weight-bold mb-3">Correos</h6>

                <div class="bloque-contacto">
                    <input type="hidden" id="txtCorreoAnterior" value="" />

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group mb-2">
                                <label for="txtCorreo">Correo</label>
                                <input type="email" id="txtCorreo" class="form-control" maxlength="150" autocomplete="off" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="cboTipoCorreo">Tipo</label>
                                <select id="cboTipoCorreo" class="form-control">
                                    <option value="0">Seleccione</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboCorreoPrincipal">Principal</label>
                                <select id="cboCorreoPrincipal" class="form-control">
                                    <option value="false">No</option>
                                    <option value="true">Sí</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboCorreoActivo">Estado</label>
                                <select id="cboCorreoActivo" class="form-control">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-1 d-flex align-items-end">
                            <div class="form-group mb-2 w-100">
                                <button type="button" class="btn btn-primary btn-block" onclick="guardarCorreoProveedor()">
                                    +
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-danger mt-2" id="mensajeErrorCorreo" style="display:none;"></div>

                    <div class="table-responsive mt-2">
                        <table class="table table-sm table-bordered tabla-contacto" id="tablaCorreosProveedor" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Correo</th>
                                    <th>Tipo</th>
                                    <th>Principal</th>
                                    <th>Estado</th>
                                    <th style="width:160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <small class="text-muted mr-auto">
                    Para agregar teléfonos o correos, primero guarde el proveedor.
                </small>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarProveedor()">
                    Guardar proveedor
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaProveedores = [];
        var tablaProveedores = null;

        var listaTelefonosProveedor = [];
        var listaCorreosProveedor = [];

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarTiposTelefonoActivos();
            cargarTiposCorreoActivos();
            cargarProveedores();

            $("#cboProvincia").on("change", function () {
                var codigoProvincia = parseInt($(this).val());

                $("#cboCanton").empty();
                $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

                $("#cboDistrito").empty();
                $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                if (!isNaN(codigoProvincia) && codigoProvincia > 0) {
                    cargarCantonesPorProvincia(codigoProvincia, null);
                }
            });

            $("#cboCanton").on("change", function () {
                var codigoCanton = parseInt($(this).val());

                $("#cboDistrito").empty();
                $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                if (!isNaN(codigoCanton) && codigoCanton > 0) {
                    cargarDistritosPorCanton(codigoCanton, null);
                }
            });

            $("#txtRazonSocial").on("input", function () {
                limpiarTextoGeneral("txtRazonSocial", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 200) {
                    $(this).val($(this).val().substring(0, 200));
                    mostrarAyudaCampo("txtRazonSocial", "La razón social no puede superar los 200 caracteres.");
                }
            });

            $("#txtNombreContacto").on("input", function () {
                limpiarTextoPersona("txtNombreContacto", "Solo se permiten letras y espacios.");

                if ($(this).val().length > 100) {
                    $(this).val($(this).val().substring(0, 100));
                    mostrarAyudaCampo("txtNombreContacto", "El nombre de contacto no puede superar los 100 caracteres.");
                }
            });

            $("#txtDireccionExacta").on("input", function () {
                limpiarTextoGeneral("txtDireccionExacta", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 250) {
                    $(this).val($(this).val().substring(0, 250));
                    mostrarAyudaCampo("txtDireccionExacta", "La dirección exacta no puede superar los 250 caracteres.");
                }
            });

            $("#txtDiasCredito").on("input", function () {
                var valor = $(this).val();
                valor = valor.replace(/[^0-9]/g, "");
                $(this).val(valor);
            });

            $("#txtTelefono").on("input", function () {
                var valor = $(this).val();
                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 15) {
                    valor = valor.substring(0, 15);
                }

                $(this).val(valor);
            });

            $("#txtCorreo").on("input", function () {
                var valor = $(this).val().trim().toLowerCase();

                if (valor.length > 150) {
                    valor = valor.substring(0, 150);
                }

                $(this).val(valor);
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }

                if ($("#mensajeErrorTelefono").is(":visible")) {
                    $("#mensajeErrorTelefono").fadeOut(150);
                }

                if ($("#mensajeErrorCorreo").is(":visible")) {
                    $("#mensajeErrorCorreo").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                limpiarErrores();
            });
        });

        function cargarProveedores() {
            $.ajax({
                url: '@Url.Action("ListarProveedores", "Proveedor")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaProveedores = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los proveedores.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaProveedores != null) {
                tablaProveedores.clear().destroy();
                tablaProveedores = null;
            }

            var tbody = $("#tablaProveedores tbody");
            tbody.empty();

            $.each(listaProveedores, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;

                }
                var identificacion = item.IdentificacionProveedor || "";
                var razonSocial = item.RazonSocial || "";
                var contacto = item.NombreContacto || "-";
                var diasCredito = item.DiasCredito || 0;

                var ubicacion = "";
                if (item.DistritoNombre && item.CantonNombre && item.ProvinciaNombre) {
                    ubicacion = item.DistritoNombre + ", " + item.CantonNombre + ", " + item.ProvinciaNombre;
                } else {
                    ubicacion = "-";
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarProveedor(item.IdentificacionProveedor);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var celdaProveedor = $("<td>");
                celdaProveedor.append($("<div>").text(razonSocial));
                celdaProveedor.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: "Dirección: " + (item.DireccionExacta || "-")
                }));

                var fila = $("<tr>");
                fila.append($("<td>").text(identificacion));
                fila.append(celdaProveedor);
                fila.append($("<td>").text(contacto));
                fila.append($("<td>").text(ubicacion));
                fila.append($("<td>").text(diasCredito));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaProveedores = $("#tablaProveedores").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[1, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>", {
                                value: item.CodigoProvincia,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las provincias.", "error");
                }
            });
        }

        function cargarCantonesPorProvincia(codigoProvincia, callback) {
            $.ajax({
                url: '@Url.Action("ListarCantonesActivosPorProvincia", "Ubicacion")',
                type: "GET",
                data: { codigoProvincia: codigoProvincia },
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCanton").empty();
                    $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboCanton").append(
                            $("<option>", {
                                value: item.CodigoCanton,
                                text: item.Nombre
                            })
                        );
                    });

                    if (callback != null) {
                        callback();
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los cantones.", "error");
                }
            });
        }

        function cargarDistritosPorCanton(codigoCanton, callback) {
            $.ajax({
                url: '@Url.Action("ListarDistritosActivosPorCanton", "Ubicacion")',
                type: "GET",
                data: { codigoCanton: codigoCanton },
                dataType: "json",
                success: function (respuesta) {
                    $("#cboDistrito").empty();
                    $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboDistrito").append(
                            $("<option>", {
                                value: item.CodigoDistrito,
                                text: item.Nombre
                            })
                        );
                    });

                    if (callback != null) {
                        callback();
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los distritos.", "error");
                }
            });
        }

        function cargarTiposTelefonoActivos() {
            $.ajax({
                url: '@Url.Action("ListarTipoTelefonos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoTelefono").empty();
                    $("#cboTipoTelefono").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoTelefono").append(
                                $("<option>", {
                                    value: item.IdTipoTelefono,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de teléfono.", "error");
                }
            });
        }

        function cargarTiposCorreoActivos() {
            $.ajax({
                url: '@Url.Action("ListarTipoCorreos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoCorreo").empty();
                    $("#cboTipoCorreo").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoCorreo").append(
                                $("<option>", {
                                    value: item.IdTipoCorreo,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de correo.", "error");
                }
            });
        }

        function abrirModal(json) {
            limpiarErrores();

            listaTelefonosProveedor = [];
            listaCorreosProveedor = [];

            $("#txtIdentificacionProveedor").val("");
            $("#txtRazonSocial").val("");
            $("#txtNombreContacto").val("");
            $("#txtDiasCredito").val("0");

            $("#cboProvincia").val(0);

            $("#cboCanton").empty();
            $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

            $("#cboDistrito").empty();
            $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

            $("#txtDireccionExacta").val("");
            $("#cboActivo").val("true");

            limpiarFormularioTelefono();
            limpiarFormularioCorreo();
            pintarTelefonosProveedor();
            pintarCorreosProveedor();

            $("#tituloModal").text("Nuevo proveedor");

            if (json != null) {
                $("#txtIdentificacionProveedor").val(json.IdentificacionProveedor || "");
                $("#txtRazonSocial").val(json.RazonSocial || "");
                $("#txtNombreContacto").val(json.NombreContacto || "");
                $("#txtDiasCredito").val(json.DiasCredito || 0);

                $("#cboProvincia").val(json.CodigoProvincia);

                cargarCantonesPorProvincia(json.CodigoProvincia, function () {
                    $("#cboCanton").val(json.CodigoCanton);

                    cargarDistritosPorCanton(json.CodigoCanton, function () {
                        $("#cboDistrito").val(json.CodigoDistrito);
                    });
                });

                $("#txtDireccionExacta").val(json.DireccionExacta || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#tituloModal").text("Editar proveedor");

                cargarTelefonosProveedor(json.IdentificacionProveedor);
                cargarCorreosProveedor(json.IdentificacionProveedor);
            }

            $("#FormModal").modal("show");
        }

        function guardarProveedor() {
            $("#mensajeError").hide().text("");

            var obj = {
                IdentificacionProveedor: $("#txtIdentificacionProveedor").val().trim(),
                RazonSocial: $("#txtRazonSocial").val().trim(),
                NombreContacto: $("#txtNombreContacto").val().trim(),
                CodigoDistrito: parseInt($("#cboDistrito").val()),
                DireccionExacta: $("#txtDireccionExacta").val().trim(),
                DiasCredito: parseInt($("#txtDiasCredito").val()),
                Activo: $("#cboActivo").val() === "true"
            };

            var codigoProvincia = parseInt($("#cboProvincia").val());
            var codigoCanton = parseInt($("#cboCanton").val());

            if (isNaN(obj.CodigoDistrito)) {
                obj.CodigoDistrito = 0;
            }

            if (isNaN(obj.DiasCredito)) {
                obj.DiasCredito = 0;
            }

            if (obj.RazonSocial === "") {
                mostrarError("Debe ingresar la razón social.", "txtRazonSocial");
                return;
            }

            if (!validarTextoGeneral(obj.RazonSocial)) {
                mostrarError("La razón social solo puede contener letras, números, espacios y caracteres básicos.", "txtRazonSocial");
                return;
            }

            if (obj.RazonSocial.length > 200) {
                mostrarError("La razón social no puede superar los 200 caracteres.", "txtRazonSocial");
                return;
            }

            if (obj.NombreContacto === "") {
                mostrarError("Debe ingresar el nombre de contacto.", "txtNombreContacto");
                return;
            }

            if (!validarTextoPersona(obj.NombreContacto)) {
                mostrarError("El nombre de contacto solo puede contener letras y espacios.", "txtNombreContacto");
                return;
            }

            if (obj.NombreContacto.length > 100) {
                mostrarError("El nombre de contacto no puede superar los 100 caracteres.", "txtNombreContacto");
                return;
            }

            if (isNaN(codigoProvincia) || codigoProvincia <= 0) {
                mostrarError("Debe seleccionar una provincia.", "cboProvincia");
                return;
            }

            if (isNaN(codigoCanton) || codigoCanton <= 0) {
                mostrarError("Debe seleccionar un cantón.", "cboCanton");
                return;
            }

            if (obj.CodigoDistrito <= 0) {
                mostrarError("Debe seleccionar un distrito.", "cboDistrito");
                return;
            }

            if (obj.DireccionExacta === "") {
                mostrarError("Debe ingresar la dirección exacta.", "txtDireccionExacta");
                return;
            }

            if (!validarTextoGeneral(obj.DireccionExacta)) {
                mostrarError("La dirección exacta solo puede contener letras, números, espacios y caracteres básicos.", "txtDireccionExacta");
                return;
            }

            if (obj.DireccionExacta.length > 250) {
                mostrarError("La dirección exacta no puede superar los 250 caracteres.", "txtDireccionExacta");
                return;
            }

            if (obj.DiasCredito < 0) {
                mostrarError("Los días de crédito no pueden ser negativos.", "txtDiasCredito");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        if (obj.IdentificacionProveedor === "") {
                            $("#txtIdentificacionProveedor").val(respuesta.identificacionProveedor || "");
                            $("#tituloModal").text("Editar proveedor");
                            mostrarMensajeSistema(
                                "Proveedor guardado correctamente. Ya puede agregar teléfonos y correos.",
                                "exito"
                            );
                        } else {
                            mostrarMensajeSistema("Proveedor actualizado correctamente.", "exito");
                        }

                        cargarProveedores();
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el proveedor.").show();
                }
            });
        }

        function inactivarProveedor(identificacionProveedor) {
