                }
                var principal = item.EsPrincipal
                    ? '<span class="badge badge-primary">Sí</span>'
                    : '<span class="badge badge-light">No</span>';

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    editarCorreoProveedor(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarCorreoProveedor(item.DireccionCorreo);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(item.DireccionCorreo || ""));
                fila.append($("<td>").text(item.TipoCorreoNombre || ""));
                fila.append($("<td>").html(principal));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function guardarCorreoProveedor() {
            $("#mensajeErrorCorreo").hide().text("");

            var identificacionProveedor = $("#txtIdentificacionProveedor").val().trim();

            if (identificacionProveedor === "") {
                $("#mensajeErrorCorreo").text("Primero debe guardar un proveedor válido.").show();
                return;
            }

            var obj = {
                IdentificacionProveedor: identificacionProveedor,
                DireccionCorreoAnterior: $("#txtCorreoAnterior").val().trim(),
                DireccionCorreo: $("#txtCorreo").val().trim().toLowerCase(),
                IdTipoCorreo: parseInt($("#cboTipoCorreo").val()),
                EsPrincipal: $("#cboCorreoPrincipal").val() === "true",
                Activo: $("#cboCorreoActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoCorreo)) {
                obj.IdTipoCorreo = 0;
            }

            if (!validarCorreo(obj.DireccionCorreo)) {
                $("#mensajeErrorCorreo").text("Debe ingresar una dirección de correo válida.").show();
                return;
            }

            if (obj.IdTipoCorreo <= 0) {
                $("#mensajeErrorCorreo").text("Debe seleccionar un tipo de correo.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCorreoProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        limpiarFormularioCorreo();
                        cargarCorreosProveedor(identificacionProveedor);
                    } else {
                        $("#mensajeErrorCorreo").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorCorreo").text("Error al guardar el correo.").show();
                }
            });
        }

        function editarCorreoProveedor(item) {
            $("#txtCorreoAnterior").val(item.DireccionCorreo || "");
            $("#txtCorreo").val(item.DireccionCorreo || "");
            $("#cboTipoCorreo").val(item.IdTipoCorreo);
            $("#cboCorreoPrincipal").val(item.EsPrincipal ? "true" : "false");
            $("#cboCorreoActivo").val(item.Activo ? "true" : "false");
        }

        function inactivarCorreoProveedor(direccionCorreo) {
            var identificacionProveedor = $("#txtIdentificacionProveedor").val().trim();

            mostrarConfirmacionSistema(
                "Inactivar correo",
                "¿Desea inactivar este correo?",
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarCorreoProveedor", "Proveedor")',
                        type: "POST",
                        data: JSON.stringify({
                            identificacionProveedor: identificacionProveedor,
                            direccionCorreo: direccionCorreo
                        }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                cargarCorreosProveedor(identificacionProveedor);
                                mostrarMensajeSistema("Correo inactivado correctamente.", "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo inactivar el correo.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al inactivar el correo.", "error");
                        }
                    });
                },
                "Inactivar",
                "btn-danger"
            );
        }

        function limpiarFormularioCorreo() {
            $("#txtCorreoAnterior").val("");
            $("#txtCorreo").val("");
            $("#cboTipoCorreo").val("0");
            $("#cboCorreoPrincipal").val("false");
            $("#cboCorreoActivo").val("true");
            $("#mensajeErrorCorreo").hide().text("");
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarErrores() {
            $("#mensajeError").hide().text("");
            $("#mensajeErrorTelefono").hide().text("");
            $("#mensajeErrorCorreo").hide().text("");

            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function limpiarTextoPersona(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoPersona(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]+$/.test(valor);
        }

        function validarTextoGeneral(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function validarTelefono(valor) {
            return /^[0-9]{8,15}$/.test(valor);
        }

        function validarCorreo(valor) {
            if (valor == null) {
                return false;
            }

            valor = valor.trim().toLowerCase();

            var arroba = String.fromCharCode(64);
            var patron = "^[^\\s" + arroba + "]+"
                + arroba
                + "[^\\s" + arroba + "]+\\.[^\\s" + arroba + "]+$";

            var regexCorreo = new RegExp(patron);
            return regexCorreo.test(valor);
        }
    </script>
}