                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarTelefonoProveedor(item.NumeroTelefono);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroTelefono || ""));
                fila.append($("<td>").text(item.TipoTelefonoNombre || ""));
                fila.append($("<td>").html(principal));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
