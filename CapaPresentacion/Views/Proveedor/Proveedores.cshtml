        function guardarTelefonoProveedor() {
            $("#mensajeErrorTelefono").hide().text("");

            var identificacionProveedor = $("#txtIdentificacionProveedor").val().trim();

            if (identificacionProveedor === "") {
                $("#mensajeErrorTelefono").text("Primero debe guardar un proveedor válido.").show();
                return;
            }

            var obj = {
                IdentificacionProveedor: identificacionProveedor,
                NumeroTelefonoAnterior: $("#txtTelefonoAnterior").val().trim(),
                NumeroTelefono: $("#txtTelefono").val().trim(),
                IdTipoTelefono: parseInt($("#cboTipoTelefono").val()),
                EsPrincipal: $("#cboTelefonoPrincipal").val() === "true",
                Activo: $("#cboTelefonoActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoTelefono)) {
                obj.IdTipoTelefono = 0;
            }

            if (!validarTelefono(obj.NumeroTelefono)) {
                $("#mensajeErrorTelefono").text("El teléfono debe contener solo números y tener entre 8 y 15 dígitos.").show();
                return;
            }

            if (obj.IdTipoTelefono <= 0) {
                $("#mensajeErrorTelefono").text("Debe seleccionar un tipo de teléfono.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTelefonoProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        limpiarFormularioTelefono();
                        cargarTelefonosProveedor(identificacionProveedor);
                    } else {
                        $("#mensajeErrorTelefono").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorTelefono").text("Error al guardar el teléfono.").show();
                }
            });
        }

        function editarTelefonoProveedor(item) {
            $("#txtTelefonoAnterior").val(item.NumeroTelefono || "");
            $("#txtTelefono").val(item.NumeroTelefono || "");
            $("#cboTipoTelefono").val(item.IdTipoTelefono);
            $("#cboTelefonoPrincipal").val(item.EsPrincipal ? "true" : "false");
            $("#cboTelefonoActivo").val(item.Activo ? "true" : "false");
        }

        function inactivarTelefonoProveedor(numeroTelefono) {
