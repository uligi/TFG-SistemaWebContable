@{
    ViewBag.Title = "Proveedores";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Proveedores</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Proveedores</li>
        <li class="breadcrumb-item active">Mantenimiento</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de proveedores</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo proveedor
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar por identificación, razón social o contacto...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaProveedores">
                <thead>
                    <tr>
                        <th>Identificación</th>
                        <th>Razón social</th>
                        <th>Contacto</th>
                        <th>Ubicación</th>
                        <th>Días crédito</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo proveedor</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtEsNuevo" value="true" />

                <h6 class="font-weight-bold">Datos del proveedor</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtIdentificacionProveedor">Identificación</label>
                        <input type="text" id="txtIdentificacionProveedor" class="form-control" readonly placeholder="Se genera automáticamente" /></div>

                    <div class="form-group col-md-4">
                        <label for="txtRazonSocial">Razón social</label>
                        <input type="text" id="txtRazonSocial" class="form-control" maxlength="200" autocomplete="off" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtNombreContacto">Nombre de contacto</label>
                        <input type="text" id="txtNombreContacto" class="form-control" maxlength="100" autocomplete="off" />
                    </div>

                </div>

                <h6 class="font-weight-bold mt-3">Ubicación</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="cboProvincia">Provincia</label>
                        <select id="cboProvincia" class="form-control">
                            <option value="0">Seleccione una provincia</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboCanton">Cantón</label>
                        <select id="cboCanton" class="form-control">
                            <option value="0">Seleccione un cantón</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboDistrito">Distrito</label>
                        <select id="cboDistrito" class="form-control">
                            <option value="0">Seleccione un distrito</option>
                        </select>
                    </div>

                </div>

                <div class="form-group">
                    <label for="txtDireccionExacta">Dirección exacta</label>
                    <textarea id="txtDireccionExacta" class="form-control" maxlength="250" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 250 caracteres.</small>
                </div>

                <h6 class="font-weight-bold mt-3">Condiciones comerciales</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtDiasCredito">Días de crédito</label>
                        <input type="number" id="txtDiasCredito" class="form-control" min="0" step="1" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboActivo">Estado</label>
                        <select id="cboActivo" class="form-control">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="font-weight-bold mb-0">Teléfonos del proveedor</h6>
                    <small class="text-muted" id="textoAyudaTelefono">
                        Para agregar teléfonos, primero guarde el proveedor.
                    </small>
                </div>

                <div class="form-row mt-3">

                    <div class="form-group col-md-4">
                        <label for="txtNumeroTelefonoProveedor">Número de teléfono</label>
                        <input type="text" id="txtNumeroTelefonoProveedor" class="form-control" maxlength="45" autocomplete="off" />
                        <input type="hidden" id="txtNumeroTelefonoAnterior" value="" />
                        <input type="hidden" id="txtTelefonoEsNuevo" value="true" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoTelefonoProveedor">Tipo de teléfono</label>
                        <select id="cboTipoTelefonoProveedor" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboTelefonoPrincipalProveedor">Principal</label>
                        <select id="cboTelefonoPrincipalProveedor" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label>&nbsp;</label>
                        <div class="btn-group btn-block">
                            <button type="button" class="btn btn-primary" id="btnGuardarTelefono" onclick="guardarTelefonoProveedor()">
                                Guardar teléfono
                            </button>
                            <button type="button" class="btn btn-secondary" id="btnLimpiarTelefono" onclick="limpiarFormularioTelefonoProveedor()">
                                Limpiar
                            </button>
                        </div>
                    </div>

                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaTelefonosProveedor">
                        <thead>
                            <tr>
                                <th>Teléfono</th>
                                <th>Tipo</th>
                                <th>Principal</th>
                                <th>Estado</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="font-weight-bold mb-0">Correos del proveedor</h6>
                    <small class="text-muted" id="textoAyudaCorreo">
                        Para agregar correos, primero guarde el proveedor.
                    </small>
                </div>

                <div class="form-row mt-3">

                    <div class="form-group col-md-4">
                        <label for="txtDireccionCorreoProveedor">Correo electrónico</label>
                        <input type="email" id="txtDireccionCorreoProveedor" class="form-control" maxlength="150" autocomplete="off" />
                        <input type="hidden" id="txtCorreoAnterior" value="" />
                        <input type="hidden" id="txtCorreoEsNuevo" value="true" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoCorreoProveedor">Tipo de correo</label>
                        <select id="cboTipoCorreoProveedor" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboCorreoPrincipalProveedor">Principal</label>
                        <select id="cboCorreoPrincipalProveedor" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label>&nbsp;</label>
                        <div class="btn-group btn-block">
                            <button type="button" class="btn btn-primary" id="btnGuardarCorreo" onclick="guardarCorreoProveedor()">
                                Guardar correo
                            </button>
                            <button type="button" class="btn btn-secondary" id="btnLimpiarCorreo" onclick="limpiarFormularioCorreoProveedor()">
                                Limpiar
                            </button>
                        </div>
                    </div>

                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaCorreosProveedor">
                        <thead>
                            <tr>
                                <th>Correo</th>
                                <th>Tipo</th>
                                <th>Principal</th>
                                <th>Estado</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarProveedor()">
                    Guardar proveedor
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaProveedores = [];
        var listaTelefonosProveedor = [];
        var listaCorreosProveedor = [];

        $(document).ready(function () {
            cargarProveedores();
            cargarProvinciasActivas();
            cargarTiposTelefonoProveedor();
            cargarTiposCorreoProveedor();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });

            $("#cboProvincia").on("change", function () {
                var idProvincia = parseInt($(this).val());
                cargarCantonesPorProvincia(idProvincia, 0);
                limpiarDistritos();
            });

            $("#cboCanton").on("change", function () {
                var idCanton = parseInt($(this).val());
                cargarDistritosPorCanton(idCanton, 0);
            });
        });

        function cargarProveedores() {
            $.ajax({
                url: '@Url.Action("ListarProveedores", "Proveedor")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaProveedores = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los proveedores.");
                }
            });
        }

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaProveedores tbody");

            tbody.empty();

            $.each(listaProveedores, function (i, item) {
                var identificacion = item.IdentificacionProveedor || "";
                var razonSocial = item.RazonSocial || "";
                var contacto = item.NombreContacto || "";

                var distrito = item.DistritoNombre || "";
                var canton = item.CantonNombre || "";
                var provincia = item.ProvinciaNombre || "";
                var ubicacion = "-";

                if (distrito !== "" || canton !== "" || provincia !== "") {
                    ubicacion = distrito + ", " + canton + ", " + provincia;
                }

                var diasCredito = item.DiasCredito == null ? "-" : item.DiasCredito;

                var texto = (identificacion + " " + razonSocial + " " + contacto + " " + ubicacion).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var fila = `
                    <tr>
                        <td>${identificacion}</td>
                        <td>${razonSocial}</td>
                        <td>${contacto}</td>
                        <td>${ubicacion}</td>
                        <td>${diasCredito}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick='inactivarProveedor(${JSON.stringify(identificacion)})'>
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtEsNuevo").val("true");

            $("#txtIdentificacionProveedor").val("");
            $("#txtIdentificacionProveedor").prop("readonly", false);

            $("#txtRazonSocial").val("");
            $("#txtNombreContacto").val("");

            $("#cboProvincia").val(0);
            $("#cboCanton").empty().append('<option value="0">Seleccione un cantón</option>');
            $("#cboDistrito").empty().append('<option value="0">Seleccione un distrito</option>');

            $("#txtDireccionExacta").val("");
            $("#txtDiasCredito").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo proveedor");

            limpiarFormularioTelefonoProveedor();
            listaTelefonosProveedor = [];
            pintarTelefonosProveedor();
            bloquearTelefonosProveedor(true);

            limpiarFormularioCorreoProveedor();
            listaCorreosProveedor = [];
            pintarCorreosProveedor();
            bloquearCorreosProveedor(true);

            if (json != null) {
                $("#txtEsNuevo").val("false");

                $("#txtIdentificacionProveedor").val(json.IdentificacionProveedor);
                $("#txtIdentificacionProveedor").prop("readonly", true);

                $("#txtRazonSocial").val(json.RazonSocial || "");
                $("#txtNombreContacto").val(json.NombreContacto || "");
                $("#txtDireccionExacta").val(json.DireccionExacta || "");
                $("#txtDiasCredito").val(json.DiasCredito == null ? "" : json.DiasCredito);
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar proveedor");

                if (json.IdProvincia != null) {
                    $("#cboProvincia").val(json.IdProvincia);
                    cargarCantonesPorProvincia(json.IdProvincia, json.IdCanton);

                    setTimeout(function () {
                        cargarDistritosPorCanton(json.IdCanton, json.IdDistrito);
                    }, 300);
                }

                bloquearTelefonosProveedor(false);
                cargarTelefonosProveedor(json.IdentificacionProveedor);

                bloquearCorreosProveedor(false);
                cargarCorreosProveedor(json.IdentificacionProveedor);
            }

            $("#FormModal").modal("show");
        }

        function guardarProveedor() {
            var diasCreditoTexto = $("#txtDiasCredito").val();

            var obj = {
                IdentificacionProveedor: $("#txtIdentificacionProveedor").val().trim(),
                RazonSocial: $("#txtRazonSocial").val().trim(),
                NombreContacto: $("#txtNombreContacto").val().trim(),
                IdDistrito: parseInt($("#cboDistrito").val()) === 0 ? null : parseInt($("#cboDistrito").val()),
                DireccionExacta: $("#txtDireccionExacta").val().trim(),
                DiasCredito: diasCreditoTexto === "" ? null : parseInt(diasCreditoTexto),
                Activo: $("#cboActivo").val() === "true"
            };

            var esNuevo = $("#txtEsNuevo").val() === "true";

            

            if (obj.RazonSocial === "") {
                $("#mensajeError").text("Debe ingresar la razón social.").show();
                return;
            }

            if (obj.RazonSocial.length > 200) {
                $("#mensajeError").text("La razón social no puede superar los 200 caracteres.").show();
                return;
            }

            if (obj.NombreContacto.length > 100) {
                $("#mensajeError").text("El nombre de contacto no puede superar los 100 caracteres.").show();
                return;
            }

            if (obj.DireccionExacta.length > 250) {
                $("#mensajeError").text("La dirección exacta no puede superar los 250 caracteres.").show();
                return;
            }

            if (diasCreditoTexto !== "" && isNaN(obj.DiasCredito)) {
                $("#mensajeError").text("Debe ingresar días de crédito válidos.").show();
                return;
            }

            if (obj.DiasCredito != null && obj.DiasCredito < 0) {
                $("#mensajeError").text("Los días de crédito no pueden ser negativos.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({
                    obj: obj,
                    esNuevo: esNuevo
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#FormModal").modal("hide");
                        cargarProveedores();

                        if (esNuevo && respuesta.identificacionProveedorGenerada !== "") {
                            alert("Proveedor registrado correctamente.\nCódigo generado: " + respuesta.identificacionProveedorGenerada);
                        }
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el proveedor.").show();
                }
            });
        }

         function inactivarProveedor(identificacionProveedor) {
            if (!confirm("¿Desea inactivar este proveedor?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({ identificacionProveedor: identificacionProveedor }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarProveedores();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el proveedor.");
                }
            });
        }

                    function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data, function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>", {
                                value: item.IdProvincia,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar las provincias.");
                }
            });
        }

        function cargarCantonesPorProvincia(idProvincia, idCantonSeleccionado) {
            $("#cboCanton").empty();
            $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

            if (idProvincia === 0 || isNaN(idProvincia)) {
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarCantonesActivosPorProvincia", "Ubicacion")',
                type: "GET",
                data: { idProvincia: idProvincia },
                dataType: "json",
                success: function (respuesta) {
                    $.each(respuesta.data, function (i, item) {
                        $("#cboCanton").append(
                            $("<option>", {
                                value: item.IdCanton,
                                text: item.Nombre
                            })
                        );
                    });

                    if (idCantonSeleccionado !== 0 && idCantonSeleccionado != null) {
                        $("#cboCanton").val(idCantonSeleccionado);
                    }
                },
                error: function () {
                    alert("Error al cargar los cantones.");
                }
            });
        }

        function cargarDistritosPorCanton(idCanton, idDistritoSeleccionado) {
            limpiarDistritos();

            if (idCanton === 0 || isNaN(idCanton)) {
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarDistritosActivosPorCanton", "Ubicacion")',
                type: "GET",
                data: { idCanton: idCanton },
                dataType: "json",
                success: function (respuesta) {
                    $.each(respuesta.data, function (i, item) {
                        $("#cboDistrito").append(
                            $("<option>", {
                                value: item.IdDistrito,
                                text: item.Nombre
                            })
                        );
                    });

                    if (idDistritoSeleccionado !== 0 && idDistritoSeleccionado != null) {
                        $("#cboDistrito").val(idDistritoSeleccionado);
                    }
                },
                error: function () {
                    alert("Error al cargar los distritos.");
                }
            });
        }

        function limpiarDistritos() {
            $("#cboDistrito").empty();
            $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');
        }

        function cargarTiposTelefonoProveedor() {
            $.ajax({
                url: '@Url.Action("ListarTipoTelefonos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoTelefonoProveedor").empty();
                    $("#cboTipoTelefonoProveedor").append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data, function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoTelefonoProveedor").append(
                                $("<option>", {
                                    value: item.IdTipoTelefono,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    alert("Error al cargar los tipos de teléfono.");
                }
            });
        }

        function bloquearTelefonosProveedor(bloquear) {
            $("#txtNumeroTelefonoProveedor").prop("disabled", bloquear);
            $("#cboTipoTelefonoProveedor").prop("disabled", bloquear);
            $("#cboTelefonoPrincipalProveedor").prop("disabled", bloquear);
            $("#btnGuardarTelefono").prop("disabled", bloquear);
            $("#btnLimpiarTelefono").prop("disabled", bloquear);

            if (bloquear) {
                $("#textoAyudaTelefono").text("Para agregar teléfonos, primero guarde el proveedor.");
            } else {
                $("#textoAyudaTelefono").text("Puede agregar, editar o inactivar teléfonos del proveedor.");
            }
        }

        function limpiarFormularioTelefonoProveedor() {
            $("#txtNumeroTelefonoProveedor").val("");
            $("#txtNumeroTelefonoAnterior").val("");
            $("#txtTelefonoEsNuevo").val("true");
            $("#cboTipoTelefonoProveedor").val(0);
            $("#cboTelefonoPrincipalProveedor").val("true");
        }

        function cargarTelefonosProveedor(identificacionProveedor) {
            listaTelefonosProveedor = [];
            pintarTelefonosProveedor();

            if (identificacionProveedor === "") {
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarTelefonosProveedor", "Proveedor")',
                type: "GET",
                data: { identificacionProveedor: identificacionProveedor },
                dataType: "json",
                success: function (respuesta) {
                    listaTelefonosProveedor = respuesta.data;
                    pintarTelefonosProveedor();
                },
                error: function () {
                    alert("Error al cargar los teléfonos del proveedor.");
                }
            });
        }

        function pintarTelefonosProveedor() {
            var tbody = $("#tablaTelefonosProveedor tbody");
            tbody.empty();

            if (listaTelefonosProveedor.length === 0) {
                tbody.append(`
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            No hay teléfonos registrados.
                        </td>
                    </tr>
                `);
                return;
            }

            $.each(listaTelefonosProveedor, function (i, item) {
                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var principal = item.EsPrincipal
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-light">No</span>';

                var fila = `
                    <tr>
                        <td>${item.NumeroTelefono}</td>
                        <td>${item.TipoTelefonoNombre}</td>
                        <td>${principal}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='editarTelefonoProveedor(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick='inactivarTelefonoProveedor(${JSON.stringify(item.NumeroTelefono)}, ${JSON.stringify(item.IdentificacionProveedor)})'>
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function editarTelefonoProveedor(item) {
            $("#txtTelefonoEsNuevo").val("false");
            $("#txtNumeroTelefonoAnterior").val(item.NumeroTelefono);
            $("#txtNumeroTelefonoProveedor").val(item.NumeroTelefono);
            $("#cboTipoTelefonoProveedor").val(item.IdTipoTelefono);
            $("#cboTelefonoPrincipalProveedor").val(item.EsPrincipal ? "true" : "false");
        }

        function guardarTelefonoProveedor() {
            var identificacionProveedor = $("#txtIdentificacionProveedor").val().trim();

            var obj = {
                IdentificacionProveedor: identificacionProveedor,
                NumeroTelefono: $("#txtNumeroTelefonoProveedor").val().trim(),
                IdTipoTelefono: parseInt($("#cboTipoTelefonoProveedor").val()),
                EsPrincipal: $("#cboTelefonoPrincipalProveedor").val() === "true",
                Activo: true
            };

            var esNuevo = $("#txtTelefonoEsNuevo").val() === "true";
            var numeroAnterior = $("#txtNumeroTelefonoAnterior").val().trim();

            if (obj.IdentificacionProveedor === "") {
                $("#mensajeError").text("Primero debe ingresar la identificación del proveedor.").show();
                return;
            }

            if (obj.NumeroTelefono === "") {
                $("#mensajeError").text("Debe ingresar el número de teléfono.").show();
                return;
            }

            if (obj.NumeroTelefono.length > 45) {
                $("#mensajeError").text("El número de teléfono no puede superar los 45 caracteres.").show();
                return;
            }

            if (obj.IdTipoTelefono === 0 || isNaN(obj.IdTipoTelefono)) {
                $("#mensajeError").text("Debe seleccionar un tipo de teléfono.").show();
                return;
            }

            if (!esNuevo && numeroAnterior === "") {
                $("#mensajeError").text("Debe seleccionar un teléfono válido para editar.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTelefonoProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({
                    obj: obj,
                    esNuevo: esNuevo,
                    numeroAnterior: numeroAnterior
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#mensajeError").hide().text("");
                        limpiarFormularioTelefonoProveedor();
                        cargarTelefonosProveedor(identificacionProveedor);
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el teléfono del proveedor.").show();
                }
            });
        }

        function inactivarTelefonoProveedor(numeroTelefono, identificacionProveedor) {
            if (!confirm("¿Desea inactivar este teléfono?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarTelefonoProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({
                    identificacionProveedor: identificacionProveedor,
                    numeroTelefono: numeroTelefono
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        limpiarFormularioTelefonoProveedor();
                        cargarTelefonosProveedor(identificacionProveedor);
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el teléfono.");
                }
            });
        }

        function cargarTiposCorreoProveedor() {
            $.ajax({
                url: '@Url.Action("ListarTipoCorreos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoCorreoProveedor").empty();
                    $("#cboTipoCorreoProveedor").append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data, function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoCorreoProveedor").append(
                                $("<option>", {
                                    value: item.IdTipoCorreo,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    alert("Error al cargar los tipos de correo.");
                }
            });
        }

        function bloquearCorreosProveedor(bloquear) {
            $("#txtDireccionCorreoProveedor").prop("disabled", bloquear);
            $("#cboTipoCorreoProveedor").prop("disabled", bloquear);
            $("#cboCorreoPrincipalProveedor").prop("disabled", bloquear);
            $("#btnGuardarCorreo").prop("disabled", bloquear);
            $("#btnLimpiarCorreo").prop("disabled", bloquear);

            if (bloquear) {
                $("#textoAyudaCorreo").text("Para agregar correos, primero guarde el proveedor.");
            } else {
                $("#textoAyudaCorreo").text("Puede agregar, editar o inactivar correos del proveedor.");
            }
        }

        function limpiarFormularioCorreoProveedor() {
            $("#txtDireccionCorreoProveedor").val("");
            $("#txtCorreoAnterior").val("");
            $("#txtCorreoEsNuevo").val("true");
            $("#cboTipoCorreoProveedor").val(0);
            $("#cboCorreoPrincipalProveedor").val("true");
        }

        function cargarCorreosProveedor(identificacionProveedor) {
            listaCorreosProveedor = [];
            pintarCorreosProveedor();

            if (identificacionProveedor === "") {
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarCorreosProveedor", "Proveedor")',
                type: "GET",
                data: { identificacionProveedor: identificacionProveedor },
                dataType: "json",
                success: function (respuesta) {
                    listaCorreosProveedor = respuesta.data;
                    pintarCorreosProveedor();
                },
                error: function () {
                    alert("Error al cargar los correos del proveedor.");
                }
            });
        }

        function pintarCorreosProveedor() {
            var tbody = $("#tablaCorreosProveedor tbody");
            tbody.empty();

            if (listaCorreosProveedor.length === 0) {
                tbody.append(`
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            No hay correos registrados.
                        </td>
                    </tr>
                `);
                return;
            }

            $.each(listaCorreosProveedor, function (i, item) {
                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var principal = item.EsPrincipal
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-light">No</span>';

                var fila = `
                    <tr>
                        <td>${item.DireccionCorreo}</td>
                        <td>${item.TipoCorreoNombre}</td>
                        <td>${principal}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='editarCorreoProveedor(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick='inactivarCorreoProveedor(${JSON.stringify(item.DireccionCorreo)}, ${JSON.stringify(item.IdentificacionProveedor)})'>
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function editarCorreoProveedor(item) {
            $("#txtCorreoEsNuevo").val("false");
            $("#txtCorreoAnterior").val(item.DireccionCorreo);
            $("#txtDireccionCorreoProveedor").val(item.DireccionCorreo);
            $("#cboTipoCorreoProveedor").val(item.IdTipoCorreo);
            $("#cboCorreoPrincipalProveedor").val(item.EsPrincipal ? "true" : "false");
        }

        function guardarCorreoProveedor() {
            var identificacionProveedor = $("#txtIdentificacionProveedor").val().trim();

            var obj = {
                IdentificacionProveedor: identificacionProveedor,
                DireccionCorreo: $("#txtDireccionCorreoProveedor").val().trim(),
                IdTipoCorreo: parseInt($("#cboTipoCorreoProveedor").val()),
                EsPrincipal: $("#cboCorreoPrincipalProveedor").val() === "true",
                Activo: true
            };

            var esNuevo = $("#txtCorreoEsNuevo").val() === "true";
            var correoAnterior = $("#txtCorreoAnterior").val().trim();

            if (obj.IdentificacionProveedor === "") {
                $("#mensajeError").text("Primero debe ingresar la identificación del proveedor.").show();
                return;
            }

            if (obj.DireccionCorreo === "") {
                $("#mensajeError").text("Debe ingresar la dirección de correo.").show();
                return;
            }

            if (obj.DireccionCorreo.length > 150) {
                $("#mensajeError").text("La dirección de correo no puede superar los 150 caracteres.").show();
                return;
            }

            if (!validarFormatoCorreo(obj.DireccionCorreo)) {
                $("#mensajeError").text("Debe ingresar un correo electrónico válido.").show();
                return;
            }

            if (obj.IdTipoCorreo === 0 || isNaN(obj.IdTipoCorreo)) {
                $("#mensajeError").text("Debe seleccionar un tipo de correo.").show();
                return;
            }

            if (!esNuevo && correoAnterior === "") {
                $("#mensajeError").text("Debe seleccionar un correo válido para editar.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCorreoProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({
                    obj: obj,
                    esNuevo: esNuevo,
                    correoAnterior: correoAnterior
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#mensajeError").hide().text("");
                        limpiarFormularioCorreoProveedor();
                        cargarCorreosProveedor(identificacionProveedor);
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el correo del proveedor.").show();
                }
            });
        }

        function inactivarCorreoProveedor(direccionCorreo, identificacionProveedor) {
            if (!confirm("¿Desea inactivar este correo?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarCorreoProveedor", "Proveedor")',
                type: "POST",
                data: JSON.stringify({
                    identificacionProveedor: identificacionProveedor,
                    direccionCorreo: direccionCorreo
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        limpiarFormularioCorreoProveedor();
                        cargarCorreosProveedor(identificacionProveedor);
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el correo.");
                }
            });
        }

        function validarFormatoCorreo(correo) {
            if (correo === null || correo === undefined) {
                return false;
            }

            correo = correo.trim();

            var arroba = String.fromCharCode(64);

            if (correo.indexOf(arroba) === -1) {
                return false;
            }

            if (correo.indexOf(arroba) !== correo.lastIndexOf(arroba)) {
                return false;
            }

            var partes = correo.split(arroba);

            if (partes.length !== 2) {
                return false;
            }

            var usuario = partes[0];
            var dominio = partes[1];

            if (usuario.length === 0 || dominio.length === 0) {
                return false;
            }

            if (dominio.indexOf(".") === -1) {
                return false;
            }

            if (dominio.startsWith(".") || dominio.endsWith(".")) {
                return false;
            }

            return true;
        }
    </script>
}
    
