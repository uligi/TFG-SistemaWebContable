                ["Fecha emisión", formatearFecha(item.FechaEmision)],
                ["Fecha vencimiento", formatearFecha(item.FechaVencimiento)],
                ["Monto original", formatearMoneda(item.MontoOriginal)],
                ["Saldo actual", formatearMoneda(item.SaldoActual)],
