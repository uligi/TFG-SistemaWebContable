@{
    ViewBag.Title = "Reportes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section estilos {
    <link href="~/Scripts/js/libs/morris/morris.css" rel="stylesheet" />
}

<h4 class="font-weight-bold py-3 mb-0">Reportes Financieros</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Reportes</li>
        <li class="breadcrumb-item active">Reportes financieros</li>
    </ol>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Filtros de reporte</h6>
    </div>

    <div class="card-body">
        <div class="form-row">

            <div class="form-group col-md-4">
                <label for="txtFechaInicio">Fecha inicio</label>
                <input type="date" id="txtFechaInicio" class="form-control" />
            </div>

            <div class="form-group col-md-4">
                <label for="txtFechaFin">Fecha final</label>
                <input type="date" id="txtFechaFin" class="form-control" />
            </div>

            <div class="form-group col-md-4 d-flex align-items-end">
                <button type="button" class="btn btn-primary btn-block" onclick="cargarReportes()">
                    Generar reportes
                </button>
            </div>

        </div>

        <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>
    </div>
</div>

<div class="row mb-4">

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Total ingresos</small>
                <h5 class="mb-0" id="lblTotalIngresos">₡0.00</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Total gastos</small>
                <h5 class="mb-0" id="lblTotalGastos">₡0.00</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Utilidad estimada</small>
                <h5 class="mb-0" id="lblUtilidadEstimada">₡0.00</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">CxC / CxP pendientes</small>
                <h5 class="mb-0">
                    <span id="lblTotalCxC">₡0.00</span> /
                    <span id="lblTotalCxP">₡0.00</span>
                </h5>
            </div>
        </div>
    </div>

</div>

<div class="row mb-4">

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Margen de utilidad</small>
                <h5 class="mb-0" id="lblMargenUtilidad">0.00%</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Capital neto pendiente</small>
                <h5 class="mb-0" id="lblCapitalNetoPendiente">₡0.00</h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Estado financiero</small>
                <h5 class="mb-0" id="lblEstadoFinanciero">
                    <span class="badge badge-secondary">Sin datos</span>
                </h5>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <small class="text-muted">Recomendación</small>
                <div class="small" id="lblRecomendacionGeneral">
                    Genere el reporte para ver la recomendación.
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row mb-4">

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0" id="tituloGraficoPrincipal">Gráfico principal</h6>
            </div>
            <div class="card-body">
                <div id="graficoPrincipal" style="height:300px;"></div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0" id="tituloGraficoResumen">Resumen gráfico</h6>
            </div>
            <div class="card-body">
                <div id="graficoResumen" style="height:300px;"></div>
            </div>
        </div>
    </div>

</div>

<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Acciones del reporte actual</h6>
    </div>

    <div class="card-body">
        <button type="button" class="btn btn-success mr-2" onclick="exportarReporteActualCSV()">
            <i class="feather icon-download"></i> Exportar CSV
        </button>

        <button type="button" class="btn btn-info mr-2" onclick="imprimirReporteActual()">
            <i class="feather icon-printer"></i> Imprimir
        </button>

        <span class="text-muted small">
            Las acciones se aplican a la pestaña activa.
        </span>
    </div>
</div>

<div class="nav-tabs-top mb-4">
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <a class="nav-link active" data-toggle="tab" href="#tabIngresos">Ingresos</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabGastos">Gastos</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabCxC">Cuentas por cobrar</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabCxP">Cuentas por pagar</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabProductos">Productos más vendidos</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabClientes">Clientes clave</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabFlujo">Flujo diario</a>
        </li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade show active" id="tabIngresos">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Reporte de ingresos</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaIngresos" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Origen</th>
                                    <th>Factura</th>
                                    <th>Cuenta</th>
                                    <th>Descripción</th>
                                    <th>Monto</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabGastos">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Reporte de gastos</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaGastos" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Cuenta</th>
                                    <th>Proveedor</th>
                                    <th>Documento</th>
                                    <th>Descripción</th>
                                    <th>Monto</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabCxC">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Cuentas por cobrar pendientes</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaCxC" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Factura</th>
                                    <th>Cliente</th>
                                    <th>Emisión</th>
                                    <th>Vencimiento</th>
                                    <th>Monto original</th>
                                    <th>Saldo actual</th>
                                    <th>Estado</th>
                                    <th>Estado crédito</th>
                                    <th>Días</th>
                                    <th>Prioridad</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabCxP">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Cuentas por pagar pendientes</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaCxP" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Documento</th>
                                    <th>Proveedor</th>
                                    <th>Emisión</th>
                                    <th>Vencimiento</th>
                                    <th>Concepto</th>
                                    <th>Monto original</th>
                                    <th>Saldo actual</th>
                                    <th>Estado</th>
                                    <th>Estado crédito</th>
                                    <th>Días</th>
                                    <th>Prioridad</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabProductos">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Productos más vendidos</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaProductos" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Producto</th>
                                    <th>Tipo</th>
                                    <th>Cantidad vendida</th>
                                    <th>Total vendido</th>
                                    <th>Veces facturado</th>
                                    <th>Stock actual</th>
                                    <th>Recomendación</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabClientes">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Clientes clave</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaClientes" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Facturas</th>
                                    <th>Total comprado</th>
                                    <th>Promedio compra</th>
                                    <th>Última compra</th>
                                    <th>Límite crédito</th>
                                    <th>Días crédito</th>
                                    <th>Clasificación</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabFlujo">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Flujo diario</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaFlujo" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Ingresos</th>
                                    <th>Gastos</th>
                                    <th>Resultado diario</th>
                                    <th>Estado</th>
                                    <th>Recomendación</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="ModalDetalleReporte" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloDetalleReporte">Detalle del reporte</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <div id="contenidoDetalleReporte"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-info" onclick="imprimirDetalleReporte()">
                    Imprimir detalle
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {

    <script src="~/Scripts/js/libs/raphael/raphael.min.js"></script>
    <script src="~/Scripts/js/libs/morris/morris.min.js"></script>
    <script>
        var tablaIngresos = null;
        var tablaGastos = null;
        var tablaCxC = null;
        var tablaCxP = null;
        var tablaProductos = null;
        var tablaClientes = null;
        var tablaFlujo = null;

        var listaIngresosGlobal = [];
        var listaGastosGlobal = [];
        var listaCxCGlobal = [];
        var listaCxPGlobal = [];
        var listaProductosGlobal = [];
        var listaClientesGlobal = [];
        var listaFlujoGlobal = [];
        var resumenGlobal = {};

        $(document).ready(function () {
            var hoy = new Date();
            var primerDia = new Date(hoy.getFullYear(), hoy.getMonth(), 1);

            $("#txtFechaInicio").val(convertirDateAInput(primerDia));
            $("#txtFechaFin").val(convertirDateAInput(hoy));

            cargarReportes();

            $('a[data-toggle="tab"]').on('shown.bs.tab', function () {
                setTimeout(function () {
                    ajustarTablas();
                    pintarGraficosPorReporteActivo();
                }, 200);
            });
        });

        function cargarReportes() {
            var fechaInicio = $("#txtFechaInicio").val();
            var fechaFin = $("#txtFechaFin").val();

            if (fechaInicio === "") {
                $("#mensajeError").text("Debe ingresar la fecha de inicio.").show();
                return;
            }

            if (fechaFin === "") {
                $("#mensajeError").text("Debe ingresar la fecha final.").show();
                return;
            }

            if (fechaFin < fechaInicio) {
                $("#mensajeError").text("La fecha final no puede ser menor que la fecha de inicio.").show();
                return;
            }

            $("#mensajeError").hide().text("");

            cargarResumenFinanciero(fechaInicio, fechaFin);
            cargarIngresos(fechaInicio, fechaFin);
            cargarGastos(fechaInicio, fechaFin);
            cargarCuentasPorCobrar();
            cargarCuentasPorPagar();
            cargarProductosMasVendidos(fechaInicio, fechaFin);
            cargarClientesMasVentas(fechaInicio, fechaFin);
            cargarFlujoDiario(fechaInicio, fechaFin);
        }

        function cargarResumenFinanciero(fechaInicio, fechaFin) {
            $.ajax({
                url: '@Url.Action("ObtenerResumenFinanciero", "Reportes")',
                type: "GET",
                data: {
                    fechaInicio: fechaInicio,
                    fechaFin: fechaFin
                },
                dataType: "json",
                success: function (respuesta) {
                    if (respuesta.resultado === false) {
                        $("#mensajeError").text(respuesta.mensaje || "No se pudo cargar el resumen financiero.").show();
                        return;
                    }

                    var item = respuesta.data || {};
                    resumenGlobal = item;

                    $("#lblTotalIngresos").text(formatearMoneda(item.TotalIngresos));
                    $("#lblTotalGastos").text(formatearMoneda(item.TotalGastos));
                    $("#lblUtilidadEstimada").text(formatearMoneda(item.UtilidadEstimada));
                    $("#lblTotalCxC").text(formatearMoneda(item.TotalCuentasPorCobrar));
                    $("#lblTotalCxP").text(formatearMoneda(item.TotalCuentasPorPagar));

                    $("#lblMargenUtilidad").text(formatearNumero(item.MargenUtilidad) + "%");
                    $("#lblCapitalNetoPendiente").text(formatearMoneda(item.CapitalNetoPendiente));
                    $("#lblEstadoFinanciero").html(obtenerBadgeEstadoFinanciero(item.EstadoFinanciero));
                    $("#lblRecomendacionGeneral").text(item.RecomendacionGeneral || "Mantener seguimiento del negocio.");

                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar el resumen financiero.");
                }
            });
        }

        function cargarIngresos(fechaInicio, fechaFin) {
            $.ajax({
                url: '@Url.Action("ReporteIngresos", "Reportes")',
                type: "GET",
                data: {
                    fechaInicio: fechaInicio,
                    fechaFin: fechaFin
                },
                dataType: "json",
                success: function (respuesta) {
                    listaIngresosGlobal = respuesta.data || [];
                    pintarTablaIngresos(listaIngresosGlobal);
                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar el reporte de ingresos.");
                }
            });
        }

        function cargarGastos(fechaInicio, fechaFin) {
            $.ajax({
                url: '@Url.Action("ReporteGastos", "Reportes")',
                type: "GET",
                data: {
                    fechaInicio: fechaInicio,
                    fechaFin: fechaFin
                },
                dataType: "json",
                success: function (respuesta) {
                    listaGastosGlobal = respuesta.data || [];
                    pintarTablaGastos(listaGastosGlobal);
                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar el reporte de gastos.");
                }
            });
        }

        function cargarCuentasPorCobrar() {
            $.ajax({
                url: '@Url.Action("ReporteCuentasPorCobrar", "Reportes")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCxCGlobal = respuesta.data || [];
                    pintarTablaCxC(listaCxCGlobal);
                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar cuentas por cobrar.");
                }
            });
        }

        function cargarCuentasPorPagar() {
            $.ajax({
                url: '@Url.Action("ReporteCuentasPorPagar", "Reportes")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCxPGlobal = respuesta.data || [];
                    pintarTablaCxP(listaCxPGlobal);
                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar cuentas por pagar.");
                }
            });
        }

        function cargarProductosMasVendidos(fechaInicio, fechaFin) {
            $.ajax({
                url: '@Url.Action("ReporteProductosMasVendidos", "Reportes")',
                type: "GET",
                data: {
                    fechaInicio: fechaInicio,
                    fechaFin: fechaFin
                },
                dataType: "json",
                success: function (respuesta) {
                    listaProductosGlobal = respuesta.data || [];
                    pintarTablaProductos(listaProductosGlobal);
                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar productos más vendidos.");
                }
            });
        }

        function cargarClientesMasVentas(fechaInicio, fechaFin) {
            $.ajax({
                url: '@Url.Action("ReporteClientesMasVentas", "Reportes")',
                type: "GET",
                data: {
                    fechaInicio: fechaInicio,
                    fechaFin: fechaFin
                },
                dataType: "json",
                success: function (respuesta) {
                    listaClientesGlobal = respuesta.data || [];
                    pintarTablaClientes(listaClientesGlobal);
                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar clientes clave.");
                }
            });
        }

        function cargarFlujoDiario(fechaInicio, fechaFin) {
            $.ajax({
                url: '@Url.Action("ReporteFlujoDiario", "Reportes")',
                type: "GET",
                data: {
                    fechaInicio: fechaInicio,
                    fechaFin: fechaFin
                },
                dataType: "json",
                success: function (respuesta) {
                    listaFlujoGlobal = respuesta.data || [];
                    pintarTablaFlujo(listaFlujoGlobal);
                    pintarGraficosPorReporteActivo();
                },
                error: function () {
                    alert("Error al cargar flujo diario.");
                }
            });
        }

        function pintarTablaIngresos(lista) {
            if (tablaIngresos != null) {
                tablaIngresos.clear().destroy();
                tablaIngresos = null;
            }

            var tbody = $("#tablaIngresos tbody");
            tbody.empty();

            $.each(lista, function (i, item) {
                var cuenta = (item.CodigoCuenta || "-") + " - " + (item.NombreCuenta || "-");

                var fila = $("<tr>");
                fila.append($("<td>").text(formatearFecha(item.FechaIngreso)));
                fila.append($("<td>").text(item.TipoIngreso || ""));
                fila.append($("<td>").text(item.OrigenIngreso || ""));
                fila.append($("<td>").text(item.NumeroFactura || "-"));
                fila.append($("<td>").text(cuenta));
                fila.append($("<td>").text(item.Descripcion || ""));
                fila.append($("<td>").text(formatearMoneda(item.Monto)));
                fila.append($("<td>").html(
                    '<button type="button" class="btn btn-sm btn-outline-primary" onclick="verDetalleIngreso(' + i + ')">Ver</button>'
                ));

                tbody.append(fila);
            });

            tablaIngresos = $("#tablaIngresos").DataTable({
                responsive: false,
                scrollX: true,
                autoWidth: false,
                pageLength: 10,
                destroy: true,
                order: [[0, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function pintarTablaGastos(lista) {
            if (tablaGastos != null) {
                tablaGastos.clear().destroy();
                tablaGastos = null;
            }

            var tbody = $("#tablaGastos tbody");
            tbody.empty();

            $.each(lista, function (i, item) {
                var cuenta = (item.CodigoCuenta || "-") + " - " + (item.NombreCuenta || "-");
                var proveedor = (item.IdentificacionProveedor || "-") + " - " + (item.ProveedorNombre || "-");

                var fila = $("<tr>");
                fila.append($("<td>").text(formatearFecha(item.FechaGasto)));
                fila.append($("<td>").text(item.TipoGasto || ""));
                fila.append($("<td>").text(cuenta));
                fila.append($("<td>").text(proveedor));
                fila.append($("<td>").text(item.NumeroDocumento || "-"));
