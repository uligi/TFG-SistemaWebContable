        function abrirDetalleReporte(titulo, datos) {
            $("#tituloDetalleReporte").text(titulo);

            var html = '<table class="table table-bordered table-striped mb-0">';
            html += '<tbody>';

            $.each(datos, function (i, fila) {
                html += '<tr>';
                html += '<th style="width:30%;">' + fila[0] + '</th>';
                html += '<td>' + (fila[1] || "") + '</td>';
                html += '</tr>';
            });

            html += '</tbody></table>';

            $("#contenidoDetalleReporte").html(html);
            $("#ModalDetalleReporte").modal("show");
        }

        function imprimirDetalleReporte() {
            var titulo = $("#tituloDetalleReporte").text();
            var contenido = $("#contenidoDetalleReporte").html();

            var html = '';

            html += '<!DOCTYPE html>';
            html += '<html><head><meta charset="utf-8">';
            html += '<title>' + titulo + '</title>';
            html += '<style>';
            html += 'body{font-family:Arial, sans-serif; font-size:12px; margin:25px;}';
            html += 'h2{margin-bottom:15px;}';
            html += 'table{width:100%; border-collapse:collapse;}';
            html += 'th,td{border:1px solid #ccc; padding:8px; text-align:left;}';
            html += 'th{background:#f2f2f2;}';
            html += '</style>';
            html += '</head><body>';
            html += '<h2>' + titulo + '</h2>';
            html += contenido;
            html += '</body></html>';

            var ventana = window.open("", "_blank");
            ventana.document.open();
            ventana.document.write(html);
            ventana.document.close();
            ventana.focus();
            ventana.print();
        }
    </script>
