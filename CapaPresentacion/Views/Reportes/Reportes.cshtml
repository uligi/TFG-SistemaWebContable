        function obtenerBadgeClasificacionCliente(clasificacion) {
            if (clasificacion === "Cliente frecuente") {
                return '<span class="badge badge-success">Cliente frecuente</span>';
            }

            if (clasificacion === "Cliente de alto valor") {
