        function pintarGraficosPorReporteActivo() {
            var tabActivo = $(".nav-tabs .nav-link.active").attr("href");

            limpiarGrafico("graficoPrincipal");
            limpiarGrafico("graficoResumen");

            if (typeof Morris === "undefined") {
                $("#graficoPrincipal").html('<div class="text-center text-danger pt-5">No se cargó Morris.js.</div>');
                $("#graficoResumen").html('<div class="text-center text-danger pt-5">No se cargó Morris.js.</div>');
                return;
            }

            if (tabActivo === "#tabIngresos") {
                $("#tituloGraficoPrincipal").text("Ingresos por tipo");
                $("#tituloGraficoResumen").text("Ingresos vs gastos");

                pintarBarraPorCampo("graficoPrincipal", listaIngresosGlobal, "TipoIngreso", "Monto", "Monto");
                pintarIngresosVsGastos("graficoResumen");
                return;
            }

            if (tabActivo === "#tabGastos") {
                $("#tituloGraficoPrincipal").text("Gastos por tipo");
                $("#tituloGraficoResumen").text("Ingresos vs gastos");

                pintarBarraPorCampo("graficoPrincipal", listaGastosGlobal, "TipoGasto", "Monto", "Monto");
                pintarIngresosVsGastos("graficoResumen");
                return;
            }

            if (tabActivo === "#tabCxC") {
                $("#tituloGraficoPrincipal").text("Cuentas por cobrar por estado de crédito");
                $("#tituloGraficoResumen").text("Saldo pendiente CxC");

                pintarBarraPorCampo("graficoPrincipal", listaCxCGlobal, "EstadoCredito", "SaldoActual", "Saldo");
                pintarDonutCuentas("graficoResumen", "CxC");
                return;
            }

            if (tabActivo === "#tabCxP") {
                $("#tituloGraficoPrincipal").text("Cuentas por pagar por estado de crédito");
                $("#tituloGraficoResumen").text("Saldo pendiente CxP");

                pintarBarraPorCampo("graficoPrincipal", listaCxPGlobal, "EstadoCredito", "SaldoActual", "Saldo");
                pintarDonutCuentas("graficoResumen", "CxP");
                return;
            }

            if (tabActivo === "#tabProductos") {
                $("#tituloGraficoPrincipal").text("Productos por total vendido");
                $("#tituloGraficoResumen").text("Top productos por cantidad");

                pintarBarraPorCampo("graficoPrincipal", listaProductosGlobal, "NombreProducto", "TotalVendido", "Total vendido");
                pintarBarraPorCampo("graficoResumen", listaProductosGlobal.slice(0, 5), "NombreProducto", "CantidadVendida", "Cantidad");
                return;
            }

            if (tabActivo === "#tabClientes") {
                $("#tituloGraficoPrincipal").text("Clientes por total comprado");
                $("#tituloGraficoResumen").text("Clientes por cantidad de facturas");

                pintarBarraPorCampo("graficoPrincipal", listaClientesGlobal, "ClienteNombre", "TotalComprado", "Total comprado");
                pintarBarraPorCampo("graficoResumen", listaClientesGlobal.slice(0, 5), "ClienteNombre", "CantidadFacturas", "Facturas");
                return;
            }

            if (tabActivo === "#tabFlujo") {
                $("#tituloGraficoPrincipal").text("Flujo diario");
                $("#tituloGraficoResumen").text("Ingresos vs gastos");

                pintarFlujoDiario("graficoPrincipal");
                pintarIngresosVsGastos("graficoResumen");
                return;
            }
        }

        function limpiarGrafico(idContenedor) {
            $("#" + idContenedor).empty();
        }

        function pintarBarraPorCampo(idContenedor, lista, campoAgrupar, campoMonto, etiquetaY) {
            limpiarGrafico(idContenedor);

            var agrupado = {};

            $.each(lista, function (i, item) {
                var grupo = item[campoAgrupar] || "Sin clasificar";
                var monto = parseFloat(item[campoMonto] || 0);

                if (!agrupado[grupo]) {
                    agrupado[grupo] = 0;
                }

                agrupado[grupo] += monto;
            });

            var data = [];

            $.each(agrupado, function (grupo, monto) {
                data.push({
                    grupo: grupo,
                    monto: monto
                });
            });

            if (data.length === 0) {
                $("#" + idContenedor).html(
                    '<div class="text-center text-muted pt-5">No hay datos para graficar.</div>'
                );
                return;
            }

            Morris.Bar({
                element: idContenedor,
                data: data,
                xkey: "grupo",
                ykeys: ["monto"],
                labels: [etiquetaY],
                resize: true,
                hideHover: "auto"
            });
        }

        function pintarIngresosVsGastos(idContenedor) {
            limpiarGrafico(idContenedor);

            var ingresos = parseFloat(resumenGlobal.TotalIngresos || 0);
            var gastos = parseFloat(resumenGlobal.TotalGastos || 0);

            if (ingresos === 0 && gastos === 0) {
                $("#" + idContenedor).html(
                    '<div class="text-center text-muted pt-5">No hay ingresos ni gastos para graficar.</div>'
                );
                return;
            }

            Morris.Donut({
                element: idContenedor,
                data: [
                    { label: "Ingresos", value: ingresos },
                    { label: "Gastos", value: gastos }
                ],
                resize: true,
                formatter: function (value) {
                    return formatearMoneda(value);
                }
            });
        }

        function pintarDonutCuentas(idContenedor, tipo) {
            limpiarGrafico(idContenedor);

            var total = 0;
            var label = "";

            if (tipo === "CxC") {
                total = parseFloat(resumenGlobal.TotalCuentasPorCobrar || 0);
                label = "CxC pendiente";
            } else {
                total = parseFloat(resumenGlobal.TotalCuentasPorPagar || 0);
                label = "CxP pendiente";
            }

            if (total === 0) {
                $("#" + idContenedor).html(
                    '<div class="text-center text-muted pt-5">No hay saldo pendiente.</div>'
                );
                return;
            }

            Morris.Donut({
                element: idContenedor,
                data: [
                    {
                        label: label,
                        value: total
                    }
                ],
                resize: true,
                formatter: function (value) {
                    return formatearMoneda(value);
                }
            });
        }

        function pintarFlujoDiario(idContenedor) {
            limpiarGrafico(idContenedor);

            var data = [];

            $.each(listaFlujoGlobal, function (i, item) {
                data.push({
                    fecha: formatearFecha(item.Fecha),
                    ingresos: parseFloat(item.TotalIngresos || 0),
                    gastos: parseFloat(item.TotalGastos || 0),
                    resultado: parseFloat(item.ResultadoDiario || 0)
                });
            });

            if (data.length === 0) {
                $("#" + idContenedor).html(
                    '<div class="text-center text-muted pt-5">No hay flujo diario para graficar.</div>'
                );
                return;
            }

            Morris.Line({
                element: idContenedor,
                data: data,
                xkey: "fecha",
                ykeys: ["ingresos", "gastos", "resultado"],
                labels: ["Ingresos", "Gastos", "Resultado"],
                parseTime: false,
                resize: true,
                hideHover: "auto"
            });
        }

