@{
    ViewBag.Title = "Gastos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-gasto,
    .codigo-documento,
    .codigo-cuenta {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Gastos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Gastos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de gastos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalGasto(null)">
            Nuevo gasto
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscarGasto" class="form-control" placeholder="Buscar por número, descripción, proveedor, documento o cuenta..." />
            </div>

            <div class="col-md-3">
                <select id="cboFiltroActivo" class="form-control">
                    <option value="">Todos</option>
                    <option value="true">Activos</option>
                    <option value="false">Inactivos</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary btn-block" onclick="cargarGastos()">
                    Actualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaGastos">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th>Cuenta</th>
                        <th>Proveedor</th>
                        <th>Documento / Abono</th>
                        <th>Monto</th>
                        <th>Comprobante</th>
                        <th>Activo</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModalGasto" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalGasto">Nuevo gasto</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtNumeroGastoInterno" value="" />

                <input type="hidden" id="txtIdentificacionProveedor" value="" />
                <input type="hidden" id="txtNumeroDocumento" value="" />

                <input type="hidden" id="txtIdentificacionProveedorAbono" value="" />
                <input type="hidden" id="txtNumeroDocumentoAbono" value="" />
                <input type="hidden" id="txtNumeroAbonoCuentaPorPagar" value="0" />

                <div class="alert alert-danger" id="mensajeErrorGasto" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoGasto" style="display:none;"></div>

                <h6 class="font-weight-bold">Datos del gasto</h6>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtNumeroGasto">Número gasto</label>
                        <input type="text" id="txtNumeroGasto" class="form-control codigo-gasto" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaGasto">Fecha gasto</label>
                        <input type="date" id="txtFechaGasto" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoGasto">Tipo de gasto</label>
                        <select id="cboTipoGasto" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboActivoGasto">Activo</label>
                        <select id="cboActivoGasto" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-5">
                        <label for="cboCuentaContable">Cuenta contable</label>
                        <select id="cboCuentaContable" class="form-control">
                            <option value="">Seleccione una cuenta</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMonto">Monto</label>
                        <input type="text" id="txtMonto" class="form-control" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtNumeroComprobante">Número comprobante</label>
                        <input type="text" id="txtNumeroComprobante" class="form-control" maxlength="45" />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-12">
                        <label for="txtDescripcion">Descripción</label>
                        <input type="text" id="txtDescripcion" class="form-control" maxlength="150" placeholder="Descripción del gasto..." />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-6">
                        <label for="txtNombreArchivoComprobante">Nombre archivo comprobante</label>
                        <input type="text" id="txtNombreArchivoComprobante" class="form-control" maxlength="150" placeholder="Ejemplo: factura_proveedor.pdf" />
                    </div>

                    <div class="form-group col-md-6">
                        <label for="txtRutaComprobante">Ruta comprobante</label>
                        <input type="text" id="txtRutaComprobante" class="form-control" maxlength="300" placeholder="Ruta o referencia del archivo..." />
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="font-weight-bold mb-0">Abonos de cuentas por pagar</h6>

                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="cargarAbonosCuentaPorPagar()">
                        Actualizar abonos
                    </button>
                </div>

                <small class="form-text text-muted mb-2">
                    Seleccione un abono de cuenta por pagar para asociarlo al gasto. Los gastos automáticos se crean al registrar abonos desde Cuentas por Pagar.
                </small>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaAbonosCxP">
                        <thead>
                            <tr>
                                <th>Proveedor</th>
                                <th>Documento</th>
                                <th># Abono</th>
                                <th>Fecha</th>
                                <th>Monto</th>
                                <th>Estado cuenta</th>
                                <th style="width:110px;">Acción</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <div class="card bg-light mt-3">
                    <div class="card-body py-2">
                        <strong>Referencia seleccionada:</strong>
                        <span id="lblReferenciaSeleccionada" class="text-muted">Ningún abono seleccionado.</span>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="limpiarFormularioGasto()">
                    Limpiar
                </button>

                <button type="button" class="btn btn-primary" onclick="guardarGasto()">
                    Guardar gasto
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaGastos = [];
        var listaAbonosCxP = [];

        $(document).ready(function () {
            cargarGastos();
            cargarTiposGasto();
            cargarCuentasContables();

            if (window.esAdministradorSistema !== true) {
                $("#cboFiltroActivo option[value='false']").remove();
            }

            $("#txtBuscarGasto, #cboFiltroActivo").on("keyup change", function () {
                pintarTablaGastos();
            });

            $("#txtMonto").on("input", function () {
                limpiarDecimal("txtMonto", "Solo se permiten números y punto decimal.");
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoGeneral("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 150 caracteres.");
                }
            });

            $("#txtNumeroComprobante").on("input", function () {
                limpiarCodigo("txtNumeroComprobante", "Solo se permiten letras, números, puntos, guiones y guion bajo.");
            });

            $("#txtNombreArchivoComprobante").on("input", function () {
                limpiarTextoArchivo("txtNombreArchivoComprobante", "El nombre del archivo contiene caracteres no permitidos.");
            });

            $("#txtRutaComprobante").on("input", function () {
                limpiarRuta("txtRutaComprobante", "La ruta contiene caracteres no permitidos.");
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorGasto").is(":visible")) {
                    $("#mensajeErrorGasto").fadeOut(150);
                }

                if ($("#mensajeExitoGasto").is(":visible")) {
                    $("#mensajeExitoGasto").fadeOut(150);
                }
            });
        });

        function cargarGastos() {
            $.ajax({
                url: '@Url.Action("ListarGastos", "GestionarGastos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaGastos = respuesta.data || [];
                    pintarTablaGastos();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los gastos.", "error");
                }
            });
        }

        function cargarTiposGasto() {
            $.ajax({
                url: '@Url.Action("ListarTiposGastoActivos", "GestionarGastos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoGasto").empty().append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboTipoGasto").append(
                            $("<option>", {
                                value: item.IdTipoGasto,
                                text: item.Nombre || item.TipoGasto || item.Descripcion
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de gasto.", "error");
                }
            });
        }

        function cargarCuentasContables() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContablesGasto", "GestionarGastos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCuentaContable").empty().append('<option value="">Seleccione una cuenta</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        var codigo = item.CodigoCuenta || "";
                        var nombre = item.NombreCuenta || item.Nombre || "";

                        $("#cboCuentaContable").append(
                            $("<option>", {
                                value: codigo,
                                text: codigo + " - " + nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las cuentas contables.", "error");
                }
            });
        }

        function pintarTablaGastos() {
            var filtro = $("#txtBuscarGasto").val().toLowerCase();
            var filtroActivo = $("#cboFiltroActivo").val();
            var tbody = $("#tablaGastos tbody");

            tbody.empty();

            if (listaGastos.length === 0) {
                tbody.append('<tr><td colspan="11" class="text-center text-muted">No hay gastos registrados.</td></tr>');
                return;
            }

            $.each(listaGastos, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var numero = item.NumeroGasto || "";
                var descripcion = item.Descripcion || "";
                var proveedor = item.ProveedorNombre || "";
                var documento = item.NumeroDocumento || "";
                var cuenta = (item.CodigoCuenta || "") + " " + (item.NombreCuenta || "");
                var comprobante = item.NumeroComprobante || "";

                var texto = (numero + " " + descripcion + " " + proveedor + " " + documento + " " + cuenta + " " + comprobante).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                if (filtroActivo !== "" && String(item.Activo).toLowerCase() !== filtroActivo) {
                    return;
                }

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var comprobanteTexto = obtenerTextoComprobante(item);

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModalGasto(item);
                });

                var botonEstado = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarGasto(item.NumeroGasto);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonEstado);
                }

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-gasto", text: numero }));
                fila.append($("<td>").text(formatearFecha(item.FechaGasto)));
                fila.append($("<td>").text(descripcion));
                fila.append($("<td>").text(item.TipoGastoNombre || ""));
                fila.append($("<td>").html('<span class="codigo-cuenta">' + (item.CodigoCuenta || "") + '</span><br/><span class="texto-tabla-secundario">' + (item.NombreCuenta || "") + '</span>'));
                fila.append($("<td>").text((item.IdentificacionProveedor || "") + " - " + proveedor));
                fila.append($("<td>").html(
                    '<span class="codigo-documento">' + (item.NumeroDocumento || "") + '</span><br/>' +
                    '<span class="texto-tabla-secundario">Abono #' + (item.NumeroAbonoCuentaPorPagar || 0) + '</span>'
                ));
                fila.append($("<td>").text(formatearNumero(item.Monto)));
                fila.append($("<td>").html(comprobanteTexto));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function obtenerTextoComprobante(item) {
            var numero = item.NumeroComprobante || "";
            var archivo = item.NombreArchivoComprobante || "";

            if (numero === "" && archivo === "") {
                return '<span class="text-muted">Sin comprobante</span>';
            }

            var texto = "";

            if (numero !== "") {
                texto += '<span class="codigo-gasto">' + numero + '</span>';
            }

            if (archivo !== "") {
                texto += '<br/><span class="texto-tabla-secundario">' + archivo + '</span>';
            }

            return texto;
        }

        function abrirModalGasto(json) {
            limpiarErrores();
            limpiarFormularioGasto();

            $("#tituloModalGasto").text("Nuevo gasto");
            $("#txtFechaGasto").val(convertirDateAInput(new Date()));
            cargarAbonosCuentaPorPagar();

            if (json != null) {
                $("#tituloModalGasto").text("Editar gasto");

                $("#txtNumeroGastoInterno").val(json.NumeroGasto || "");
                $("#txtNumeroGasto").val(json.NumeroGasto || "");

                $("#txtFechaGasto").val(convertirFechaInput(json.FechaGasto));
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboTipoGasto").val(json.IdTipoGasto);
                $("#cboCuentaContable").val(json.CodigoCuenta || "");
                $("#txtMonto").val(formatearNumero(json.Monto));

                $("#txtIdentificacionProveedor").val(json.IdentificacionProveedor || "");
                $("#txtNumeroDocumento").val(json.NumeroDocumento || "");

                $("#txtIdentificacionProveedorAbono").val(json.IdentificacionProveedorAbono || "");
                $("#txtNumeroDocumentoAbono").val(json.NumeroDocumentoAbono || "");
                $("#txtNumeroAbonoCuentaPorPagar").val(json.NumeroAbonoCuentaPorPagar || 0);

                $("#txtNumeroComprobante").val(json.NumeroComprobante || "");
                $("#txtNombreArchivoComprobante").val(json.NombreArchivoComprobante || "");
                $("#txtRutaComprobante").val(json.RutaComprobante || "");
                $("#cboActivoGasto").val(json.Activo ? "true" : "false");

                $("#lblReferenciaSeleccionada").text(
                    "Proveedor: " + (json.IdentificacionProveedor || "") +
                    " - " + (json.ProveedorNombre || "") +
                    " | Documento: " + (json.NumeroDocumento || "") +
                    " | Abono #" + (json.NumeroAbonoCuentaPorPagar || 0)
                );
            }

            $("#FormModalGasto").modal("show");
        }

        function cargarAbonosCuentaPorPagar() {
            $.ajax({
                url: '@Url.Action("ListarAbonosCuentaPorPagarActivos", "GestionarGastos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaAbonosCxP = respuesta.data || [];
                    pintarAbonosCuentaPorPagar();
                },
                error: function () {
                    $("#mensajeErrorGasto").text("Error al cargar abonos de cuentas por pagar.").show();
                }
            });
        }

        function pintarAbonosCuentaPorPagar() {
            var tbody = $("#tablaAbonosCxP tbody");
            tbody.empty();

            if (listaAbonosCxP.length === 0) {
                tbody.append('<tr><td colspan="7" class="text-center text-muted">No hay abonos activos disponibles.</td></tr>');
                return;
            }

            $.each(listaAbonosCxP, function (i, item) {
                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarAbonoCuentaPorPagar(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text((item.IdentificacionProveedor || "") + " - " + (item.ProveedorNombre || "")));
                fila.append($("<td>", { class: "codigo-documento", text: item.NumeroDocumento || "" }));
                fila.append($("<td>").text(item.NumeroAbono || 0));
                fila.append($("<td>").text(formatearFecha(item.FechaAbono)));
                fila.append($("<td>").text(formatearNumero(item.MontoAbono)));
                fila.append($("<td>").text(item.EstadoCuenta || ""));
                fila.append($("<td>").append(boton));

                tbody.append(fila);
            });
        }

        function seleccionarAbonoCuentaPorPagar(item) {
            $("#txtIdentificacionProveedor").val(item.IdentificacionProveedor || "");
            $("#txtNumeroDocumento").val(item.NumeroDocumento || "");

            $("#txtIdentificacionProveedorAbono").val(item.IdentificacionProveedor || "");
            $("#txtNumeroDocumentoAbono").val(item.NumeroDocumento || "");
            $("#txtNumeroAbonoCuentaPorPagar").val(item.NumeroAbono || 0);

            $("#txtMonto").val(formatearNumero(item.MontoAbono));

            if ($("#txtDescripcion").val().trim() === "") {
                $("#txtDescripcion").val("Gasto por abono CxP documento " + (item.NumeroDocumento || "") + " abono #" + (item.NumeroAbono || 0));
            }

            $("#lblReferenciaSeleccionada").text(
                "Proveedor: " +
                (item.IdentificacionProveedor || "") +
                " - " +
                (item.ProveedorNombre || "") +
                " | Documento: " +
                (item.NumeroDocumento || "") +
                " | Abono #" +
                (item.NumeroAbono || 0)
            );
        }

        function guardarGasto() {
            $("#mensajeErrorGasto").hide().text("");
            $("#mensajeExitoGasto").hide().text("");

            var obj = {
                NumeroGasto: $("#txtNumeroGastoInterno").val().trim(),
                FechaGasto: $("#txtFechaGasto").val(),
                Descripcion: $("#txtDescripcion").val().trim(),
                IdTipoGasto: parseInt($("#cboTipoGasto").val()),
                CodigoCuenta: $("#cboCuentaContable").val(),
                Monto: parseFloat($("#txtMonto").val()),

                IdentificacionProveedor: $("#txtIdentificacionProveedor").val(),
                NumeroDocumento: $("#txtNumeroDocumento").val(),

                IdentificacionProveedorAbono: $("#txtIdentificacionProveedorAbono").val(),
                NumeroDocumentoAbono: $("#txtNumeroDocumentoAbono").val(),
                NumeroAbonoCuentaPorPagar: parseInt($("#txtNumeroAbonoCuentaPorPagar").val()),

                NumeroComprobante: $("#txtNumeroComprobante").val().trim(),
                NombreArchivoComprobante: $("#txtNombreArchivoComprobante").val().trim(),
                RutaComprobante: $("#txtRutaComprobante").val().trim(),

                Activo: $("#cboActivoGasto").val() === "true"
            };

            if (isNaN(obj.IdTipoGasto)) obj.IdTipoGasto = 0;
            if (isNaN(obj.Monto)) obj.Monto = 0;
            if (isNaN(obj.NumeroAbonoCuentaPorPagar)) obj.NumeroAbonoCuentaPorPagar = 0;

            if (obj.FechaGasto === "") {
                mostrarErrorGasto("Debe ingresar la fecha del gasto.", "txtFechaGasto");
                return;
            }

            if (obj.Descripcion === "") {
                mostrarErrorGasto("Debe ingresar una descripción.", "txtDescripcion");
                return;
            }

            if (obj.IdTipoGasto === 0) {
                mostrarErrorGasto("Debe seleccionar un tipo de gasto.", "cboTipoGasto");
                return;
            }

            if (obj.CodigoCuenta === "") {
                mostrarErrorGasto("Debe seleccionar una cuenta contable.", "cboCuentaContable");
                return;
            }

            if (obj.Monto <= 0) {
                mostrarErrorGasto("El monto del gasto debe ser mayor a cero.", "txtMonto");
                return;
            }

            var textoTipoGasto = $("#cboTipoGasto option:selected").text().trim().toUpperCase();
            var esGastoPorAbonoCxP = textoTipoGasto.includes("ABONO") || textoTipoGasto.includes("CUENTA POR PAGAR");

            if (esGastoPorAbonoCxP) {
                if (obj.IdentificacionProveedorAbono === "" || obj.NumeroDocumentoAbono === "" || obj.NumeroAbonoCuentaPorPagar <= 0) {
                    mostrarErrorGasto("Debe seleccionar un abono de cuenta por pagar.", "tablaAbonosCxP");
                    return;
                }
            } else {
                obj.IdentificacionProveedor = "";
                obj.NumeroDocumento = "";
                obj.IdentificacionProveedorAbono = "";
                obj.NumeroDocumentoAbono = "";
                obj.NumeroAbonoCuentaPorPagar = 0;
            }

            $.ajax({
                url: '@Url.Action("GuardarGasto", "GestionarGastos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        var numeroGasto = respuesta.numeroGasto || obj.NumeroGasto;

                        $("#txtNumeroGastoInterno").val(numeroGasto);
                        $("#txtNumeroGasto").val(numeroGasto);

                        $("#FormModalGasto").modal("hide");

                        cargarGastos();
                        cargarAbonosCuentaPorPagar();

                        mostrarMensajeSistema(respuesta.mensaje || "Gasto guardado correctamente.", "exito");

                    } else {
                        $("#mensajeErrorGasto").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorGasto").text("Error al guardar el gasto.").show();
                }
            });
        }

        function inactivarGasto(numeroGasto) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este gasto"),
                function () {
                    ejecutarInactivarGasto(numeroGasto);
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function ejecutarInactivarGasto(numeroGasto) {
            $.ajax({
                url: '@Url.Action("InactivarGasto", "GestionarGastos")',
                type: "POST",
                data: JSON.stringify({ numeroGasto: numeroGasto }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarGastos();
                        mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Gasto"), "exito");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el gasto.", "error");
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al procesar el gasto.", "error");
                }
            });
        }

        function limpiarFormularioGasto() {
            $("#txtNumeroGastoInterno").val("");
            $("#txtNumeroGasto").val("");

            $("#txtFechaGasto").val(convertirDateAInput(new Date()));
            $("#txtDescripcion").val("");
            $("#cboTipoGasto").val("0");
            $("#cboCuentaContable").val("");
            $("#txtMonto").val("");

            $("#txtIdentificacionProveedor").val("");
            $("#txtNumeroDocumento").val("");

            $("#txtIdentificacionProveedorAbono").val("");
            $("#txtNumeroDocumentoAbono").val("");
            $("#txtNumeroAbonoCuentaPorPagar").val("0");

            $("#txtNumeroComprobante").val("");
            $("#txtNombreArchivoComprobante").val("");
            $("#txtRutaComprobante").val("");

            $("#cboActivoGasto").val("true");

            $("#lblReferenciaSeleccionada").text("Ningún abono seleccionado.");
        }

        function mostrarErrorGasto(mensaje, idCampo) {
            $("#mensajeErrorGasto").text(mensaje).show();

            if (idCampo && $("#" + idCampo).length > 0) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function limpiarErrores() {
            $("#mensajeErrorGasto").hide().text("");
            $("#mensajeExitoGasto").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarCodigo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9A-Za-z.\-_]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoArchivo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&().]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarRuta(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,:#\-_/\\&().]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            return formatearFecha(valor);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }
    </script>
}