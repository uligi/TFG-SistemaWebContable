@{
    ViewBag.Title = "Gastos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestionar Gastos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Gastos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de gastos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo gasto
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaGastos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo gasto</th>
                        <th>Cuenta contable</th>
                        <th>Proveedor</th>
                        <th>Documento</th>
                        <th>Descripción</th>
                        <th>Monto</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo gasto</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdGasto" value="0" />
                <input type="hidden" id="txtIdCuentaPorPagar" />
                <input type="hidden" id="txtIdAbonoCuentaPorPagar" />

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="cboOrigen">Origen del gasto</label>
                        <select id="cboOrigen" class="form-control" onchange="cambiarOrigenGasto()">
                            <option value="Manual">Manual</option>
                            <option value="Cuenta por pagar">Cuenta por pagar</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaGasto">Fecha gasto</label>
                        <input type="date" id="txtFechaGasto" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoGasto">Tipo gasto</label>
                        <select id="cboTipoGasto" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMonto">Monto</label>
                        <input type="number" id="txtMonto" class="form-control" min="0" step="0.01" />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-12">
                        <label for="cboCuentaContable">Cuenta contable</label>
                        <select id="cboCuentaContable" class="form-control">
                            <option value="0">Seleccione una cuenta contable</option>
                        </select>
                        <small class="form-text text-muted">
                            Esta cuenta se utilizará para comparar el gasto real contra el presupuesto mensual.
                        </small>
                    </div>

                </div>

                <div id="seccionCuentaPorPagar" style="display:none;">
                    <hr />
                    <h6 class="font-weight-bold">Buscar cuenta por pagar pendiente</h6>

                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <input type="text" id="txtBuscarCuentaPorPagar" class="form-control" placeholder="Buscar por documento, proveedor o identificación..." />
                        </div>

                        <div class="form-group col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-block" onclick="buscarCuentasPorPagarPendientes()">
                                Buscar cuenta
                            </button>
                        </div>
                    </div>

                    <small class="form-text text-muted mb-2" id="lblCuentaSeleccionada">
                        Ninguna cuenta por pagar seleccionada.
                    </small>

                    <div class="table-responsive" id="contenedorCuentasPorPagar" style="display:none;">
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Documento</th>
                                    <th>Proveedor</th>
                                    <th>Vencimiento</th>
                                    <th>Concepto</th>
                                    <th>Saldo</th>
                                    <th style="width:100px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyCuentasPorPagar"></tbody>
                        </table>
                    </div>
                </div>

                <hr />

                <div class="form-row">

                    <div class="form-group col-md-8">
                        <label for="txtDescripcion">Descripción</label>
                        <input type="text" id="txtDescripcion" class="form-control" maxlength="150" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboActivo">Estado</label>
                        <select id="cboActivo" class="form-control">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                </div>

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarGasto()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var tablaGastos = null;
        var listaGastos = [];
        var listaCuentasPorPagar = [];

        $(document).ready(function () {
            cargarGastos();
            cargarTiposGasto();
            cargarCuentasContables();

            $("#txtBuscarCuentaPorPagar").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarCuentasPorPagarPendientes();
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
            });

            $("#txtMonto").on("input", function () {
                limpiarNoDecimal("txtMonto", "Solo se permiten números y punto decimal en el monto.");
            });

            $("#txtDescripcion").on("input", function () {
                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 150 caracteres.");
                } else {
                    ocultarAyudaCampo("txtDescripcion");
                }
            });

            $("#txtBuscarCuentaPorPagar").on("input", function () {
                limpiarTextoBusqueda("txtBuscarCuentaPorPagar", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });
        });

        function cargarGastos() {
            $.ajax({
                url: '@Url.Action("ListarGastos", "GestionarGastos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaGastos = respuesta.data || [];
                    pintarTablaGastos();
                },
                error: function () {
                    alert("Error al cargar los gastos.");
                }
            });
        }

        function cargarTiposGasto() {
            $.ajax({
                url: '@Url.Action("ListarTiposGastoActivos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoGasto").empty();
                    $("#cboTipoGasto").append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboTipoGasto").append(
                            $("<option>", {
                                value: item.IdTipoGasto,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar los tipos de gasto.");
                }
            });
        }

        function cargarCuentasContables() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContablesMovimiento", "GestionarGastos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCuentaContable").empty();
                    $("#cboCuentaContable").append('<option value="0">Seleccione una cuenta contable</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboCuentaContable").append(
                            $("<option>", {
                                value: item.IdCuentaContable,
                                text: (item.CodigoCuenta || "") + " - " + (item.NombreCuenta || "")
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar las cuentas contables.");
                }
            });
        }

        function pintarTablaGastos() {
            if (tablaGastos != null) {
                tablaGastos.clear().destroy();
                tablaGastos = null;
            }

            var tbody = $("#tablaGastos tbody");
            tbody.empty();

            $.each(listaGastos, function (i, item) {
                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var proveedor = item.ProveedorNombre
                    ? (item.IdentificacionProveedor || "") + " - " + (item.ProveedorNombre || "")
                    : "-";

                var documento = item.NumeroDocumento || "-";

                var cuenta = item.CodigoCuenta
                    ? item.CodigoCuenta + " - " + item.NombreCuenta
                    : "-";

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarGasto(item.IdGasto);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonInactivar);

                var fila = $("<tr>");
                fila.append($("<td>").text(formatearFecha(item.FechaGasto)));
                fila.append($("<td>").text(item.TipoGastoNombre || ""));
                fila.append($("<td>").text(cuenta));
                fila.append($("<td>").text(proveedor));
                fila.append($("<td>").text(documento));
                fila.append($("<td>").text(item.Descripcion || ""));
                fila.append($("<td>").text("₡" + parseFloat(item.Monto || 0).toFixed(2)));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaGastos = $("#tablaGastos").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtIdGasto").val(0);
            $("#txtIdCuentaPorPagar").val("");
            $("#txtIdAbonoCuentaPorPagar").val("");

            $("#cboOrigen").val("Manual");
            $("#txtFechaGasto").val(convertirDateAInput(new Date()));
            $("#cboTipoGasto").val(0);
            $("#cboCuentaContable").val(0);
            $("#txtMonto").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");

            $("#txtBuscarCuentaPorPagar").val("");
            $("#lblCuentaSeleccionada").text("Ninguna cuenta por pagar seleccionada.");
            $("#contenedorCuentasPorPagar").hide();
            $("#tbodyCuentasPorPagar").empty();

            $("#tituloModal").text("Nuevo gasto");

            habilitarCamposOrigen(true);
            cambiarOrigenGasto();

            if (json != null) {
                $("#txtIdGasto").val(json.IdGasto);
                $("#txtIdCuentaPorPagar").val(json.IdCuentaPorPagar || "");
                $("#txtIdAbonoCuentaPorPagar").val(json.IdAbonoCuentaPorPagar || "");

                if (json.IdCuentaPorPagar != null) {
                    $("#cboOrigen").val("Cuenta por pagar");
                    $("#lblCuentaSeleccionada").text(
                        "Cuenta seleccionada: " + (json.NumeroDocumento || "") +
                        " | Proveedor: " + (json.IdentificacionProveedor || "") + " - " + (json.ProveedorNombre || "")
                    );
                } else {
                    $("#cboOrigen").val("Manual");
                }

                $("#txtFechaGasto").val(convertirFechaInput(json.FechaGasto));
                $("#cboTipoGasto").val(json.IdTipoGasto);
                $("#cboCuentaContable").val(json.IdCuentaContable);
                $("#txtMonto").val(parseFloat(json.Monto || 0).toFixed(2));
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#tituloModal").text("Editar gasto");

                habilitarCamposOrigen(false);
                cambiarOrigenGasto();
            }

            $("#FormModal").modal("show");
        }

        function habilitarCamposOrigen(habilitar) {
            $("#cboOrigen").prop("disabled", !habilitar);
            $("#txtBuscarCuentaPorPagar").prop("disabled", !habilitar);
        }

        function cambiarOrigenGasto() {
            var origen = $("#cboOrigen").val();

            $("#seccionCuentaPorPagar").hide();

            if (origen === "Cuenta por pagar") {
                $("#seccionCuentaPorPagar").show();
            } else {
                $("#txtIdCuentaPorPagar").val("");
                $("#txtIdAbonoCuentaPorPagar").val("");
            }
        }

        function buscarCuentasPorPagarPendientes() {
            var filtro = $("#txtBuscarCuentaPorPagar").val().trim().toLowerCase();
            if (filtro.length < 2) {
                mostrarError("Digite al menos 2 caracteres para buscar la cuenta por pagar.", "txtBuscarCuentaPorPagar");
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarCuentasPorPagarPendientes", "GestionarGastos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCuentasPorPagar = (respuesta.data || []).filter(function (x) {
                        var texto = (
                            (x.NumeroDocumento || "") + " " +
                            (x.ProveedorNombre || "") + " " +
                            (x.IdentificacionProveedor || "") + " " +
                            (x.Concepto || "")
                        ).toLowerCase();

                        return texto.indexOf(filtro) !== -1;
                    });

                    pintarCuentasPorPagarPendientes();
                    $("#mensajeError").hide().text("");
                },
                error: function () {
                    $("#mensajeError").text("Error al buscar cuentas por pagar pendientes.").show();
                }
            });
        }

        function pintarCuentasPorPagarPendientes() {
            var tbody = $("#tbodyCuentasPorPagar");
            tbody.empty();

            if (listaCuentasPorPagar.length === 0) {
                tbody.append(
                    '<tr>' +
                        '<td colspan="6" class="text-center text-muted">' +
                            'No se encontraron cuentas por pagar pendientes.' +
                        '</td>' +
                    '</tr>'
                );

                $("#contenedorCuentasPorPagar").show();
                return;
            }

            $.each(listaCuentasPorPagar, function (i, item) {
                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarCuentaPorPagar(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroDocumento || ""));
                fila.append($("<td>").text((item.IdentificacionProveedor || "") + " - " + (item.ProveedorNombre || "")));
                fila.append($("<td>").text(formatearFecha(item.FechaVencimiento)));
                fila.append($("<td>").text(item.Concepto || ""));
                fila.append($("<td>").text("₡" + parseFloat(item.SaldoActual || 0).toFixed(2)));

                var acciones = $("<td>");
                acciones.append(boton);

                fila.append(acciones);
                tbody.append(fila);
            });

            $("#contenedorCuentasPorPagar").show();
        }

        function seleccionarCuentaPorPagar(item) {
            $("#txtIdCuentaPorPagar").val(item.IdCuentaPorPagar);
            $("#txtIdAbonoCuentaPorPagar").val("");

            $("#txtBuscarCuentaPorPagar").val(item.NumeroDocumento || "");

            $("#lblCuentaSeleccionada").text(
                "Cuenta seleccionada: " + (item.NumeroDocumento || "") +
                " | Proveedor: " + (item.IdentificacionProveedor || "") + " - " + (item.ProveedorNombre || "")
            );

            $("#txtFechaGasto").val(convertirDateAInput(new Date()));
            $("#txtMonto").val(parseFloat(item.SaldoActual || 0).toFixed(2));
            $("#txtDescripcion").val("Gasto asociado a cuenta por pagar " + (item.NumeroDocumento || ""));
            $("#cboOrigen").val("Cuenta por pagar");

            $("#contenedorCuentasPorPagar").hide();
        }

        function guardarGasto() {
    $("#mensajeError").hide().text("");

    var montoTexto = $("#txtMonto").val().trim();

    var idCuenta = $("#txtIdCuentaPorPagar").val() === "" ? null : parseInt($("#txtIdCuentaPorPagar").val());
    var idAbono = $("#txtIdAbonoCuentaPorPagar").val() === "" ? null : parseInt($("#txtIdAbonoCuentaPorPagar").val());

    var obj = {
        IdGasto: parseInt($("#txtIdGasto").val()),
        IdCuentaPorPagar: idCuenta,
        IdAbonoCuentaPorPagar: idAbono,
        IdCuentaContable: parseInt($("#cboCuentaContable").val()),
        FechaGasto: $("#txtFechaGasto").val(),
        Descripcion: $("#txtDescripcion").val().trim(),
        IdTipoGasto: parseInt($("#cboTipoGasto").val()),
        Monto: montoTexto === "" ? 0 : parseFloat(montoTexto),
        Activo: $("#cboActivo").val() === "true"
    };

    if (isNaN(obj.IdGasto)) {
        obj.IdGasto = 0;
    }

    if (obj.IdCuentaPorPagar != null && obj.IdAbonoCuentaPorPagar != null) {
        mostrarError("El gasto no puede estar asociado a una cuenta por pagar y a un abono al mismo tiempo.", "cboOrigen");
        return;
    }

    if (obj.FechaGasto === "") {
        mostrarError("Debe ingresar la fecha del gasto.", "txtFechaGasto");
        return;
    }

    var mensajeFecha = validarFechaNoFutura(obj.FechaGasto, "La fecha del gasto no puede ser futura.");
    if (mensajeFecha !== "") {
        mostrarError(mensajeFecha, "txtFechaGasto");
        return;
    }

    if (obj.IdTipoGasto === 0 || isNaN(obj.IdTipoGasto)) {
        mostrarError("Debe seleccionar un tipo de gasto.", "cboTipoGasto");
        return;
    }

    if (obj.IdCuentaContable === 0 || isNaN(obj.IdCuentaContable)) {
        mostrarError("Debe seleccionar una cuenta contable.", "cboCuentaContable");
        return;
    }

    if ($("#cboOrigen").val() === "Cuenta por pagar" && obj.IdCuentaPorPagar == null) {
        mostrarError("Debe seleccionar una cuenta por pagar pendiente.", "txtBuscarCuentaPorPagar");
        return;
    }

    if (obj.Descripcion === "") {
        mostrarError("Debe ingresar una descripción.", "txtDescripcion");
        return;
    }

    if (obj.Descripcion.length > 150) {
        mostrarError("La descripción no puede superar los 150 caracteres.", "txtDescripcion");
        return;
    }

    var mensajeMonto = validarDecimalMayorCero(montoTexto, "el monto del gasto");
    if (mensajeMonto !== "") {
        mostrarError(mensajeMonto, "txtMonto");
        return;
    }

    $.ajax({
        url: '@Url.Action("GuardarGasto", "GestionarGastos")',
        type: "POST",
        data: JSON.stringify({ obj: obj }),
        dataType: "json",
        contentType: "application/json; charset=utf-8",
        success: function (respuesta) {
            if (respuesta.resultado) {
                $("#FormModal").modal("hide");
                cargarGastos();
            } else {
                $("#mensajeError").text(respuesta.mensaje).show();
            }
        },
        error: function () {
            $("#mensajeError").text("Error al guardar el gasto.").show();
        }
    });
}

        function inactivarGasto(idGasto) {
            if (!confirm("¿Desea inactivar este gasto?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarGasto", "GestionarGastos")',
                type: "POST",
                data: JSON.stringify({ idGasto: idGasto }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarGastos();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el gasto.");
                }
            });
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }
        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarNoDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoBusqueda(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarDecimalMayorCero(texto, nombreCampo) {
            if (texto === "") {
                return "Debe ingresar " + nombreCampo + ".";
            }

            if (!/^[0-9]+(\.[0-9]+)?$/.test(texto)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            var numero = parseFloat(texto);

            if (isNaN(numero)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            if (numero <= 0) {
                return nombreCampo + " debe ser mayor a cero.";
            }

            return "";
        }

        function validarFechaNoFutura(fechaTexto, mensaje) {
            if (fechaTexto === "") {
                return "";
            }

            var fecha = new Date(fechaTexto + "T00:00:00");
            var hoy = new Date();

            if (isNaN(fecha.getTime())) {
                return "Debe ingresar una fecha válida.";
            }

            hoy.setHours(0, 0, 0, 0);

            if (fecha > hoy) {
                return mensaje;
            }

            return "";
        }
    </script>
}