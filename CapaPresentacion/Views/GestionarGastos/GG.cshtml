
@{
    ViewBag.Title = "Gestionar Gastos";
    Layout = "~/Views/Shared/_Layout.cshtml";


}

<h4 class="font-weight-bold py-3 mb-0">Gestionar Gastos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Operación</li>
        <li class="breadcrumb-item active">Gastos</li>
    </ol>
</div>

<div class="card mb-4">
    <h6 class="card-header">Registro de gasto</h6>

    <div class="card-body">

        <form>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Tipo de gasto</label>
                    <select class="custom-select" name="TipoGasto">
                        <option value="">Seleccione un tipo</option>
                        <option value="Fijo">Gasto fijo</option>
                        <option value="Variable">Gasto variable</option>
                        <option value="Operativo">Gasto operativo</option>
                        <option value="Administrativo">Gasto administrativo</option>
                        <option value="Otro">Otro gasto</option>
                    </select>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Categoría del gasto</label>
                    <select class="custom-select" name="CategoriaGasto">
                        <option value="">Seleccione una categoría</option>
                        <option value="ServiciosPublicos">Servicios públicos</option>
                        <option value="Compras">Compras</option>
                        <option value="Mercaderia">Mercadería</option>
                        <option value="Transporte">Transporte</option>
                        <option value="Mantenimiento">Mantenimiento</option>
                        <option value="Alquiler">Alquiler</option>
                        <option value="Salarios">Salarios</option>
                        <option value="Otros">Otros</option>
                    </select>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Fecha del gasto</label>
                    <input type="date"
                           class="form-control"
                           name="FechaGasto" />
                    <div class="clearfix"></div>
                </div>

            </div>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Monto</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="MontoGasto"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Método de pago</label>
                    <select class="custom-select" name="MetodoPago">
                        <option value="">Seleccione el método</option>
                        <option value="Efectivo">Efectivo</option>
                        <option value="Transferencia">Transferencia</option>
                        <option value="Tarjeta">Tarjeta</option>
                        <option value="CreditoProveedor">Crédito proveedor</option>
                    </select>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Número de comprobante</label>
                    <input type="text"
                           class="form-control"
                           name="NumeroComprobante"
                           placeholder="Ejemplo: COMP-0001" />
                    <div class="clearfix"></div>
                </div>

            </div>

            <div class="form-group">
                <label class="form-label">Descripción</label>
                <textarea class="form-control"
                          name="Descripcion"
                          rows="3"
                          placeholder="Ingrese la descripción del gasto"></textarea>
            </div>

            <div class="form-row">

                <div class="form-group col-md-6">
                    <label class="form-label">Comprobante asociado</label>
                    <input type="file"
                           class="form-control"
                           name="ComprobanteAsociado" />
                    <small class="form-text text-muted">
                        Adjunte el comprobante cuando aplique.
                    </small>
                </div>

                <div class="form-group col-md-6">
                    <label class="form-label">Cuenta contable asociada</label>
                    <select class="custom-select" name="IdCuentaContable">
                        <option value="">Seleccione una cuenta contable</option>
                        <option value="5.1.01">5.1.01 - Gastos operativos</option>
                        <option value="5.1.02">5.1.02 - Servicios públicos</option>
                        <option value="5.1.03">5.1.03 - Compras de mercadería</option>
                        <option value="5.1.04">5.1.04 - Transporte</option>
                        <option value="1.1.01">1.1.01 - Caja general</option>
                        <option value="1.1.02">1.1.02 - Bancos</option>
                    </select>
                </div>

            </div>

            <div class="form-group mt-4">
                <button type="button" class="btn btn-primary">
                    Guardar
                </button>

                <button type="button" class="btn btn-secondary">
                    Modificar
                </button>

                <button type="button" class="btn btn-danger">
                    Eliminar
                </button>

                <button type="reset" class="btn btn-outline-secondary">
                    Limpiar
                </button>
            </div>

        </form>

    </div>
</div>

<div class="card mb-4">
    <h6 class="card-header">Listado de gastos</h6>

    <div class="card-body">

        <div class="form-group">
            <label class="form-label">Buscar gasto</label>
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       placeholder="Buscar por tipo, categoría, descripción o fecha" />

                <span class="input-group-append">
                    <button class="btn btn-secondary" type="button">
                        Buscar
                    </button>
                </span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Categoría</th>
                        <th>Descripción</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th>Método de pago</th>
                        <th>Comprobante</th>
                        <th>Cuenta contable</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>Fijo</td>
                        <td>Servicios públicos</td>
                        <td>Pago de electricidad</td>
                        <td>2026-04-01</td>
                        <td>₡38,000.00</td>
                        <td>Efectivo</td>
                        <td>COMP-0001</td>
                        <td>5.1.02 - Servicios públicos</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>Variable</td>
                        <td>Mercadería</td>
                        <td>Compra de productos para venta</td>
                        <td>2026-04-05</td>
                        <td>₡220,000.00</td>
                        <td>Transferencia</td>
                        <td>COMP-0002</td>
                        <td>5.1.03 - Compras de mercadería</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>Operativo</td>
                        <td>Transporte</td>
                        <td>Pago de transporte de mercadería</td>
                        <td>2026-04-10</td>
                        <td>₡25,000.00</td>
                        <td>Efectivo</td>
                        <td>COMP-0003</td>
                        <td>5.1.04 - Transporte</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

