
@{
    ViewBag.Title = "Rol";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}



<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Roles</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Seguridad</li>
        <li class="breadcrumb-item active">Roles</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de roles</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo rol
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-4">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar rol...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaRoles">
                <thead>
                    <tr>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo rol</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdRol" value="0" />

                <div class="form-group">
                    <label for="txtNombre">Nombre del rol</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarRol()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaRoles = [];

        $(document).ready(function () {
            cargarRoles();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });
        });

        function cargarRoles() {
            $.ajax({
                url: '@Url.Action("ListarRoles", "Seguridad")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaRoles = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los roles.");
                }
            });
        }

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaRoles tbody");

            tbody.empty();

            $.each(listaRoles, function (i, item) {
                var texto = item.Nombre.toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var fila = `
                    <tr>
                        <td>${item.Nombre}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarRol(${item.IdRol})">
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtIdRol").val(0);
            $("#txtNombre").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo rol");

            if (json != null) {
                $("#txtIdRol").val(json.IdRol);
                $("#txtNombre").val(json.Nombre);
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar rol");
            }

            $("#FormModal").modal("show");
        }

        function guardarRol() {
            var obj = {
                IdRol: parseInt($("#txtIdRol").val()),
                Nombre: $("#txtNombre").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (obj.Nombre === "") {
                $("#mensajeError").text("Debe ingresar el nombre del rol.").show();
                return;
            }

            if (obj.Nombre.length > 45) {
                $("#mensajeError").text("El nombre no puede superar los 45 caracteres.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarRol", "Seguridad")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {

                    if (obj.IdRol === 0) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarRoles();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarRoles();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el rol.").show();
                }
            });
        }

        function inactivarRol(id) {
            if (!confirm("¿Desea inactivar este rol?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarRol", "Seguridad")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarRoles();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el rol.");
                }
            });
        }
    </script>
}

