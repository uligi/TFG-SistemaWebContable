@{
    ViewBag.Title = "Roles y permisos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<h4 class="font-weight-bold py-3 mb-0">Roles y permisos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Seguridad</li>
        <li class="breadcrumb-item active">Roles y permisos</li>
    </ol>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Seleccionar rol</h6>
    </div>

    <div class="card-body">
        <div class="alert alert-danger" id="mensajeError" style="display:none;"></div>
        <div class="alert alert-success" id="mensajeExito" style="display:none;"></div>

        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="cboRol">Rol</label>
                <select id="cboRol" class="form-control">
                    <option value="0">Seleccione un rol</option>
                </select>
            </div>

            <div class="form-group col-md-3 d-flex align-items-end">
                <button type="button" class="btn btn-primary btn-block" onclick="cargarPermisosRol()">
                    Cargar permisos
                </button>
            </div>
        </div>

        <small class="text-muted">
            Los permisos se asignan por rol. Todo empleado que tenga este rol recibirá los mismos permisos.
        </small>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Permisos del rol</h6>

        <div>
            <button type="button" class="btn btn-outline-primary btn-sm mr-2" onclick="marcarTodosLosPermisos()">
                Marcar todo
            </button>

            <button type="button" class="btn btn-outline-secondary btn-sm mr-2" onclick="limpiarTodosLosPermisos()">
                Limpiar todo
            </button>

            <button type="button" class="btn btn-success btn-sm" onclick="guardarTodosLosPermisos()">
                Guardar cambios
            </button>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaPermisos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Área</th>
                        <th>Módulo</th>
                        <th class="text-center">
                            Toda fila
                        </th>
                        <th class="text-center">
                            Ver<br />
                            <input type="checkbox" onchange="seleccionarColumnaPermiso('PuedeVer', this.checked)" />
                        </th>
                        <th class="text-center">
                            Crear<br />
                            <input type="checkbox" onchange="seleccionarColumnaPermiso('PuedeCrear', this.checked)" />
                        </th>
                        <th class="text-center">
                            Editar<br />
                            <input type="checkbox" onchange="seleccionarColumnaPermiso('PuedeEditar', this.checked)" />
                        </th>
                        <th class="text-center">
                            Eliminar<br />
                            <input type="checkbox" onchange="seleccionarColumnaPermiso('PuedeEliminar', this.checked)" />
                        </th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <small class="text-muted d-block mt-3">
            Puede marcar toda una fila, marcar una columna completa o usar “Marcar todo”. Si se desmarca “Ver”, automáticamente se desmarcan Crear, Editar y Eliminar.
        </small>
    </div>
</div>

@section scripts {
    <script>
    var tablaPermisos = null;
    var listaPermisosGlobal = [];

    $(document).ready(function () {
        cargarRoles();
    });

    function cargarRoles() {
        $.ajax({
            url: '@Url.Action("ListarRoles", "Seguridad")',
            type: "GET",
            dataType: "json",
            success: function (respuesta) {
                var lista = respuesta.data || [];
                var combo = $("#cboRol");

                combo.empty();
                combo.append('<option value="0">Seleccione un rol</option>');

                $.each(lista, function (i, item) {
                    if (item.Activo === true || item.Activo === 1) {
                        combo.append(
                            '<option value="' + item.IdRol + '">' + escaparHtml(item.Nombre) + '</option>'
                        );
                    }
                });
            },
            error: function () {
                mostrarError("Error al cargar los roles.");
            }
        });
    }

    function cargarPermisosRol() {
        var idRol = parseInt($("#cboRol").val() || 0);

        ocultarMensajes();

        if (idRol <= 0) {
            mostrarError("Debe seleccionar un rol.");
            return;
        }

        $.ajax({
            url: '@Url.Action("ListarPermisosPorRol", "Seguridad")',
            type: "GET",
            dataType: "json",
            data: {
                idRol: idRol
            },
            success: function (respuesta) {
                listaPermisosGlobal = respuesta.data || [];
                pintarTablaPermisos(listaPermisosGlobal);
            },
            error: function () {
                mostrarError("Error al cargar los permisos del rol.");
            }
        });
    }

        function pintarTablaPermisos(lista) {
            if (tablaPermisos != null) {
                tablaPermisos.clear().destroy();
                tablaPermisos = null;
            }

            var tbody = $("#tablaPermisos tbody");
            tbody.empty();

            $.each(lista, function (i, item) {
                var fila = $("<tr>");

                fila.append($("<td>").text(item.AreaSistema || ""));

                fila.append($("<td>").html(
                    '<strong>' + escaparHtml(item.NombreModulo || "") + '</strong>' +
                    '<br><small class="text-muted">' + escaparHtml(item.CodigoModulo || "") + '</small>'
                ));

                fila.append($("<td class='text-center'>").html(
                    crearCheckboxFila(i)
                ));

                fila.append($("<td class='text-center'>").html(
                    crearCheckboxPermiso(i, "PuedeVer", item.PuedeVer, "cambiarPermisoVer")
                ));

                fila.append($("<td class='text-center'>").html(
                    crearCheckboxPermiso(i, "PuedeCrear", item.PuedeCrear, "cambiarPermisoAccion")
                ));

                fila.append($("<td class='text-center'>").html(
                    crearCheckboxPermiso(i, "PuedeEditar", item.PuedeEditar, "cambiarPermisoAccion")
                ));

                fila.append($("<td class='text-center'>").html(
                    crearCheckboxPermiso(i, "PuedeEliminar", item.PuedeEliminar, "cambiarPermisoAccion")
                ));

                tbody.append(fila);
            });

            tablaPermisos = $("#tablaPermisos").DataTable({
                responsive: false,
                scrollX: true,
                autoWidth: false,
                pageLength: 25,
                destroy: true,
                order: [[0, "asc"], [1, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }



        function crearCheckboxFila(index) {
            var item = listaPermisosGlobal[index];

            var checked = item.PuedeVer === true &&
                item.PuedeCrear === true &&
                item.PuedeEditar === true &&
                item.PuedeEliminar === true
                ? "checked"
                : "";

            return '<input type="checkbox" ' +
                'class="chk-permiso chk-fila" ' +
                'data-index="' + index + '" ' +
                checked + ' ' +
                'onchange="seleccionarFilaPermiso(' + index + ', this.checked)" />';
        }

        function seleccionarFilaPermiso(index, valor) {
            listaPermisosGlobal[index].PuedeVer = valor;
            listaPermisosGlobal[index].PuedeCrear = valor;
            listaPermisosGlobal[index].PuedeEditar = valor;
            listaPermisosGlobal[index].PuedeEliminar = valor;

            pintarTablaPermisos(listaPermisosGlobal);
        }

        function seleccionarColumnaPermiso(campo, valor) {
            if (listaPermisosGlobal.length === 0) {
                return;
            }

            $.each(listaPermisosGlobal, function (i, item) {
                item[campo] = valor;

                if (campo !== "PuedeVer" && valor === true) {
                    item.PuedeVer = true;
                }

                if (campo === "PuedeVer" && valor === false) {
                    item.PuedeCrear = false;
                    item.PuedeEditar = false;
                    item.PuedeEliminar = false;
                }
            });

            pintarTablaPermisos(listaPermisosGlobal);
        }

        function marcarTodosLosPermisos() {
            if (listaPermisosGlobal.length === 0) {
                mostrarError("Debe cargar los permisos de un rol.");
                return;
            }

            $.each(listaPermisosGlobal, function (i, item) {
                item.PuedeVer = true;
                item.PuedeCrear = true;
                item.PuedeEditar = true;
                item.PuedeEliminar = true;
            });

            pintarTablaPermisos(listaPermisosGlobal);
            mostrarExito("Se marcaron todos los permisos. Presione Guardar cambios para aplicar.");
        }

        function limpiarTodosLosPermisos() {
            if (listaPermisosGlobal.length === 0) {
                mostrarError("Debe cargar los permisos de un rol.");
                return;
            }

            $.each(listaPermisosGlobal, function (i, item) {
                item.PuedeVer = false;
                item.PuedeCrear = false;
                item.PuedeEditar = false;
                item.PuedeEliminar = false;
            });

            pintarTablaPermisos(listaPermisosGlobal);
            mostrarExito("Se limpiaron todos los permisos. Presione Guardar cambios para aplicar.");
        }


    function crearCheckboxPermiso(index, campo, valor, funcionCambio) {
        var checked = valor === true || valor === 1 ? "checked" : "";

        return '<input type="checkbox" ' +
            'class="chk-permiso" ' +
            'data-index="' + index + '" ' +
            'data-campo="' + campo + '" ' +
            checked + ' ' +
            'onchange="' + funcionCambio + '(' + index + ', \'' + campo + '\', this.checked)" />';
    }

    function cambiarPermisoVer(index, campo, valor) {
        listaPermisosGlobal[index].PuedeVer = valor;

        if (!valor) {
            listaPermisosGlobal[index].PuedeCrear = false;
            listaPermisosGlobal[index].PuedeEditar = false;
            listaPermisosGlobal[index].PuedeEliminar = false;

            pintarTablaPermisos(listaPermisosGlobal);
        }
    }

    function cambiarPermisoAccion(index, campo, valor) {
        listaPermisosGlobal[index][campo] = valor;

        if (valor) {
            listaPermisosGlobal[index].PuedeVer = true;
            pintarTablaPermisos(listaPermisosGlobal);
        }
    }

    function guardarTodosLosPermisos() {
        var idRol = parseInt($("#cboRol").val() || 0);

        ocultarMensajes();

        if (idRol <= 0) {
            mostrarError("Debe seleccionar un rol.");
            return;
        }

        if (listaPermisosGlobal.length === 0) {
            mostrarError("No hay permisos para guardar.");
            return;
        }

        var total = listaPermisosGlobal.length;
        var guardados = 0;
        var errores = [];

        bloquearPantalla(true);

        guardarPermisoSecuencial(0, total, guardados, errores);
    }

    function guardarPermisoSecuencial(indice, total, guardados, errores) {
        if (indice >= total) {
            bloquearPantalla(false);

            if (errores.length > 0) {
                mostrarError("Algunos permisos no se guardaron: " + errores.join(" | "));
                return;
            }

            mostrarExito("Permisos guardados correctamente.");
            cargarPermisosRol();
            return;
        }

        var item = listaPermisosGlobal[indice];

        $.ajax({
            url: '@Url.Action("GuardarPermisoRolModulo", "Seguridad")',
            type: "POST",
            dataType: "json",
            data: {
                IdRol: item.IdRol,
                CodigoModulo: item.CodigoModulo,
                PuedeVer: item.PuedeVer,
                PuedeCrear: item.PuedeCrear,
                PuedeEditar: item.PuedeEditar,
                PuedeEliminar: item.PuedeEliminar
            },
            success: function (respuesta) {
                if (respuesta.resultado === true) {
                    guardados++;
                } else {
                    errores.push(item.CodigoModulo + ": " + (respuesta.mensaje || "No se pudo guardar."));
                }

                guardarPermisoSecuencial(indice + 1, total, guardados, errores);
            },
            error: function () {
                errores.push(item.CodigoModulo + ": error de comunicación.");
                guardarPermisoSecuencial(indice + 1, total, guardados, errores);
            }
        });
    }

    function bloquearPantalla(bloquear) {
        $("#cboRol").prop("disabled", bloquear);
        $("button").prop("disabled", bloquear);
        $(".chk-permiso").prop("disabled", bloquear);
    }

    function mostrarError(mensaje) {
        $("#mensajeExito").hide().text("");
        $("#mensajeError").text(mensaje).show();
    }

    function mostrarExito(mensaje) {
        $("#mensajeError").hide().text("");
        $("#mensajeExito").text(mensaje).show();
    }

    function ocultarMensajes() {
        $("#mensajeError").hide().text("");
        $("#mensajeExito").hide().text("");
    }

    function escaparHtml(valor) {
        valor = valor === null || valor === undefined ? "" : valor.toString();

        return valor
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }
    </script>
}