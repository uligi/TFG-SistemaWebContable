            <div class="category-label">Contabilidad</div>
            <h5>Tipos de cuenta contable</h5>
            <p>Clasificación de cuentas contables.</p>
            <a href="@Url.Action("TiposCuentaContable", "Catalogos")" class="btn btn-outline-primary btn-sm">
