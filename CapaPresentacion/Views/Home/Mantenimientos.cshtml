@{
    ViewBag.Title = "Mantenimientos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .home-wrapper {
        padding: 10px 0 30px 0;
    }

    .hero-panel {
        background: linear-gradient(135deg, #0f172a, #1d4ed8);
        color: white;
        border-radius: 22px;
        padding: 38px;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.25);
        margin-bottom: 28px;
        overflow: hidden;
        position: relative;
    }

        .hero-panel::after {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: rgba(255,255,255,0.08);
            right: -80px;
            top: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.25);
        padding: 7px 14px;
        border-radius: 999px;
        font-size: 14px;
        margin-bottom: 12px;
    }

    .hero-title {
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .hero-text {
        font-size: 16px;
        max-width: 760px;
        opacity: .95;
        margin-bottom: 0;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
        height: 100%;
    }

        .dashboard-card h5 {
            color: #0f172a;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .dashboard-card p {
            color: #64748b;
            margin: 0;
            font-size: 14px;
        }

    .game-panel {
        background: #ffffff;
        border-radius: 22px;
        padding: 26px;
        margin-top: 28px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.10);
    }

    .game-header {
        display: flex;
        justify-content: space-between;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .game-title {
        font-size: 24px;
        color: #0f172a;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .game-subtitle {
        color: #64748b;
        margin: 0;
        font-size: 14px;
    }

    .score-board {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .score-item {
        background: #eff6ff;
        color: #1d4ed8;
        border-radius: 14px;
        padding: 10px 14px;
        font-weight: 700;
        min-width: 115px;
        text-align: center;
    }

    .game-area {
        position: relative;
        height: 260px;
        background: linear-gradient(#f8fafc, #eef2ff);
        border: 2px solid #cbd5e1;
        border-radius: 18px;
        overflow: hidden;
        margin-top: 18px;
    }

    .game-ground {
        position: absolute;
        left: 0;
        bottom: 45px;
        width: 100%;
        height: 3px;
        background: #334155;
    }

    .player {
        position: absolute;
        left: 60px;
        bottom: 48px;
        width: 54px;
        height: 54px;
        border-radius: 14px;
        background: #1d4ed8;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        box-shadow: 0 8px 18px rgba(29, 78, 216, .35);
        user-select: none;
    }

    .obstacle {
        position: absolute;
        bottom: 48px;
        width: 42px;
        height: 52px;
        border-radius: 10px;
        background: #ef4444;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        box-shadow: 0 8px 16px rgba(239, 68, 68, .30);
        user-select: none;
    }

    .cloud {
        position: absolute;
        top: 35px;
        width: 90px;
        height: 32px;
        background: rgba(148, 163, 184, .22);
        border-radius: 999px;
    }

        .cloud::before,
        .cloud::after {
            content: "";
            position: absolute;
            background: rgba(148, 163, 184, .22);
            border-radius: 50%;
        }

        .cloud::before {
            width: 38px;
            height: 38px;
            top: -18px;
            left: 14px;
        }

        .cloud::after {
            width: 48px;
            height: 48px;
            top: -24px;
            right: 12px;
        }

    .game-message {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, .72);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 25px;
        z-index: 10;
    }

    .game-message-box {
        max-width: 520px;
    }

    .game-message h3 {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .game-message p {
        margin-bottom: 18px;
        color: #e2e8f0;
    }

    .game-controls {
        margin-top: 16px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    .instruction-box {
        color: #64748b;
        font-size: 14px;
    }

    .btn-game {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 700;
    }

    .module-links {
        margin-top: 28px;
    }

    .module-link-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 20px;
        height: 100%;
        transition: all .2s ease;
    }

        .module-link-card:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
            transform: translateY(-3px);
        }

        .module-link-card h5 {
            color: #0f172a;
            font-weight: 700;
        }

        .module-link-card p {
            color: #64748b;
            font-size: 14px;
            margin: 0;
        }

    @@media (max-width: 768px) {
        .hero-panel {
            padding: 28px;
        }

        .hero-title {
            font-size: 28px;
        }

        .game-area {
            height: 230px;
        }

        .player {
            left: 38px;
        }
    }
</style>

<main class="home-wrapper">

    <section class="hero-panel">
        <div class="hero-content">
            <span class="hero-badge">Sistema Web Contable</span>
            <h1 class="hero-title">Abastecedor Las Graditas</h1>
            <p class="hero-text">
                Plataforma para apoyar la gestión de facturación, cuentas contables,
                cuentas por cobrar, cuentas por pagar, ingresos, gastos y presupuesto mensual.
            </p>
        </div>
    </section>

    <section class="row g-4">
        <div class="col-md-4">
            <div class="dashboard-card">
                <h5>Gestión financiera</h5>
                <p>Centralización de movimientos para mejorar el control del negocio.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-card">
                <h5>Procesos contables</h5>
                <p>Registro ordenado de ingresos, egresos, cuentas y facturación.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-card">
                <h5>Soporte a decisiones</h5>
                <p>Consulta de información clara para los dueños y colaboradores autorizados.</p>
            </div>
        </div>
    </section>

    <section class="game-panel">
        <div class="game-header">
            <div>
                <h2 class="game-title">Reto de control contable</h2>
                <p class="game-subtitle">
                    Evite los errores administrativos y mantenga el control financiero del negocio.
                </p>
            </div>

            <div class="score-board">
                <div class="score-item">
                    Puntos: <span id="score">0</span>
                </div>
                <div class="score-item">
                    Mejor: <span id="bestScore">0</span>
                </div>
            </div>
        </div>

        <div id="gameArea" class="game-area">
            <div class="cloud" style="left: 70%;"></div>
            <div class="game-ground"></div>

            <div id="player" class="player">₡</div>

            <div id="gameMessage" class="game-message">
                <div class="game-message-box">
                    <h3>Reto contable</h3>
                    <p>
                        Salte los errores de registro, facturas vencidas y gastos sin clasificar.
                        Entre más tiempo mantenga el control, mayor será su puntaje.
                    </p>
                    <button type="button" class="btn btn-light btn-game" onclick="startGame()">
                        Iniciar reto
                    </button>
                </div>
            </div>
        </div>

        <div class="game-controls">
            <div class="instruction-box">
                Presione <strong>Espacio</strong>, <strong>Flecha Arriba</strong> o toque el área del juego para saltar.
            </div>

            <button type="button" class="btn btn-primary btn-game" onclick="startGame()">
                Reiniciar
            </button>
        </div>
    </section>

    <section class="module-links row g-4">
        <div class="col-md-3">
            <div class="module-link-card">
                <h5>Facturación</h5>
                <p>Registro de ventas y emisión de facturas.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="module-link-card">
                <h5>Cuentas por cobrar</h5>
                <p>Control de créditos, abonos y saldos pendientes.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="module-link-card">
                <h5>Cuentas por pagar</h5>
                <p>Seguimiento de obligaciones con proveedores.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="module-link-card">
                <h5>Presupuesto</h5>
                <p>Comparación entre montos reales y planificados.</p>
            </div>
        </div>
    </section>

</main>

<script>
    let gameArea;
    let player;
    let gameMessage;
    let scoreElement;
    let bestScoreElement;

    let isPlaying = false;
    let isJumping = false;
    let score = 0;
    let bestScore = 0;

    let playerBottom = 48;
    let velocity = 0;
    let gravity = 0.9;
    let jumpPower = 16;

    let obstacles = [];
    let obstacleSpeed = 6;
    let spawnTimer = 0;
    let spawnInterval = 95;

    let animationFrame;

    const obstacleIcons = ["📄", "⚠️", "💸", "🧾"];

    document.addEventListener("DOMContentLoaded", function () {
        gameArea = document.getElementById("gameArea");
        player = document.getElementById("player");
        gameMessage = document.getElementById("gameMessage");
        scoreElement = document.getElementById("score");
        bestScoreElement = document.getElementById("bestScore");

        bestScore = localStorage.getItem("bestScoreContable") || 0;
        bestScoreElement.textContent = bestScore;

        document.addEventListener("keydown", function (e) {
            if (e.code === "Space" || e.code === "ArrowUp") {
                e.preventDefault();

                if (!isPlaying) {
                    startGame();
                } else {
                    jump();
                }
            }
        });

        gameArea.addEventListener("click", function () {
            if (!isPlaying) {
                startGame();
            } else {
                jump();
            }
        });
    });

    function startGame() {
        cancelAnimationFrame(animationFrame);

        isPlaying = true;
        isJumping = false;
        score = 0;
        playerBottom = 48;
        velocity = 0;
        obstacleSpeed = 6;
        spawnTimer = 0;
        spawnInterval = 95;

        scoreElement.textContent = score;
        gameMessage.style.display = "none";

        clearObstacles();

        player.style.bottom = playerBottom + "px";

        gameLoop();
    }

    function gameLoop() {
        updatePlayer();
        updateObstacles();
        updateScore();
        checkCollision();

        if (isPlaying) {
            animationFrame = requestAnimationFrame(gameLoop);
        }
    }

    function updatePlayer() {
        if (isJumping) {
            playerBottom += velocity;
            velocity -= gravity;

            if (playerBottom <= 48) {
                playerBottom = 48;
                isJumping = false;
                velocity = 0;
            }

            player.style.bottom = playerBottom + "px";
        }
    }

    function jump() {
        if (!isJumping) {
            isJumping = true;
            velocity = jumpPower;
        }
    }

    function updateObstacles() {
        spawnTimer++;

        if (spawnTimer >= spawnInterval) {
            createObstacle();
            spawnTimer = 0;

            if (spawnInterval > 55) {
                spawnInterval -= 2;
            }
        }

        for (let i = obstacles.length - 1; i >= 0; i--) {
            let obstacle = obstacles[i];
            obstacle.x -= obstacleSpeed;
            obstacle.element.style.left = obstacle.x + "px";

            if (obstacle.x < -60) {
                obstacle.element.remove();
                obstacles.splice(i, 1);
            }
        }

        if (score > 0 && score % 300 === 0) {
            obstacleSpeed += 0.01;
        }
    }

    function createObstacle() {
        const obstacle = document.createElement("div");
        obstacle.className = "obstacle";

        const randomIcon = obstacleIcons[Math.floor(Math.random() * obstacleIcons.length)];
        obstacle.textContent = randomIcon;

        const startX = gameArea.offsetWidth + 30;

        obstacle.style.left = startX + "px";
        gameArea.appendChild(obstacle);

        obstacles.push({
            element: obstacle,
            x: startX
        });
    }

    function updateScore() {
        score++;
        scoreElement.textContent = score;
    }

    function checkCollision() {
        const playerRect = player.getBoundingClientRect();

        for (let i = 0; i < obstacles.length; i++) {
            const obstacleRect = obstacles[i].element.getBoundingClientRect();

            const collision =
                playerRect.left < obstacleRect.right &&
                playerRect.right > obstacleRect.left &&
                playerRect.top < obstacleRect.bottom &&
                playerRect.bottom > obstacleRect.top;

            if (collision) {
                endGame();
                return;
            }
        }
    }

    function endGame() {
        isPlaying = false;
        cancelAnimationFrame(animationFrame);

        if (score > bestScore) {
            bestScore = score;
            localStorage.setItem("bestScoreContable", bestScore);
            bestScoreElement.textContent = bestScore;
        }

        gameMessage.innerHTML = `
            <div class="game-message-box">
                <h3>Control interrumpido</h3>
                <p>
                    Se detectó un error administrativo. Puntaje obtenido: <strong>${score}</strong>.
                    Reinicie el reto para continuar practicando.
                </p>
                <button type="button" class="btn btn-light btn-game" onclick="startGame()">
                    Intentar nuevamente
                </button>
            </div>
        `;

        gameMessage.style.display = "flex";
    }

    function clearObstacles() {
        obstacles.forEach(function (obstacle) {
            obstacle.element.remove();
        });

        obstacles = [];
    }
</script>