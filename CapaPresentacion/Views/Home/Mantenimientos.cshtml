            <p>Catálogo para clasificar ingresos.</p>
            <a href="@Url.Action("TiposIngreso", "Catalogos")" class="btn btn-outline-primary btn-sm">
                Abrir
            </a>
        </div>
    </div>

    <div class="col-md-3">
        <div class="maintenance-card">
            <div class="category-label">Contabilidad</div>
            <h5>Tipos de gasto</h5>
            <p>Catálogo para clasificar egresos.</p>
            <a href="@Url.Action("TiposGasto", "Catalogos")" class="btn btn-outline-primary btn-sm">
