    <div class="col-md-3">
        <div class="maintenance-card">
            <div class="category-label">Administración</div>
            <h5>Puestos</h5>
            <p>Catálogo de cargos o funciones del personal.</p>
            <a href="@Url.Action("Puestos", "Catalogos")" class="btn btn-outline-primary btn-sm">
