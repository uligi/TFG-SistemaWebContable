            align-items: center;
            gap: 12px;
            color: #fff;
            text-decoration: none;
        }

            .brand-box:hover {
                color: #fff;
                text-decoration: none;
            }

        .brand-logo {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: rgba(255,255,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: #fff;
            font-size: 18px;
        }

        .brand-text-main {
            display: block;
            font-weight: 700;
            font-size: 15px;
            line-height: 1.1;
        }

        .brand-text-sub {
            display: block;
            font-size: 12px;
            color: rgba(255,255,255,0.62);
            margin-top: 3px;
        }

        .sidenav-header {
            color: rgba(255,255,255,0.48) !important;
            padding-top: 14px;
            padding-bottom: 8px;
            letter-spacing: .06em;
        }

        .sidenav-divider {
            border-color: rgba(255,255,255,0.08) !important;
        }

        .layout-navbar {
            min-height: 66px;
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 5px 18px rgba(15, 23, 42, 0.04);
        }

        .navbar-page-title {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

            .navbar-page-title strong {
                color: #0f172a;
                font-size: 16px;
            }

            .navbar-page-title span {
                color: #64748b;
                font-size: 12px;
                margin-top: 2px;
            }

        .user-box {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 12px;
            border-radius: 999px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #1d4ed8;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
        }

        .user-info {
            line-height: 1.1;
        }

            .user-info strong {
                display: block;
                color: #0f172a;
                font-size: 13px;
            }

            .user-info span {
                display: block;
                color: #64748b;
                font-size: 11px;
                margin-top: 2px;
            }

        .logout-link {
            color: #dc2626 !important;
            font-weight: 600;
            border-radius: 10px;
            padding: 8px 12px !important;
        }

            .logout-link:hover {
                background: #fee2e2;
                color: #991b1b !important;
            }

        .back-system-link {
            color: #93c5fd !important;
        }

            .back-system-link:hover {
                color: #ffffff !important;
            }

        .content-shell {
            animation: fadeInContent .22s ease-in-out;
        }

        @@keyframes fadeInContent {
            from {
                opacity: 0;
                transform: translateY(4px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 768px) {
            .user-info {
                display: none;
            }

            .navbar-page-title span {
                display: none;
            }
        }
        /* ==============================
        SCROLL EN MENÚ LATERAL
        ============================== */

        #layout-sidenav {
            height: 100vh !important;
            overflow: hidden !important;
        }

            #layout-sidenav .sidenav-inner {
                height: calc(100vh - 74px) !important;
                overflow-y: auto !important;
                overflow-x: hidden !important;
                padding-bottom: 30px !important;
            }

                /* Scrollbar visible y con buen contraste */
                #layout-sidenav .sidenav-inner::-webkit-scrollbar {
                    width: 8px;
                }

                #layout-sidenav .sidenav-inner::-webkit-scrollbar-track {
                    background: #020617;
                }

                #layout-sidenav .sidenav-inner::-webkit-scrollbar-thumb {
                    background: #475569;
                    border-radius: 10px;
                }

                    #layout-sidenav .sidenav-inner::-webkit-scrollbar-thumb:hover {
                        background: #64748b;
                    }

        /* ==============================
        MENSAJES GLOBALES DEL SISTEMA
        ============================== */

        .mensaje-flotante-sistema {
            position: fixed;
            top: 82px;
            right: 24px;
            z-index: 99999;
            min-width: 280px;
            max-width: 420px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
        }
    </style>
</head>

<body>
    @{
        var controller = (ViewContext.RouteData.Values["controller"] ?? "").ToString();
        var action = (ViewContext.RouteData.Values["action"] ?? "").ToString();

        UsuarioSesion usuarioSesion = Session["UsuarioSesion"] as UsuarioSesion;

        Func<string, string, string> activo = (ctrl, act) =>
            controller.Equals(ctrl, StringComparison.OrdinalIgnoreCase)
            && (string.IsNullOrEmpty(act) || action.Equals(act, StringComparison.OrdinalIgnoreCase))
                ? "active"
                : "";

        Func<string[], string> abierto = (controles) =>
            controles.Any(c => controller.Equals(c, StringComparison.OrdinalIgnoreCase))
                ? "open active"
                : "";

        Func<string, bool> puedeVer = (codigoModulo) =>
            usuarioSesion != null
            && usuarioSesion.Permisos != null
            && usuarioSesion.Permisos.Any(p =>
                p.CodigoModulo == codigoModulo
                && p.Activo
                && p.PuedeVer
            );

        Func<string[], bool> puedeVerAlguno = (codigos) =>
            usuarioSesion != null
            && usuarioSesion.Permisos != null
            && usuarioSesion.Permisos.Any(p =>
                codigos.Contains(p.CodigoModulo)
                && p.Activo
                && p.PuedeVer
            );

        string nombreUsuario = "Usuario";
        string nombreRol = "Sin rol";

        if (usuarioSesion != null)
        {
            nombreUsuario = usuarioSesion.NombreUsuario;
            nombreRol = usuarioSesion.NombreRol;
        }
        else if (Session["NombreUsuario"] != null)
        {
            nombreUsuario = Session["NombreUsuario"].ToString();
        }
        else if (User != null && User.Identity != null && User.Identity.IsAuthenticated)
        {
            nombreUsuario = User.Identity.Name;
        }

        bool esAdministradorSistema = !string.IsNullOrWhiteSpace(nombreRol)
         && nombreRol.ToLower().Contains("administrador");

        string inicialUsuario = !string.IsNullOrWhiteSpace(nombreUsuario)
        ? nombreUsuario.Substring(0, 1).ToUpper()
        : "U";
    }

    <div class="page-loader">
        <div class="bg-primary"></div>
    </div>

    <div class="layout-wrapper layout-2">
        <div class="layout-inner">

            <div id="layout-sidenav" class="layout-sidenav sidenav sidenav-vertical bg-dark">

                <div class="app-brand">
                    <a href="@Url.Action("Index", "Home")" class="brand-box">
                        <div class="brand-logo">₡</div>
                        <div>
                            <span class="brand-text-main">Mantenimientos</span>
                            <span class="brand-text-sub">Sistema Contable</span>
                        </div>
                    </a>
                </div>

                <div class="sidenav-divider mt-0"></div>

                <ul class="sidenav-inner py-1">

                    @if (puedeVerAlguno(new[] { "CATALOGOS", "PRODUCTOS", "CLIENTES", "EMPLEADOS", "PROVEEDORES", "UBICACIONES", "ROLES", "CONFIG_CUENTA_CONTABLE", "PERIODO_CONTABLE" }))
                    {
                        <li class="sidenav-header small font-weight-semibold">
                            General
                        </li>

                        <li class="sidenav-item @activo("Home", "Mantenimientos")">
                            <a href="@Url.Action("Mantenimientos", "Home")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-grid"></i>
                                <div>Panel principal</div>
                            </a>
                        </li>

                        <li class="sidenav-item">
                            <a href="@Url.Action("Index", "Home")" class="sidenav-link back-system-link">
                                <i class="sidenav-icon feather icon-arrow-left"></i>
                                <div>Volver al sistema</div>
                            </a>
