@using System
@using System.Linq
@using CapaEntidad.Seguridad

<!DOCTYPE html>
<html lang="es" class="material-style layout-fixed">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - Mantenimientos</title>

    @Styles.Render("~/Content/css")
    @Styles.Render("~/Content/datatables")
    @RenderSection("estilos", required: false)
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body {
            background: #f3f6fb;
        }

        .layout-content {
            background: #f3f6fb;
        }
        /* ==============================
                MENÚ LATERAL - ALTO CONTRASTE
                ============================== */

        #layout-sidenav {
            background: #07111f !important;
            color: #ffffff !important;
            border-right: 1px solid #1e293b;
        }

            #layout-sidenav .app-brand {
                background: #020617 !important;
                border-bottom: 1px solid #1e293b;
            }

            #layout-sidenav .brand-logo {
                background: #2563eb !important;
                color: #ffffff !important;
                box-shadow: 0 0 0 3px rgba(37, 99, 235, .25);
            }

            #layout-sidenav .brand-text-main {
                color: #ffffff !important;
                font-size: 15px;
                font-weight: 800;
            }

            #layout-sidenav .brand-text-sub {
                color: #cbd5e1 !important;
                font-size: 12px;
            }

            #layout-sidenav .sidenav-header {
                color: #93c5fd !important;
                font-size: 11px;
                font-weight: 800 !important;
                text-transform: uppercase;
                letter-spacing: .09em;
                padding: 18px 20px 8px 20px;
            }

            #layout-sidenav .sidenav-divider {
                border-color: #1e293b !important;
                margin: 8px 18px !important;
            }

            #layout-sidenav .sidenav-link {
                color: #e5e7eb !important;
                font-weight: 600;
                margin: 2px 10px;
                border-radius: 10px;
            }

                #layout-sidenav .sidenav-link div {
                    color: #e5e7eb !important;
                }

            #layout-sidenav .sidenav-icon {
                color: #bfdbfe !important;
                opacity: 1 !important;
            }

            #layout-sidenav .sidenav-link:hover {
                background: #1d4ed8 !important;
                color: #ffffff !important;
            }

                #layout-sidenav .sidenav-link:hover div,
                #layout-sidenav .sidenav-link:hover .sidenav-icon {
                    color: #ffffff !important;
                }

            #layout-sidenav .sidenav-item.active > .sidenav-link,
            #layout-sidenav .sidenav-item.open > .sidenav-link {
                background: #2563eb !important;
                color: #ffffff !important;
                box-shadow: inset 4px 0 0 #facc15;
            }

                #layout-sidenav .sidenav-item.active > .sidenav-link div,
                #layout-sidenav .sidenav-item.open > .sidenav-link div,
                #layout-sidenav .sidenav-item.active > .sidenav-link .sidenav-icon,
                #layout-sidenav .sidenav-item.open > .sidenav-link .sidenav-icon {
                    color: #ffffff !important;
                }

            #layout-sidenav .sidenav-menu {
                background: #0f172a !important;
                margin: 4px 10px 8px 10px;
                border-radius: 10px;
                padding: 6px 0;
                border: 1px solid #1e293b;
            }

                #layout-sidenav .sidenav-menu .sidenav-link {
                    color: #dbeafe !important;
                    font-size: 13px;
                    margin: 2px 6px;
                    padding-left: 18px !important;
                }

                    #layout-sidenav .sidenav-menu .sidenav-link:hover {
                        background: #334155 !important;
                        color: #ffffff !important;
                    }

                #layout-sidenav .sidenav-menu .sidenav-item.active > .sidenav-link {
                    background: #1d4ed8 !important;
                    color: #ffffff !important;
                    box-shadow: inset 4px 0 0 #facc15;
                }

        .menu-section-label {
            display: block;
            padding: 3px 18px 6px 18px;
            color: #94a3b8;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .container-p-y {
            padding-top: 1.5rem !important;
            padding-bottom: 1.5rem !important;
        }

        .app-brand {
            height: 72px;
            display: flex;
            align-items: center;
            padding: 0 22px;
            background: rgba(255,255,255,0.04);
        }

        .brand-box {
