                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">
                            Administración
                        </li>
                    }

                    @if (puedeVerAlguno(new[] { "ROLES", "CATALOGOS" }))
                    {
                        <li class="sidenav-item @abierto(new[] { "Seguridad", "Catalogos" })">
                            <a href="javascript:void(0)" class="sidenav-link sidenav-toggle">
                                <i class="sidenav-icon feather icon-shield"></i>
                                <div>Seguridad y personal</div>
                            </a>

                            <ul class="sidenav-menu">

                                @if (puedeVer("ROLES"))
                                {
                                    <li class="sidenav-item @activo("Seguridad", "Rol")">
                                        <a href="@Url.Action("Rol", "Seguridad")" class="sidenav-link">
                                            <div>Roles</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("ROLES"))
                                {
                                    <li class="sidenav-item @activo("Seguridad", "RolPermiso")">
                                        <a href="@Url.Action("RolPermiso", "Seguridad")" class="sidenav-link">
                                            <div>Roles y Permisos</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("CATALOGOS"))
                                {
                                    <li class="sidenav-item @activo("Catalogos", "Puestos")">
                                        <a href="@Url.Action("Puestos", "Catalogos")" class="sidenav-link">
                                            <div>Puestos</div>
                                        </a>
                                    </li>

                                    <li class="sidenav-item @activo("Catalogos", "TipoDeObservacion")">
                                        <a href="@Url.Action("TipoDeObservacion", "Catalogos")" class="sidenav-link">
                                            <div>Tipos de observación</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("HISTORIAL_CAMBIOS"))
                                {
                                    <li class="sidenav-item @activo("Seguridad", "HistorialCambios")">
                                        <a href="@Url.Action("HistorialCambios", "Seguridad")" class="sidenav-link">
                                            <div>Historial de cambios</div>
                                        </a>
                                    </li>
                                }

                            </ul>
                        </li>
                    }

                </ul>
            </div>

            <!-- CONTENIDO PRINCIPAL -->
            <div class="layout-container">

                <!-- NAVBAR SUPERIOR -->
                <nav class="layout-navbar navbar navbar-expand-lg align-items-lg-center bg-white container-p-x">

                    <a href="javascript:void(0)" class="layout-sidenav-toggle sidenav-link text-large mr-3">
                        <i class="ion ion-md-menu align-middle"></i>
                    </a>

                    <div class="navbar-nav align-items-lg-center mr-auto">
                        <div class="nav-item navbar-text navbar-page-title">
                            <strong>@ViewBag.Title</strong>
                            <span>Mantenimientos - Sistema Web Contable</span>
                        </div>
                    </div>

                    <div class="navbar-collapse collapse" id="layout-navbar-collapse">
                        <div class="navbar-nav align-items-lg-center ml-auto">

                            <div class="nav-item user-box">
                                <div class="user-avatar">
                                    @inicialUsuario
                                </div>

                                <div class="user-info">
                                    <strong>@nombreUsuario</strong>
                                    <span>@nombreRol</span>
                                </div>
                            </div>

                            <div class="nav-item ml-3">
                                <a class="nav-link logout-link" href="@Url.Action("CerrarSesion", "Acceso")">
                                    <i class="feather icon-log-out mr-1"></i>
                                    Cerrar sesión
                                </a>
                            </div>

                        </div>
                    </div>

                </nav>

                <!-- BODY -->
                <div class="layout-content">
                    <div class="container-fluid flex-grow-1 container-p-y">
                        <div class="content-shell">
                            @RenderBody()
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>

    <div class="modal fade" id="modalConfirmacionSistema" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">

                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="tituloConfirmacionSistema">Confirmar acción</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <p id="textoConfirmacionSistema" class="mb-0"></p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="button" class="btn btn-danger" id="btnAceptarConfirmacionSistema">
                        Aceptar
                    </button>
                </div>

            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/datatables")
    @Scripts.Render("~/bundles/morris")

    <script>
    window.esAdministradorSistema = @esAdministradorSistema.ToString().ToLower();
    </script>

    <script src="~/Scripts/js/sistema-global.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>

