@using System
@using System.Linq
@using CapaEntidad.Seguridad

<!DOCTYPE html>
<html lang="es" class="material-style layout-fixed">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - Sistema Web Contable</title>

    @Styles.Render("~/Content/css")
    @Styles.Render("~/Content/datatables")
    @RenderSection("estilos", required: false)
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body {
            background: #f3f6fb;
        }

        .layout-content {
            background: #f3f6fb;
        }
        /* ==============================
                MENÚ LATERAL - ALTO CONTRASTE
                ============================== */

        #layout-sidenav {
            background: #07111f !important;
            color: #ffffff !important;
            border-right: 1px solid #1e293b;
        }

            #layout-sidenav .app-brand {
                background: #020617 !important;
                border-bottom: 1px solid #1e293b;
            }

            #layout-sidenav .brand-logo {
                background: #2563eb !important;
                color: #ffffff !important;
                box-shadow: 0 0 0 3px rgba(37, 99, 235, .25);
            }

            #layout-sidenav .brand-text-main {
                color: #ffffff !important;
                font-size: 15px;
                font-weight: 800;
            }

            #layout-sidenav .brand-text-sub {
                color: #cbd5e1 !important;
                font-size: 12px;
            }

            #layout-sidenav .sidenav-header {
                color: #93c5fd !important;
                font-size: 11px;
                font-weight: 800 !important;
                text-transform: uppercase;
                letter-spacing: .09em;
                padding: 18px 20px 8px 20px;
            }

            #layout-sidenav .sidenav-divider {
                border-color: #1e293b !important;
                margin: 8px 18px !important;
            }

            #layout-sidenav .sidenav-link {
                color: #e5e7eb !important;
                font-weight: 600;
                margin: 2px 10px;
                border-radius: 10px;
            }

                #layout-sidenav .sidenav-link div {
                    color: #e5e7eb !important;
                }

            #layout-sidenav .sidenav-icon {
                color: #bfdbfe !important;
                opacity: 1 !important;
            }

            #layout-sidenav .sidenav-link:hover {
                background: #1d4ed8 !important;
                color: #ffffff !important;
            }

                #layout-sidenav .sidenav-link:hover div,
                #layout-sidenav .sidenav-link:hover .sidenav-icon {
                    color: #ffffff !important;
                }

            #layout-sidenav .sidenav-item.active > .sidenav-link,
            #layout-sidenav .sidenav-item.open > .sidenav-link {
                background: #2563eb !important;
                color: #ffffff !important;
                box-shadow: inset 4px 0 0 #facc15;
            }

                #layout-sidenav .sidenav-item.active > .sidenav-link div,
                #layout-sidenav .sidenav-item.open > .sidenav-link div,
                #layout-sidenav .sidenav-item.active > .sidenav-link .sidenav-icon,
                #layout-sidenav .sidenav-item.open > .sidenav-link .sidenav-icon {
                    color: #ffffff !important;
                }

            #layout-sidenav .sidenav-menu {
                background: #0f172a !important;
                margin: 4px 10px 8px 10px;
                border-radius: 10px;
                padding: 6px 0;
                border: 1px solid #1e293b;
            }

                #layout-sidenav .sidenav-menu .sidenav-link {
                    color: #dbeafe !important;
                    font-size: 13px;
                    margin: 2px 6px;
                    padding-left: 18px !important;
                }

                    #layout-sidenav .sidenav-menu .sidenav-link:hover {
                        background: #334155 !important;
                        color: #ffffff !important;
                    }

                #layout-sidenav .sidenav-menu .sidenav-item.active > .sidenav-link {
                    background: #1d4ed8 !important;
                    color: #ffffff !important;
                    box-shadow: inset 4px 0 0 #facc15;
                }

        .menu-section-label {
            display: block;
            padding: 3px 18px 6px 18px;
            color: #94a3b8;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .container-p-y {
            padding-top: 1.5rem !important;
            padding-bottom: 1.5rem !important;
        }

        .app-brand {
            height: 72px;
            display: flex;
            align-items: center;
            padding: 0 22px;
            background: rgba(255,255,255,0.04);
        }

        .brand-box {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #fff;
            text-decoration: none;
        }

            .brand-box:hover {
                color: #fff;
                text-decoration: none;
            }

        .brand-logo {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: rgba(255,255,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: #fff;
            font-size: 18px;
        }

        .brand-text-main {
            display: block;
            font-weight: 700;
            font-size: 15px;
            line-height: 1.1;
        }

        .brand-text-sub {
            display: block;
            font-size: 12px;
            color: rgba(255,255,255,0.62);
            margin-top: 3px;
        }

        .sidenav-header {
            color: rgba(255,255,255,0.48) !important;
            padding-top: 14px;
            padding-bottom: 8px;
            letter-spacing: .06em;
        }

        .sidenav-divider {
            border-color: rgba(255,255,255,0.08) !important;
        }

        .layout-navbar {
            min-height: 66px;
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 5px 18px rgba(15, 23, 42, 0.04);
        }

        .navbar-page-title {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

            .navbar-page-title strong {
                color: #0f172a;
                font-size: 16px;
            }

            .navbar-page-title span {
                color: #64748b;
                font-size: 12px;
                margin-top: 2px;
            }

        .user-box {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 12px;
            border-radius: 999px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #1d4ed8;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
        }

        .user-info {
            line-height: 1.1;
        }

            .user-info strong {
                display: block;
                color: #0f172a;
                font-size: 13px;
            }

            .user-info span {
                display: block;
                color: #64748b;
                font-size: 11px;
                margin-top: 2px;
            }

        .logout-link {
            color: #dc2626 !important;
            font-weight: 600;
            border-radius: 10px;
            padding: 8px 12px !important;
        }

            .logout-link:hover {
                background: #fee2e2;
                color: #991b1b !important;
            }

        .content-shell {
            animation: fadeInContent .22s ease-in-out;
        }

        @@keyframes fadeInContent {
            from {
                opacity: 0;
                transform: translateY(4px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 768px) {
            .user-info {
                display: none;
            }

            .navbar-page-title span {
                display: none;
            }
        }
        /* ==============================
        SCROLL EN MENÚ LATERAL
        ============================== */

        #layout-sidenav {
            height: 100vh !important;
            overflow: hidden !important;
        }

            #layout-sidenav .sidenav-inner {
                height: calc(100vh - 74px) !important;
                overflow-y: auto !important;
                overflow-x: hidden !important;
                padding-bottom: 30px !important;
            }

                /* Scrollbar visible y con buen contraste */
                #layout-sidenav .sidenav-inner::-webkit-scrollbar {
                    width: 8px;
                }

                #layout-sidenav .sidenav-inner::-webkit-scrollbar-track {
                    background: #020617;
                }

                #layout-sidenav .sidenav-inner::-webkit-scrollbar-thumb {
                    background: #475569;
                    border-radius: 10px;
                }

                    #layout-sidenav .sidenav-inner::-webkit-scrollbar-thumb:hover {
                        background: #64748b;
                    }

        /* ==============================
   MENSAJES GLOBALES DEL SISTEMA
   ============================== */

        .mensaje-flotante-sistema {
            position: fixed;
            top: 82px;
            right: 24px;
            z-index: 99999;
            min-width: 280px;
            max-width: 420px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
        }
    </style>
</head>

<body>
    @{
        var controller = (ViewContext.RouteData.Values["controller"] ?? "").ToString();
        var action = (ViewContext.RouteData.Values["action"] ?? "").ToString();

        UsuarioSesion usuarioSesion = Session["UsuarioSesion"] as UsuarioSesion;

        Func<string, string, string> activo = (ctrl, act) =>
            controller.Equals(ctrl, StringComparison.OrdinalIgnoreCase)
            && (string.IsNullOrEmpty(act) || action.Equals(act, StringComparison.OrdinalIgnoreCase))
                ? "active"
                : "";

        Func<string[], string> abierto = (controles) =>
            controles.Any(c => controller.Equals(c, StringComparison.OrdinalIgnoreCase))
                ? "open active"
                : "";

        Func<string, bool> puedeVer = (codigoModulo) =>
            usuarioSesion != null
            && usuarioSesion.Permisos != null
            && usuarioSesion.Permisos.Any(p =>
                p.CodigoModulo == codigoModulo
                && p.Activo
                && p.PuedeVer
            );

        Func<string[], bool> puedeVerAlguno = (codigos) =>
            usuarioSesion != null
            && usuarioSesion.Permisos != null
            && usuarioSesion.Permisos.Any(p =>
                codigos.Contains(p.CodigoModulo)
                && p.Activo
                && p.PuedeVer
            );

        string nombreUsuario = "Usuario";
        string nombreCompleto = "Usuario del sistema";
        string nombreRol = "Sin rol";

        if (usuarioSesion != null)
        {
            nombreUsuario = usuarioSesion.NombreUsuario;
            nombreCompleto = usuarioSesion.NombreCompleto;
            nombreRol = usuarioSesion.NombreRol;
        }
        else if (Session["NombreUsuario"] != null)
        {
            nombreUsuario = Session["NombreUsuario"].ToString();
        }
        else if (User != null && User.Identity != null && User.Identity.IsAuthenticated)
        {
            nombreUsuario = User.Identity.Name;
        }
        bool esAdministradorSistema = !string.IsNullOrWhiteSpace(nombreRol)
        && nombreRol.ToLower().Contains("administrador");

        string inicialUsuario = !string.IsNullOrWhiteSpace(nombreUsuario)
        ? nombreUsuario.Substring(0, 1).ToUpper()
        : "U";
    }

    <div class="page-loader">
        <div class="bg-primary"></div>
    </div>

    <div class="layout-wrapper layout-2">
        <div class="layout-inner">

            <div id="layout-sidenav" class="layout-sidenav sidenav sidenav-vertical bg-dark">

                <div class="app-brand">
                    <a href="@Url.Action("Index", "Home")" class="brand-box">
                        <div class="brand-logo">₡</div>
                        <div>
                            <span class="brand-text-main">Sistema Contable</span>
                            <span class="brand-text-sub">Las Graditas</span>
                        </div>
                    </a>
                </div>

                <div class="sidenav-divider mt-0"></div>

                <ul class="sidenav-inner py-1">

                    @if (puedeVer("HOME"))
                    {
                        <li class="sidenav-item @activo("Home", "Index")">
                            <a href="@Url.Action("Index", "Home")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-home"></i>
                                <div>Inicio</div>
                            </a>
                        </li>
                    }

                    @if (puedeVerAlguno(new[] { "CUENTAS_CONTABLES", "CONFIG_CUENTA_CONTABLE", "ASIENTOS", "PERIODO_CONTABLE" }))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Gestionar cuentas contables</li>

                        <li class="sidenav-item @abierto(new[] { "GestionarCuentaContable", "ConfiguracionCuentaContable", "GestionarAsientoContable", "GestionarPeriodoContable" })">
                            <a href="javascript:void(0)" class="sidenav-link sidenav-toggle">
                                <i class="sidenav-icon feather icon-book-open"></i>
                                <div>Cuentas contables</div>
                            </a>

                            <ul class="sidenav-menu">

                                @if (puedeVer("CUENTAS_CONTABLES"))
                                {
                                    <li class="sidenav-item @activo("GestionarCuentaContable", "CuentasContables")">
                                        <a href="@Url.Action("CuentasContables", "GestionarCuentaContable")" class="sidenav-link">
                                            <div>Catálogo contable</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("CONFIG_CUENTA_CONTABLE"))
                                {
                                    <li class="sidenav-item @activo("ConfiguracionCuentaContable", "ConfiguracionCuentaContable")">
                                        <a href="@Url.Action("ConfiguracionCuentaContable", "ConfiguracionCuentaContable")" class="sidenav-link">
                                            <div>Configuración contable</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("ASIENTOS"))
                                {
                                    <li class="sidenav-item @activo("GestionarAsientoContable", "AsientosContables")">
                                        <a href="@Url.Action("AsientosContables", "GestionarAsientoContable")" class="sidenav-link">
                                            <div>Asientos contables</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("PERIODO_CONTABLE"))
                                {
                                    <li class="sidenav-item @activo("GestionarPeriodoContable", "PeriodosContables")">
                                        <a href="@Url.Action("PeriodosContables", "GestionarPeriodoContable")" class="sidenav-link">
                                            <div>Períodos contables</div>
                                        </a>
                                    </li>
                                }

                            </ul>
                        </li>
                    }

                    @if (puedeVer("CUENTAS_COBRAR"))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Gestionar cuentas por cobrar</li>

                        <li class="sidenav-item @activo("GestionarCuentasPorCobrar", "CuentasPorCobrar")">
                            <a href="@Url.Action("CuentasPorCobrar", "GestionarCuentasPorCobrar")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-credit-card"></i>
                                <div>Cuentas por cobrar</div>
                            </a>
                        </li>
                    }

                    @if (puedeVer("CUENTAS_PAGAR"))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Gestionar cuentas por pagar</li>

                        <li class="sidenav-item @activo("GestionarCuentasPorPagar", "CuentasPorPagar")">
                            <a href="@Url.Action("CuentasPorPagar", "GestionarCuentasPorPagar")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-file-text"></i>
                                <div>Cuentas por pagar</div>
                            </a>
                        </li>
                    }

                    @if (puedeVer("INGRESOS"))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Gestionar ingresos</li>

                        <li class="sidenav-item @activo("GestionarIngresos", "Ingresos")">
                            <a href="@Url.Action("Ingresos", "GestionarIngresos")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-trending-up"></i>
                                <div>Ingresos</div>
                            </a>
                        </li>
                    }

                    @if (puedeVer("GASTOS"))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Gestionar gastos</li>

                        <li class="sidenav-item @activo("GestionarGastos", "Gastos")">
                            <a href="@Url.Action("Gastos", "GestionarGastos")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-trending-down"></i>
                                <div>Gastos</div>
                            </a>
                        </li>
                    }

                    @if (puedeVerAlguno(new[] { "FACTURAS", "NOTAS_CREDITO", "PRODUCTOS", "CLIENTES" }))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Gestionar facturación</li>

                        <li class="sidenav-item @abierto(new[] { "Facturacion", "Producto", "Persona" })">
                            <a href="javascript:void(0)" class="sidenav-link sidenav-toggle">
                                <i class="sidenav-icon feather icon-shopping-cart"></i>
                                <div>Facturación</div>
                            </a>

                            <ul class="sidenav-menu">

                                @if (puedeVer("FACTURAS"))
                                {
                                    <li class="sidenav-item @activo("Facturacion", "Facturas")">
                                        <a href="@Url.Action("Facturas", "Facturacion")" class="sidenav-link">
                                            <div>Emitir facturas</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("NOTAS_CREDITO"))
                                {
                                    <li class="sidenav-item @activo("Facturacion", "NotasCredito")">
                                        <a href="@Url.Action("NotasCredito", "Facturacion")" class="sidenav-link">
                                            <div>Notas de crédito</div>
                                        </a>
                                    </li>
                                }

                            </ul>
                        </li>
                    }

                    @if (puedeVer("PRESUPUESTOS"))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Generar presupuesto mensual</li>

                        <li class="sidenav-item @activo("GestionarPresupuestoMensual", "PresupuestoMensual")">
                            <a href="@Url.Action("PresupuestoMensual", "GestionarPresupuestoMensual")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-bar-chart-2"></i>
                                <div>Presupuesto mensual</div>
                            </a>
                        </li>
                    }

                    @if (puedeVerAlguno(new[] { "PRODUCTOS", "CLIENTES", "PROVEEDORES", "EMPLEADOS", "UBICACIONES", "CATALOGOS", "ROLES", "CONFIG_CUENTA_CONTABLE", "PERIODO_CONTABLE" }))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Mantenimientos</li>

                        <li class="sidenav-item @activo("Home", "Mantenimientos")">
                            <a href="@Url.Action("Mantenimientos", "Home")" class="sidenav-link">
                                <i class="sidenav-icon feather icon-settings"></i>
                                <div>Panel de mantenimientos</div>
                            </a>
                        </li>
                    }

                    @if (puedeVerAlguno(new[] { "CONSULTAS", "REPORTES" }))
                    {
                        <li class="sidenav-divider mb-1"></li>
                        <li class="sidenav-header small font-weight-semibold">Consultas y reportes</li>

                        <li class="sidenav-item @abierto(new[] { "Consultas", "Reportes" })">
                            <a href="javascript:void(0)" class="sidenav-link sidenav-toggle">
                                <i class="sidenav-icon feather icon-pie-chart"></i>
                                <div>Información del sistema</div>
                            </a>

                            <ul class="sidenav-menu">

                                @if (puedeVer("CONSULTAS"))
                                {
                                    <li class="sidenav-item @activo("Consultas", "Consultas")">
                                        <a href="@Url.Action("Consultas", "Consultas")" class="sidenav-link">
                                            <div>Consultas</div>
                                        </a>
                                    </li>
                                }

                                @if (puedeVer("REPORTES"))
                                {
                                    <li class="sidenav-item @activo("Reportes", "Reportes")">
                                        <a href="@Url.Action("Reportes", "Reportes")" class="sidenav-link">
                                            <div>Reportes</div>
                                        </a>
                                    </li>
                                }

                            </ul>
                        </li>
                    }



                </ul>
            </div>

            <div class="layout-container">

                <nav class="layout-navbar navbar navbar-expand-lg align-items-lg-center bg-white container-p-x">

                    <a href="javascript:void(0)" class="layout-sidenav-toggle sidenav-link text-large mr-3">
                        <i class="ion ion-md-menu align-middle"></i>
                    </a>

                    <div class="navbar-nav align-items-lg-center mr-auto">
                        <div class="nav-item navbar-text navbar-page-title">
                            <strong>@ViewBag.Title</strong>
                            <span>Sistema Web Contable</span>
                        </div>
                    </div>

                    <div class="navbar-collapse collapse" id="layout-navbar-collapse">
                        <div class="navbar-nav align-items-lg-center ml-auto">

                            <div class="nav-item user-box">
                                <div class="user-avatar">
                                    @inicialUsuario
                                </div>

                                <div class="user-info">
                                    <strong>@nombreUsuario</strong>
                                    <span>@nombreRol</span>
                                </div>
                            </div>

                            <div class="nav-item ml-3">
                                <a class="nav-link logout-link" href="@Url.Action("CerrarSesion", "Acceso")">
                                    <i class="feather icon-log-out mr-1"></i>
                                    Cerrar sesión
                                </a>
                            </div>

                        </div>
                    </div>

                </nav>

                <div class="layout-content">
                    <div class="container-fluid flex-grow-1 container-p-y">
                        <div class="content-shell">
                            @RenderBody()
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>



    <div class="modal fade" id="modalConfirmacionSistema" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">

                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="tituloConfirmacionSistema">Confirmar acción</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <p id="textoConfirmacionSistema" class="mb-0"></p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="button" class="btn btn-danger" id="btnAceptarConfirmacionSistema">
                        Aceptar
                    </button>
                </div>

            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/datatables")
    @Scripts.Render("~/bundles/morris")

    <script>
    window.esAdministradorSistema = @esAdministradorSistema.ToString().ToLower();
    </script>

    <script src="~/Scripts/js/sistema-global.js"></script>

    @RenderSection("scripts", required: false)

</body>
</html>
