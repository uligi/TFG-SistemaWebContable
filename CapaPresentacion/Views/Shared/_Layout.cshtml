<!DOCTYPE html>
<html lang="es">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - Sistema Web Contable</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    <div class="layout-wrapper layout-2">
        <div class="layout-inner">

            <!-- SIDEBAR -->
            <div id="layout-sidenav" class="layout-sidenav sidenav sidenav-vertical bg-dark">

                <div class="app-brand">
                    <a href="@Url.Action("Index", "Home")" class="app-brand-text sidenav-text font-weight-normal ml-2">
                        Sistema Contable
                    </a>
                </div>

                <div class="sidenav-divider mt-0"></div>

                <ul class="sidenav-inner py-1">

                    <li class="sidenav-item">
                        <a href="@Url.Action("Index", "Home")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-home"></i>
                            <div>Inicio</div>
                        </a>
                    </li>

                    <li class="sidenav-divider mb-1"></li>
                    <li class="sidenav-header small font-weight-semibold">Módulos principales</li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("CuentasContables", "GestionarCuentaContable")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-book"></i>
                            <div>Cuentas contables</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("CuentasContables", "GestionarCuentasPorCobrar")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-dollar-sign"></i>
                            <div>Cuentas por cobrar</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("CxP", "GestionarCuentasPorPagar")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-credit-card"></i>
                            <div>Cuentas por pagar</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("GI", "GestionarIngresos")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-trending-up"></i>
                            <div>Ingresos</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("GG", "GestionarGastos")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-trending-down"></i>
                            <div>Gastos</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("Facturacion", "Facturacion")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-file-text"></i>
                            <div>Facturación</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("GPM", "GestionarPresupuestoMensual")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-bar-chart-2"></i>
                            <div>Presupuesto mensual</div>
                        </a>
                    </li>

                    <li class="sidenav-divider mb-1"></li>
                    <li class="sidenav-header small font-weight-semibold">Mantenimientos</li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("Mantenimientos", "Home")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-users"></i>
                            <div>Mantenimientos</div>
                        </a>
                    </li>

                    

                    <li class="sidenav-divider mb-1"></li>
                    <li class="sidenav-header small font-weight-semibold">Sistema</li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("Reportes", "Reportes")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-printer"></i>
                            <div>Reportes</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("Consultas", "Consultas")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-search"></i>
                            <div>Consultas</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("Index", "HistorialCambio")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-clock"></i>
                            <div>Historial de cambios</div>
                        </a>
                    </li>

                    <li class="sidenav-item">
                        <a href="@Url.Action("Index", "IntentoAcceso")" class="sidenav-link">
                            <i class="sidenav-icon feather icon-shield"></i>
                            <div>Intentos de acceso</div>
                        </a>
                    </li>

                </ul>
            </div>

            <!-- CONTENIDO -->
            <div class="layout-container">

                <!-- NAVBAR SUPERIOR -->
                <nav class="layout-navbar navbar navbar-expand-lg align-items-lg-center bg-white container-p-x">

                    <a href="javascript:" class="layout-sidenav-toggle sidenav-link text-large mr-3">
                        <i class="ion ion-md-menu align-middle"></i>
                    </a>

                    <div class="navbar-collapse collapse" id="layout-navbar-collapse">
                        <div class="navbar-nav align-items-lg-center ml-auto">

                            <div class="nav-item navbar-text">
                                Usuario: @User.Identity.Name
                            </div>

                            <div class="nav-item ml-3">
                                <a class="nav-link" href="@Url.Action("InicioSesion", "Acceso")">
                                    Cerrar sesión
                                </a>
                            </div>

                        </div>
                    </div>

                </nav>

                <!-- BODY -->
                <div class="layout-content">
                    <div class="container-fluid flex-grow-1 container-p-y">
                        @RenderBody()
                    </div>
                </div>

            </div>

        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>