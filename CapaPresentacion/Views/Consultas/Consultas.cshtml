    function cargarDetalleFactura(numeroFactura) {
        $("#contenedorDetalleFactura").hide();
        $("#tablaDetalleFactura tbody").empty();

        $.ajax({
            url: '@Url.Action("ConsultarDetalleFactura", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                numeroFactura: numeroFactura
            },
            success: function (respuesta) {
                var lista = respuesta.data || [];
                var tbody = $("#tablaDetalleFactura tbody");

                tbody.empty();

                if (lista.length === 0) {
                    tbody.append('<tr><td colspan="8" class="text-center text-muted">No hay productos en esta factura.</td></tr>');
                }

                $.each(lista, function (i, item) {
                    var fila = $("<tr>");

                    fila.append($("<td>").text((item.CodigoProducto || "") + " - " + (item.NombreProducto || "")));
                    fila.append($("<td>").text(item.DescripcionItem || ""));
                    fila.append($("<td>").text(formatearNumero(item.Cantidad)));
                    fila.append($("<td>").text(formatearMoneda(item.PrecioUnitario)));
                    fila.append($("<td>").text(formatearNumero(item.PorcentajeImpuesto) + "%"));
                    fila.append($("<td>").text(formatearNumero(item.PorcentajeDescuento) + "%"));
                    fila.append($("<td>").text(formatearMoneda(item.SubtotalLinea)));
                    fila.append($("<td>").text(formatearMoneda(item.TotalLinea)));

                    tbody.append(fila);
                });

                $("#contenedorDetalleFactura").show();
            },
            error: function () {
                $("#contenedorDetalleFactura").hide();
            }
        });
    }

