@{
    ViewBag.Title = "Consultas Generales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .codigo-consulta {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .texto-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Consultas Generales</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Consultas</li>
        <li class="breadcrumb-item active">Consultas generales</li>
    </ol>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Filtros de búsqueda</h6>
    </div>

    <div class="card-body">

        <div class="alert alert-danger" id="mensajeErrorConsulta" style="display:none;"></div>

        <div class="form-row">

            <div class="form-group col-md-4">
                <label for="txtFiltroGeneral">Buscar</label>
                <input type="text" id="txtFiltroGeneral" class="form-control" maxlength="100"
                       placeholder="Número, nombre, identificación, cuenta, producto..." />
            </div>

            <div class="form-group col-md-2">
                <label for="txtFechaInicio">Fecha inicio</label>
                <input type="date" id="txtFechaInicio" class="form-control" />
            </div>

            <div class="form-group col-md-2">
                <label for="txtFechaFin">Fecha final</label>
                <input type="date" id="txtFechaFin" class="form-control" />
            </div>

            <div class="form-group col-md-2">
                <label for="cboEstado">Estado</label>
                <select id="cboEstado" class="form-control">
                    <option value="">Todos</option>
                    <option value="Emitida">Emitida</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Parcial">Parcial</option>
                    <option value="Pagada">Pagada</option>
                    <option value="Anulada">Anulada</option>
                    <option value="Vencida">Vencida</option>
                </select>
            </div>

            <div class="form-group col-md-2">
                <label for="cboEstadoCredito">Estado crédito</label>
                <select id="cboEstadoCredito" class="form-control">
                    <option value="">Todos</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Por vencer">Por vencer</option>
                    <option value="Vencida">Vencida</option>
                    <option value="Pagada">Pagada</option>
                    <option value="Anulada">Anulada</option>
                </select>
            </div>

        </div>

        <div class="form-row">

            <div class="form-group col-md-3">
                <label for="cboTipoMovimiento">Tipo movimiento</label>
                <select id="cboTipoMovimiento" class="form-control">
                    <option value="">Todos</option>
                    <option value="Ingreso">Ingreso</option>
                    <option value="Gasto">Gasto</option>
                </select>
            </div>

            <div class="form-group col-md-3">
                <label>Filtros rápidos</label>

                <div class="custom-control custom-checkbox">
                    <input type="checkbox" class="custom-control-input" id="chkSoloBajoStock">
                    <label class="custom-control-label" for="chkSoloBajoStock">Solo bajo stock</label>
                </div>

                <div class="custom-control custom-checkbox">
                    <input type="checkbox" class="custom-control-input" id="chkSoloSinStock">
                    <label class="custom-control-label" for="chkSoloSinStock">Solo sin stock</label>
                </div>
            </div>

            <div class="form-group col-md-3">
                <label>&nbsp;</label>

                <div class="custom-control custom-checkbox">
                    <input type="checkbox" class="custom-control-input" id="chkSoloConSaldo">
                    <label class="custom-control-label" for="chkSoloConSaldo">Solo con saldo pendiente</label>
                </div>

                <div class="custom-control custom-checkbox">
                    <input type="checkbox" class="custom-control-input" id="chkSoloActivos" checked>
                    <label class="custom-control-label" for="chkSoloActivos">Solo activos</label>
                </div>
            </div>

            <div class="form-group col-md-3 d-flex align-items-end">
                <button type="button" class="btn btn-primary btn-block" onclick="ejecutarConsultaActiva()">
                    Consultar
                </button>
            </div>

        </div>

        <small class="text-muted">
            Las fechas aplican principalmente para facturas y movimientos contables. Cuentas, productos, clientes y proveedores se consultan por estado actual.
        </small>

    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <button type="button" class="btn btn-success mr-2" onclick="exportarConsultaActualCSV()">
            Exportar CSV
        </button>

        <button type="button" class="btn btn-info mr-2" onclick="imprimirConsultaActual()">
            Imprimir
        </button>

        <span class="text-muted small">
            Exporta o imprime la pestaña activa.
        </span>
    </div>
</div>

<div class="nav-tabs-top mb-4">
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <a class="nav-link active" data-toggle="tab" href="#tabFacturas">Facturas</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabCxC">Cuentas por cobrar</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabCxP">Cuentas por pagar</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabProductos">Productos</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabClientes">Clientes</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabProveedores">Proveedores</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-toggle="tab" href="#tabMovimientos">Movimientos contables</a>
        </li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade show active" id="tabFacturas">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Consulta de facturas</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaFacturas" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Número</th>
                                    <th>Fecha</th>
                                    <th>Cliente</th>
                                    <th>Empleado</th>
                                    <th>Tipo factura</th>
                                    <th>Tipo pago</th>
                                    <th>Total</th>
                                    <th>Estado</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabCxC">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Consulta de cuentas por cobrar</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaCxC" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Factura</th>
                                    <th>Cliente</th>
                                    <th>Emisión</th>
                                    <th>Vencimiento</th>
                                    <th>Monto original</th>
                                    <th>Saldo actual</th>
                                    <th>Estado</th>
                                    <th>Estado crédito</th>
                                    <th>Días</th>
                                    <th>Prioridad</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabCxP">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Consulta de cuentas por pagar</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaCxP" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Documento</th>
                                    <th>Proveedor</th>
                                    <th>Emisión</th>
                                    <th>Vencimiento</th>
                                    <th>Concepto</th>
                                    <th>Monto original</th>
                                    <th>Saldo actual</th>
                                    <th>Estado</th>
                                    <th>Estado crédito</th>
                                    <th>Días</th>
                                    <th>Prioridad</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabProductos">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Consulta de productos</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaProductos" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Producto</th>
                                    <th>Tipo</th>
                                    <th>Precio venta</th>
                                    <th>Stock actual</th>
                                    <th>IVA</th>
                                    <th>Estado inventario</th>
                                    <th>Activo</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabClientes">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Consulta de clientes</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaClientes" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Identificación</th>
                                    <th>Cliente</th>
                                    <th>Límite crédito</th>
                                    <th>Días crédito</th>
                                    <th>Saldo pendiente</th>
                                    <th>Facturas pendientes</th>
                                    <th>Estado</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabProveedores">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Consulta de proveedores</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaProveedores" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Identificación</th>
                                    <th>Razón social</th>
                                    <th>Contacto</th>
                                    <th>Días crédito</th>
                                    <th>Saldo pendiente</th>
                                    <th>Documentos pendientes</th>
                                    <th>Estado</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tabMovimientos">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Consulta de movimientos contables</h6>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered nowrap" id="tablaMovimientos" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Número</th>
                                    <th>Fecha</th>
                                    <th>Cuenta</th>
                                    <th>Descripción</th>
                                    <th>Monto</th>
                                    <th>Origen</th>
                                    <th>Referencia</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="ModalDetalleConsulta" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloDetalleConsulta">Detalle de consulta</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <div id="contenidoDetalleConsulta"></div>

                <div id="contenedorDetalleFactura" style="display:none;">
                    <hr />
                    <h6 class="font-weight-bold">Productos de la factura</h6>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered" id="tablaDetalleFactura">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Descripción</th>
                                    <th>Cantidad</th>
                                    <th>Precio</th>
                                    <th>IVA</th>
                                    <th>Descuento</th>
                                    <th>Subtotal</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-info" onclick="imprimirDetalleConsulta()">
                    Imprimir detalle
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
    var tablaFacturas = null;
    var tablaCxC = null;
    var tablaCxP = null;
    var tablaProductos = null;
    var tablaClientes = null;
    var tablaProveedores = null;
    var tablaMovimientos = null;

    var listaFacturasGlobal = [];
    var listaCxCGlobal = [];
    var listaCxPGlobal = [];
    var listaProductosGlobal = [];
    var listaClientesGlobal = [];
    var listaProveedoresGlobal = [];
    var listaMovimientosGlobal = [];

    $(document).ready(function () {
        $('a[data-toggle="tab"]').on('shown.bs.tab', function () {
            setTimeout(function () {
                ajustarTablas();
            }, 200);
        });

        $("#txtFiltroGeneral").on("keypress", function (e) {
            if (e.which === 13) {
                ejecutarConsultaActiva();
            }
        });

        $("#chkSoloSinStock").on("change", function () {
            if ($(this).is(":checked")) {
                $("#chkSoloBajoStock").prop("checked", false);
            }
        });

        $("#chkSoloBajoStock").on("change", function () {
            if ($(this).is(":checked")) {
                $("#chkSoloSinStock").prop("checked", false);
            }
        });

        ejecutarConsultaActiva();
    });

    function ejecutarConsultaActiva() {
        var tabActivo = $(".nav-tabs .nav-link.active").attr("href");

        $("#mensajeErrorConsulta").hide().text("");

        if (tabActivo === "#tabFacturas") {
            consultarFacturas();
            return;
        }

        if (tabActivo === "#tabCxC") {
            consultarCuentasPorCobrar();
            return;
        }

        if (tabActivo === "#tabCxP") {
            consultarCuentasPorPagar();
            return;
        }

        if (tabActivo === "#tabProductos") {
            consultarProductos();
            return;
        }

        if (tabActivo === "#tabClientes") {
            consultarClientes();
            return;
        }

        if (tabActivo === "#tabProveedores") {
            consultarProveedores();
            return;
        }

        if (tabActivo === "#tabMovimientos") {
            consultarMovimientosContables();
            return;
        }
    }

    function obtenerFiltroBase() {
        return $("#txtFiltroGeneral").val().trim();
    }

    function consultarFacturas() {
        $.ajax({
            url: '@Url.Action("ConsultarFacturas", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                filtro: obtenerFiltroBase(),
                fechaInicio: $("#txtFechaInicio").val(),
                fechaFin: $("#txtFechaFin").val(),
                estado: $("#cboEstado").val()
            },
            success: function (respuesta) {
                if (respuesta.resultado === false) {
                    mostrarErrorConsulta(respuesta.mensaje);
                    return;
                }

                listaFacturasGlobal = respuesta.data || [];
                pintarTablaFacturas(listaFacturasGlobal);
            },
            error: function () {
                mostrarErrorConsulta("Error al consultar facturas.");
            }
        });
    }

    function consultarCuentasPorCobrar() {
        $.ajax({
            url: '@Url.Action("ConsultarCuentasPorCobrar", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                filtro: obtenerFiltroBase(),
                estado: $("#cboEstado").val(),
                estadoCredito: $("#cboEstadoCredito").val()
            },
            success: function (respuesta) {
                listaCxCGlobal = respuesta.data || [];
                pintarTablaCxC(listaCxCGlobal);
            },
            error: function () {
                mostrarErrorConsulta("Error al consultar cuentas por cobrar.");
            }
        });
    }

    function consultarCuentasPorPagar() {
        $.ajax({
            url: '@Url.Action("ConsultarCuentasPorPagar", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                filtro: obtenerFiltroBase(),
                estado: $("#cboEstado").val(),
                estadoCredito: $("#cboEstadoCredito").val()
            },
            success: function (respuesta) {
                listaCxPGlobal = respuesta.data || [];
                pintarTablaCxP(listaCxPGlobal);
            },
            error: function () {
                mostrarErrorConsulta("Error al consultar cuentas por pagar.");
            }
        });
    }

    function consultarProductos() {
        $.ajax({
            url: '@Url.Action("ConsultarProductos", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                filtro: obtenerFiltroBase(),
                soloBajoStock: $("#chkSoloBajoStock").is(":checked"),
                soloSinStock: $("#chkSoloSinStock").is(":checked"),
                soloActivos: $("#chkSoloActivos").is(":checked")
            },
            success: function (respuesta) {
                listaProductosGlobal = respuesta.data || [];
                pintarTablaProductos(listaProductosGlobal);
            },
            error: function () {
                mostrarErrorConsulta("Error al consultar productos.");
            }
        });
    }

    function consultarClientes() {
        $.ajax({
            url: '@Url.Action("ConsultarClientes", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                filtro: obtenerFiltroBase(),
                soloConSaldo: $("#chkSoloConSaldo").is(":checked"),
                soloActivos: $("#chkSoloActivos").is(":checked")
            },
            success: function (respuesta) {
                listaClientesGlobal = respuesta.data || [];
                pintarTablaClientes(listaClientesGlobal);
            },
            error: function () {
                mostrarErrorConsulta("Error al consultar clientes.");
            }
        });
    }

    function consultarProveedores() {
        $.ajax({
            url: '@Url.Action("ConsultarProveedores", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                filtro: obtenerFiltroBase(),
                soloConSaldo: $("#chkSoloConSaldo").is(":checked"),
                soloActivos: $("#chkSoloActivos").is(":checked")
            },
            success: function (respuesta) {
                listaProveedoresGlobal = respuesta.data || [];
                pintarTablaProveedores(listaProveedoresGlobal);
            },
            error: function () {
                mostrarErrorConsulta("Error al consultar proveedores.");
            }
        });
    }

    function consultarMovimientosContables() {
        $.ajax({
            url: '@Url.Action("ConsultarMovimientosContables", "Consultas")',
            type: "GET",
            dataType: "json",
            data: {
                filtro: obtenerFiltroBase(),
                fechaInicio: $("#txtFechaInicio").val(),
                fechaFin: $("#txtFechaFin").val(),
                tipoMovimiento: $("#cboTipoMovimiento").val()
            },
            success: function (respuesta) {
                if (respuesta.resultado === false) {
                    mostrarErrorConsulta(respuesta.mensaje);
                    return;
                }

                listaMovimientosGlobal = respuesta.data || [];
                pintarTablaMovimientos(listaMovimientosGlobal);
            },
            error: function () {
                mostrarErrorConsulta("Error al consultar movimientos contables.");
            }
        });
    }

    function pintarTablaFacturas(lista) {
        if (tablaFacturas != null) {
            tablaFacturas.clear().destroy();
            tablaFacturas = null;
        }

        var tbody = $("#tablaFacturas tbody");
        tbody.empty();

        $.each(lista, function (i, item) {
            var fila = $("<tr>");

            fila.append($("<td>", { class: "codigo-consulta", text: item.NumeroFactura || "" }));
            fila.append($("<td>").text(formatearFecha(item.FechaFactura)));
            fila.append($("<td>").text((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")));
            fila.append($("<td>").text((item.IdentificacionEmpleado || "") + " - " + (item.EmpleadoNombre || "")));
            fila.append($("<td>").text(item.TipoFacturaNombre || ""));
            fila.append($("<td>").text(item.TipoPagoNombre || ""));
            fila.append($("<td>").text(formatearMoneda(item.TotalFactura)));
            fila.append($("<td>").html(obtenerBadgeEstado(item.Estado)));
            fila.append($("<td>").html('<button type="button" class="btn btn-sm btn-outline-primary" onclick="verDetalleFactura(' + i + ')">Ver</button>'));

            tbody.append(fila);
        });

        tablaFacturas = crearDataTable("#tablaFacturas", [[1, "desc"]]);
    }

    function pintarTablaCxC(lista) {
        if (tablaCxC != null) {
            tablaCxC.clear().destroy();
            tablaCxC = null;
        }

        var tbody = $("#tablaCxC tbody");
        tbody.empty();

        $.each(lista, function (i, item) {
            var fila = $("<tr>");

            fila.append($("<td>", { class: "codigo-consulta", text: item.NumeroFactura || "" }));
            fila.append($("<td>").text((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")));
            fila.append($("<td>").text(formatearFecha(item.FechaEmision)));
            fila.append($("<td>").text(formatearFecha(item.FechaVencimiento)));
            fila.append($("<td>").text(formatearMoneda(item.MontoOriginal)));
            fila.append($("<td>").text(formatearMoneda(item.SaldoActual)));
            fila.append($("<td>").html(obtenerBadgeEstado(item.Estado)));
            fila.append($("<td>").html(obtenerBadgeEstadoCredito(item.EstadoCredito)));
            fila.append($("<td>").text(item.DiasRestantesTexto || obtenerTextoDias(item.DiasRestantes, item.EstadoCredito)));
