    function exportarConsultaActualCSV() {
        var consulta = obtenerConsultaActiva();

        if (consulta === null || consulta.lista.length === 0) {
            alert("No hay datos para exportar.");
            return;
        }

        var lineas = [];

        lineas.push(consulta.columnas.map(function (c) {
            return escaparCSV(c.titulo);
        }).join(";"));

        $.each(consulta.lista, function (i, item) {
            var fila = consulta.columnas.map(function (columna) {
                return escaparCSV(obtenerValorFormateado(item, columna));
            });

            lineas.push(fila.join(";"));
        });

        var contenido = "\uFEFF" + lineas.join("\n");
        var blob = new Blob([contenido], { type: "text/csv;charset=utf-8;" });

        var enlace = document.createElement("a");
        var url = URL.createObjectURL(blob);

        enlace.setAttribute("href", url);
        enlace.setAttribute("download", consulta.archivo + ".csv");
        enlace.style.visibility = "hidden";

        document.body.appendChild(enlace);
        enlace.click();
        document.body.removeChild(enlace);
    }

    function imprimirConsultaActual() {
        var consulta = obtenerConsultaActiva();

        if (consulta === null || consulta.lista.length === 0) {
            alert("No hay datos para imprimir.");
            return;
        }

        var html = generarHTMLImpresion(consulta.nombre, consulta.lista, consulta.columnas);

        var ventana = window.open("", "_blank");
        ventana.document.open();
        ventana.document.write(html);
        ventana.document.close();
        ventana.focus();
        ventana.print();
    }

    function generarHTMLImpresion(titulo, lista, columnas) {
        var html = '';

        html += '<!DOCTYPE html>';
        html += '<html><head><meta charset="utf-8">';
        html += '<title>' + titulo + '</title>';
        html += '<style>';
        html += 'body{font-family:Arial, sans-serif; font-size:12px; margin:25px;}';
        html += 'h2{margin-bottom:5px;}';
        html += 'table{width:100%; border-collapse:collapse; margin-top:15px;}';
        html += 'th,td{border:1px solid #ccc; padding:6px; text-align:left;}';
        html += 'th{background:#f2f2f2;}';
        html += '</style>';
        html += '</head><body>';

        html += '<h2>' + titulo + '</h2>';
        html += '<table>';
        html += '<thead><tr>';

        $.each(columnas, function (i, columna) {
            html += '<th>' + columna.titulo + '</th>';
        });

        html += '</tr></thead><tbody>';

        $.each(lista, function (i, item) {
            html += '<tr>';

            $.each(columnas, function (j, columna) {
                html += '<td>' + obtenerValorFormateado(item, columna) + '</td>';
            });

            html += '</tr>';
        });

        html += '</tbody></table>';
        html += '</body></html>';

        return html;
    }

    function obtenerValorFormateado(item, columna) {
        var valor = item[columna.campo];

        if (columna.tipo === "fecha") {
            return formatearFecha(valor);
        }

        if (columna.tipo === "moneda") {
            return formatearMoneda(valor);
        }

        return valor || "";
    }

    function escaparCSV(valor) {
        valor = valor === null || valor === undefined ? "" : valor.toString();
        valor = valor.replace(/"/g, '""');
        return '"' + valor + '"';
    }

    function mostrarErrorConsulta(mensaje) {
        $("#mensajeErrorConsulta").text(mensaje).show();
    }

    function obtenerBadgeEstado(estado) {
        if (estado === "Emitida" || estado === "Pagada") {
            return '<span class="badge badge-success">' + estado + '</span>';
        }

        if (estado === "Parcial") {
            return '<span class="badge badge-info">Parcial</span>';
        }

        if (estado === "Vencida" || estado === "Anulada") {
            return '<span class="badge badge-danger">' + estado + '</span>';
        }

        return '<span class="badge badge-warning">' + (estado || "Pendiente") + '</span>';
    }

    function obtenerBadgeEstadoCredito(estado) {
        if (estado === "Pagada") {
            return '<span class="badge badge-success">Pagada</span>';
        }

        if (estado === "Vencida") {
            return '<span class="badge badge-danger">Vencida</span>';
        }

        if (estado === "Por vencer") {
            return '<span class="badge badge-warning">Por vencer</span>';
        }

        if (estado === "Anulada") {
            return '<span class="badge badge-secondary">Anulada</span>';
        }

        return '<span class="badge badge-info">' + (estado || "Pendiente") + '</span>';
    }

    function obtenerBadgePrioridad(prioridad) {
        if (prioridad === "Alta") {
            return '<span class="badge badge-danger">Alta</span>';
        }

        if (prioridad === "Media") {
            return '<span class="badge badge-warning">Media</span>';
        }

        return '<span class="badge badge-info">' + (prioridad || "Normal") + '</span>';
    }

    function obtenerBadgeInventario(estado) {
        if (estado === "Sin stock") {
            return '<span class="badge badge-danger">Sin stock</span>';
        }

        if (estado === "Bajo stock") {
            return '<span class="badge badge-warning">Bajo stock</span>';
        }

        return '<span class="badge badge-success">' + (estado || "Stock disponible") + '</span>';
    }

    function obtenerBadgeEstadoClienteProveedor(estado) {
        if (estado === "Con saldo pendiente") {
            return '<span class="badge badge-warning">Con saldo pendiente</span>';
        }

        if (estado === "Inactivo") {
            return '<span class="badge badge-secondary">Inactivo</span>';
        }

        return '<span class="badge badge-success">' + (estado || "Al día") + '</span>';
    }

    function obtenerBadgeTipoMovimiento(tipo) {
        if (tipo === "Ingreso") {
            return '<span class="badge badge-success">Ingreso</span>';
        }

        if (tipo === "Gasto") {
            return '<span class="badge badge-danger">Gasto</span>';
        }

        return '<span class="badge badge-secondary">' + (tipo || "") + '</span>';
    }

    function obtenerTextoDias(diasRestantes, estadoCredito) {
        diasRestantes = parseInt(diasRestantes || 0);

        if (estadoCredito === "Pagada") {
            return "Pagada";
        }

        if (diasRestantes < 0) {
            return Math.abs(diasRestantes) + " día(s) vencida";
        }

        if (diasRestantes === 0) {
            return "Vence hoy";
        }

        return diasRestantes + " día(s)";
    }

    function formatearFecha(valor) {
        if (!valor) {
            return "";
        }

        var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

        if (isNaN(fecha.getTime())) {
            fecha = new Date(valor);
        }

        if (isNaN(fecha.getTime())) {
            return "";
        }

        return convertirDateAInput(fecha);
    }

    function convertirDateAInput(fecha) {
        var anio = fecha.getFullYear();
        var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
        var dia = ("0" + fecha.getDate()).slice(-2);

        return anio + "-" + mes + "-" + dia;
    }

    function formatearMoneda(valor) {
        var numero = parseFloat(valor || 0);
        return "₡" + numero.toFixed(2);
    }

    function formatearNumero(valor) {
        var numero = parseFloat(valor || 0);
        return numero.toFixed(2);
    }
    </script>
}