
@{
    ViewBag.Title = "Consultas";
    Layout = "~/Views/Shared/_Layout.cshtml";
   
       
    }

    <h4 class="font-weight-bold py-3 mb-0">Consultas</h4>

    <div class="text-muted small mt-0 mb-4 d-block breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")">
                    <i class="feather icon-home"></i>
                </a>
            </li>
            <li class="breadcrumb-item">Sistema</li>
            <li class="breadcrumb-item active">Consultas</li>
        </ol>
    </div>

    <div class="card mb-4">
        <h6 class="card-header">Parámetros de consulta</h6>

        <div class="card-body">

            <form>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label class="form-label">Tipo de consulta</label>
                        <select class="custom-select" name="TipoConsulta">
                            <option value="">Seleccione el tipo de consulta</option>
                            <option value="Facturas">Facturas</option>
                            <option value="CuentasPorCobrar">Cuentas por cobrar</option>
                            <option value="CuentasPorPagar">Cuentas por pagar</option>
                            <option value="Ingresos">Ingresos</option>
                            <option value="Gastos">Gastos</option>
                            <option value="PresupuestoMensual">Presupuesto mensual</option>
                            <option value="Clientes">Clientes</option>
                            <option value="Proveedores">Proveedores</option>
                            <option value="Productos">Productos</option>
                            <option value="AsientosContables">Asientos contables</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label class="form-label">Criterio de búsqueda</label>
                        <select class="custom-select" name="CriterioBusqueda">
                            <option value="">Seleccione un criterio</option>
                            <option value="Codigo">Código</option>
                            <option value="Nombre">Nombre</option>
                            <option value="NumeroDocumento">Número de documento</option>
                            <option value="Factura">Factura</option>
                            <option value="Descripcion">Descripción</option>
                            <option value="Categoria">Categoría</option>
                            <option value="Fecha">Fecha</option>
                            <option value="Estado">Estado</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label class="form-label">Palabra clave</label>
                        <input type="text"
                               class="form-control"
                               name="PalabraClave"
                               placeholder="Ingrese una palabra clave" />
                        <div class="clearfix"></div>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label class="form-label">Cliente</label>
                        <select class="custom-select" name="IdentificacionCliente">
                            <option value="">Todos los clientes</option>
                            <option value="101110111">Cliente ejemplo 1</option>
                            <option value="202220222">Cliente ejemplo 2</option>
                            <option value="303330333">Cliente ejemplo 3</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label class="form-label">Proveedor</label>
                        <select class="custom-select" name="IdentificacionProveedor">
                            <option value="">Todos los proveedores</option>
                            <option value="310100001">Proveedor ejemplo 1</option>
                            <option value="310100002">Proveedor ejemplo 2</option>
                            <option value="310100003">Proveedor ejemplo 3</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label class="form-label">Estado</label>
                        <select class="custom-select" name="Estado">
                            <option value="">Todos los estados</option>
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                            <option value="Pendiente">Pendiente</option>
                            <option value="Parcial">Parcial</option>
                            <option value="Pagada">Pagada</option>
                            <option value="Vencida">Vencida</option>
                            <option value="Anulada">Anulada</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label class="form-label">Fecha inicial</label>
                        <input type="date"
                               class="form-control"
                               name="FechaInicial" />
                        <div class="clearfix"></div>
                    </div>

                    <div class="form-group col-md-3">
                        <label class="form-label">Fecha final</label>
                        <input type="date"
                               class="form-control"
                               name="FechaFinal" />
                        <div class="clearfix"></div>
                    </div>

                    <div class="form-group col-md-3">
                        <label class="form-label">Monto mínimo</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">₡</span>
                            </div>
                            <input type="number"
                                   class="form-control"
                                   name="MontoMinimo"
                                   placeholder="0.00"
                                   step="0.01" />
                            <div class="clearfix"></div>
                        </div>
                    </div>

                    <div class="form-group col-md-3">
                        <label class="form-label">Monto máximo</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">₡</span>
                            </div>
                            <input type="number"
                                   class="form-control"
                                   name="MontoMaximo"
                                   placeholder="0.00"
                                   step="0.01" />
                            <div class="clearfix"></div>
                        </div>
                    </div>

                </div>

                <div class="form-group mt-4">
                    <button type="button" class="btn btn-primary">
                        Consultar
                    </button>

                    <button type="button" class="btn btn-secondary">
                        Exportar
                    </button>

                    <button type="reset" class="btn btn-outline-secondary">
                        Limpiar filtros
                    </button>
                </div>

            </form>

        </div>
    </div>

    <div class="card mb-4">
        <h6 class="card-header">Resultados de la consulta</h6>

        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Documento</th>
                            <th>Cliente / Proveedor</th>
                            <th>Descripción</th>
                            <th>Fecha</th>
                            <th>Monto</th>
                            <th>Estado</th>
                            <th>Detalle</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>Factura</td>
                            <td>FAC-0001</td>
                            <td>Cliente ejemplo 1</td>
                            <td>Venta de productos</td>
                            <td>2026-04-01</td>
                            <td>₡125,000.00</td>
                            <td>Activo</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary">
                                    Ver
                                </button>
                            </td>
                        </tr>

                        <tr>
                            <td>Cuenta por cobrar</td>
                            <td>CXC-0001</td>
                            <td>Cliente ejemplo 2</td>
                            <td>Saldo pendiente de factura</td>
                            <td>2026-04-05</td>
                            <td>₡60,000.00</td>
                            <td>Parcial</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary">
                                    Ver
                                </button>
                            </td>
                        </tr>

                        <tr>
                            <td>Cuenta por pagar</td>
                            <td>CXP-0001</td>
                            <td>Proveedor ejemplo 1</td>
                            <td>Compra de mercadería</td>
                            <td>2026-04-10</td>
                            <td>₡220,000.00</td>
                            <td>Pendiente</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary">
                                    Ver
                                </button>
                            </td>
                        </tr>

                        <tr>
                            <td>Gasto</td>
                            <td>COMP-0001</td>
                            <td>Proveedor ejemplo 2</td>
                            <td>Pago de servicio público</td>
                            <td>2026-04-12</td>
                            <td>₡38,000.00</td>
                            <td>Activo</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary">
                                    Ver
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

