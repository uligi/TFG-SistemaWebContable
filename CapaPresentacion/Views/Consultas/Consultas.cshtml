    function abrirDetalleConsulta(titulo, datos) {
        $("#tituloDetalleConsulta").text(titulo);

        var html = '<table class="table table-bordered table-striped mb-0">';
        html += '<tbody>';

        $.each(datos, function (i, fila) {
            html += '<tr>';
            html += '<th style="width:35%;">' + fila[0] + '</th>';
            html += '<td>' + (fila[1] || "") + '</td>';
            html += '</tr>';
        });

        html += '</tbody></table>';

        $("#contenidoDetalleConsulta").html(html);
        $("#contenedorDetalleFactura").hide();
        $("#ModalDetalleConsulta").modal("show");
    }

