
@{
    ViewBag.Title = "Gestionar Cuentas Contables";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<h4 class="font-weight-bold py-3 mb-0">Gestionar Cuentas Contables</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Cuentas Contables</li>
    </ol>
</div>

<div class="card mb-4">
    <h6 class="card-header">Registro de cuenta contable</h6>

    <div class="card-body">

        <form>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Código de cuenta</label>
                    <input type="text"
                           class="form-control"
                           name="CodigoCuenta"
                           placeholder="Ejemplo: 1.1.01" />
                    <div class="clearfix"></div>
                </div>

                <div class="form-group col-md-8">
                    <label class="form-label">Nombre de cuenta</label>
                    <input type="text"
                           class="form-control"
                           name="NombreCuenta"
                           placeholder="Ejemplo: Caja general" />
                    <div class="clearfix"></div>
                </div>

            </div>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Tipo de cuenta</label>
                    <select class="custom-select" name="TipoCuenta">
                        <option value="">Seleccione un tipo</option>
                        <option value="Activo">Activo</option>
                        <option value="Pasivo">Pasivo</option>
                        <option value="Patrimonio">Patrimonio</option>
                        <option value="Ingreso">Ingreso</option>
                        <option value="Gasto">Gasto</option>
                    </select>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Naturaleza contable</label>
                    <select class="custom-select" name="Naturaleza">
                        <option value="">Seleccione la naturaleza</option>
                        <option value="Deudora">Deudora</option>
                        <option value="Acreedora">Acreedora</option>
                    </select>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Cuenta padre</label>
                    <select class="custom-select" name="IdCuentaPadre">
                        <option value="">Sin cuenta padre</option>
                        <option value="1">Activo</option>
                        <option value="2">Pasivo</option>
                        <option value="3">Patrimonio</option>
                        <option value="4">Ingresos</option>
                        <option value="5">Gastos</option>
                    </select>
                </div>

            </div>

            <div class="form-row">

                <div class="form-group col-md-6">
                    <label class="form-label">Estado</label>
                    <select class="custom-select" name="Activo">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="form-group col-md-6">
                    <label class="form-label d-block">Acepta movimientos</label>

                    <label class="custom-control custom-checkbox mt-2">
                        <input type="checkbox"
                               class="custom-control-input"
                               name="AceptaMovimientos" />
                        <span class="custom-control-label">
                            La cuenta permite registrar movimientos contables
                        </span>
                    </label>
                </div>

            </div>

            <div class="form-group mt-4">
                <button type="button" class="btn btn-primary">
                    Guardar
                </button>

                <button type="button" class="btn btn-secondary">
                    Modificar
                </button>

                <button type="button" class="btn btn-danger">
                    Eliminar
                </button>

                <button type="reset" class="btn btn-outline-secondary">
                    Limpiar
                </button>
            </div>

        </form>

    </div>
</div>

<div class="card mb-4">
    <h6 class="card-header">Listado de cuentas contables</h6>

    <div class="card-body">

        <div class="form-group">
            <label class="form-label">Buscar cuenta</label>
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       placeholder="Buscar por código o nombre de cuenta" />

                <span class="input-group-append">
                    <button class="btn btn-secondary" type="button">
                        Buscar
                    </button>
                </span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre de cuenta</th>
                        <th>Tipo</th>
                        <th>Naturaleza</th>
                        <th>Cuenta padre</th>
                        <th>Acepta movimientos</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>1.1.01</td>
                        <td>Caja general</td>
                        <td>Activo</td>
                        <td>Deudora</td>
                        <td>Activo</td>
                        <td>Sí</td>
                        <td>Activo</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>2.1.01</td>
                        <td>Cuentas por pagar</td>
                        <td>Pasivo</td>
                        <td>Acreedora</td>
                        <td>Pasivo</td>
                        <td>Sí</td>
                        <td>Activo</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>4.1.01</td>
                        <td>Ingresos por ventas</td>
                        <td>Ingreso</td>
                        <td>Acreedora</td>
                        <td>Ingresos</td>
                        <td>Sí</td>
                        <td>Activo</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

