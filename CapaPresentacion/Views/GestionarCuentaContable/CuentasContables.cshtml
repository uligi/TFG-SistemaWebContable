@{
    ViewBag.Title = "Cuentas Contables";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .codigo-cuenta {
        font-family: Consolas, monospace;
        font-weight: bold;
    }
    .contenedor-vista-cuentas {
        display: none;
    }

        .contenedor-vista-cuentas.activo {
            display: block;
        }

    .panel-arbol-cuentas {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        background: #ffffff;
        padding: 15px;
        max-height: 650px;
        overflow-y: auto;
    }

    .arbol-cuentas,
    .arbol-cuentas ul {
        list-style: none;
        padding-left: 0;
        margin: 0;
    }

        .arbol-cuentas ul {
            margin-left: 28px;
            border-left: 1px dashed #ced4da;
            padding-left: 16px;
        }

    .nodo-cuenta {
        margin-bottom: 6px;
    }

    .fila-nodo-cuenta {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 10px;
        border-radius: 6px;
        border: 1px solid #e9ecef;
        background: #f8f9fa;
        transition: all .15s ease-in-out;
    }

        .fila-nodo-cuenta:hover {
            background: #eef3ff;
            border-color: #b6ccff;
        }

    .btn-toggle-cuenta {
        border: none;
        background: transparent;
        width: 24px;
        height: 24px;
        font-weight: bold;
        color: #495057;
        cursor: pointer;
        line-height: 1;
    }

        .btn-toggle-cuenta:focus {
            outline: none;
        }

        .btn-toggle-cuenta.sin-hijos {
            visibility: hidden;
        }

    .codigo-nodo-cuenta {
        font-family: Consolas, monospace;
        font-weight: bold;
        color: #0d6efd;
        min-width: 80px;
    }

    .nombre-nodo-cuenta {
        font-weight: 600;
        color: #212529;
        flex: 1;
    }

    .badge-nivel-cuenta {
        background: #e9ecef;
        color: #495057;
        font-size: 11px;
        padding: 4px 7px;
        border-radius: 20px;
    }

    .acciones-nodo-cuenta .btn {
        padding: 2px 7px;
        font-size: 12px;
    }

    .hijos-cuenta.oculto {
        display: none;
    }

    .leyenda-arbol {
        font-size: 13px;
        color: #6c757d;
        margin-bottom: 12px;
    }

    .mensaje-operacion {
        display: none;
        border-radius: 8px;
        padding: 12px 15px;
        margin-bottom: 15px;
        font-size: 14px;
        font-weight: 600;
        border-left: 5px solid transparent;
    }

        .mensaje-operacion.exito {
            display: block;
            background: #eaf7ee;
            color: #1f7a3f;
            border-left-color: #28a745;
        }

        .mensaje-operacion.error {
            display: block;
            background: #fdecea;
            color: #b02a37;
            border-left-color: #dc3545;
        }

        .mensaje-operacion.advertencia {
            display: block;
            background: #fff8e1;
            color: #8a6d1d;
            border-left-color: #ffc107;
        }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Cuentas Contables</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Cuentas contables</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-center">
        <div>
            <h6 class="mb-1">Catálogo de cuentas contables</h6>
            <span class="text-muted small">
                Visualización jerárquica y mantenimiento del catálogo contable.
            </span>
        </div>

        <div class="mt-2 mt-md-0">
            <div class="btn-group mr-2" role="group">
                <button type="button" id="btnVistaArbol" class="btn btn-outline-primary btn-sm active" onclick="cambiarVistaCuentas('arbol')">
                    Vista árbol
                </button>
                <button type="button" id="btnVistaTabla" class="btn btn-outline-primary btn-sm" onclick="cambiarVistaCuentas('tabla')">
                    Vista tabla
                </button>
            </div>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nueva cuenta
            </button>
        </div>
    </div>

    <div class="card-body">

        <div id="mensajeOperacion" class="mensaje-operacion"></div>

        <div id="vistaArbolCuentas" class="contenedor-vista-cuentas activo">
            <div class="leyenda-arbol">
                La vista árbol muestra la jerarquía del catálogo contable a partir de la cuenta padre de cada registro.
                Las cuentas marcadas como “Acepta movimientos” representan cuentas finales para registrar operaciones.
            </div>

            <div class="panel-arbol-cuentas">
                <ul id="arbolCuentas" class="arbol-cuentas"></ul>
            </div>
        </div>

        <div id="vistaTablaCuentas" class="contenedor-vista-cuentas">
            <div class="table-responsive">
                <table class="table table-striped table-bordered nowrap" id="tablaCuentas" style="width:100%;">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Cuenta</th>
                            <th>Tipo</th>
                            <th>Naturaleza</th>
                            <th>Cuenta padre</th>
                            <th>Acepta movimientos</th>
                            <th>Estado</th>
                            <th style="width:170px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nueva cuenta contable</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtEsEdicion" value="false" />

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

                <div class="form-group">
                    <label for="cboCuentaPadre">Cuenta padre</label>
                    <select id="cboCuentaPadre" class="form-control">
                        <option value="0">Cuenta raíz</option>
                    </select>
                    <small class="form-text text-muted">
                        Si la cuenta no tiene padre, seleccione Cuenta raíz.
                    </small>
                </div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label for="txtCodigoCuenta">Código de cuenta</label>
                            <input type="text" id="txtCodigoCuenta" class="form-control codigo-cuenta" maxlength="45" autocomplete="off" />
                            <small class="form-text text-muted">
                                Puede generarse automáticamente según la cuenta padre.
                            </small>
                        </div>
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-group w-100">
                            <button type="button" id="btnGenerarCodigo" class="btn btn-outline-secondary btn-block" onclick="generarCodigoCuenta()">
                                Generar código
                            </button>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info" id="mensajeLlavePrimaria" style="display:none;">
                    El código de cuenta no se puede cambiar porque es la llave principal.
                </div>

                <div class="form-group">
                    <label for="txtNombreCuenta">Nombre de cuenta</label>
                    <input type="text" id="txtNombreCuenta" class="form-control" maxlength="100" autocomplete="off" />
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="cboTipoCuentaContable">Tipo de cuenta</label>
                            <select id="cboTipoCuentaContable" class="form-control">
                                <option value="0">Seleccione</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="cboNaturalezaCuentaContable">Naturaleza</label>
                            <select id="cboNaturalezaCuentaContable" class="form-control">
                                <option value="0">Seleccione</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="cboAceptaMovimientos">Acepta movimientos</label>
                    <select id="cboAceptaMovimientos" class="form-control">
                        <option value="false">No</option>
                        <option value="true">Sí</option>
                    </select>
                    <small class="form-text text-muted">
                        Solo las cuentas finales deberían aceptar movimientos contables.
                    </small>
                </div>

                <div class="form-group" id="grupoActivo">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarCuenta()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaCuentas = [];
        var tablaCuentas = null;
        var vistaActualCuentas = "arbol";

        $(document).ready(function () {
            cargarTiposCuentaContable();
            cargarNaturalezasCuentaContable();
            cargarCuentas();

            $("#txtCodigoCuenta").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(/[^0-9A-Za-z.\-_]/g, "");

                if (valor.length > 45) {
                    valor = valor.substring(0, 45);
                }

                $(this).val(valor);
            });

            $("#txtNombreCuenta").on("input", function () {
                limpiarTextoGeneral("txtNombreCuenta", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 100) {
                    $(this).val($(this).val().substring(0, 100));
                    mostrarAyudaCampo("txtNombreCuenta", "El nombre de cuenta no puede superar los 100 caracteres.");
                }
            });

            $("input, select").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                limpiarErrores();
            });
        });

        function cargarCuentas() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContables", "GestionarCuentaContable")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCuentas = respuesta.data || [];
                    pintarArbolCuentas();
                    pintarTabla();
                    cargarComboCuentaPadre();
                },
                error: function () {
                    alert("Error al cargar las cuentas contables.");
                }
            });
        }
        function cambiarVistaCuentas(vista) {
            vistaActualCuentas = vista;

            $("#vistaArbolCuentas").removeClass("activo");
            $("#vistaTablaCuentas").removeClass("activo");

            $("#btnVistaArbol").removeClass("active");
            $("#btnVistaTabla").removeClass("active");

            if (vista === "arbol") {
                $("#vistaArbolCuentas").addClass("activo");
                $("#btnVistaArbol").addClass("active");
            } else {
                $("#vistaTablaCuentas").addClass("activo");
                $("#btnVistaTabla").addClass("active");

                if (tablaCuentas != null) {
                    setTimeout(function () {
                        tablaCuentas.columns.adjust();
                    }, 150);
                }
            }
        }

        function pintarArbolCuentas() {
            var contenedor = $("#arbolCuentas");
            contenedor.empty();

            var cuentas = $.grep(listaCuentas, function (item) {
                return item.CodigoCuenta !== "0";
            });

            if (cuentas.length === 0) {
                contenedor.append(
                    $("<li>").addClass("text-muted").text("No hay cuentas contables registradas.")
                );
                return;
            }

            var mapa = {};
            var raices = [];

            $.each(cuentas, function (i, cuenta) {
                cuenta.Hijos = [];
                mapa[cuenta.CodigoCuenta] = cuenta;
            });

            $.each(cuentas, function (i, cuenta) {
                var codigoPadre = cuenta.CodigoCuentaPadre || "0";

                if (codigoPadre !== "0" && mapa[codigoPadre]) {
                    mapa[codigoPadre].Hijos.push(cuenta);
                } else {
                    raices.push(cuenta);
                }
            });

            ordenarCuentasJerarquicas(raices);

            $.each(raices, function (i, cuenta) {
                contenedor.append(crearNodoCuenta(cuenta, 1));
            });
        }

        function ordenarCuentasJerarquicas(lista) {
            lista.sort(function (a, b) {
                return compararCodigosCuenta(a.CodigoCuenta, b.CodigoCuenta);
            });

            $.each(lista, function (i, cuenta) {
                if (cuenta.Hijos && cuenta.Hijos.length > 0) {
                    ordenarCuentasJerarquicas(cuenta.Hijos);
                }
            });
        }

        function compararCodigosCuenta(a, b) {
            var partesA = (a || "").split(".");
            var partesB = (b || "").split(".");
            var max = Math.max(partesA.length, partesB.length);

            for (var i = 0; i < max; i++) {
                var valorA = partesA[i] || "0";
                var valorB = partesB[i] || "0";

                var numeroA = parseInt(valorA, 10);
                var numeroB = parseInt(valorB, 10);

                if (!isNaN(numeroA) && !isNaN(numeroB)) {
                    if (numeroA !== numeroB) {
                        return numeroA - numeroB;
                    }
                } else {
                    var comparacion = valorA.localeCompare(valorB);
                    if (comparacion !== 0) {
                        return comparacion;
                    }
                }
            }

            return 0;
        }

        function crearNodoCuenta(cuenta, nivel) {
            var tieneHijos = cuenta.Hijos && cuenta.Hijos.length > 0;

            var li = $("<li>").addClass("nodo-cuenta");
            var fila = $("<div>").addClass("fila-nodo-cuenta");

            var botonToggle = $("<button>", {
                type: "button",
                class: tieneHijos ? "btn-toggle-cuenta" : "btn-toggle-cuenta sin-hijos",
                text: tieneHijos ? "−" : ""
            });

            var codigo = $("<span>")
                .addClass("codigo-nodo-cuenta")
                .text(cuenta.CodigoCuenta);

            var nombre = $("<span>")
                .addClass("nombre-nodo-cuenta")
                .text(cuenta.NombreCuenta);

            var nivelBadge = $("<span>")
                .addClass("badge-nivel-cuenta")
                .text("Nivel " + nivel);

            var badgeTipo = $("<span>")
                .addClass("badge badge-info")
                .text(cuenta.TipoCuentaContableNombre || "Sin tipo");

            var badgeMovimiento = cuenta.AceptaMovimientos
                ? $("<span>").addClass("badge badge-primary").text("Acepta movimientos")
                : $("<span>").addClass("badge badge-light").text("Agrupadora");

            var badgeEstado = cuenta.Activo
                ? $("<span>").addClass("badge badge-success").text("Activa")
                : $("<span>").addClass("badge badge-secondary").text("Inactiva");

            var acciones = $("<span>").addClass("acciones-nodo-cuenta ml-auto");

            var botonEditar = $("<button>", {
                type: "button",
                class: "btn btn-outline-primary btn-sm mr-1",
                text: "Editar"
            }).on("click", function () {
                abrirModal(cuenta);
            });

            acciones.append(botonEditar);

            if (cuenta.Activo) {
                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-outline-danger btn-sm",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarCuenta(cuenta.CodigoCuenta);
                });

                acciones.append(botonInactivar);
            }

            fila.append(botonToggle);
            fila.append(codigo);
            fila.append(nombre);
            fila.append(nivelBadge);
            fila.append(badgeTipo);
            fila.append(badgeMovimiento);
            fila.append(badgeEstado);
            fila.append(acciones);

            li.append(fila);

            if (tieneHijos) {
                var ulHijos = $("<ul>").addClass("hijos-cuenta");

                $.each(cuenta.Hijos, function (i, hijo) {
                    ulHijos.append(crearNodoCuenta(hijo, nivel + 1));
                });

                li.append(ulHijos);

                botonToggle.on("click", function () {
                    ulHijos.toggleClass("oculto");
                    botonToggle.text(ulHijos.hasClass("oculto") ? "+" : "−");
                });
            }

            return li;
        }

        function pintarTabla() {
            if (tablaCuentas != null) {
                tablaCuentas.clear().destroy();
                tablaCuentas = null;
            }

            var tbody = $("#tablaCuentas tbody");
            tbody.empty();

            $.each(listaCuentas, function (i, item) {
                if (item.CodigoCuenta === "0") {
                    return true;
                }

                var codigoCuenta = item.CodigoCuenta || "";
                var nombreCuenta = item.NombreCuenta || "";
                var tipo = item.TipoCuentaContableNombre || "-";
                var naturaleza = item.NaturalezaCuentaContableNombre || "-";

                var cuentaPadre = "";
                if (item.CodigoCuentaPadre && item.CodigoCuentaPadre !== "0") {
                    cuentaPadre = item.CodigoCuentaPadre + " - " + (item.NombreCuentaPadre || "");
                } else {
                    cuentaPadre = "Cuenta raíz";
                }

                var aceptaMovimientos = item.AceptaMovimientos
                    ? '<span class="badge badge-primary">Sí</span>'
                    : '<span class="badge badge-light">No</span>';

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarCuenta(item.CodigoCuenta);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var celdaCodigo = $("<td>", {
                    class: "codigo-cuenta",
                    text: codigoCuenta
                });

                var celdaCuenta = $("<td>");
                celdaCuenta.append($("<div>").text(nombreCuenta));
                celdaCuenta.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: "Código: " + codigoCuenta
                }));

                var fila = $("<tr>");
                fila.append(celdaCodigo);
                fila.append(celdaCuenta);
                fila.append($("<td>").text(tipo));
                fila.append($("<td>").text(naturaleza));
                fila.append($("<td>").text(cuentaPadre));
                fila.append($("<td>").html(aceptaMovimientos));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaCuentas = $("#tablaCuentas").DataTable({
                pageLength: 10,
                destroy: true,
                autoWidth: false,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

            if (vistaActualCuentas === "tabla") {
                setTimeout(function () {
                    tablaCuentas.columns.adjust();
                }, 150);
            }
        }

        function cargarComboCuentaPadre() {
            var valorActual = $("#cboCuentaPadre").val();

            $("#cboCuentaPadre").empty();
            $("#cboCuentaPadre").append('<option value="0">Cuenta raíz</option>');

            $.each(listaCuentas, function (i, item) {
                if (item.CodigoCuenta !== "0" && item.Activo && !item.AceptaMovimientos) {
                    $("#cboCuentaPadre").append(
                        $("<option>", {
                            value: item.CodigoCuenta,
                            text: obtenerTextoCuentaPadre(item)
                        })
                    );
                }
            });

            if (valorActual) {
                $("#cboCuentaPadre").val(valorActual);
            }
        }

        function obtenerTextoCuentaPadre(item) {
            var nivel = obtenerNivelCuenta(item.CodigoCuenta);
            var sangria = "";

            for (var i = 1; i < nivel; i++) {
                sangria += "— ";
            }

            return sangria + item.CodigoCuenta + " - " + item.NombreCuenta;
        }

        function obtenerNivelCuenta(codigoCuenta) {
            if (!codigoCuenta || codigoCuenta === "0") {
                return 0;
            }

            return codigoCuenta.split(".").length;
        }

        function cargarTiposCuentaContable() {
            $.ajax({
                url: '@Url.Action("ListarTiposCuentaContable", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoCuentaContable").empty();
                    $("#cboTipoCuentaContable").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoCuentaContable").append(
                                $("<option>", {
                                    value: item.IdTipoCuentaContable,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    alert("Error al cargar los tipos de cuenta contable.");
                }
            });
        }

        function cargarNaturalezasCuentaContable() {
            $.ajax({
                url: '@Url.Action("ListarNaturalezasCuentaContable", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboNaturalezaCuentaContable").empty();
                    $("#cboNaturalezaCuentaContable").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        if (item.Activo) {
                            $("#cboNaturalezaCuentaContable").append(
                                $("<option>", {
                                    value: item.IdNaturalezaCuentaContable,
                                    text: item.Naturaleza || item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    alert("Error al cargar las naturalezas de cuenta contable.");
                }
            });
        }

        function abrirModal(json) {
            limpiarErrores();
            ocultarMensajeOperacion();

            $("#txtEsEdicion").val("false");

            $("#txtCodigoCuenta").val("");
            $("#txtCodigoCuenta").prop("disabled", false);
            $("#btnGenerarCodigo").prop("disabled", false);

            $("#txtNombreCuenta").val("");
            $("#cboTipoCuentaContable").val("0");
            $("#cboNaturalezaCuentaContable").val("0");
            $("#cboAceptaMovimientos").val("false");
            $("#cboActivo").val("true");
            $("#cboCuentaPadre").val("0");

            $("#grupoActivo").hide();
            $("#mensajeLlavePrimaria").hide();

            $("#tituloModal").text("Nueva cuenta contable");

            if (json != null) {
                $("#txtEsEdicion").val("true");

                $("#txtCodigoCuenta").val(json.CodigoCuenta || "");
                $("#txtCodigoCuenta").prop("disabled", true);
                $("#btnGenerarCodigo").prop("disabled", true);

                $("#txtNombreCuenta").val(json.NombreCuenta || "");
                $("#cboTipoCuentaContable").val(json.IdTipoCuentaContable);
                $("#cboNaturalezaCuentaContable").val(json.IdNaturalezaCuentaContable);
                $("#cboAceptaMovimientos").val(json.AceptaMovimientos ? "true" : "false");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#cboCuentaPadre").val(json.CodigoCuentaPadre || "0");

                $("#grupoActivo").show();
                $("#mensajeLlavePrimaria").show();

                $("#tituloModal").text("Editar cuenta contable");
            }

            $("#FormModal").modal("show");
        }

        function generarCodigoCuenta() {
            $("#mensajeError").hide().text("");

            var codigoCuentaPadre = $("#cboCuentaPadre").val();

            if (codigoCuentaPadre == null || codigoCuentaPadre === "") {
                codigoCuentaPadre = "0";
            }

            $.ajax({
                url: '@Url.Action("GenerarCodigoCuentaContable", "GestionarCuentaContable")',
                type: "GET",
                data: { codigoCuentaPadre: codigoCuentaPadre },
                dataType: "json",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#txtCodigoCuenta").val(respuesta.codigoGenerado || "");
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al generar el código de cuenta.").show();
                }
            });
        }

        function guardarCuenta() {
            $("#mensajeError").hide().text("");

            var obj = {
                CodigoCuenta: $("#txtCodigoCuenta").val().trim(),
                NombreCuenta: $("#txtNombreCuenta").val().trim(),
                IdTipoCuentaContable: parseInt($("#cboTipoCuentaContable").val()),
                IdNaturalezaCuentaContable: parseInt($("#cboNaturalezaCuentaContable").val()),
                AceptaMovimientos: $("#cboAceptaMovimientos").val() === "true",
                Activo: $("#cboActivo").val() === "true",
                CodigoCuentaPadre: $("#cboCuentaPadre").val()
            };

            if (obj.CodigoCuentaPadre == null || obj.CodigoCuentaPadre === "") {
                obj.CodigoCuentaPadre = "0";
            }

            if (isNaN(obj.IdTipoCuentaContable)) {
                obj.IdTipoCuentaContable = 0;
            }

            if (isNaN(obj.IdNaturalezaCuentaContable)) {
                obj.IdNaturalezaCuentaContable = 0;
            }

            if (obj.CodigoCuenta === "") {
                mostrarError("Debe ingresar el código de cuenta.", "txtCodigoCuenta");
                return;
            }

            if (!validarCodigoCuenta(obj.CodigoCuenta)) {
                mostrarError("El código de cuenta solo puede contener letras, números, puntos, guiones y guion bajo.", "txtCodigoCuenta");
                return;
            }

            if (obj.CodigoCuenta === "0") {
                mostrarError("No se puede registrar o editar la cuenta raíz del sistema.", "txtCodigoCuenta");
                return;
            }
            var esEdicion = $("#txtEsEdicion").val() === "true";

            if (!esEdicion && existeCodigoCuenta(obj.CodigoCuenta)) {
                mostrarError("Ya existe una cuenta contable con ese código. Ingrese un código diferente.", "txtCodigoCuenta");
                return;
            }

            if (obj.NombreCuenta === "") {
                mostrarError("Debe ingresar el nombre de la cuenta.", "txtNombreCuenta");
                return;
            }

            if (!validarTextoGeneral(obj.NombreCuenta)) {
                mostrarError("El nombre de la cuenta solo puede contener letras, números, espacios y caracteres básicos.", "txtNombreCuenta");
                return;
            }

            if (obj.NombreCuenta.length > 100) {
                mostrarError("El nombre de la cuenta no puede superar los 100 caracteres.", "txtNombreCuenta");
                return;
            }

            if (obj.IdTipoCuentaContable <= 0) {
                mostrarError("Debe seleccionar un tipo de cuenta contable.", "cboTipoCuentaContable");
                return;
            }

            if (obj.IdNaturalezaCuentaContable <= 0) {
                mostrarError("Debe seleccionar una naturaleza de cuenta contable.", "cboNaturalezaCuentaContable");
                return;
            }

            if (!validarCodigoCuenta(obj.CodigoCuentaPadre)) {
                mostrarError("El código de cuenta padre tiene un formato inválido.", "cboCuentaPadre");
                return;
            }

            if (obj.CodigoCuentaPadre === obj.CodigoCuenta) {
                mostrarError("Una cuenta no puede ser su propia cuenta padre.", "cboCuentaPadre");
                return;
            }
            if (obj.AceptaMovimientos && tieneCuentasHijas(obj.CodigoCuenta)) {
                mostrarError("Esta cuenta tiene cuentas hijas, por lo que no puede aceptar movimientos.", "cboAceptaMovimientos");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCuentaContable", "GestionarCuentaContable")',
                type: "POST",
                data: JSON.stringify({
                    obj: obj,
                    esEdicion: $("#txtEsEdicion").val() === "true"
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        var esEdicion = $("#txtEsEdicion").val() === "true";

                        $("#FormModal").modal("hide");

                        cargarCuentas();

                        if (esEdicion) {
                            mostrarMensajeOperacion("exito", "Cuenta contable actualizada correctamente.");
                        } else {
                            mostrarMensajeOperacion("exito", "Cuenta contable registrada correctamente.");
                        }
                    } else {
                        $("#mensajeError").text(respuesta.mensaje || "No se pudo guardar la cuenta contable.").show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar la cuenta contable.").show();
                }
            });
        }

        function inactivarCuenta(codigoCuenta) {
            if (!confirm("¿Desea inactivar esta cuenta contable?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarCuentaContable", "GestionarCuentaContable")',
                type: "POST",
                data: JSON.stringify({ codigoCuenta: codigoCuenta }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarCuentas();
                        mostrarMensajeOperacion("exito", "Cuenta contable inactivada correctamente.");
                    } else {
                        mostrarMensajeOperacion("error", respuesta.mensaje || "No se pudo inactivar la cuenta contable.");
                    }
                },
                error: function () {
                    mostrarMensajeOperacion("error", "Error al inactivar la cuenta contable.");
                }
            });
        }
        function tieneCuentasHijas(codigoCuenta) {
            var tieneHijas = false;

            $.each(listaCuentas, function (i, item) {
                if (item.CodigoCuentaPadre === codigoCuenta && item.Activo) {
                    tieneHijas = true;
                    return false;
                }
            });

            return tieneHijas;
        }

        function mostrarMensajeOperacion(tipo, mensaje) {
            var contenedor = $("#mensajeOperacion");

            contenedor
                .removeClass("exito error advertencia")
                .addClass(tipo)
                .html(mensaje)
                .fadeIn(150);

            setTimeout(function () {
                contenedor.fadeOut(300);
            }, 5000);
        }

        function ocultarMensajeOperacion() {
            $("#mensajeOperacion")
                .removeClass("exito error advertencia")
                .hide()
                .html("");
        }
        function existeCodigoCuenta(codigoCuenta) {
            var existe = false;

            $.each(listaCuentas, function (i, item) {
                if ((item.CodigoCuenta || "").toLowerCase() === (codigoCuenta || "").toLowerCase()) {
                    existe = true;
                    return false;
                }
            });

            return existe;
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarErrores() {
            $("#mensajeError").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoGeneral(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function validarCodigoCuenta(valor) {
            return /^[0-9A-Za-z.\-_]+$/.test(valor);
        }
    </script>
}