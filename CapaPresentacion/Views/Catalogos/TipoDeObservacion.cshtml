
@{
    ViewBag.Title = "TipoDeObservacion";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Tipos de Observación</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Catálogos</li>
        <li class="breadcrumb-item active">Tipos de observación</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de tipos de observación</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo tipo
        </button>
    </div>

    <div class="card-body">


        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaTipoDeObservaciones" style="width:100%;">
                <thead>
                    <tr>
                        <th>Tipo de observación</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo tipo de observación</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdTipoDeObservacion" value="0" />

                <div class="form-group">
                    <label for="txtTipoDeObservacion">Nombre del tipo de observación</label>
                    <input type="text" id="txtTipoDeObservacion" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="150" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 150 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarTipoDeObservacion()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaTipoDeObservaciones = [];
        var tablaTipoDeObservaciones = null;

        $(document).ready(function () {
            cargarTipoDeObservaciones();

            $("#txtTipoDeObservacion").on("input", function () {
                limpiarTextoCatalogo("txtTipoDeObservacion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtTipoDeObservacion", "El tipo de observación no puede superar los 45 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoCatalogo("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 150 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtTipoDeObservacion");
                ocultarAyudaCampo("txtDescripcion");
            });
        });

        function cargarTipoDeObservaciones() {
            $.ajax({
                url: '@Url.Action("ListarTipoDeObservaciones", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaTipoDeObservaciones = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los tipos de observación.");
                }
            });
        }

        function pintarTabla() {
            if (tablaTipoDeObservaciones != null) {
                tablaTipoDeObservaciones.clear().destroy();
                tablaTipoDeObservaciones = null;
            }

            var tbody = $("#tablaTipoDeObservaciones tbody");
            tbody.empty();

            $.each(listaTipoDeObservaciones, function (i, item) {
                var nombre = item.Tipo_Observacion || "";
                var descripcion = item.Descripcion || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var descripcionMostrar = descripcion === "" ? "-" : descripcion;

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarTipoDeObservacion(item.IdTipoDeObservacion);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonInactivar);

                var fila = $("<tr>");
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").text(descripcionMostrar));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaTipoDeObservaciones = $("#tablaTipoDeObservaciones").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtTipoDeObservacion");
            ocultarAyudaCampo("txtDescripcion");

            $("#txtIdTipoDeObservacion").val(0);
            $("#txtTipoDeObservacion").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo tipo de observación");

            if (json != null) {
                $("#txtIdTipoDeObservacion").val(json.IdTipoDeObservacion);
                $("#txtTipoDeObservacion").val(json.Tipo_Observacion || "");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar tipo de observación");
            }

            $("#FormModal").modal("show");
        }

        function guardarTipoDeObservacion() {
            $("#mensajeError").hide().text("");

            var obj = {
                IdTipoDeObservacion: parseInt($("#txtIdTipoDeObservacion").val()),
                Tipo_Observacion: $("#txtTipoDeObservacion").val().trim(),
                Descripcion: $("#txtDescripcion").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoDeObservacion)) {
                obj.IdTipoDeObservacion = 0;
            }

            if (obj.Tipo_Observacion === "") {
                mostrarError("Debe ingresar el nombre del tipo de observación.", "txtTipoDeObservacion");
                return;
            }

            if (!validarTextoCatalogo(obj.Tipo_Observacion)) {
                mostrarError("El tipo de observación solo puede contener letras, números, espacios y caracteres básicos.", "txtTipoDeObservacion");
                return;
            }

            if (obj.Tipo_Observacion.length > 45) {
                mostrarError("El tipo de observación no puede superar los 45 caracteres.", "txtTipoDeObservacion");
                return;
            }

            if (obj.Descripcion === "") {
                mostrarError("Debe ingresar la descripción.", "txtDescripcion");
                return;
            }

            if (!validarTextoCatalogo(obj.Descripcion)) {
                mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
                return;
            }

            if (obj.Descripcion.length > 150) {
                mostrarError("La descripción no puede superar los 150 caracteres.", "txtDescripcion");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTipoDeObservacion", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (obj.IdTipoDeObservacion === 0) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarTipoDeObservaciones();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarTipoDeObservaciones();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el tipo de observación.").show();
                }
            });
        }

        function inactivarTipoDeObservacion(id) {
            if (!confirm("¿Desea inactivar este tipo de observación?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarTipoDeObservacion", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarTipoDeObservaciones();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el tipo de observación.");
                }
            });
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoCatalogo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoCatalogo(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }
    </script>
}