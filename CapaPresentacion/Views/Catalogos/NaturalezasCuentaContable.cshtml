@{
    ViewBag.Title = "NaturalezasCuentaContable";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Naturalezas de Cuenta Contable</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Catálogos</li>
        <li class="breadcrumb-item active">Naturalezas de cuenta contable</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de naturalezas contables</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nueva naturaleza
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaNaturalezas" style="width:100%;">
                <thead>
                    <tr>
                        <th>Naturaleza</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nueva naturaleza</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdNaturalezaCuentaContable" value="0" />

                <div class="form-group">
                    <label for="txtNaturaleza">Naturaleza</label>
                    <input type="text" id="txtNaturaleza" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="255" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 255 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarNaturaleza()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaNaturalezas = [];
        var tablaNaturalezas = null;

        $(document).ready(function () {
            cargarNaturalezas();

            $("#txtNaturaleza").on("input", function () {
                limpiarTextoCatalogo("txtNaturaleza", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtNaturaleza", "La naturaleza no puede superar los 45 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoCatalogo("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 255) {
                    $(this).val($(this).val().substring(0, 255));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 255 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtNaturaleza");
                ocultarAyudaCampo("txtDescripcion");
            });
        });

        function cargarNaturalezas() {
            $.ajax({
                url: '@Url.Action("ListarNaturalezasCuentaContable", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaNaturalezas = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar las naturalezas contables.");
                }
            });
        }

        function pintarTabla() {
            if (tablaNaturalezas != null) {
                tablaNaturalezas.clear().destroy();
                tablaNaturalezas = null;
            }

            var tbody = $("#tablaNaturalezas tbody");
            tbody.empty();

            $.each(listaNaturalezas, function (i, item) {
                var naturaleza = item.Naturaleza || "";
                var descripcion = item.Descripcion || "";
                var descripcionMostrar = descripcion === "" ? "-" : descripcion;

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarNaturaleza(item.IdNaturalezaCuentaContable);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(naturaleza));
                fila.append($("<td>").text(descripcionMostrar));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaNaturalezas = $("#tablaNaturalezas").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtNaturaleza");
            ocultarAyudaCampo("txtDescripcion");

            $("#txtIdNaturalezaCuentaContable").val(0);
            $("#txtNaturaleza").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nueva naturaleza");

            if (json != null) {
                $("#txtIdNaturalezaCuentaContable").val(json.IdNaturalezaCuentaContable);
                $("#txtNaturaleza").val(json.Naturaleza || "");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar naturaleza");
            }

            $("#FormModal").modal("show");
        }

        function guardarNaturaleza() {
            $("#mensajeError").hide().text("");

            var obj = {
                IdNaturalezaCuentaContable: parseInt($("#txtIdNaturalezaCuentaContable").val()),
                Naturaleza: $("#txtNaturaleza").val().trim(),
                Descripcion: $("#txtDescripcion").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdNaturalezaCuentaContable)) {
                obj.IdNaturalezaCuentaContable = 0;
            }

            if (obj.Naturaleza === "") {
                mostrarError("Debe ingresar la naturaleza.", "txtNaturaleza");
                return;
            }

            if (!validarTextoCatalogo(obj.Naturaleza)) {
                mostrarError("La naturaleza solo puede contener letras, números, espacios y caracteres básicos.", "txtNaturaleza");
                return;
            }

            if (obj.Naturaleza.length > 45) {
                mostrarError("La naturaleza no puede superar los 45 caracteres.", "txtNaturaleza");
                return;
            }

            if (obj.Descripcion === "") {
                mostrarError("Debe ingresar la descripción.", "txtDescripcion");
                return;
            }

            if (!validarTextoCatalogo(obj.Descripcion)) {
                mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
                return;
            }

            if (obj.Descripcion.length > 255) {
                mostrarError("La descripción no puede superar los 255 caracteres.", "txtDescripcion");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarNaturalezaCuentaContable", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarNaturalezas();
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar la naturaleza contable.").show();
                }
            });
        }

        function inactivarNaturaleza(idNaturalezaCuentaContable) {
            if (!confirm("¿Desea inactivar esta naturaleza?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarNaturalezaCuentaContable", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ idNaturalezaCuentaContable: idNaturalezaCuentaContable }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarNaturalezas();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar la naturaleza contable.");
                }
            });
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoCatalogo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoCatalogo(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }
    </script>
}