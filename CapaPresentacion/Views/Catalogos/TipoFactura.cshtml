@{
    ViewBag.Title = "Tipos de factura";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Tipos de Factura</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Catálogos</li>
        <li class="breadcrumb-item active">Tipos de factura</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de tipos de factura</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo tipo
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaTipoFacturas" style="width:100%;">
                <thead>
                    <tr>
                        <th>Tipo de factura</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo tipo de factura</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdTipoFactura" value="0" />

                <div class="form-group">
                    <label for="txtTipoFactura">Nombre del tipo de factura</label>
                    <input type="text" id="txtTipoFactura" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="150" rows="3" autocomplete="off"></textarea>
                    <small class="form-text text-muted">Máximo 150 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarTipoFactura()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaTipoFacturas = [];
        var tablaTipoFacturas = null;

        $(document).ready(function () {
            cargarTipoFacturas();

            $("#txtTipoFactura").on("input", function () {
                limpiarTextoCatalogo("txtTipoFactura", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtTipoFactura", "El tipo de factura no puede superar los 45 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoCatalogo("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 150 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtTipoFactura");
                ocultarAyudaCampo("txtDescripcion");
            });
        });

        function cargarTipoFacturas() {
            $.ajax({
                url: '@Url.Action("ListarTipoFacturas", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaTipoFacturas = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de factura.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaTipoFacturas != null) {
                tablaTipoFacturas.clear().destroy();
                tablaTipoFacturas = null;
            }

            var tbody = $("#tablaTipoFacturas tbody");
            tbody.empty();

            $.each(listaTipoFacturas, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var nombre = item.Tipo_Factura || "";
                var descripcion = item.Descripcion || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var descripcionMostrar = descripcion === "" ? "-" : descripcion;

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarTipoFactura(item.IdTipoFactura);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").text(descripcionMostrar));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaTipoFacturas = $("#tablaTipoFacturas").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtTipoFactura");
            ocultarAyudaCampo("txtDescripcion");

            $("#txtIdTipoFactura").val(0);
            $("#txtTipoFactura").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo tipo de factura");

            if (json != null) {
                $("#txtIdTipoFactura").val(json.IdTipoFactura);
                $("#txtTipoFactura").val(json.Tipo_Factura || "");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar tipo de factura");
            }

            $("#FormModal").modal("show");
        }

        function guardarTipoFactura() {
            $("#mensajeError").hide().text("");

            var obj = {
                IdTipoFactura: parseInt($("#txtIdTipoFactura").val()),
                Tipo_Factura: $("#txtTipoFactura").val().trim(),
                Descripcion: $("#txtDescripcion").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoFactura)) {
                obj.IdTipoFactura = 0;
            }

            if (obj.Tipo_Factura === "") {
                mostrarError("Debe ingresar el nombre del tipo de factura.", "txtTipoFactura");
                return;
            }

            if (!validarTextoCatalogo(obj.Tipo_Factura)) {
                mostrarError("El tipo de factura solo puede contener letras, números, espacios y caracteres básicos.", "txtTipoFactura");
                return;
            }

            if (obj.Tipo_Factura.length > 45) {
                mostrarError("El tipo de factura no puede superar los 45 caracteres.", "txtTipoFactura");
                return;
            }

            if (obj.Descripcion.length > 150) {
                mostrarError("La descripción no puede superar los 150 caracteres.", "txtDescripcion");
                return;
            }

            if (obj.Descripcion !== "" && !validarTextoCatalogo(obj.Descripcion)) {
                mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTipoFactura", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarTipoFacturas();
                        mostrarMensajeSistema("Tipo de factura guardado correctamente.", "exito");
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el tipo de factura.").show();
                }
            });
        }

        function inactivarTipoFactura(idTipoFactura) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este tipo de factura"),
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarTipoFactura", "Catalogos")',
                        type: "POST",
                        data: JSON.stringify({ idTipoFactura: idTipoFactura }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                cargarTipoFacturas();
                                mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Tipo de factura"), "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el tipo de factura.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al procesar el tipo de factura.", "error");
                        }
                    });
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoCatalogo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoCatalogo(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }
    </script>
}