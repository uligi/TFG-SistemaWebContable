@{
    ViewBag.Title = "TipoProducto";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Tipos de Producto</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Catálogos</li>
        <li class="breadcrumb-item active">Tipos de producto</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de tipos de producto</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo tipo
        </button>
    </div>

    <div class="card-body">



        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaTipoProductos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Tipo de producto</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo tipo de producto</h5>

                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdTipoProducto" value="0" />

                <div class="form-group">
                    <label for="txtNombre">Nombre del tipo de producto</label>
                    <input type="text"
                           id="txtNombre"
                           class="form-control"
                           maxlength="100"
                           autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion"
                              class="form-control"
                              maxlength="150"
                              rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 150 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>

                <button type="button" class="btn btn-primary" onclick="guardarTipoProducto()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaTipoProductos = [];
        var tablaTipoProductos = null;

        $(document).ready(function () {
            cargarTipoProductos();

            $("#txtNombre").on("input", function () {
                limpiarTextoCatalogo("txtNombre", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 100) {
                    $(this).val($(this).val().substring(0, 100));
                    mostrarAyudaCampo("txtNombre", "El nombre no puede superar los 100 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoCatalogo("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 150 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtNombre");
                ocultarAyudaCampo("txtDescripcion");
            });
        });

        function cargarTipoProductos() {
            $.ajax({
                url: '@Url.Action("ListarTipoProductos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaTipoProductos = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los tipos de producto.");
                }
            });
        }

        function pintarTabla() {
            if (tablaTipoProductos != null) {
                tablaTipoProductos.clear().destroy();
                tablaTipoProductos = null;
            }

            var tbody = $("#tablaTipoProductos tbody");
            tbody.empty();

            $.each(listaTipoProductos, function (i, item) {
                var nombre = item.TipoProductoNombre || "";
                var descripcion = item.Descripcion || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var descripcionMostrar = descripcion === "" ? "-" : descripcion;

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarTipoProducto(item.IdTipoProducto);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonInactivar);

                var fila = $("<tr>");
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").text(descripcionMostrar));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaTipoProductos = $("#tablaTipoProductos").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtNombre");
            ocultarAyudaCampo("txtDescripcion");

            $("#txtIdTipoProducto").val(0);
            $("#txtNombre").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo tipo de producto");

            if (json != null) {
                $("#txtIdTipoProducto").val(json.IdTipoProducto);
                $("#txtNombre").val(json.TipoProductoNombre || "");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar tipo de producto");
            }

            $("#FormModal").modal("show");
        }

        function guardarTipoProducto() {
            $("#mensajeError").hide().text("");

            var obj = {
                IdTipoProducto: parseInt($("#txtIdTipoProducto").val()),
                TipoProductoNombre: $("#txtNombre").val().trim(),
                Descripcion: $("#txtDescripcion").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoProducto)) {
                obj.IdTipoProducto = 0;
            }

            if (obj.TipoProductoNombre === "") {
                mostrarError("Debe ingresar el nombre del tipo de producto.", "txtNombre");
                return;
            }

            if (!validarTextoCatalogo(obj.TipoProductoNombre)) {
                mostrarError("El nombre solo puede contener letras, números, espacios y caracteres básicos.", "txtNombre");
                return;
            }

            if (obj.TipoProductoNombre.length > 100) {
                mostrarError("El nombre no puede superar los 100 caracteres.", "txtNombre");
                return;
            }

            if (obj.Descripcion !== "" && !validarTextoCatalogo(obj.Descripcion)) {
                mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
                return;
            }

            if (obj.Descripcion.length > 150) {
                mostrarError("La descripción no puede superar los 150 caracteres.", "txtDescripcion");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTipoProducto", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (obj.IdTipoProducto === 0) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarTipoProductos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarTipoProductos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el tipo de producto.").show();
                }
            });
        }

        function inactivarTipoProducto(id) {
            if (!confirm("¿Desea inactivar este tipo de producto?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarTipoProducto", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarTipoProductos();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el tipo de producto.");
                }
            });
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoCatalogo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoCatalogo(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }
    </script>
}