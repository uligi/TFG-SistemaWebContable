@{
    ViewBag.Title = "Tipos de Ingreso";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}
<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Tipos de Ingreso</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Catálogos</li>
        <li class="breadcrumb-item active">Tipos de Ingreso</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de tipos de ingreso</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo tipo de ingreso
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaTiposIngreso" style="width:100%">
                <thead>
                    <tr>
                        <th>Tipo de ingreso</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo tipo de ingreso</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdTipoIngreso" value="0" />

                <div class="form-group">
                    <label for="txtNombre">Tipo de ingreso</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="255" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 255 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarTipoIngreso()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var tablaData;
        var listaTiposIngreso = [];

        $(document).ready(function () {
            cargarTiposIngreso();

            $("#txtNombre").on("input", function () {
                limpiarTextoCatalogo("txtNombre", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtNombre", "El tipo de ingreso no puede superar los 45 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoCatalogo("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 255) {
                    $(this).val($(this).val().substring(0, 255));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 255 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtNombre");
                ocultarAyudaCampo("txtDescripcion");
            });
        });

        function cargarTiposIngreso() {
            $.ajax({
                url: '@Url.Action("ListarTiposIngreso", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaTiposIngreso = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los tipos de ingreso.");
                }
            });
        }

        function pintarTabla() {
            if ($.fn.DataTable.isDataTable("#tablaTiposIngreso")) {
                $("#tablaTiposIngreso").DataTable().destroy();
            }

            var tbody = $("#tablaTiposIngreso tbody");
            tbody.empty();

            $.each(listaTiposIngreso, function (i, item) {
                var nombre = item.Nombre || "";
                var descripcion = item.Descripcion || "";

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonInactivar = item.Activo
                    ? `<button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarTipoIngreso(${item.IdTipoIngreso})">Inactivar</button>`
                    : `<button type="button" class="btn btn-sm btn-outline-secondary" disabled>Inactivo</button>`;

                var fila = `
                    <tr>
                        <td>${nombre}</td>
                        <td>${descripcion}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="abrirModal(${i})">
                                Editar
                            </button>
                            ${botonInactivar}
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });

            tablaData = $("#tablaTiposIngreso").DataTable({
                responsive: true,
                ordering: true,
                pageLength: 10,
                lengthChange: true,
                searching: true,
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(index) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtNombre");
            ocultarAyudaCampo("txtDescripcion");

            $("#txtIdTipoIngreso").val(0);
            $("#txtNombre").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo tipo de ingreso");

            if (index != null) {
                var json = listaTiposIngreso[index];

                $("#txtIdTipoIngreso").val(json.IdTipoIngreso);
                $("#txtNombre").val(json.Nombre || "");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar tipo de ingreso");
            }

            $("#FormModal").modal("show");
        }

        function guardarTipoIngreso() {
    $("#mensajeError").hide().text("");

    var obj = {
        IdTipoIngreso: parseInt($("#txtIdTipoIngreso").val()),
        Nombre: $("#txtNombre").val().trim(),
        Descripcion: $("#txtDescripcion").val().trim(),
        Activo: $("#cboActivo").val() === "true"
    };

    if (isNaN(obj.IdTipoIngreso)) {
        obj.IdTipoIngreso = 0;
    }

    if (obj.Nombre === "") {
        mostrarError("Debe ingresar el tipo de ingreso.", "txtNombre");
        return;
    }

    if (!validarTextoCatalogo(obj.Nombre)) {
        mostrarError("El tipo de ingreso solo puede contener letras, números, espacios y caracteres básicos.", "txtNombre");
        return;
    }

    if (obj.Nombre.length > 45) {
        mostrarError("El tipo de ingreso no puede superar los 45 caracteres.", "txtNombre");
        return;
    }

    if (obj.Descripcion === "") {
        mostrarError("Debe ingresar la descripción.", "txtDescripcion");
        return;
    }

    if (!validarTextoCatalogo(obj.Descripcion)) {
        mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
        return;
    }

    if (obj.Descripcion.length > 255) {
        mostrarError("La descripción no puede superar los 255 caracteres.", "txtDescripcion");
        return;
    }

    $.ajax({
        url: '@Url.Action("GuardarTipoIngreso", "Catalogos")',
        type: "POST",
        data: JSON.stringify({ obj: obj }),
        dataType: "json",
        contentType: "application/json; charset=utf-8",
        success: function (respuesta) {
            if (respuesta.resultado) {
                $("#FormModal").modal("hide");
                cargarTiposIngreso();
            } else {
                $("#mensajeError").text(respuesta.mensaje).show();
            }
        },
        error: function () {
            $("#mensajeError").text("Error al guardar el tipo de ingreso.").show();
        }
    });
}

        function inactivarTipoIngreso(id) {
            if (!confirm("¿Desea inactivar este tipo de ingreso?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarTipoIngreso", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarTiposIngreso();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el tipo de ingreso.");
                }
            });
        }
        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoCatalogo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoCatalogo(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }
    </script>
}