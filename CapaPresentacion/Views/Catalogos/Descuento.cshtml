@{
    ViewBag.Title = "Descuentos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Descuentos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Catálogos</li>
        <li class="breadcrumb-item active">Descuentos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de descuentos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo descuento
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaDescuentos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Descuento</th>
                        <th>Porcentaje</th>
                        <th>Requiere autorización</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo descuento</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdDescuento" value="0" />

                <div class="form-group">
                    <label for="txtNombre">Nombre del descuento</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="100" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtPorcentaje">Porcentaje</label>
                    <input type="number" id="txtPorcentaje" class="form-control" min="0" max="100" step="0.01" autocomplete="off" />
                    <small class="form-text text-muted">Debe estar entre 0 y 100.</small>
                </div>

                <div class="form-group">
                    <label for="cboRequiereAutorizacion">Requiere autorización</label>
                    <select id="cboRequiereAutorizacion" class="form-control">
                        <option value="false">No</option>
                        <option value="true">Sí</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="255" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 255 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarDescuento()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaDescuentos = [];
        var tablaDescuentos = null;

        $(document).ready(function () {
            cargarDescuentos();

            $("#txtNombre").on("input", function () {
                limpiarTextoCatalogo("txtNombre", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 100) {
                    $(this).val($(this).val().substring(0, 100));
                    mostrarAyudaCampo("txtNombre", "El nombre del descuento no puede superar los 100 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoCatalogo("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 255) {
                    $(this).val($(this).val().substring(0, 255));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 255 caracteres.");
                }
            });

            $("#txtPorcentaje").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(",", ".");
                valor = valor.replace(/[^0-9.]/g, "");

                var partes = valor.split(".");
                if (partes.length > 2) {
                    valor = partes[0] + "." + partes[1];
                }

                if (partes.length === 2 && partes[1].length > 2) {
                    valor = partes[0] + "." + partes[1].substring(0, 2);
                }

                $(this).val(valor);
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
                ocultarAyudaCampo("txtNombre");
                ocultarAyudaCampo("txtPorcentaje");
                ocultarAyudaCampo("txtDescripcion");
            });
        });

        function cargarDescuentos() {
            $.ajax({
                url: '@Url.Action("ListarDescuentos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaDescuentos = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los descuentos.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaDescuentos != null) {
                tablaDescuentos.clear().destroy();
                tablaDescuentos = null;
            }

            var tbody = $("#tablaDescuentos tbody");
            tbody.empty();

            $.each(listaDescuentos, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }
                var nombre = item.Nombre || "";
                var porcentaje = parseFloat(item.Porcentaje || 0).toFixed(2);
                var requiereAutorizacion = item.RequiereAutorizacion
                    ? '<span class="badge badge-warning">Sí</span>'
                    : '<span class="badge badge-info">No</span>';

                var descripcion = item.Descripcion || "";
                var descripcionMostrar = descripcion === "" ? "-" : descripcion;

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarDescuento(item.IdDescuento);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(nombre));
                fila.append($("<td>").text(porcentaje + "%"));
                fila.append($("<td>").html(requiereAutorizacion));
                fila.append($("<td>").text(descripcionMostrar));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaDescuentos = $("#tablaDescuentos").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");
            ocultarAyudaCampo("txtNombre");
            ocultarAyudaCampo("txtPorcentaje");
            ocultarAyudaCampo("txtDescripcion");

            $("#txtIdDescuento").val(0);
            $("#txtNombre").val("");
            $("#txtPorcentaje").val("");
            $("#cboRequiereAutorizacion").val("false");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo descuento");

            if (json != null) {
                $("#txtIdDescuento").val(json.IdDescuento);
                $("#txtNombre").val(json.Nombre || "");
                $("#txtPorcentaje").val(parseFloat(json.Porcentaje || 0).toFixed(2));
                $("#cboRequiereAutorizacion").val(json.RequiereAutorizacion ? "true" : "false");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar descuento");
            }

            $("#FormModal").modal("show");
        }

        function guardarDescuento() {
            $("#mensajeError").hide().text("");

            var porcentaje = parseFloat($("#txtPorcentaje").val());

            var obj = {
                IdDescuento: parseInt($("#txtIdDescuento").val()),
                Nombre: $("#txtNombre").val().trim(),
                Porcentaje: porcentaje,
                RequiereAutorizacion: $("#cboRequiereAutorizacion").val() === "true",
                Descripcion: $("#txtDescripcion").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdDescuento)) {
                obj.IdDescuento = 0;
            }

            if (obj.Nombre === "") {
                mostrarError("Debe ingresar el nombre del descuento.", "txtNombre");
                return;
            }

            if (!validarTextoCatalogo(obj.Nombre)) {
                mostrarError("El nombre del descuento solo puede contener letras, números, espacios y caracteres básicos.", "txtNombre");
                return;
            }

            if (obj.Nombre.length > 100) {
                mostrarError("El nombre del descuento no puede superar los 100 caracteres.", "txtNombre");
                return;
            }

            if (isNaN(obj.Porcentaje)) {
                mostrarError("Debe ingresar el porcentaje del descuento.", "txtPorcentaje");
                return;
            }

            if (obj.Porcentaje < 0 || obj.Porcentaje > 100) {
                mostrarError("El porcentaje del descuento debe estar entre 0 y 100.", "txtPorcentaje");
                return;
            }

            if (obj.Descripcion === "") {
                mostrarError("Debe ingresar la descripción.", "txtDescripcion");
                return;
            }

            if (!validarTextoCatalogo(obj.Descripcion)) {
                mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
                return;
            }

            if (obj.Descripcion.length > 255) {
                mostrarError("La descripción no puede superar los 255 caracteres.", "txtDescripcion");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarDescuento", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarDescuentos();
                        mostrarMensajeSistema("Descuento guardado correctamente.", "exito");
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el descuento.").show();
                }
            });
        }

        function inactivarDescuento(idDescuento) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este descuento"),
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarDescuento", "Catalogos")',
                        type: "POST",
                        data: JSON.stringify({ idDescuento: idDescuento }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                cargarDescuentos();
                                mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Descuento"), "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el descuento.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al procesar el descuento.", "error");
                        }
                    });
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarTextoCatalogo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()%]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoCatalogo(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()%]+$/.test(valor);
        }
    </script>
}