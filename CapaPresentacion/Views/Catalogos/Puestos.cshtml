
@{
    ViewBag.Title = "Puestos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}


<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Puestos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Catálogos</li>
        <li class="breadcrumb-item active">Puestos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de puestos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo puesto
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar por puesto o descripción...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaPuestos">
                <thead>
                    <tr>
                        <th>Puesto</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo puesto</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdPuesto" value="0" />

                <div class="form-group">
                    <label for="txtNombre">Puesto</label>
                    <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="255" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 255 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarPuesto()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaPuestos = [];

        $(document).ready(function () {
            cargarPuestos();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });
        });

        function cargarPuestos() {
            $.ajax({
                url: '@Url.Action("ListarPuestos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaPuestos = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los puestos.");
                }
            });
        }

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaPuestos tbody");

            tbody.empty();

            $.each(listaPuestos, function (i, item) {
                var nombre = item.Nombre || "";
                var descripcion = item.Descripcion || "";

                var texto = (nombre + " " + descripcion).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var fila = `
                    <tr>
                        <td>${nombre}</td>
                        <td>${descripcion}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarPuesto(${item.IdPuesto})">
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtIdPuesto").val(0);
            $("#txtNombre").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo puesto");

            if (json != null) {
                $("#txtIdPuesto").val(json.IdPuesto);
                $("#txtNombre").val(json.Nombre || "");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar puesto");
            }

            $("#FormModal").modal("show");
        }

        function guardarPuesto() {
            var obj = {
                IdPuesto: parseInt($("#txtIdPuesto").val()),
                Nombre: $("#txtNombre").val().trim(),
                Descripcion: $("#txtDescripcion").val().trim(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (obj.Nombre === "") {
                $("#mensajeError").text("Debe ingresar el nombre del puesto.").show();
                return;
            }

            if (obj.Nombre.length > 45) {
                $("#mensajeError").text("El nombre del puesto no puede superar los 45 caracteres.").show();
                return;
            }

            if (obj.Descripcion === "") {
                $("#mensajeError").text("Debe ingresar la descripción.").show();
                return;
            }

            if (obj.Descripcion.length > 255) {
                $("#mensajeError").text("La descripción no puede superar los 255 caracteres.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarPuesto", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#FormModal").modal("hide");
                        cargarPuestos();
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el puesto.").show();
                }
            });
        }

        function inactivarPuesto(id) {
            if (!confirm("¿Desea inactivar este puesto?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarPuesto", "Catalogos")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarPuestos();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el puesto.");
                }
            });
        }
    </script>
}
