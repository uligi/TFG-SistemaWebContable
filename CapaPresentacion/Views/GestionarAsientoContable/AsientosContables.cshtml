@{
    ViewBag.Title = "Asientos Contables";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .codigo-asiento,
    .codigo-cuenta {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .bloque-detalle {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 12px;
        margin-top: 15px;
    }

    .resumen-cuadre {
        font-size: 14px;
        font-weight: bold;
    }

    .tabla-detalle th,
    .tabla-detalle td {
        vertical-align: middle !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Asientos Contables</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Asientos contables</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de asientos contables</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalAsiento(null)">
            Nuevo asiento
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaAsientos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Período</th>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Concepto</th>
                        <th>Total debe</th>
                        <th>Total haber</th>
                        <th>Cuadre</th>
                        <th>Estado</th>
                        <th style="width:230px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModalAsiento" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalAsiento">Nuevo asiento contable</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtNumeroAsiento" value="" />

                <div class="alert alert-danger mt-2" id="mensajeErrorAsiento" style="display:none;"></div>
                <div class="alert alert-success mt-2" id="mensajeExitoAsiento" style="display:none;"></div>

                <h6 class="font-weight-bold mb-3">Encabezado del asiento</h6>

                <div class="form-group">
                    <label for="txtNumeroAsientoVisible">Número de asiento</label>
                    <input type="text" id="txtNumeroAsientoVisible" class="form-control codigo-asiento" disabled />
                    <small class="form-text text-muted">El número se genera automáticamente al guardar.</small>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboPeriodoContable">Período contable</label>
                            <select id="cboPeriodoContable" class="form-control">
                                <option value="">Seleccione</option>
                            </select>
                            <small class="form-text text-muted">Solo se muestran períodos abiertos.</small>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtFechaAsiento">Fecha asiento</label>
                            <input type="date" id="txtFechaAsiento" class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtTipoAsiento">Tipo asiento</label>
                            <input type="text" id="txtTipoAsiento" class="form-control" maxlength="45" autocomplete="off" placeholder="Manual, Ajuste, Venta, Gasto..." />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="txtConcepto">Concepto</label>
                    <input type="text" id="txtConcepto" class="form-control" maxlength="150" autocomplete="off" />
                </div>

                <div class="form-group" id="grupoActivoAsiento">
                    <label for="cboActivoAsiento">Estado</label>
                    <select id="cboActivoAsiento" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="bloque-detalle">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="font-weight-bold mb-0">Detalle del asiento</h6>

                        <div>
                            <button type="button" class="btn btn-outline-secondary btn-sm mr-1" onclick="validarCuadreAsiento()">
                                Validar cuadre
                            </button>
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="recalcularTotalesAsiento()">
                                Recalcular totales
                            </button>
                        </div>
                    </div>

                    <small class="text-muted d-block mb-3">
                        Para agregar líneas, primero guarde el asiento.
                    </small>

                    <input type="hidden" id="txtNumeroLinea" value="0" />

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group mb-2">
                                <label for="cboCuentaContable">Cuenta contable</label>
                                <select id="cboCuentaContable" class="form-control">
                                    <option value="">Seleccione</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="txtDebe">Debe</label>
                                <input type="text" id="txtDebe" class="form-control" autocomplete="off" value="0.00" />
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="txtHaber">Haber</label>
                                <input type="text" id="txtHaber" class="form-control" autocomplete="off" value="0.00" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="txtDescripcionLinea">Descripción línea</label>
                                <input type="text" id="txtDescripcionLinea" class="form-control" maxlength="150" autocomplete="off" />
                            </div>
                        </div>

                        <div class="col-md-1 d-flex align-items-end">
                            <div class="form-group mb-2 w-100">
                                <button type="button" class="btn btn-primary btn-block" onclick="guardarDetalleAsiento()">
                                    +
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="form-group" id="grupoActivoDetalle">
                        <label for="cboActivoDetalle">Estado línea</label>
                        <select id="cboActivoDetalle" class="form-control">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                    <div class="alert alert-danger mt-2" id="mensajeErrorDetalle" style="display:none;"></div>

                    <div class="row mt-3 mb-2">
                        <div class="col-md-4">
                            <div class="resumen-cuadre">
                                Total debe: <span id="lblTotalDebe">₡0.00</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="resumen-cuadre">
                                Total haber: <span id="lblTotalHaber">₡0.00</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="resumen-cuadre">
                                Diferencia: <span id="lblDiferencia">₡0.00</span>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered tabla-detalle" id="tablaDetalles" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Línea</th>
                                    <th>Cuenta</th>
                                    <th>Debe</th>
                                    <th>Haber</th>
                                    <th>Descripción</th>
                                    <th>Estado</th>
                                    <th style="width:160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>

                </div>

            </div>

            <div class="modal-footer">
                <small class="text-muted mr-auto">
                    El asiento debe tener al menos dos líneas y debe quedar cuadrado.
                </small>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarAsiento()">
                    Guardar asiento
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaAsientos = [];
        var listaDetalles = [];
        var listaPeriodos = [];
        var listaCuentas = [];
        var tablaAsientos = null;

        $(document).ready(function () {
            cargarPeriodosAbiertos();
            cargarCuentasParaMovimientos();
            cargarAsientos();

            $("#txtTipoAsiento").on("input", function () {
                limpiarTextoGeneral("txtTipoAsiento", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo("txtTipoAsiento", "El tipo de asiento no puede superar los 45 caracteres.");
                }
            });

            $("#txtConcepto").on("input", function () {
                limpiarTextoGeneral("txtConcepto", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtConcepto", "El concepto no puede superar los 150 caracteres.");
                }
            });

            $("#txtDescripcionLinea").on("input", function () {
                limpiarTextoGeneral("txtDescripcionLinea", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcionLinea", "La descripción de la línea no puede superar los 150 caracteres.");
                }
            });

            $("#txtDebe, #txtHaber").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(",", ".");
                valor = valor.replace(/[^0-9.]/g, "");

                var partes = valor.split(".");
                if (partes.length > 2) {
                    valor = partes[0] + "." + partes.slice(1).join("");
                }

                $(this).val(valor);
            });

            $("#txtDebe").on("keyup change", function () {
                var debe = parseFloat($(this).val());

                if (!isNaN(debe) && debe > 0) {
                    $("#txtHaber").val("0.00");
                }
            });

            $("#txtHaber").on("keyup change", function () {
                var haber = parseFloat($(this).val());

                if (!isNaN(haber) && haber > 0) {
                    $("#txtDebe").val("0.00");
                }
            });

            $("#cboPeriodoContable").on("change", function () {
                var periodo = obtenerPeriodoSeleccionado();

                if (periodo != null && $("#txtFechaAsiento").val() === "") {
                    $("#txtFechaAsiento").val(formatearFechaInput(periodo.FechaInicio));
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorAsiento").is(":visible")) {
                    $("#mensajeErrorAsiento").fadeOut(150);
                }

                if ($("#mensajeExitoAsiento").is(":visible")) {
                    $("#mensajeExitoAsiento").fadeOut(150);
                }

                if ($("#mensajeErrorDetalle").is(":visible")) {
                    $("#mensajeErrorDetalle").fadeOut(150);
                }
            });

            $("#FormModalAsiento").on("hidden.bs.modal", function () {
                limpiarErrores();
            });
        });

        function cargarAsientos() {
            $.ajax({
                url: '@Url.Action("ListarAsientosContables", "GestionarAsientoContable")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaAsientos = respuesta.data || [];
                    pintarTablaAsientos();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los asientos contables.", "error");
                }
            });
        }

        function pintarTablaAsientos() {
            if (tablaAsientos != null) {
                tablaAsientos.clear().destroy();
                tablaAsientos = null;
            }

            var tbody = $("#tablaAsientos tbody");
            tbody.empty();

            $.each(listaAsientos, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var numeroAsiento = item.NumeroAsiento || "";
                var periodo = obtenerNombreMes(item.Mes) + " " + item.Anio;
                var fecha = formatearFechaTexto(item.FechaAsiento);
                var tipo = item.TipoAsiento || "";
                var concepto = item.Concepto || "";

                var totalDebe = formatearMoneda(item.TotalDebe);
                var totalHaber = formatearMoneda(item.TotalHaber);

                var estaCuadrado = parseFloat(item.TotalDebe) === parseFloat(item.TotalHaber) && parseFloat(item.TotalDebe) > 0;

                var cuadre = estaCuadrado
                    ? '<span class="badge badge-success">Cuadrado</span>'
                    : '<span class="badge badge-warning">Descuadrado</span>';

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1 mb-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModalAsiento(item);
                });

                var botonValidar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-secondary mr-1 mb-1",
                    text: "Validar"
                }).on("click", function () {
                    validarCuadreAsientoDesdeTabla(item.NumeroAsiento);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger mb-1",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarAsiento(item.NumeroAsiento);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonValidar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var celdaNumero = $("<td>");
                celdaNumero.append($("<div>", {
                    class: "codigo-asiento",
                    text: numeroAsiento
                }));
                celdaNumero.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: "Estado período: " + (item.EstadoPeriodo || "-")
                }));

                var fila = $("<tr>");
                fila.append(celdaNumero);
                fila.append($("<td>").text(periodo));
                fila.append($("<td>").text(fecha));
                fila.append($("<td>").text(tipo));
                fila.append($("<td>").text(concepto));
                fila.append($("<td>").text(totalDebe));
                fila.append($("<td>").text(totalHaber));
                fila.append($("<td>").html(cuadre));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaAsientos = $("#tablaAsientos").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[2, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function cargarPeriodosAbiertos() {
            $.ajax({
                url: '@Url.Action("ListarPeriodosContablesAbiertos", "GestionarPeriodoContable")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaPeriodos = respuesta.data || [];
                    pintarComboPeriodos();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los períodos contables.", "error");
                }
            });
        }

        function pintarComboPeriodos() {
            $("#cboPeriodoContable").empty();
            $("#cboPeriodoContable").append('<option value="">Seleccione</option>');

            $.each(listaPeriodos, function (i, item) {
                var valor = item.Anio + "|" + item.Mes;
                var texto = obtenerNombreMes(item.Mes) + " " + item.Anio;

                $("#cboPeriodoContable").append(
                    $("<option>", {
                        value: valor,
                        text: texto
                    })
                );
            });
        }

        function cargarCuentasParaMovimientos() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContablesParaMovimientos", "GestionarCuentaContable")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCuentas = respuesta.data || [];
                    pintarComboCuentas();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las cuentas contables.", "error");
                }
            });
        }

        function pintarComboCuentas() {
            $("#cboCuentaContable").empty();
            $("#cboCuentaContable").append('<option value="">Seleccione</option>');

            $.each(listaCuentas, function (i, item) {
                $("#cboCuentaContable").append(
                    $("<option>", {
                        value: item.CodigoCuenta,
                        text: item.CodigoCuenta + " - " + item.NombreCuenta
                    })
                );
            });
        }

        function abrirModalAsiento(json) {
            limpiarErrores();

            listaDetalles = [];
            pintarDetalles();

            $("#txtNumeroAsiento").val("");
            $("#txtNumeroAsientoVisible").val("Se generará automáticamente");

            $("#cboPeriodoContable").val("");
            $("#txtFechaAsiento").val(convertirFechaInput(new Date()));
            $("#txtTipoAsiento").val("Manual");
            $("#txtConcepto").val("");

            $("#cboActivoAsiento").val("true");
            $("#grupoActivoAsiento").hide();

            limpiarFormularioDetalle();

            $("#tituloModalAsiento").text("Nuevo asiento contable");

            if (json != null) {
                $("#txtNumeroAsiento").val(json.NumeroAsiento || "");
                $("#txtNumeroAsientoVisible").val(json.NumeroAsiento || "");

                $("#cboPeriodoContable").val(json.Anio + "|" + json.Mes);
                $("#txtFechaAsiento").val(formatearFechaInput(json.FechaAsiento));
                $("#txtTipoAsiento").val(json.TipoAsiento || "");
                $("#txtConcepto").val(json.Concepto || "");

                $("#cboActivoAsiento").val(json.Activo ? "true" : "false");
                if (window.esAdministradorSistema === true) {
                    $("#grupoActivoAsiento").show();
                } else {
                    $("#grupoActivoAsiento").hide();
                    $("#cboActivoAsiento").val("true");
                }

                $("#tituloModalAsiento").text("Editar asiento contable");

                cargarDetallesAsiento(json.NumeroAsiento);
            }

            $("#FormModalAsiento").modal("show");
        }

        function guardarAsiento() {
            $("#mensajeErrorAsiento").hide().text("");
            $("#mensajeExitoAsiento").hide().text("");

            var periodo = obtenerPeriodoSeleccionado();

            if (periodo == null) {
                mostrarErrorAsiento("Debe seleccionar un período contable.", "cboPeriodoContable");
                return;
            }

            var obj = {
                NumeroAsiento: $("#txtNumeroAsiento").val().trim(),
                Anio: periodo.Anio,
                Mes: periodo.Mes,
                FechaAsiento: $("#txtFechaAsiento").val(),
                TipoAsiento: $("#txtTipoAsiento").val().trim(),
                Concepto: $("#txtConcepto").val().trim(),
                Activo: $("#cboActivoAsiento").val() === "true"
            };

            if (obj.FechaAsiento === "") {
                mostrarErrorAsiento("Debe ingresar la fecha del asiento.", "txtFechaAsiento");
                return;
            }

            if (obj.TipoAsiento === "") {
                mostrarErrorAsiento("Debe ingresar el tipo de asiento.", "txtTipoAsiento");
                return;
            }

            if (!validarTextoGeneral(obj.TipoAsiento)) {
                mostrarErrorAsiento("El tipo de asiento solo puede contener letras, números, espacios y caracteres básicos.", "txtTipoAsiento");
                return;
            }

            if (obj.TipoAsiento.length > 45) {
                mostrarErrorAsiento("El tipo de asiento no puede superar los 45 caracteres.", "txtTipoAsiento");
                return;
            }

            if (obj.Concepto === "") {
                mostrarErrorAsiento("Debe ingresar el concepto del asiento.", "txtConcepto");
                return;
            }

            if (!validarTextoGeneral(obj.Concepto)) {
                mostrarErrorAsiento("El concepto solo puede contener letras, números, espacios y caracteres básicos.", "txtConcepto");
                return;
            }

            if (obj.Concepto.length > 150) {
                mostrarErrorAsiento("El concepto no puede superar los 150 caracteres.", "txtConcepto");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarAsientoContable", "GestionarAsientoContable")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        if (obj.NumeroAsiento === "") {
                            $("#txtNumeroAsiento").val(respuesta.numeroAsiento || "");
                            $("#txtNumeroAsientoVisible").val(respuesta.numeroAsiento || "");
                            if (window.esAdministradorSistema === true) {
                                $("#grupoActivoAsiento").show();
                            } else {
                                $("#grupoActivoAsiento").hide();
                                $("#cboActivoAsiento").val("true");
                            }
                            $("#tituloModalAsiento").text("Editar asiento contable");
                            $("#mensajeExitoAsiento").text("Asiento guardado correctamente. Ya puede agregar líneas.").show();
                        } else {
                            $("#mensajeExitoAsiento").text("Asiento actualizado correctamente.").show();
                        }

                        cargarAsientos();
                    } else {
                        $("#mensajeErrorAsiento").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorAsiento").text("Error al guardar el asiento contable.").show();
                }
            });
        }

        function cargarDetallesAsiento(numeroAsiento) {
            $.ajax({
                url: '@Url.Action("ListarDetallesAsientoContablePorAsiento", "GestionarAsientoContable")',
                type: "GET",
                data: { numeroAsiento: numeroAsiento },
                dataType: "json",
                success: function (respuesta) {
                    listaDetalles = respuesta.data || [];
                    pintarDetalles();
                },
                error: function () {
                    $("#mensajeErrorDetalle").text("Error al cargar los detalles del asiento.").show();
                }
            });
        }

        function pintarDetalles() {
            var tbody = $("#tablaDetalles tbody");
            tbody.empty();

            var totalDebe = 0;
            var totalHaber = 0;

            $.each(listaDetalles, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                if (item.Activo) {
                    totalDebe += parseFloat(item.Debe || 0);
                    totalHaber += parseFloat(item.Haber || 0);
                }

                var cuenta = (item.CodigoCuenta || "") + " - " + (item.NombreCuenta || "");

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    editarDetalle(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarDetalle(item.NumeroAsiento, item.NumeroLinea);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroLinea));
                fila.append($("<td>", { class: "codigo-cuenta", text: cuenta }));
                fila.append($("<td>").text(formatearMoneda(item.Debe)));
                fila.append($("<td>").text(formatearMoneda(item.Haber)));
                fila.append($("<td>").text(item.DescripcionLinea || ""));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            $("#lblTotalDebe").text(formatearMoneda(totalDebe));
            $("#lblTotalHaber").text(formatearMoneda(totalHaber));
            $("#lblDiferencia").text(formatearMoneda(Math.abs(totalDebe - totalHaber)));
        }

        function guardarDetalleAsiento() {
            $("#mensajeErrorDetalle").hide().text("");

            var numeroAsiento = $("#txtNumeroAsiento").val().trim();

            if (numeroAsiento === "") {
                $("#mensajeErrorDetalle").text("Primero debe guardar el asiento contable.").show();
                return;
            }

            var obj = {
                NumeroAsiento: numeroAsiento,
                NumeroLinea: parseInt($("#txtNumeroLinea").val()),
                CodigoCuenta: $("#cboCuentaContable").val(),
                Debe: parseFloat($("#txtDebe").val()),
                Haber: parseFloat($("#txtHaber").val()),
                DescripcionLinea: $("#txtDescripcionLinea").val().trim(),
                Activo: $("#cboActivoDetalle").val() === "true"
            };

            if (isNaN(obj.NumeroLinea)) obj.NumeroLinea = 0;
            if (isNaN(obj.Debe)) obj.Debe = 0;
            if (isNaN(obj.Haber)) obj.Haber = 0;

            if (obj.CodigoCuenta == null || obj.CodigoCuenta === "") {
                $("#mensajeErrorDetalle").text("Debe seleccionar una cuenta contable.").show();
                return;
            }

            if (obj.Debe < 0 || obj.Haber < 0) {
                $("#mensajeErrorDetalle").text("Los montos de debe y haber no pueden ser negativos.").show();
                return;
            }

            if (obj.Debe === 0 && obj.Haber === 0) {
                $("#mensajeErrorDetalle").text("Debe ingresar un monto en debe o en haber.").show();
                return;
            }

            if (obj.Debe > 0 && obj.Haber > 0) {
                $("#mensajeErrorDetalle").text("No puede ingresar monto en debe y haber al mismo tiempo.").show();
                return;
            }

            if (obj.DescripcionLinea.length > 150) {
                $("#mensajeErrorDetalle").text("La descripción de la línea no puede superar los 150 caracteres.").show();
                return;
            }

            if (obj.DescripcionLinea !== "" && !validarTextoGeneral(obj.DescripcionLinea)) {
                $("#mensajeErrorDetalle").text("La descripción de la línea solo puede contener letras, números, espacios y caracteres básicos.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarDetalleAsientoContable", "GestionarAsientoContable")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        limpiarFormularioDetalle();
                        cargarDetallesAsiento(numeroAsiento);
                        cargarAsientos();
                    } else {
                        $("#mensajeErrorDetalle").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorDetalle").text("Error al guardar el detalle del asiento.").show();
                }
            });
        }

        function editarDetalle(item) {
            $("#txtNumeroLinea").val(item.NumeroLinea);
            $("#cboCuentaContable").val(item.CodigoCuenta);
            $("#txtDebe").val(formatearNumero(item.Debe));
            $("#txtHaber").val(formatearNumero(item.Haber));
            $("#txtDescripcionLinea").val(item.DescripcionLinea || "");
            $("#cboActivoDetalle").val(item.Activo ? "true" : "false");
            if (window.esAdministradorSistema === true) {
                $("#grupoActivoDetalle").show();
            } else {
                $("#grupoActivoDetalle").hide();
                $("#cboActivoDetalle").val("true");
            }
        }

        function limpiarFormularioDetalle() {
            $("#txtNumeroLinea").val("0");
            $("#cboCuentaContable").val("");
            $("#txtDebe").val("0.00");
            $("#txtHaber").val("0.00");
            $("#txtDescripcionLinea").val("");
            $("#cboActivoDetalle").val("true");
            $("#grupoActivoDetalle").hide();
            $("#mensajeErrorDetalle").hide().text("");
        }

        function inactivarDetalle(numeroAsiento, numeroLinea) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "esta línea del asiento"),
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarDetalleAsientoContable", "GestionarAsientoContable")',
                        type: "POST",
                        data: JSON.stringify({
                            numeroAsiento: numeroAsiento,
                            numeroLinea: numeroLinea
                        }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                limpiarFormularioDetalle();
                                cargarDetallesAsiento(numeroAsiento);
                                cargarAsientos();
                                mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Línea del asiento"), "exito");
                            } else {
                                $("#mensajeErrorDetalle").text(respuesta.mensaje || "No se pudo procesar la línea.").show();
                            }
                        },
                        error: function () {
                            $("#mensajeErrorDetalle").text("Error al procesar la línea.").show();
                        }
                    });
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function validarCuadreAsiento() {
            var numeroAsiento = $("#txtNumeroAsiento").val().trim();

            if (numeroAsiento === "") {
                $("#mensajeErrorAsiento").text("Primero debe guardar el asiento contable.").show();
                return;
            }

            validarCuadreAsientoDesdeTabla(numeroAsiento);
        }

        function validarCuadreAsientoDesdeTabla(numeroAsiento) {
            $.ajax({
                url: '@Url.Action("ValidarCuadreAsientoContable", "GestionarAsientoContable")',
                type: "POST",
                data: JSON.stringify({ numeroAsiento: numeroAsiento }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        mostrarMensajeSistema(respuesta.mensaje || "El asiento contable se encuentra cuadrado.", "exito");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "El asiento contable no se encuentra cuadrado.", "error");
                    }

                    cargarAsientos();

                    if ($("#txtNumeroAsiento").val().trim() === numeroAsiento) {
                        cargarDetallesAsiento(numeroAsiento);
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al validar el cuadre del asiento.", "error");
                }
            });
        }

        function recalcularTotalesAsiento() {
            var numeroAsiento = $("#txtNumeroAsiento").val().trim();

            if (numeroAsiento === "") {
                $("#mensajeErrorAsiento").text("Primero debe guardar el asiento contable.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("RecalcularTotalesAsientoContable", "GestionarAsientoContable")',
                type: "POST",
                data: JSON.stringify({ numeroAsiento: numeroAsiento }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#mensajeExitoAsiento").text(respuesta.mensaje).show();
                        cargarDetallesAsiento(numeroAsiento);
                        cargarAsientos();
                    } else {
                        $("#mensajeErrorAsiento").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorAsiento").text("Error al recalcular totales.").show();
                }
            });
        }

        function inactivarAsiento(numeroAsiento) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este asiento contable") + " También se procesarán sus líneas.",
                function () {
                    $.ajax({
                        url: '@Url.Action("InactivarAsientoContable", "GestionarAsientoContable")',
                        type: "POST",
                        data: JSON.stringify({ numeroAsiento: numeroAsiento }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
                            if (respuesta.resultado) {
                                cargarAsientos();

                                if ($("#txtNumeroAsiento").val().trim() === numeroAsiento) {
                                    $("#FormModalAsiento").modal("hide");
                                }

                                mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Asiento contable"), "exito");
                            } else {
                                mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el asiento contable.", "error");
                            }
                        },
                        error: function () {
                            mostrarMensajeSistema("Error al procesar el asiento contable.", "error");
                        }
                    });
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function obtenerPeriodoSeleccionado() {
            var valor = $("#cboPeriodoContable").val();

            if (valor == null || valor === "") {
                return null;
            }

            var partes = valor.split("|");

            if (partes.length !== 2) {
                return null;
            }

            var anio = parseInt(partes[0]);
            var mes = parseInt(partes[1]);

            if (isNaN(anio) || isNaN(mes)) {
                return null;
            }

            for (var i = 0; i < listaPeriodos.length; i++) {
                if (parseInt(listaPeriodos[i].Anio) === anio && parseInt(listaPeriodos[i].Mes) === mes) {
                    return listaPeriodos[i];
                }
            }

            return {
                Anio: anio,
                Mes: mes
            };
        }

        function mostrarErrorAsiento(mensaje, idCampo) {
            $("#mensajeErrorAsiento").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarErrores() {
            $("#mensajeErrorAsiento").hide().text("");
            $("#mensajeExitoAsiento").hide().text("");
            $("#mensajeErrorDetalle").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoGeneral(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function convertirFechaInput(fecha) {
            var mes = (fecha.getMonth() + 1).toString().padStart(2, "0");
            var dia = fecha.getDate().toString().padStart(2, "0");

            return fecha.getFullYear() + "-" + mes + "-" + dia;
        }

        function formatearFechaInput(valor) {
            if (valor == null || valor === "") {
                return "";
            }

            if (typeof valor === "string" && valor.indexOf("/Date(") === 0) {
                var ticks = parseInt(valor.replace("/Date(", "").replace(")/", ""));
                var fecha = new Date(ticks);

                return convertirFechaInput(fecha);
            }

            if (typeof valor === "string" && valor.length >= 10) {
                return valor.substring(0, 10);
            }

            return "";
        }

        function formatearFechaTexto(valor) {
            var fechaInput = formatearFechaInput(valor);

            if (fechaInput === "") {
                return "-";
            }

            var partes = fechaInput.split("-");

            if (partes.length !== 3) {
                return fechaInput;
            }

            return partes[2] + "/" + partes[1] + "/" + partes[0];
        }

        function obtenerNombreMes(mes) {
            switch (parseInt(mes)) {
                case 1: return "Enero";
                case 2: return "Febrero";
                case 3: return "Marzo";
                case 4: return "Abril";
                case 5: return "Mayo";
                case 6: return "Junio";
                case 7: return "Julio";
                case 8: return "Agosto";
                case 9: return "Septiembre";
                case 10: return "Octubre";
                case 11: return "Noviembre";
                case 12: return "Diciembre";
                default: return "";
            }
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function formatearMoneda(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                numero = 0;
            }

            return "₡" + numero.toLocaleString("es-CR", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }
    </script>
}