


@{
    ViewBag.Title = "Configuración Cuenta Contable";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .codigo-operacion {
        font-family: Consolas, monospace;
        font-weight: bold;
    }
    .mensaje-operacion {
        display: none;
        border-radius: 8px;
        padding: 12px 15px;
        margin-bottom: 15px;
        font-size: 14px;
        font-weight: 600;
        border-left: 5px solid transparent;
    }

        .mensaje-operacion.exito {
            display: block;
            background: #eaf7ee;
            color: #1f7a3f;
            border-left-color: #28a745;
        }

        .mensaje-operacion.error {
            display: block;
            background: #fdecea;
            color: #b02a37;
            border-left-color: #dc3545;
        }

        .mensaje-operacion.advertencia {
            display: block;
            background: #fff8e1;
            color: #8a6d1d;
            border-left-color: #ffc107;
        }
</style>

<h4 class="font-weight-bold py-3 mb-0">Configuración de Cuentas Contables</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Configuración contable</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de configuraciones contables</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nueva configuración
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaConfiguraciones" style="width:100%;">
                <thead>
                    <tr>
                        <th>Código operación</th>
                        <th>Operación</th>
                        <th>Cuenta contable</th>
                        <th>Estado cuenta</th>
                        <th>Estado configuración</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nueva configuración contable</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtEsEdicion" value="false" />

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

                <div class="form-group">
                    <label for="txtCodigoOperacion">Código de operación</label>
                    <input type="text" id="txtCodigoOperacion" class="form-control codigo-operacion" maxlength="45" autocomplete="off" />
                    <small class="form-text text-muted">
                        Ejemplo: VENTA_CONTADO, VENTA_CREDITO, ABONO_CXC, GASTO_CONTADO.
                    </small>
                </div>

                <div class="alert alert-info" id="mensajeLlavePrimaria" style="display:none;">
                    El código de operación no se puede cambiar porque es la llave principal.
                </div>

                <div class="form-group">
                    <label for="txtNombreOperacion">Nombre de operación</label>
                    <input type="text" id="txtNombreOperacion" class="form-control" maxlength="100" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="200" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 200 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboCuentaContable">Cuenta contable</label>
                    <select id="cboCuentaContable" class="form-control">
                        <option value="">Seleccione una cuenta</option>
                    </select>
                    <small class="form-text text-muted">
                        Solo se muestran cuentas activas que aceptan movimientos.
                    </small>
                </div>

                <div class="form-group" id="grupoActivo">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarConfiguracion()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaConfiguraciones = [];
        var listaCuentas = [];
        var tablaConfiguraciones = null;

        $(document).ready(function () {
            cargarCuentasParaMovimientos();
            cargarConfiguraciones();

            $("#txtCodigoOperacion").on("input", function () {
                var valor = $(this).val();

                valor = valor.toUpperCase();
                valor = valor.replace(/[^0-9A-Z_\-]/g, "");

                if (valor.length > 45) {
                    valor = valor.substring(0, 45);
                }

                $(this).val(valor);
            });

            $("#txtNombreOperacion").on("input", function () {
                limpiarTextoGeneral("txtNombreOperacion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 100) {
                    $(this).val($(this).val().substring(0, 100));
                    mostrarAyudaCampo("txtNombreOperacion", "El nombre de operación no puede superar los 100 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoGeneral("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 200) {
                    $(this).val($(this).val().substring(0, 200));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 200 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                limpiarErrores();
            });
        });

        function cargarConfiguraciones() {
            $.ajax({
                url: '@Url.Action("ListarConfiguracionesCuentaContable", "ConfiguracionCuentaContable")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaConfiguraciones = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar las configuraciones contables.");
                }
            });
        }

        function cargarCuentasParaMovimientos() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContablesParaMovimientos", "GestionarCuentaContable")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaCuentas = respuesta.data || [];
                    pintarComboCuentas();
                },
                error: function () {
                    alert("Error al cargar las cuentas contables.");
                }
            });
        }

        function pintarComboCuentas() {
            var valorActual = $("#cboCuentaContable").val();

            $("#cboCuentaContable").empty();
            $("#cboCuentaContable").append('<option value="">Seleccione una cuenta</option>');

            $.each(listaCuentas, function (i, item) {
                $("#cboCuentaContable").append(
                    $("<option>", {
                        value: item.CodigoCuenta,
                        text: item.CodigoCuenta + " - " + item.NombreCuenta
                    })
                );
            });

            if (valorActual) {
                $("#cboCuentaContable").val(valorActual);
            }
        }

        function pintarTabla() {
            if (tablaConfiguraciones != null) {
                tablaConfiguraciones.clear().destroy();
                tablaConfiguraciones = null;
            }

            var tbody = $("#tablaConfiguraciones tbody");
            tbody.empty();

            $.each(listaConfiguraciones, function (i, item) {
                var codigoOperacion = item.CodigoOperacion || "";
                var nombreOperacion = item.NombreOperacion || "";
                var descripcion = item.Descripcion || "";
                var codigoCuenta = item.CodigoCuenta || "";
                var nombreCuenta = item.NombreCuenta || "";

                var estadoCuenta = "";

                if (!item.CuentaActiva) {
                    estadoCuenta = '<span class="badge badge-danger">Cuenta inactiva</span>';
                } else if (!item.AceptaMovimientos) {
                    estadoCuenta = '<span class="badge badge-warning">No acepta movimientos</span>';
                } else {
                    estadoCuenta = '<span class="badge badge-success">Disponible</span>';
                }

                var estadoConfiguracion = item.Activo
                    ? '<span class="badge badge-success">Activa</span>'
                    : '<span class="badge badge-secondary">Inactiva</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarConfiguracion(item.CodigoOperacion);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var celdaOperacion = $("<td>");
                celdaOperacion.append($("<div>", {
                    class: "codigo-operacion",
                    text: codigoOperacion
                }));
                celdaOperacion.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: descripcion || "Sin descripción"
                }));

                var celdaCuenta = $("<td>");
                celdaCuenta.append($("<div>").text(codigoCuenta + " - " + nombreCuenta));
                celdaCuenta.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: "Cuenta usada en procesos automáticos"
                }));

                var fila = $("<tr>");
                fila.append(celdaOperacion);
                fila.append($("<td>").text(nombreOperacion));
                fila.append(celdaCuenta);
                fila.append($("<td>").html(estadoCuenta));
                fila.append($("<td>").html(estadoConfiguracion));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaConfiguraciones = $("#tablaConfiguraciones").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            limpiarErrores();

            $("#txtEsEdicion").val("false");

            $("#txtCodigoOperacion").val("");
            $("#txtCodigoOperacion").prop("disabled", false);

            $("#txtNombreOperacion").val("");
            $("#txtDescripcion").val("");
            $("#cboCuentaContable").val("");
            $("#cboActivo").val("true");

            $("#grupoActivo").hide();
            $("#mensajeLlavePrimaria").hide();

            $("#tituloModal").text("Nueva configuración contable");

            if (json != null) {
                $("#txtEsEdicion").val("true");

                $("#txtCodigoOperacion").val(json.CodigoOperacion || "");
                $("#txtCodigoOperacion").prop("disabled", true);

                $("#txtNombreOperacion").val(json.NombreOperacion || "");
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboCuentaContable").val(json.CodigoCuenta || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#grupoActivo").show();
                $("#mensajeLlavePrimaria").show();

                $("#tituloModal").text("Editar configuración contable");
            }

            $("#FormModal").modal("show");
        }

        function guardarConfiguracion() {
            $("#mensajeError").hide().text("");

            var obj = {
                CodigoOperacion: $("#txtCodigoOperacion").val().trim().toUpperCase(),
                NombreOperacion: $("#txtNombreOperacion").val().trim(),
                Descripcion: $("#txtDescripcion").val().trim(),
                CodigoCuenta: $("#cboCuentaContable").val(),
                Activo: $("#cboActivo").val() === "true"
            };

            if (obj.CodigoOperacion === "") {
                mostrarError("Debe ingresar el código de operación.", "txtCodigoOperacion");
                return;
            }

            if (!validarCodigoOperacion(obj.CodigoOperacion)) {
                mostrarError("El código de operación solo puede contener letras mayúsculas, números, guiones y guion bajo.", "txtCodigoOperacion");
                return;
            }

            if (obj.CodigoOperacion.length > 45) {
                mostrarError("El código de operación no puede superar los 45 caracteres.", "txtCodigoOperacion");
                return;
            }

            if (obj.NombreOperacion === "") {
                mostrarError("Debe ingresar el nombre de operación.", "txtNombreOperacion");
                return;
            }

            if (!validarTextoGeneral(obj.NombreOperacion)) {
                mostrarError("El nombre de operación solo puede contener letras, números, espacios y caracteres básicos.", "txtNombreOperacion");
                return;
            }

            if (obj.NombreOperacion.length > 100) {
                mostrarError("El nombre de operación no puede superar los 100 caracteres.", "txtNombreOperacion");
                return;
            }

            if (obj.Descripcion.length > 200) {
                mostrarError("La descripción no puede superar los 200 caracteres.", "txtDescripcion");
                return;
            }

            if (obj.Descripcion !== "" && !validarTextoGeneral(obj.Descripcion)) {
                mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
                return;
            }

            if (obj.CodigoCuenta == null || obj.CodigoCuenta === "") {
                mostrarError("Debe seleccionar una cuenta contable.", "cboCuentaContable");
                return;
            }

            if (!validarCodigoCuenta(obj.CodigoCuenta)) {
                mostrarError("El código de cuenta tiene un formato inválido.", "cboCuentaContable");
                return;
            }

            if (obj.CodigoCuenta === "0") {
                mostrarError("No se puede usar la cuenta raíz como configuración contable.", "cboCuentaContable");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarConfiguracionCuentaContable", "ConfiguracionCuentaContable")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarConfiguraciones();
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar la configuración contable.").show();
                }
            });
        }

        function inactivarConfiguracion(codigoOperacion) {
            if (!confirm("¿Desea inactivar esta configuración contable?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarConfiguracionCuentaContable", "ConfiguracionCuentaContable")',
                type: "POST",
                data: JSON.stringify({ codigoOperacion: codigoOperacion }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarConfiguraciones();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar la configuración contable.");
                }
            });
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarErrores() {
            $("#mensajeError").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoGeneral(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function validarCodigoOperacion(valor) {
            return /^[0-9A-Z_\-]+$/.test(valor);
        }

        function validarCodigoCuenta(valor) {
            return /^[0-9A-Za-z.\-_]+$/.test(valor);
        }
    </script>
}