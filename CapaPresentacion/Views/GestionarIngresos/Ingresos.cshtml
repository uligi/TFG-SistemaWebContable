@{
    ViewBag.Title = "Ingresos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestionar Ingresos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Ingresos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de ingresos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo ingreso
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaIngresos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo ingreso</th>
                        <th>Origen</th>
                        <th>Factura</th>
                        <th>Cuenta contable</th>
                        <th>Descripción</th>
                        <th>Monto</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo ingreso</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdIngreso" value="0" />
                <input type="hidden" id="txtIdFactura" />
                <input type="hidden" id="txtIdAbonoCuentaPorCobrar" />

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="cboOrigen">Origen del ingreso</label>
                        <select id="cboOrigen" class="form-control" onchange="cambiarOrigenIngreso()">
                            <option value="Manual">Manual</option>
                            <option value="Factura">Factura contado</option>
                            <option value="Abono CxC">Abono cuenta por cobrar</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaIngreso">Fecha ingreso</label>
                        <input type="date" id="txtFechaIngreso" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoIngreso">Tipo ingreso</label>
                        <select id="cboTipoIngreso" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMonto">Monto</label>
                        <input type="number" id="txtMonto" class="form-control" min="0" step="0.01" />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-12">
                        <label for="cboCuentaContable">Cuenta contable</label>
                        <select id="cboCuentaContable" class="form-control">
                            <option value="0">Seleccione una cuenta contable</option>
                        </select>
                        <small class="form-text text-muted">
                            Esta cuenta se utilizará para comparar el ingreso real contra el presupuesto mensual.
                        </small>
                    </div>

                </div>

                <div id="seccionFactura" style="display:none;">
                    <hr />
                    <h6 class="font-weight-bold">Buscar factura de contado pendiente</h6>

                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <input type="text" id="txtBuscarFactura" class="form-control" placeholder="Buscar por número de factura, cliente o identificación..." />
                        </div>

                        <div class="form-group col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-block" onclick="buscarFacturasPendientes()">
                                Buscar factura
                            </button>
                        </div>
                    </div>

                    <small class="form-text text-muted mb-2" id="lblFacturaSeleccionada">
                        Ninguna factura seleccionada.
                    </small>

                    <div class="table-responsive" id="contenedorFacturas" style="display:none;">
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Factura</th>
                                    <th>Cliente</th>
                                    <th>Fecha</th>
                                    <th>Total</th>
                                    <th style="width:100px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyFacturas"></tbody>
                        </table>
                    </div>
                </div>

                <div id="seccionAbono" style="display:none;">
                    <hr />
                    <h6 class="font-weight-bold">Buscar abono pendiente</h6>

                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <input type="text" id="txtBuscarAbono" class="form-control" placeholder="Buscar por factura, cliente o identificación..." />
                        </div>

                        <div class="form-group col-md-4">
                            <button type="button" class="btn btn-outline-primary btn-block" onclick="buscarAbonosPendientes()">
                                Buscar abono
                            </button>
                        </div>
                    </div>

                    <small class="form-text text-muted mb-2" id="lblAbonoSeleccionado">
                        Ningún abono seleccionado.
                    </small>

                    <div class="table-responsive" id="contenedorAbonos" style="display:none;">
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Factura</th>
                                    <th>Cliente</th>
                                    <th>Fecha abono</th>
                                    <th>Monto</th>
                                    <th style="width:100px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyAbonos"></tbody>
                        </table>
                    </div>
                </div>

                <hr />

                <div class="form-row">

                    <div class="form-group col-md-8">
                        <label for="txtDescripcion">Descripción</label>
                        <input type="text" id="txtDescripcion" class="form-control" maxlength="150" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboActivo">Estado</label>
                        <select id="cboActivo" class="form-control">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                </div>

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarIngreso()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var tablaIngresos = null;
        var listaIngresos = [];
        var listaFacturasPendientes = [];
        var listaAbonosPendientes = [];

        $(document).ready(function () {
            cargarIngresos();
            cargarTipoIngresos();
            cargarCuentasContables();

            $("#txtBuscarFactura").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarFacturasPendientes();
                }
            });

            $("#txtBuscarAbono").on("keypress", function (e) {
                if (e.which === 13) {
                    buscarAbonosPendientes();
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                $("#mensajeError").hide().text("");
            });

            $("#txtMonto").on("input", function () {
                limpiarNoDecimal("txtMonto", "Solo se permiten números y punto decimal en el monto.");
            });

            $("#txtDescripcion").on("input", function () {
                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 150 caracteres.");
                } else {
                    ocultarAyudaCampo("txtDescripcion");
                }
            });

            $("#txtBuscarFactura").on("input", function () {
                limpiarTextoBusqueda("txtBuscarFactura", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("#txtBuscarAbono").on("input", function () {
                limpiarTextoBusqueda("txtBuscarAbono", "Solo se permiten letras, números, espacios y caracteres básicos.");
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }
            });
        });

        function cargarIngresos() {
            $.ajax({
                url: '@Url.Action("ListarIngresos", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaIngresos = respuesta.data || [];
                    pintarTablaIngresos();
                },
                error: function () {
                    alert("Error al cargar los ingresos.");
                }
            });
        }

        function cargarTipoIngresos() {
            $.ajax({
                url: '@Url.Action("ListarTipoIngresosActivos", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoIngreso").empty();
                    $("#cboTipoIngreso").append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboTipoIngreso").append(
                            $("<option>", {
                                value: item.IdTipoIngreso,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar los tipos de ingreso.");
                }
            });
        }

        function cargarCuentasContables() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContablesMovimiento", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCuentaContable").empty();
                    $("#cboCuentaContable").append('<option value="0">Seleccione una cuenta contable</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboCuentaContable").append(
                            $("<option>", {
                                value: item.IdCuentaContable,
                                text: (item.CodigoCuenta || "") + " - " + (item.NombreCuenta || "")
                            })
                        );
                    });
                },
                error: function () {
                    alert("Error al cargar las cuentas contables.");
                }
            });
        }

        function pintarTablaIngresos() {
            if (tablaIngresos != null) {
                tablaIngresos.clear().destroy();
                tablaIngresos = null;
            }

            var tbody = $("#tablaIngresos tbody");
            tbody.empty();

            $.each(listaIngresos, function (i, item) {
                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var factura = item.NumeroFactura || "-";

                var cuenta = item.CodigoCuenta
                    ? item.CodigoCuenta + " - " + item.NombreCuenta
                    : "-";

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarIngreso(item.IdIngreso);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonInactivar);

                var fila = $("<tr>");
                fila.append($("<td>").text(formatearFecha(item.FechaIngreso)));
                fila.append($("<td>").text(item.TipoIngresoNombre || ""));
                fila.append($("<td>").text(item.OrigenIngreso || ""));
                fila.append($("<td>").text(factura));
                fila.append($("<td>").text(cuenta));
                fila.append($("<td>").text(item.Descripcion || ""));
                fila.append($("<td>").text("₡" + parseFloat(item.Monto || 0).toFixed(2)));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaIngresos = $("#tablaIngresos").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtIdIngreso").val(0);
            $("#txtIdFactura").val("");
            $("#txtIdAbonoCuentaPorCobrar").val("");

            $("#cboOrigen").val("Manual");
            $("#txtFechaIngreso").val(convertirDateAInput(new Date()));
            $("#cboTipoIngreso").val(0);
            $("#cboCuentaContable").val(0);
            $("#txtMonto").val("");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");

            $("#txtBuscarFactura").val("");
            $("#lblFacturaSeleccionada").text("Ninguna factura seleccionada.");
            $("#contenedorFacturas").hide();
            $("#tbodyFacturas").empty();

            $("#txtBuscarAbono").val("");
            $("#lblAbonoSeleccionado").text("Ningún abono seleccionado.");
            $("#contenedorAbonos").hide();
            $("#tbodyAbonos").empty();

            $("#tituloModal").text("Nuevo ingreso");

            habilitarCamposOrigen(true);
            cambiarOrigenIngreso();

            if (json != null) {
                $("#txtIdIngreso").val(json.IdIngreso);
                $("#txtIdFactura").val(json.IdFactura || "");
                $("#txtIdAbonoCuentaPorCobrar").val(json.IdAbonoCuentaPorCobrar || "");

                $("#cboOrigen").val(json.OrigenIngreso || "Manual");
                $("#txtFechaIngreso").val(convertirFechaInput(json.FechaIngreso));
                $("#cboTipoIngreso").val(json.IdTipoIngreso);
                $("#cboCuentaContable").val(json.IdCuentaContable);
                $("#txtMonto").val(parseFloat(json.Monto || 0).toFixed(2));
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#tituloModal").text("Editar ingreso");

                habilitarCamposOrigen(false);
                cambiarOrigenIngreso();
            }

            $("#FormModal").modal("show");
        }

        function habilitarCamposOrigen(habilitar) {
            $("#cboOrigen").prop("disabled", !habilitar);
            $("#txtBuscarFactura").prop("disabled", !habilitar);
            $("#txtBuscarAbono").prop("disabled", !habilitar);
        }

        function cambiarOrigenIngreso() {
            var origen = $("#cboOrigen").val();

            $("#seccionFactura").hide();
            $("#seccionAbono").hide();

            if (origen === "Factura") {
                $("#seccionFactura").show();
                $("#txtIdAbonoCuentaPorCobrar").val("");
            } else if (origen === "Abono CxC") {
                $("#seccionAbono").show();
                $("#txtIdFactura").val("");
            } else {
                $("#txtIdFactura").val("");
                $("#txtIdAbonoCuentaPorCobrar").val("");
            }
        }

        function buscarFacturasPendientes() {
            var filtro = $("#txtBuscarFactura").val().trim().toLowerCase();

            if (filtro.length < 2) {
                mostrarError("Digite al menos 2 caracteres para buscar la factura.", "txtBuscarFactura");
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarFacturasContadoPendientes", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaFacturasPendientes = (respuesta.data || []).filter(function (x) {
                        var texto = (
                            (x.NumeroFactura || "") + " " +
                            (x.ClienteNombre || "") + " " +
                            (x.IdentificacionCliente || "")
                        ).toLowerCase();

                        return texto.indexOf(filtro) !== -1;
                    });

                    pintarFacturasPendientes();
                    $("#mensajeError").hide().text("");
                },
                error: function () {
                    $("#mensajeError").text("Error al buscar facturas pendientes.").show();
                }
            });
        }

        function pintarFacturasPendientes() {
            var tbody = $("#tbodyFacturas");
            tbody.empty();

            if (listaFacturasPendientes.length === 0) {
                tbody.append(
                    '<tr>' +
                        '<td colspan="5" class="text-center text-muted">' +
                            'No se encontraron facturas de contado pendientes.' +
                        '</td>' +
                    '</tr>'
                );

                $("#contenedorFacturas").show();
                return;
            }

            $.each(listaFacturasPendientes, function (i, item) {
                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarFactura(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroFactura || ""));
                fila.append($("<td>").text((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")));
                fila.append($("<td>").text(formatearFecha(item.FechaFactura)));
                fila.append($("<td>").text("₡" + parseFloat(item.TotalFactura || 0).toFixed(2)));

                var acciones = $("<td>");
                acciones.append(boton);

                fila.append(acciones);
                tbody.append(fila);
            });

            $("#contenedorFacturas").show();
        }

        function seleccionarFactura(item) {
            $("#txtIdFactura").val(item.IdFactura);
            $("#txtIdAbonoCuentaPorCobrar").val("");

            $("#txtBuscarFactura").val(item.NumeroFactura || "");
            $("#lblFacturaSeleccionada").text(
                "Factura seleccionada: " + (item.NumeroFactura || "") +
                " | Cliente: " + (item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")
            );

            $("#txtFechaIngreso").val(convertirFechaInput(item.FechaFactura));
            $("#txtMonto").val(parseFloat(item.TotalFactura || 0).toFixed(2));
            $("#txtDescripcion").val("Ingreso por factura " + (item.NumeroFactura || ""));
            $("#cboOrigen").val("Factura");

            $("#contenedorFacturas").hide();
        }

        function buscarAbonosPendientes() {
            var filtro = $("#txtBuscarAbono").val().trim().toLowerCase();
            if (filtro.length < 2) {
                mostrarError("Digite al menos 2 caracteres para buscar el abono.", "txtBuscarAbono");
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarAbonosPendientes", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaAbonosPendientes = (respuesta.data || []).filter(function (x) {
                        var texto = (
                            (x.NumeroFactura || "") + " " +
                            (x.ClienteNombre || "") + " " +
                            (x.IdentificacionCliente || "")
                        ).toLowerCase();

                        return texto.indexOf(filtro) !== -1;
                    });

                    pintarAbonosPendientes();
                    $("#mensajeError").hide().text("");
                },
                error: function () {
                    $("#mensajeError").text("Error al buscar abonos pendientes.").show();
                }
            });
        }

        function pintarAbonosPendientes() {
            var tbody = $("#tbodyAbonos");
            tbody.empty();

            if (listaAbonosPendientes.length === 0) {
                tbody.append(
                    '<tr>' +
                        '<td colspan="5" class="text-center text-muted">' +
                            'No se encontraron abonos pendientes.' +
                        '</td>' +
                    '</tr>'
                );

                $("#contenedorAbonos").show();
                return;
            }

            $.each(listaAbonosPendientes, function (i, item) {
                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarAbono(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>").text(item.NumeroFactura || ""));
                fila.append($("<td>").text((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")));
                fila.append($("<td>").text(formatearFecha(item.FechaAbono)));
                fila.append($("<td>").text("₡" + parseFloat(item.MontoAbono || 0).toFixed(2)));

                var acciones = $("<td>");
                acciones.append(boton);

                fila.append(acciones);
                tbody.append(fila);
            });

            $("#contenedorAbonos").show();
        }

        function seleccionarAbono(item) {
            $("#txtIdFactura").val("");
            $("#txtIdAbonoCuentaPorCobrar").val(item.IdAbonoCuentaPorCobrar);

            $("#txtBuscarAbono").val(item.NumeroFactura || "");
            $("#lblAbonoSeleccionado").text(
                "Abono seleccionado de factura: " + (item.NumeroFactura || "") +
                " | Cliente: " + (item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")
            );

            $("#txtFechaIngreso").val(convertirFechaInput(item.FechaAbono));
            $("#txtMonto").val(parseFloat(item.MontoAbono || 0).toFixed(2));
            $("#txtDescripcion").val("Ingreso por abono de factura " + (item.NumeroFactura || ""));
            $("#cboOrigen").val("Abono CxC");

            $("#contenedorAbonos").hide();
        }

        function guardarIngreso() {
    $("#mensajeError").hide().text("");

    var montoTexto = $("#txtMonto").val().trim();

    var idFactura = $("#txtIdFactura").val() === "" ? null : parseInt($("#txtIdFactura").val());
    var idAbono = $("#txtIdAbonoCuentaPorCobrar").val() === "" ? null : parseInt($("#txtIdAbonoCuentaPorCobrar").val());

    var obj = {
        IdIngreso: parseInt($("#txtIdIngreso").val()),
        IdFactura: idFactura,
        IdAbonoCuentaPorCobrar: idAbono,
        IdCuentaContable: parseInt($("#cboCuentaContable").val()),
        FechaIngreso: $("#txtFechaIngreso").val(),
        Descripcion: $("#txtDescripcion").val().trim(),
        IdTipoIngreso: parseInt($("#cboTipoIngreso").val()),
        OrigenIngreso: $("#cboOrigen").val(),
        Monto: montoTexto === "" ? 0 : parseFloat(montoTexto),
        Activo: $("#cboActivo").val() === "true"
    };

    if (isNaN(obj.IdIngreso)) {
        obj.IdIngreso = 0;
    }

    if (obj.IdFactura != null && obj.IdAbonoCuentaPorCobrar != null) {
        mostrarError("El ingreso no puede estar asociado a una factura y a un abono al mismo tiempo.", "cboOrigen");
        return;
    }

    if (obj.FechaIngreso === "") {
        mostrarError("Debe ingresar la fecha del ingreso.", "txtFechaIngreso");
        return;
    }

    var mensajeFecha = validarFechaNoFutura(obj.FechaIngreso, "La fecha del ingreso no puede ser futura.");
    if (mensajeFecha !== "") {
        mostrarError(mensajeFecha, "txtFechaIngreso");
        return;
    }

    if (obj.IdTipoIngreso === 0 || isNaN(obj.IdTipoIngreso)) {
        mostrarError("Debe seleccionar un tipo de ingreso.", "cboTipoIngreso");
        return;
    }

    if (obj.IdCuentaContable === 0 || isNaN(obj.IdCuentaContable)) {
        mostrarError("Debe seleccionar una cuenta contable.", "cboCuentaContable");
        return;
    }

    if (obj.OrigenIngreso === "Factura" && obj.IdFactura == null) {
        mostrarError("Debe seleccionar una factura de contado pendiente.", "txtBuscarFactura");
        return;
    }

    if (obj.OrigenIngreso === "Abono CxC" && obj.IdAbonoCuentaPorCobrar == null) {
        mostrarError("Debe seleccionar un abono de cuenta por cobrar.", "txtBuscarAbono");
        return;
    }

    if (obj.Descripcion === "") {
        mostrarError("Debe ingresar una descripción.", "txtDescripcion");
        return;
    }

    if (obj.Descripcion.length > 150) {
        mostrarError("La descripción no puede superar los 150 caracteres.", "txtDescripcion");
        return;
    }

    var mensajeMonto = validarDecimalMayorCero(montoTexto, "el monto del ingreso");
    if (mensajeMonto !== "") {
        mostrarError(mensajeMonto, "txtMonto");
        return;
    }

    $.ajax({
        url: '@Url.Action("GuardarIngreso", "GestionarIngresos")',
        type: "POST",
        data: JSON.stringify({ obj: obj }),
        dataType: "json",
        contentType: "application/json; charset=utf-8",
        success: function (respuesta) {
            if (respuesta.resultado) {
                $("#FormModal").modal("hide");
                cargarIngresos();
            } else {
                $("#mensajeError").text(respuesta.mensaje).show();
            }
        },
        error: function () {
            $("#mensajeError").text("Error al guardar el ingreso.").show();
        }
    });
}

        function inactivarIngreso(idIngreso) {
            if (!confirm("¿Desea inactivar este ingreso?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarIngreso", "GestionarIngresos")',
                type: "POST",
                data: JSON.stringify({ idIngreso: idIngreso }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarIngresos();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el ingreso.");
                }
            });
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarNoDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoBusqueda(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarDecimalMayorCero(texto, nombreCampo) {
            if (texto === "") {
                return "Debe ingresar " + nombreCampo + ".";
            }

            if (!/^[0-9]+(\.[0-9]+)?$/.test(texto)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            var numero = parseFloat(texto);

            if (isNaN(numero)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            if (numero <= 0) {
                return nombreCampo + " debe ser mayor a cero.";
            }

            return "";
        }

        function validarFechaNoFutura(fechaTexto, mensaje) {
            if (fechaTexto === "") {
                return "";
            }

            var fecha = new Date(fechaTexto + "T00:00:00");
            var hoy = new Date();

            if (isNaN(fecha.getTime())) {
                return "Debe ingresar una fecha válida.";
            }

            hoy.setHours(0, 0, 0, 0);

            if (fecha > hoy) {
                return mensaje;
            }

            return "";
        }
    </script>
}