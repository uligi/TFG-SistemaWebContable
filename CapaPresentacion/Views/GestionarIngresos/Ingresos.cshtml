@{
    ViewBag.Title = "Ingresos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-ingreso,
    .codigo-factura,
    .codigo-cuenta {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Ingresos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Movimientos</li>
        <li class="breadcrumb-item active">Ingresos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de ingresos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalIngreso(null)">
            Nuevo ingreso
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscarIngreso" class="form-control" placeholder="Buscar por número, descripción, origen o cuenta..." />
            </div>

            <div class="col-md-3">
                <select id="cboFiltroOrigen" class="form-control">
                    <option value="">Todos los orígenes</option>
                    <option value="Factura">Factura</option>
                    <option value="Abono CxC">Abono CxC</option>
                    <option value="Manual">Manual</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary btn-block" onclick="cargarIngresos()">
                    Actualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaIngresos">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th>Cuenta</th>
                        <th>Origen</th>
                        <th>Referencia</th>
                        <th>Monto</th>
                        <th>Activo</th>
                        <th style="width:180px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModalIngreso" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalIngreso">Nuevo ingreso</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtNumeroIngresoInterno" value="" />

                <input type="hidden" id="txtIdentificacionCliente" value="" />
                <input type="hidden" id="txtNumeroFactura" value="" />

                <input type="hidden" id="txtIdentificacionClienteAbono" value="" />
                <input type="hidden" id="txtNumeroFacturaAbono" value="" />
                <input type="hidden" id="txtNumeroAbonoCuentaPorCobrar" value="0" />

                <div class="alert alert-danger" id="mensajeErrorIngreso" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoIngreso" style="display:none;"></div>

                <h6 class="font-weight-bold">Datos del ingreso</h6>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtNumeroIngreso">Número ingreso</label>
                        <input type="text" id="txtNumeroIngreso" class="form-control codigo-ingreso" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtFechaIngreso">Fecha ingreso</label>
                        <input type="date" id="txtFechaIngreso" class="form-control" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoIngreso">Tipo de ingreso</label>
                        <select id="cboTipoIngreso" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboOrigenIngreso">Origen</label>
                        <select id="cboOrigenIngreso" class="form-control" onchange="cambiarOrigenIngreso()">
                            <option value="Manual">Manual</option>
                            <option value="Factura">Factura contado</option>
                            <option value="Abono CxC">Abono cuenta por cobrar</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-5">
                        <label for="cboCuentaContable">Cuenta contable</label>
                        <select id="cboCuentaContable" class="form-control">
                            <option value="">Seleccione una cuenta</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtMonto">Monto</label>
                        <input type="text" id="txtMonto" class="form-control" />
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboActivoIngreso">Activo</label>
                        <select id="cboActivoIngreso" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-12">
                        <label for="txtDescripcion">Descripción</label>
                        <input type="text" id="txtDescripcion" class="form-control" maxlength="150" placeholder="Descripción del ingreso..." />
                    </div>

                </div>

                <hr />

                <div id="panelFactura" style="display:none;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="font-weight-bold mb-0">Facturas de contado pendientes de ingreso</h6>

                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="cargarFacturasContadoPendientes()">
                            Actualizar facturas
                        </button>
                    </div>

                    <small class="form-text text-muted mb-2">
                        Seleccione una factura de contado emitida que todavía no tenga ingreso registrado.
                    </small>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered" id="tablaFacturasPendientes">
                            <thead>
                                <tr>
                                    <th>Factura</th>
                                    <th>Cliente</th>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Total</th>
                                    <th style="width:110px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div id="panelAbono" style="display:none;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="font-weight-bold mb-0">Abonos CxC pendientes de ingreso</h6>

                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="cargarAbonosPendientes()">
                            Actualizar abonos
                        </button>
                    </div>

                    <small class="form-text text-muted mb-2">
                        Seleccione un abono de cuenta por cobrar que todavía no tenga ingreso registrado.
                    </small>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered" id="tablaAbonosPendientes">
                            <thead>
                                <tr>
                                    <th>Factura</th>
                                    <th># Abono</th>
                                    <th>Cliente</th>
                                    <th>Fecha</th>
                                    <th>Monto abono</th>
                                    <th>Estado cuenta</th>
                                    <th style="width:110px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div class="card bg-light mt-3">
                    <div class="card-body py-2">
                        <strong>Referencia seleccionada:</strong>
                        <span id="lblReferenciaSeleccionada" class="text-muted">Ingreso manual sin referencia.</span>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="limpiarFormularioIngreso()">
                    Limpiar
                </button>

                <button type="button" class="btn btn-primary" onclick="guardarIngreso()">
                    Guardar ingreso
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaIngresos = [];
        var listaFacturasPendientes = [];
        var listaAbonosPendientes = [];

        $(document).ready(function () {
            cargarIngresos();
            cargarTiposIngreso();
            cargarCuentasContables();

            $("#txtBuscarIngreso, #cboFiltroOrigen").on("keyup change", function () {
                pintarTablaIngresos();
            });

            $("#txtMonto").on("input", function () {
                limpiarDecimal("txtMonto", "Solo se permiten números y punto decimal.");
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoGeneral("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 150 caracteres.");
                }
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorIngreso").is(":visible")) {
                    $("#mensajeErrorIngreso").fadeOut(150);
                }

                if ($("#mensajeExitoIngreso").is(":visible")) {
                    $("#mensajeExitoIngreso").fadeOut(150);
                }
            });
        });

        function cargarIngresos() {
            $.ajax({
                url: '@Url.Action("ListarIngresos", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaIngresos = respuesta.data || [];
                    pintarTablaIngresos();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los ingresos.", "error");
                }
            });
        }

        function cargarTiposIngreso() {
            $.ajax({
                url: '@Url.Action("ListarTiposIngresoActivos", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoIngreso").empty().append('<option value="0">Seleccione un tipo</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboTipoIngreso").append(
                            $("<option>", {
                                value: item.IdTipoIngreso,
                                text: item.Nombre || item.TipoIngreso || item.Descripcion
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de ingreso.", "error");
                }
            });
        }

        function cargarCuentasContables() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContablesIngreso", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCuentaContable").empty().append('<option value="">Seleccione una cuenta</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        var codigo = item.CodigoCuenta || "";
                        var nombre = item.NombreCuenta || item.Nombre || "";

                        $("#cboCuentaContable").append(
                            $("<option>", {
                                value: codigo,
                                text: codigo + " - " + nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las cuentas contables.", "error");
                }
            });
        }

        function pintarTablaIngresos() {
            var filtro = $("#txtBuscarIngreso").val().toLowerCase();
            var origenFiltro = $("#cboFiltroOrigen").val();
            var tbody = $("#tablaIngresos tbody");

            tbody.empty();

            if (listaIngresos.length === 0) {
                tbody.append('<tr><td colspan="10" class="text-center text-muted">No hay ingresos registrados.</td></tr>');
                return;
            }

            $.each(listaIngresos, function (i, item) {
                var numero = item.NumeroIngreso || "";
                var descripcion = item.Descripcion || "";
                var tipo = item.TipoIngresoNombre || "";
                var cuenta = (item.CodigoCuenta || "") + " - " + (item.NombreCuenta || "");
                var origen = item.OrigenIngreso || "";

                var referencia = obtenerReferenciaIngreso(item);

                var texto = (numero + " " + descripcion + " " + tipo + " " + cuenta + " " + origen + " " + referencia).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                if (origenFiltro !== "" && origen !== origenFiltro) {
                    return;
                }

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModalIngreso(item);
                });

                var botonEstado = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarIngreso(item.NumeroIngreso);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonEstado);
                }

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-ingreso", text: numero }));
                fila.append($("<td>").text(formatearFecha(item.FechaIngreso)));
                fila.append($("<td>").text(descripcion));
                fila.append($("<td>").text(tipo));
                fila.append($("<td>").html('<span class="codigo-cuenta">' + (item.CodigoCuenta || "") + '</span><br/><span class="texto-tabla-secundario">' + (item.NombreCuenta || "") + '</span>'));
                fila.append($("<td>").html(obtenerBadgeOrigen(origen)));
                fila.append($("<td>").text(referencia));
                fila.append($("<td>").text(formatearNumero(item.Monto)));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function obtenerReferenciaIngreso(item) {
            if ((item.OrigenIngreso || "") === "Factura") {
                return (item.NumeroFactura || "") + " - " + (item.ClienteNombre || "");
            }

            if ((item.OrigenIngreso || "") === "Abono CxC") {
                return (item.NumeroFacturaAbono || "") + " / Abono #" + (item.NumeroAbonoCuentaPorCobrar || 0);
            }

            return "Ingreso manual";
        }

        function obtenerBadgeOrigen(origen) {
            if (origen === "Factura") {
                return '<span class="badge badge-success">Factura</span>';
            }

            if (origen === "Abono CxC") {
                return '<span class="badge badge-warning">Abono CxC</span>';
            }

            return '<span class="badge badge-secondary">Manual</span>';
        }

        function abrirModalIngreso(json) {
            limpiarErrores();
            limpiarFormularioIngreso();

            $("#tituloModalIngreso").text("Nuevo ingreso");
            $("#txtFechaIngreso").val(convertirDateAInput(new Date()));
            $("#cboOrigenIngreso").val("Manual");
            cambiarOrigenIngreso();

            if (json != null) {
                $("#tituloModalIngreso").text("Editar ingreso");

                $("#txtNumeroIngresoInterno").val(json.NumeroIngreso || "");
                $("#txtNumeroIngreso").val(json.NumeroIngreso || "");

                $("#txtFechaIngreso").val(convertirFechaInput(json.FechaIngreso));
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboTipoIngreso").val(json.IdTipoIngreso);
                $("#cboCuentaContable").val(json.CodigoCuenta || "");
                $("#cboOrigenIngreso").val(json.OrigenIngreso || "Manual");
                $("#txtMonto").val(formatearNumero(json.Monto));
                $("#cboActivoIngreso").val(json.Activo ? "true" : "false");

                $("#txtIdentificacionCliente").val(json.IdentificacionCliente || "");
                $("#txtNumeroFactura").val(json.NumeroFactura || "");

                $("#txtIdentificacionClienteAbono").val(json.IdentificacionClienteAbono || "");
                $("#txtNumeroFacturaAbono").val(json.NumeroFacturaAbono || "");
                $("#txtNumeroAbonoCuentaPorCobrar").val(json.NumeroAbonoCuentaPorCobrar || 0);

                $("#lblReferenciaSeleccionada").text(obtenerReferenciaIngreso(json));

                cambiarOrigenIngreso();

                $("#cboOrigenIngreso").prop("disabled", true);
            } else {
                $("#cboOrigenIngreso").prop("disabled", false);
            }

            $("#FormModalIngreso").modal("show");
        }

        function cambiarOrigenIngreso() {
            var origen = $("#cboOrigenIngreso").val();

            $("#panelFactura").hide();
            $("#panelAbono").hide();

            limpiarReferenciaSeleccionada();

            if (origen === "Factura") {
                $("#panelFactura").show();
                cargarFacturasContadoPendientes();
                $("#lblReferenciaSeleccionada").text("Seleccione una factura de contado pendiente.");
            } else if (origen === "Abono CxC") {
                $("#panelAbono").show();
                cargarAbonosPendientes();
                $("#lblReferenciaSeleccionada").text("Seleccione un abono de cuenta por cobrar pendiente.");
            } else {
                $("#lblReferenciaSeleccionada").text("Ingreso manual sin referencia.");
            }
        }

        function cargarFacturasContadoPendientes() {
            $.ajax({
                url: '@Url.Action("ListarFacturasContadoPendientes", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaFacturasPendientes = respuesta.data || [];
                    pintarFacturasPendientes();
                },
                error: function () {
                    $("#mensajeErrorIngreso").text("Error al cargar facturas pendientes.").show();
                }
            });
        }

        function pintarFacturasPendientes() {
            var tbody = $("#tablaFacturasPendientes tbody");
            tbody.empty();

            if (listaFacturasPendientes.length === 0) {
                tbody.append('<tr><td colspan="6" class="text-center text-muted">No hay facturas de contado pendientes de ingreso.</td></tr>');
                return;
            }

            $.each(listaFacturasPendientes, function (i, item) {
                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarFacturaPendiente(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-factura", text: item.NumeroFactura || "" }));
                fila.append($("<td>").text((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")));
                fila.append($("<td>").text(formatearFecha(item.FechaFactura)));
                fila.append($("<td>").text(item.TipoFactura || ""));
                fila.append($("<td>").text(formatearNumero(item.TotalFactura)));
                fila.append($("<td>").append(boton));

                tbody.append(fila);
            });
        }

        function seleccionarFacturaPendiente(item) {
            $("#txtIdentificacionCliente").val(item.IdentificacionCliente || "");
            $("#txtNumeroFactura").val(item.NumeroFactura || "");

            $("#txtIdentificacionClienteAbono").val("000000000");
            $("#txtNumeroFacturaAbono").val("FAC-GENERAL-000000");
            $("#txtNumeroAbonoCuentaPorCobrar").val("0");

            $("#txtMonto").val(formatearNumero(item.TotalFactura));

            if ($("#txtDescripcion").val().trim() === "") {
                $("#txtDescripcion").val("Ingreso por factura " + (item.NumeroFactura || ""));
            }

            $("#lblReferenciaSeleccionada").text(
                "Factura seleccionada: " +
                (item.NumeroFactura || "") +
                " - " +
                (item.IdentificacionCliente || "") +
                " - " +
                (item.ClienteNombre || "")
            );
        }

        function cargarAbonosPendientes() {
            $.ajax({
                url: '@Url.Action("ListarAbonosPendientesIngreso", "GestionarIngresos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaAbonosPendientes = respuesta.data || [];
                    pintarAbonosPendientes();
                },
                error: function () {
                    $("#mensajeErrorIngreso").text("Error al cargar abonos pendientes.").show();
                }
            });
        }

        function pintarAbonosPendientes() {
            var tbody = $("#tablaAbonosPendientes tbody");
            tbody.empty();

            if (listaAbonosPendientes.length === 0) {
                tbody.append('<tr><td colspan="7" class="text-center text-muted">No hay abonos pendientes de ingreso.</td></tr>');
                return;
            }

            $.each(listaAbonosPendientes, function (i, item) {
                var boton = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-primary",
                    text: "Seleccionar"
                }).on("click", function () {
                    seleccionarAbonoPendiente(item);
                });

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-factura", text: item.NumeroFactura || "" }));
                fila.append($("<td>").text(item.NumeroAbono || 0));
                fila.append($("<td>").text((item.IdentificacionCliente || "") + " - " + (item.ClienteNombre || "")));
                fila.append($("<td>").text(formatearFecha(item.FechaAbono)));
                fila.append($("<td>").text(formatearNumero(item.MontoAbono)));
                fila.append($("<td>").text(item.EstadoCuenta || ""));
                fila.append($("<td>").append(boton));

                tbody.append(fila);
            });
        }

        function seleccionarAbonoPendiente(item) {
            $("#txtIdentificacionCliente").val("000000000");
            $("#txtNumeroFactura").val("FAC-GENERAL-000000");

            $("#txtIdentificacionClienteAbono").val(item.IdentificacionCliente || "");
            $("#txtNumeroFacturaAbono").val(item.NumeroFactura || "");
            $("#txtNumeroAbonoCuentaPorCobrar").val(item.NumeroAbono || 0);

            $("#txtMonto").val(formatearNumero(item.MontoAbono));

            if ($("#txtDescripcion").val().trim() === "") {
                $("#txtDescripcion").val("Ingreso por abono CxC factura " + (item.NumeroFactura || "") + " abono #" + (item.NumeroAbono || 0));
            }

            $("#lblReferenciaSeleccionada").text(
                "Abono seleccionado: Factura " +
                (item.NumeroFactura || "") +
                " / Abono #" +
                (item.NumeroAbono || 0) +
                " - " +
                (item.IdentificacionCliente || "") +
                " - " +
                (item.ClienteNombre || "")
            );
        }

        function guardarIngreso() {
            $("#mensajeErrorIngreso").hide().text("");
            $("#mensajeExitoIngreso").hide().text("");

            var obj = {
                NumeroIngreso: $("#txtNumeroIngresoInterno").val().trim(),
                FechaIngreso: $("#txtFechaIngreso").val(),
                Descripcion: $("#txtDescripcion").val().trim(),
                IdTipoIngreso: parseInt($("#cboTipoIngreso").val()),
                CodigoCuenta: $("#cboCuentaContable").val(),
                IdentificacionCliente: $("#txtIdentificacionCliente").val(),
                NumeroFactura: $("#txtNumeroFactura").val(),
                IdentificacionClienteAbono: $("#txtIdentificacionClienteAbono").val(),
                NumeroFacturaAbono: $("#txtNumeroFacturaAbono").val(),
                NumeroAbonoCuentaPorCobrar: parseInt($("#txtNumeroAbonoCuentaPorCobrar").val()),
                OrigenIngreso: $("#cboOrigenIngreso").val(),
                Monto: parseFloat($("#txtMonto").val()),
                Activo: $("#cboActivoIngreso").val() === "true"
            };

            if (isNaN(obj.IdTipoIngreso)) obj.IdTipoIngreso = 0;
            if (isNaN(obj.NumeroAbonoCuentaPorCobrar)) obj.NumeroAbonoCuentaPorCobrar = 0;
            if (isNaN(obj.Monto)) obj.Monto = 0;

            if (obj.FechaIngreso === "") {
                mostrarErrorIngreso("Debe ingresar la fecha del ingreso.", "txtFechaIngreso");
                return;
            }

            if (obj.Descripcion === "") {
                mostrarErrorIngreso("Debe ingresar una descripción.", "txtDescripcion");
                return;
            }

            if (obj.IdTipoIngreso === 0) {
                mostrarErrorIngreso("Debe seleccionar un tipo de ingreso.", "cboTipoIngreso");
                return;
            }

            if (obj.CodigoCuenta === "") {
                mostrarErrorIngreso("Debe seleccionar una cuenta contable.", "cboCuentaContable");
                return;
            }

            if (obj.Monto <= 0) {
                mostrarErrorIngreso("El monto del ingreso debe ser mayor a cero.", "txtMonto");
                return;
            }

            if (obj.OrigenIngreso === "Factura") {
                if (obj.IdentificacionCliente === "" || obj.NumeroFactura === "") {
                    mostrarErrorIngreso("Debe seleccionar una factura de contado pendiente.", "tablaFacturasPendientes");
                    return;
                }
            }

            if (obj.OrigenIngreso === "Abono CxC") {
                if (obj.IdentificacionClienteAbono === "" || obj.NumeroFacturaAbono === "" || obj.NumeroAbonoCuentaPorCobrar <= 0) {
                    mostrarErrorIngreso("Debe seleccionar un abono pendiente de ingreso.", "tablaAbonosPendientes");
                    return;
                }
            }

            $.ajax({
                url: '@Url.Action("GuardarIngreso", "GestionarIngresos")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        var numeroIngreso = respuesta.numeroIngreso || obj.NumeroIngreso;

                        $("#txtNumeroIngresoInterno").val(numeroIngreso);
                        $("#txtNumeroIngreso").val(numeroIngreso);

                        $("#mensajeExitoIngreso").text(respuesta.mensaje || "Ingreso guardado correctamente.").show();

                        cargarIngresos();

                        if (obj.OrigenIngreso === "Factura") {
                            cargarFacturasContadoPendientes();
                        }

                        if (obj.OrigenIngreso === "Abono CxC") {
                            cargarAbonosPendientes();
                        }
                    } else {
                        $("#mensajeErrorIngreso").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorIngreso").text("Error al guardar el ingreso.").show();
                }
            });
        }

        function inactivarIngreso(numeroIngreso) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este ingreso"),
                function () {
                    ejecutarInactivarIngreso(numeroIngreso);
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function ejecutarInactivarIngreso(numeroIngreso) {
            $.ajax({
                url: '@Url.Action("InactivarIngreso", "GestionarIngresos")',
                type: "POST",
                data: JSON.stringify({ numeroIngreso: numeroIngreso }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarIngresos();
                        mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Ingreso"), "exito");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el ingreso.", "error");
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al procesar el ingreso.", "error");
                }
            });
        }

        function limpiarFormularioIngreso() {
            $("#txtNumeroIngresoInterno").val("");
            $("#txtNumeroIngreso").val("");

            $("#txtFechaIngreso").val(convertirDateAInput(new Date()));
            $("#txtDescripcion").val("");
            $("#cboTipoIngreso").val("0");
            $("#cboCuentaContable").val("");
            $("#cboOrigenIngreso").val("Manual");
            $("#txtMonto").val("");
            $("#cboActivoIngreso").val("true");

            $("#cboOrigenIngreso").prop("disabled", false);

            limpiarReferenciaSeleccionada();

            $("#panelFactura").hide();
            $("#panelAbono").hide();

            $("#lblReferenciaSeleccionada").text("Ingreso manual sin referencia.");
        }

        function limpiarReferenciaSeleccionada() {
            $("#txtIdentificacionCliente").val("");
            $("#txtNumeroFactura").val("");

            $("#txtIdentificacionClienteAbono").val("");
            $("#txtNumeroFacturaAbono").val("");
            $("#txtNumeroAbonoCuentaPorCobrar").val("0");
        }

        function mostrarErrorIngreso(mensaje, idCampo) {
            $("#mensajeErrorIngreso").text(mensaje).show();

            if (idCampo && $("#" + idCampo).length > 0) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function limpiarErrores() {
            $("#mensajeErrorIngreso").hide().text("");
            $("#mensajeExitoIngreso").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function formatearFecha(valor) {
            if (!valor) {
                return "";
            }

            var fecha = new Date(parseInt(valor.replace("/Date(", "").replace(")/", "")));

            if (isNaN(fecha.getTime())) {
                fecha = new Date(valor);
            }

            return convertirDateAInput(fecha);
        }

        function convertirFechaInput(valor) {
            return formatearFecha(valor);
        }

        function convertirDateAInput(fecha) {
            var anio = fecha.getFullYear();
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var dia = ("0" + fecha.getDate()).slice(-2);

            return anio + "-" + mes + "-" + dia;
        }
    </script>
}