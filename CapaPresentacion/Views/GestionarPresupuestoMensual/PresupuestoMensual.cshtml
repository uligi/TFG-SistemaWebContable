        function obtenerBadgeEstadoPresupuesto(estado) {
            if (estado === "Abierto") {
                return '<span class="badge badge-success">Abierto</span>';
            }

            if (estado === "Cerrado") {
                return '<span class="badge badge-warning">Cerrado</span>';
            }

            if (estado === "Inactivo") {
                return '<span class="badge badge-secondary">Inactivo</span>';
            }

            return '<span class="badge badge-info">' + estado + '</span>';
        }

        function obtenerBadgeTipoMovimiento(tipo) {
            if (tipo === "Ingreso") {
                return '<span class="badge badge-success">Ingreso</span>';
            }

            if (tipo === "Gasto") {
                return '<span class="badge badge-danger">Gasto</span>';
            }

            return '<span class="badge badge-secondary">' + tipo + '</span>';
        }

        function obtenerBadgeEstadoEjecucion(estado) {
            if (estado === "Cumplido") {
                return '<span class="badge badge-success">Cumplido</span>';
            }

            if (estado === "Dentro del presupuesto") {
                return '<span class="badge badge-info">Dentro del presupuesto</span>';
            }

            if (estado === "Excedido") {
                return '<span class="badge badge-danger">Excedido</span>';
            }

            if (estado === "Por debajo") {
                return '<span class="badge badge-warning">Por debajo</span>';
            }

            return '<span class="badge badge-secondary">' + estado + '</span>';
        }

        function obtenerNombreMes(mes) {
            var nombres = [
                "",
                "Enero",
                "Febrero",
                "Marzo",
                "Abril",
                "Mayo",
                "Junio",
                "Julio",
                "Agosto",
                "Septiembre",
                "Octubre",
                "Noviembre",
                "Diciembre"
            ];

            return nombres[mes] || "";
        }

        function mostrarErrorPresupuesto(mensaje, idCampo) {
            $("#mensajeErrorPresupuesto").text(mensaje).show();

            if (idCampo && $("#" + idCampo).length > 0) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function limpiarErrores() {
            $("#mensajeErrorPresupuesto").hide().text("");
            $("#mensajeExitoPresupuesto").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarEntero(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function esAdministradorPresupuesto() {
            return window.esAdministradorSistema === true;
        }

        function obtenerTextoInactivarPresupuesto() {
            return esAdministradorPresupuesto() ? "Inactivar" : "Eliminar";
        }

        function obtenerTextoActivarPresupuesto() {
            return esAdministradorPresupuesto() ? "Activar" : "Restaurar";
        }

        function obtenerTituloInactivarPresupuesto(tipo) {
            var accion = obtenerTextoInactivarPresupuesto();

            if (tipo === "detalle") {
                return accion + " detalle";
            }

            return accion + " presupuesto";
        }

        function obtenerTituloActivarPresupuesto(tipo) {
            var accion = obtenerTextoActivarPresupuesto();

            if (tipo === "detalle") {
                return accion + " detalle";
            }

            return accion + " presupuesto";
        }

        function obtenerMensajeInactivarPresupuesto(tipo) {
            var accion = obtenerTextoInactivarPresupuesto().toLowerCase();

            if (tipo === "detalle") {
                return "¿Desea " + accion + " este detalle de presupuesto?";
            }

            return "¿Desea " + accion + " este presupuesto mensual?";
        }

        function obtenerMensajeActivarPresupuesto(tipo) {
            var accion = obtenerTextoActivarPresupuesto().toLowerCase();

            if (tipo === "detalle") {
                return "¿Desea " + accion + " este detalle de presupuesto?";
            }

            return "¿Desea " + accion + " este presupuesto mensual?";
        }

    </script>
}