                        url: '@Url.Action("InactivarPresupuestoMensual", "GestionarPresupuestoMensual")',
                        type: "POST",
                        data: JSON.stringify({
                            anio: anio,
                            mes: mes
                        }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (respuesta) {
