@{
    ViewBag.Title = "Presupuesto Mensual";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .codigo-cuenta {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .resumen-box {
        border-radius: 8px;
        padding: 12px;
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        margin-bottom: 10px;
    }

    .resumen-titulo {
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 4px;
    }

    .resumen-valor {
        font-size: 18px;
        font-weight: bold;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Presupuesto Mensual</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Contabilidad</li>
        <li class="breadcrumb-item active">Presupuesto mensual</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de presupuestos mensuales</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModalPresupuesto(null)">
            Nuevo presupuesto
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-4">
                <input type="text" id="txtBuscarPresupuesto" class="form-control" placeholder="Buscar por año, mes o estado..." />
            </div>

            <div class="col-md-3">
                <select id="cboFiltroEstado" class="form-control">
                    <option value="">Todos los estados</option>
                    <option value="Abierto">Abierto</option>
                    <option value="Cerrado">Cerrado</option>
                    <option value="Inactivo">Inactivo</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary btn-block" onclick="cargarPresupuestos()">
                    Actualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaPresupuestos">
                <thead>
                    <tr>
                        <th>Año</th>
                        <th>Mes</th>
                        <th>Periodo</th>
                        <th>Estado</th>
                        <th>Activo</th>
                        <th style="width:330px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModalPresupuesto" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModalPresupuesto">Nuevo presupuesto mensual</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtAnioSeleccionado" value="0" />
                <input type="hidden" id="txtMesSeleccionado" value="0" />

                <div class="alert alert-danger" id="mensajeErrorPresupuesto" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoPresupuesto" style="display:none;"></div>

                <h6 class="font-weight-bold">Encabezado del presupuesto</h6>

                <div class="form-row">

                    <div class="form-group col-md-3">
                        <label for="txtAnio">Año</label>
                        <input type="number" id="txtAnio" class="form-control" min="2000" max="2100" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboMes">Mes</label>
                        <select id="cboMes" class="form-control">
                            <option value="0">Seleccione un mes</option>
                            <option value="1">Enero</option>
                            <option value="2">Febrero</option>
                            <option value="3">Marzo</option>
                            <option value="4">Abril</option>
                            <option value="5">Mayo</option>
                            <option value="6">Junio</option>
                            <option value="7">Julio</option>
                            <option value="8">Agosto</option>
                            <option value="9">Septiembre</option>
                            <option value="10">Octubre</option>
                            <option value="11">Noviembre</option>
                            <option value="12">Diciembre</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboEstadoPresupuesto">Estado</label>
                        <select id="cboEstadoPresupuesto" class="form-control">
                            <option value="Abierto">Abierto</option>
                            <option value="Cerrado">Cerrado</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboActivoPresupuesto">Activo</label>
                        <select id="cboActivoPresupuesto" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                </div>

                <div class="text-right mb-3">
                    <button type="button" class="btn btn-primary" onclick="guardarPresupuesto()">
                        Guardar encabezado
                    </button>
                </div>

                <hr />

                <div class="row mb-3">
                    <div class="col-md-2">
                        <div class="resumen-box">
                            <div class="resumen-titulo">Ingreso presupuestado</div>
                            <div class="resumen-valor" id="lblIngresoPresupuestado">0.00</div>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="resumen-box">
                            <div class="resumen-titulo">Ingreso real</div>
                            <div class="resumen-valor" id="lblIngresoReal">0.00</div>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="resumen-box">
                            <div class="resumen-titulo">Gasto presupuestado</div>
                            <div class="resumen-valor" id="lblGastoPresupuestado">0.00</div>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="resumen-box">
                            <div class="resumen-titulo">Gasto real</div>
                            <div class="resumen-valor" id="lblGastoReal">0.00</div>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="resumen-box">
                            <div class="resumen-titulo">Utilidad presupuestada</div>
                            <div class="resumen-valor" id="lblUtilidadPresupuestada">0.00</div>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="resumen-box">
                            <div class="resumen-titulo">Utilidad real</div>
                            <div class="resumen-valor" id="lblUtilidadReal">0.00</div>
                        </div>
                    </div>
                </div>

                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-toggle="tab" href="#tabDetalles" role="tab">
                            Detalles del presupuesto
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tabResumen" role="tab">
                            Presupuesto vs real
                        </a>
                    </li>
                </ul>

                <div class="tab-content pt-3">

                    <div class="tab-pane fade show active" id="tabDetalles" role="tabpanel">

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="font-weight-bold mb-0">Detalle por cuenta contable</h6>

                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="cargarDetallesYResumen()">
                                Actualizar detalle
                            </button>
                        </div>

                        <div class="form-row">

                            <div class="form-group col-md-4">
                                <label for="cboCuentaContable">Cuenta contable</label>
                                <select id="cboCuentaContable" class="form-control">
                                    <option value="">Seleccione una cuenta</option>
                                </select>
                            </div>

                            <div class="form-group col-md-3">
                                <label for="cboTipoMovimiento">Tipo movimiento</label>
                                <select id="cboTipoMovimiento" class="form-control">
                                    <option value="">Seleccione un tipo</option>
                                    <option value="Ingreso">Ingreso</option>
                                    <option value="Gasto">Gasto</option>
                                </select>
                            </div>

                            <div class="form-group col-md-3">
                                <label for="txtMontoPresupuestado">Monto presupuestado</label>
                                <input type="text" id="txtMontoPresupuestado" class="form-control" />
                            </div>

                            <div class="form-group col-md-2">
                                <label for="cboActivoDetalle">Activo</label>
                                <select id="cboActivoDetalle" class="form-control">
                                    <option value="true">Sí</option>
                                    <option value="false">No</option>
                                </select>
                            </div>

                        </div>

                        <div class="text-right mb-3">
                            <button type="button" class="btn btn-secondary" onclick="limpiarDetalle()">
                                Limpiar detalle
                            </button>

                            <button type="button" class="btn btn-primary" onclick="guardarDetalle()">
                                Guardar detalle
                            </button>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered" id="tablaDetalles">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Cuenta</th>
                                        <th>Monto presupuestado</th>
                                        <th>Activo</th>
                                        <th style="width:190px;">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>

                    </div>

                    <div class="tab-pane fade" id="tabResumen" role="tabpanel">

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="font-weight-bold mb-0">Comparativo presupuestado vs real</h6>

                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="cargarResumenVsReal()">
                                Actualizar resumen
                            </button>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered" id="tablaResumen">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Cuenta</th>
                                        <th>Presupuestado</th>
                                        <th>Real</th>
                                        <th>Diferencia</th>
                                        <th>% ejecución</th>
                                        <th>Estado ejecución</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>

                    </div>

                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-warning" onclick="cerrarPresupuestoActual()">
                    Cerrar presupuesto
                </button>

                <button type="button" class="btn btn-info" onclick="reabrirPresupuestoActual()">
                    Reabrir presupuesto
                </button>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar ventana
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaPresupuestos = [];
        var listaDetalles = [];
        var listaResumen = [];

        $(document).ready(function () {
            cargarPresupuestos();
            cargarCuentasContables();

            $("#txtBuscarPresupuesto, #cboFiltroEstado").on("keyup change", function () {
                pintarTablaPresupuestos();
            });

            $("#txtMontoPresupuestado").on("input", function () {
                limpiarDecimal("txtMontoPresupuestado", "Solo se permiten números y punto decimal.");
            });

            $("#txtAnio").on("input", function () {
                limpiarEntero("txtAnio", "Solo se permiten números en el año.");
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeErrorPresupuesto").is(":visible")) {
                    $("#mensajeErrorPresupuesto").fadeOut(150);
                }

                if ($("#mensajeExitoPresupuesto").is(":visible")) {
                    $("#mensajeExitoPresupuesto").fadeOut(150);
                }
            });
        });

        function cargarPresupuestos() {
            $.ajax({
                url: '@Url.Action("ListarPresupuestosMensuales", "GestionarPresupuestoMensual")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaPresupuestos = respuesta.data || [];
                    pintarTablaPresupuestos();
                },
                error: function () {
                    alert("Error al cargar los presupuestos mensuales.");
                }
            });
        }

        function pintarTablaPresupuestos() {
            var filtro = $("#txtBuscarPresupuesto").val().toLowerCase();
            var estadoFiltro = $("#cboFiltroEstado").val();
            var tbody = $("#tablaPresupuestos tbody");

            tbody.empty();

            if (listaPresupuestos.length === 0) {
                tbody.append('<tr><td colspan="6" class="text-center text-muted">No hay presupuestos registrados.</td></tr>');
                return;
            }

            $.each(listaPresupuestos, function (i, item) {
                var anio = item.Anio || 0;
                var mes = item.Mes || 0;
                var mesNombre = item.MesNombre || obtenerNombreMes(mes);
                var estado = item.Estado || "";

                var texto = (anio + " " + mes + " " + mesNombre + " " + estado).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                if (estadoFiltro !== "" && estado !== estadoFiltro) {
                    return;
                }

                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var estadoBadge = obtenerBadgeEstadoPresupuesto(estado);

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Abrir"
                }).on("click", function () {
                    abrirModalPresupuesto(item);
                });

                var botonCerrar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-warning mr-1",
                    text: "Cerrar"
                }).on("click", function () {
                    cerrarPresupuesto(anio, mes);
                });

                var botonReabrir = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-info mr-1",
                    text: "Reabrir"
                }).on("click", function () {
                    reabrirPresupuesto(anio, mes);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoInactivarPresupuesto()
                }).on("click", function () {
                    inactivarPresupuesto(anio, mes);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo && estado !== "Cerrado") {
                    acciones.append(botonCerrar);
                }

                if (item.Activo && estado === "Cerrado") {
                    acciones.append(botonReabrir);
                }

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").text(anio));
                fila.append($("<td>").text(mesNombre));
                fila.append($("<td>").text(anio + "-" + ("0" + mes).slice(-2)));
                fila.append($("<td>").html(estadoBadge));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function abrirModalPresupuesto(json) {
            limpiarErrores();
            limpiarDetalle();

            listaDetalles = [];
            listaResumen = [];
            pintarDetalles();
            pintarResumen([]);
            actualizarResumenGeneral(null);

            var hoy = new Date();

            $("#tituloModalPresupuesto").text("Nuevo presupuesto mensual");
            $("#txtAnio").val(hoy.getFullYear());
            $("#cboMes").val(hoy.getMonth() + 1);
            $("#cboEstadoPresupuesto").val("Abierto");
            $("#cboActivoPresupuesto").val("true");
            $("#txtAnioSeleccionado").val("0");
            $("#txtMesSeleccionado").val("0");

            $("#txtAnio").prop("readonly", false);
            $("#cboMes").prop("disabled", false);

            if (json != null) {
                $("#tituloModalPresupuesto").text("Presupuesto mensual - " + (json.MesNombre || obtenerNombreMes(json.Mes)) + " " + json.Anio);

                $("#txtAnio").val(json.Anio);
                $("#cboMes").val(json.Mes);
                $("#cboEstadoPresupuesto").val(json.Estado || "Abierto");
                $("#cboActivoPresupuesto").val(json.Activo ? "true" : "false");

                $("#txtAnioSeleccionado").val(json.Anio);
                $("#txtMesSeleccionado").val(json.Mes);

                $("#txtAnio").prop("readonly", true);
                $("#cboMes").prop("disabled", true);

                cargarDetallesYResumen();
            }

            $("#FormModalPresupuesto").modal("show");
        }

        function guardarPresupuesto() {
            $("#mensajeErrorPresupuesto").hide().text("");
            $("#mensajeExitoPresupuesto").hide().text("");

            var obj = {
                Anio: parseInt($("#txtAnio").val()),
                Mes: parseInt($("#cboMes").val()),
                Estado: $("#cboEstadoPresupuesto").val(),
                Activo: $("#cboActivoPresupuesto").val() === "true"
            };

            if (isNaN(obj.Anio)) obj.Anio = 0;
            if (isNaN(obj.Mes)) obj.Mes = 0;

            if (obj.Anio < 2000 || obj.Anio > 2100) {
                mostrarErrorPresupuesto("Debe ingresar un año válido.", "txtAnio");
                return;
            }

            if (obj.Mes < 1 || obj.Mes > 12) {
                mostrarErrorPresupuesto("Debe seleccionar un mes.", "cboMes");
                return;
            }

            if (obj.Estado === "") {
                mostrarErrorPresupuesto("Debe seleccionar un estado.", "cboEstadoPresupuesto");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarPresupuestoMensual", "GestionarPresupuestoMensual")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#mensajeExitoPresupuesto").text(respuesta.mensaje || "Presupuesto guardado correctamente.").show();

                        $("#txtAnioSeleccionado").val(obj.Anio);
                        $("#txtMesSeleccionado").val(obj.Mes);

                        $("#txtAnio").prop("readonly", true);
                        $("#cboMes").prop("disabled", true);

                        cargarPresupuestos();
                        cargarDetallesYResumen();
                    } else {
                        $("#mensajeErrorPresupuesto").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorPresupuesto").text("Error al guardar el presupuesto mensual.").show();
                }
            });
        }

        function cargarCuentasContables() {
            $.ajax({
                url: '@Url.Action("ListarCuentasContablesPresupuesto", "GestionarPresupuestoMensual")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCuentaContable").empty().append('<option value="">Seleccione una cuenta</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        var codigo = item.CodigoCuenta || "";
                        var nombre = item.NombreCuenta || item.Nombre || "";

                        $("#cboCuentaContable").append(
                            $("<option>", {
                                value: codigo,
                                text: codigo + " - " + nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las cuentas contables.", "error");
                }
            });
        }

        function cargarDetallesYResumen() {
            cargarDetalles();
            cargarResumenVsReal();
            cargarResumenGeneral();
        }

        function cargarDetalles() {
            var anio = parseInt($("#txtAnioSeleccionado").val());
            var mes = parseInt($("#txtMesSeleccionado").val());

            if (anio === 0 || mes === 0 || isNaN(anio) || isNaN(mes)) {
                return;
            }

            $.ajax({
                url: '@Url.Action("ListarDetallesPresupuestoMensual", "GestionarPresupuestoMensual")',
                type: "GET",
                data: {
                    anio: anio,
                    mes: mes
                },
                dataType: "json",
                success: function (respuesta) {
                    listaDetalles = respuesta.data || [];
                    pintarDetalles();
                },
                error: function () {
                    $("#mensajeErrorPresupuesto").text("Error al cargar los detalles del presupuesto.").show();
                }
            });
        }

        function pintarDetalles() {
            var tbody = $("#tablaDetalles tbody");
            tbody.empty();

            if (listaDetalles.length === 0) {
                tbody.append('<tr><td colspan="5" class="text-center text-muted">No hay detalles registrados.</td></tr>');
                return;
            }

            $.each(listaDetalles, function (i, item) {
                var activo = item.Activo
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-secondary">No</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    editarDetalle(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger mr-1",
                    text: obtenerTextoInactivarPresupuesto()
                }).on("click", function () {
                    inactivarDetalle(item.Anio, item.Mes, item.CodigoCuenta, item.TipoMovimiento);
                });

                var botonActivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-success",
                    text: obtenerTextoActivarPresupuesto()
                }).on("click", function () {
                    activarDetalle(item.Anio, item.Mes, item.CodigoCuenta, item.TipoMovimiento);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                } else {
                    acciones.append(botonActivar);
                }

                var fila = $("<tr>");
                fila.append($("<td>").html(obtenerBadgeTipoMovimiento(item.TipoMovimiento)));
                fila.append($("<td>").html('<span class="codigo-cuenta">' + (item.CodigoCuenta || "") + '</span><br/><span class="texto-tabla-secundario">' + (item.NombreCuenta || "") + '</span>'));
                fila.append($("<td>").text(formatearNumero(item.MontoPresupuestado)));
                fila.append($("<td>").html(activo));
                fila.append(acciones);

                tbody.append(fila);
            });
        }

        function guardarDetalle() {
            $("#mensajeErrorPresupuesto").hide().text("");
            $("#mensajeExitoPresupuesto").hide().text("");

            var anio = parseInt($("#txtAnioSeleccionado").val());
            var mes = parseInt($("#txtMesSeleccionado").val());

            if (anio === 0 || mes === 0 || isNaN(anio) || isNaN(mes)) {
                mostrarErrorPresupuesto("Primero debe guardar el encabezado del presupuesto.", "txtAnio");
                return;
            }

            var obj = {
                Anio: anio,
                Mes: mes,
                CodigoCuenta: $("#cboCuentaContable").val(),
                TipoMovimiento: $("#cboTipoMovimiento").val(),
                MontoPresupuestado: parseFloat($("#txtMontoPresupuestado").val()),
                Activo: $("#cboActivoDetalle").val() === "true"
            };

            if (isNaN(obj.MontoPresupuestado)) obj.MontoPresupuestado = 0;

            if (obj.CodigoCuenta === "") {
                mostrarErrorPresupuesto("Debe seleccionar una cuenta contable.", "cboCuentaContable");
                return;
            }

            if (obj.TipoMovimiento === "") {
                mostrarErrorPresupuesto("Debe seleccionar el tipo de movimiento.", "cboTipoMovimiento");
                return;
            }

            if (obj.MontoPresupuestado < 0) {
                mostrarErrorPresupuesto("El monto presupuestado no puede ser negativo.", "txtMontoPresupuestado");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarDetallePresupuestoMensual", "GestionarPresupuestoMensual")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#mensajeExitoPresupuesto").text(respuesta.mensaje || "Detalle guardado correctamente.").show();

                        limpiarDetalle();
                        cargarDetallesYResumen();
                    } else {
                        $("#mensajeErrorPresupuesto").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorPresupuesto").text("Error al guardar el detalle del presupuesto.").show();
                }
            });
        }

        function editarDetalle(item) {
            $("#cboCuentaContable").val(item.CodigoCuenta || "");
            $("#cboTipoMovimiento").val(item.TipoMovimiento || "");
            $("#txtMontoPresupuestado").val(formatearNumero(item.MontoPresupuestado));
            $("#cboActivoDetalle").val(item.Activo ? "true" : "false");

            $("#cboCuentaContable").prop("disabled", true);
            $("#cboTipoMovimiento").prop("disabled", true);
        }

        function limpiarDetalle() {
            $("#cboCuentaContable").val("");
            $("#cboTipoMovimiento").val("");
            $("#txtMontoPresupuestado").val("");
            $("#cboActivoDetalle").val("true");

            $("#cboCuentaContable").prop("disabled", false);
            $("#cboTipoMovimiento").prop("disabled", false);
        }

        function cargarResumenVsReal() {
            var anio = parseInt($("#txtAnioSeleccionado").val());
            var mes = parseInt($("#txtMesSeleccionado").val());

            if (anio === 0 || mes === 0 || isNaN(anio) || isNaN(mes)) {
                pintarResumen([]);
                return;
            }

            $.ajax({
                url: '@Url.Action("ObtenerResumenVsReal", "GestionarPresupuestoMensual")',
                type: "GET",
                data: {
                    anio: anio,
                    mes: mes
                },
                dataType: "json",
                success: function (respuesta) {
                    listaResumen = respuesta.data || [];
                    pintarResumen(listaResumen);
                },
                error: function () {
                    $("#mensajeErrorPresupuesto").text("Error al cargar el resumen presupuesto vs real.").show();
                }
            });
        }

        function pintarResumen(lista) {
            var tbody = $("#tablaResumen tbody");
            tbody.empty();

            if (!lista || lista.length === 0) {
                tbody.append('<tr><td colspan="7" class="text-center text-muted">No hay resumen disponible.</td></tr>');
                return;
            }

            $.each(lista, function (i, item) {
                var fila = $("<tr>");

                fila.append($("<td>").html(obtenerBadgeTipoMovimiento(item.TipoMovimiento)));
                fila.append($("<td>").html('<span class="codigo-cuenta">' + (item.CodigoCuenta || "") + '</span><br/><span class="texto-tabla-secundario">' + (item.NombreCuenta || "") + '</span>'));
                fila.append($("<td>").text(formatearNumero(item.MontoPresupuestado)));
                fila.append($("<td>").text(formatearNumero(item.MontoReal)));
                fila.append($("<td>").text(formatearNumero(item.Diferencia)));
                fila.append($("<td>").text(formatearNumero(item.PorcentajeEjecucion) + "%"));
                fila.append($("<td>").html(obtenerBadgeEstadoEjecucion(item.EstadoEjecucion)));

                tbody.append(fila);
            });
        }

        function cargarResumenGeneral() {
            var anio = parseInt($("#txtAnioSeleccionado").val());
            var mes = parseInt($("#txtMesSeleccionado").val());

            if (anio === 0 || mes === 0 || isNaN(anio) || isNaN(mes)) {
                actualizarResumenGeneral(null);
                return;
            }

            $.ajax({
                url: '@Url.Action("ObtenerResumenGeneral", "GestionarPresupuestoMensual")',
                type: "GET",
                data: {
                    anio: anio,
                    mes: mes
                },
                dataType: "json",
                success: function (respuesta) {
                    actualizarResumenGeneral(respuesta.data);
                },
                error: function () {
                    $("#mensajeErrorPresupuesto").text("Error al cargar el resumen general.").show();
                }
            });
        }

        function actualizarResumenGeneral(item) {
            item = item || {};

            $("#lblIngresoPresupuestado").text(formatearNumero(item.TotalIngresoPresupuestado || 0));
            $("#lblIngresoReal").text(formatearNumero(item.TotalIngresoReal || 0));

            $("#lblGastoPresupuestado").text(formatearNumero(item.TotalGastoPresupuestado || 0));
            $("#lblGastoReal").text(formatearNumero(item.TotalGastoReal || 0));

            $("#lblUtilidadPresupuestada").text(formatearNumero(item.UtilidadPresupuestada || 0));
            $("#lblUtilidadReal").text(formatearNumero(item.UtilidadReal || 0));
        }


        function inactivarDetalle(anio, mes, codigoCuenta, tipoMovimiento) {
            mostrarConfirmacionSistema(
                obtenerTituloInactivarPresupuesto("detalle"),
                obtenerMensajeInactivarPresupuesto("detalle"),
