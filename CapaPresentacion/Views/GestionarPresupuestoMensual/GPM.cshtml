
@{
    ViewBag.Title = "Generar Presupuesto Mensual";
    Layout = "~/Views/Shared/_Layout.cshtml";


}

<h4 class="font-weight-bold py-3 mb-0">Generar Presupuesto Mensual</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Operación</li>
        <li class="breadcrumb-item active">Presupuesto Mensual</li>
    </ol>
</div>

<div class="card mb-4">
    <h6 class="card-header">Registro de presupuesto mensual</h6>

    <div class="card-body">

        <form>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Mes</label>
                    <select class="custom-select" name="Mes">
                        <option value="">Seleccione el mes</option>
                        <option value="1">Enero</option>
                        <option value="2">Febrero</option>
                        <option value="3">Marzo</option>
                        <option value="4">Abril</option>
                        <option value="5">Mayo</option>
                        <option value="6">Junio</option>
                        <option value="7">Julio</option>
                        <option value="8">Agosto</option>
                        <option value="9">Septiembre</option>
                        <option value="10">Octubre</option>
                        <option value="11">Noviembre</option>
                        <option value="12">Diciembre</option>
                    </select>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Año</label>
                    <input type="number"
                           class="form-control"
                           name="Anio"
                           placeholder="Ejemplo: 2026"
                           min="2020"
                           max="2100" />
                    <div class="clearfix"></div>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Categoría presupuestaria</label>
                    <select class="custom-select" name="CategoriaPresupuestaria">
                        <option value="">Seleccione una categoría</option>
                        <option value="Ingresos">Ingresos</option>
                        <option value="GastosOperativos">Gastos operativos</option>
                        <option value="ComprasMercaderia">Compras de mercadería</option>
                        <option value="ServiciosPublicos">Servicios públicos</option>
                        <option value="Transporte">Transporte</option>
                        <option value="Mantenimiento">Mantenimiento</option>
                        <option value="Otros">Otros</option>
                    </select>
                </div>

            </div>

            <div class="form-row">

                <div class="form-group col-md-4">
                    <label class="form-label">Monto presupuestado de ingresos</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="MontoPresupuestadoIngresos"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Monto presupuestado de gastos</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">₡</span>
                        </div>
                        <input type="number"
                               class="form-control"
                               name="MontoPresupuestadoGastos"
                               placeholder="0.00"
                               step="0.01" />
                        <div class="clearfix"></div>
                    </div>
                </div>

                <div class="form-group col-md-4">
                    <label class="form-label">Estado del presupuesto</label>
                    <select class="custom-select" name="EstadoPresupuesto">
                        <option value="">Seleccione el estado</option>
                        <option value="Planificado">Planificado</option>
                        <option value="EnEjecucion">En ejecución</option>
                        <option value="Cerrado">Cerrado</option>
                        <option value="Anulado">Anulado</option>
                    </select>
                </div>

            </div>

            <div class="form-group">
                <label class="form-label">Observación</label>
                <textarea class="form-control"
                          name="Observacion"
                          rows="3"
                          placeholder="Ingrese una observación sobre el presupuesto mensual"></textarea>
            </div>

            <div class="form-group mt-4">
                <button type="button" class="btn btn-primary">
                    Guardar
                </button>

                <button type="button" class="btn btn-secondary">
                    Modificar
                </button>

                <button type="button" class="btn btn-danger">
                    Eliminar
                </button>

                <button type="reset" class="btn btn-outline-secondary">
                    Limpiar
                </button>
            </div>

        </form>

    </div>
</div>

<div class="card mb-4">
    <h6 class="card-header">Comparativo presupuestario</h6>

    <div class="card-body">

        <div class="form-row">

            <div class="form-group col-md-4">
                <label class="form-label">Ingresos reales registrados</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text">₡</span>
                    </div>
                    <input type="number"
                           class="form-control"
                           name="IngresosReales"
                           placeholder="0.00"
                           step="0.01" />
                    <div class="clearfix"></div>
                </div>
            </div>

            <div class="form-group col-md-4">
                <label class="form-label">Gastos reales registrados</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text">₡</span>
                    </div>
                    <input type="number"
                           class="form-control"
                           name="GastosReales"
                           placeholder="0.00"
                           step="0.01" />
                    <div class="clearfix"></div>
                </div>
            </div>

            <div class="form-group col-md-4">
                <label class="form-label">Diferencia presupuestaria</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text">₡</span>
                    </div>
                    <input type="number"
                           class="form-control"
                           name="DiferenciaPresupuestaria"
                           placeholder="0.00"
                           step="0.01" />
                    <div class="clearfix"></div>
                </div>
            </div>

        </div>

        <small class="form-text text-muted">
            Estos campos permitirán comparar posteriormente los montos presupuestados contra los valores reales registrados en ingresos y gastos.
        </small>

    </div>
</div>

<div class="card mb-4">
    <h6 class="card-header">Listado de presupuestos mensuales</h6>

    <div class="card-body">

        <div class="form-group">
            <label class="form-label">Buscar presupuesto</label>
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       placeholder="Buscar por mes, año, categoría o estado" />

                <span class="input-group-append">
                    <button class="btn btn-secondary" type="button">
                        Buscar
                    </button>
                </span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Mes</th>
                        <th>Año</th>
                        <th>Categoría</th>
                        <th>Ingresos presupuestados</th>
                        <th>Gastos presupuestados</th>
                        <th>Ingresos reales</th>
                        <th>Gastos reales</th>
                        <th>Diferencia</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>Abril</td>
                        <td>2026</td>
                        <td>Ingresos</td>
                        <td>₡1,500,000.00</td>
                        <td>₡0.00</td>
                        <td>₡1,250,000.00</td>
                        <td>₡0.00</td>
                        <td>₡-250,000.00</td>
                        <td>En ejecución</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>Abril</td>
                        <td>2026</td>
                        <td>Compras de mercadería</td>
                        <td>₡0.00</td>
                        <td>₡700,000.00</td>
                        <td>₡0.00</td>
                        <td>₡620,000.00</td>
                        <td>₡80,000.00</td>
                        <td>En ejecución</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>Mayo</td>
                        <td>2026</td>
                        <td>Servicios públicos</td>
                        <td>₡0.00</td>
                        <td>₡120,000.00</td>
                        <td>₡0.00</td>
                        <td>₡0.00</td>
                        <td>₡120,000.00</td>
                        <td>Planificado</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary">
                                Seleccionar
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

