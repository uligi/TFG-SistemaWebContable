@{
    ViewBag.Title = "Empleados";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .bloque-credenciales {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 12px;
        margin-top: 10px;
        display: none;
    }

    .bloque-contacto {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 12px;
        margin-bottom: 12px;
    }

    .tabla-contacto th,
    .tabla-contacto td {
        vertical-align: middle !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Empleados</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Personas</li>
        <li class="breadcrumb-item active">Empleados</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de empleados</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo empleado
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaEmpleados" style="width:100%;">
                <thead>
                    <tr>
                        <th>Código empleado</th>
                        <th>Identificación</th>
                        <th>Empleado</th>
                        <th>Puesto</th>
                        <th>Rol</th>
                        <th>Usuario</th>
                        <th>Ubicación</th>
                        <th>Estado</th>
                        <th style="width:240px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo empleado</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtCodigoEmpleado" value="" />
                <input type="hidden" id="txtNombreUsuarioActual" value="" />

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

                <h6 class="font-weight-bold mb-3">Datos personales</h6>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="txtIdentificacion">Identificación</label>
                            <input type="text" id="txtIdentificacion" class="form-control" maxlength="11" autocomplete="off" inputmode="numeric" />
                            <small class="form-text text-muted">Cédula nacional: 9 dígitos. Cédula extranjera: 11 dígitos.</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="txtFechaNacimiento">Fecha de nacimiento</label>
                            <input type="date" id="txtFechaNacimiento" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtNombre">Nombre</label>
                            <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtPrimerApellido">Primer apellido</label>
                            <input type="text" id="txtPrimerApellido" class="form-control" maxlength="45" autocomplete="off" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtSegundoApellido">Segundo apellido</label>
                            <input type="text" id="txtSegundoApellido" class="form-control" maxlength="45" autocomplete="off" />
                        </div>
                    </div>
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Ubicación</h6>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboProvincia">Provincia</label>
                            <select id="cboProvincia" class="form-control">
                                <option value="0">Seleccione una provincia</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboCanton">Cantón</label>
                            <select id="cboCanton" class="form-control">
                                <option value="0">Seleccione un cantón</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboDistrito">Distrito</label>
                            <select id="cboDistrito" class="form-control">
                                <option value="0">Seleccione un distrito</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="txtDireccion">Dirección exacta</label>
                    <textarea id="txtDireccion" class="form-control" maxlength="250" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 250 caracteres.</small>
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Datos laborales y acceso</h6>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboPuesto">Puesto</label>
                            <select id="cboPuesto" class="form-control">
                                <option value="0">Seleccione un puesto</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtFechaIngreso">Fecha de ingreso</label>
                            <input type="date" id="txtFechaIngreso" class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboRol">Rol</label>
                            <select id="cboRol" class="form-control">
                                <option value="0">Seleccione un rol</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info" id="mensajeClaveAutomatica">
                    La contraseña temporal se generará automáticamente al guardar el empleado.
                </div>

                <div class="row" id="filaEstadoEmpleado">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboActivo">Estado</label>
                            <select id="cboActivo" class="form-control">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="bloque-credenciales" id="bloqueCredenciales">
                    <div class="font-weight-bold mb-1">Credenciales generadas</div>
                    <div><strong>Código empleado:</strong> <span id="lblCodigoEmpleadoGenerado"></span></div>
                    <div><strong>Usuario:</strong> <span id="lblNombreUsuarioGenerado"></span></div>
                    <div><strong>Contraseña temporal:</strong> <span id="lblClaveTemporalGenerada"></span></div>
                    <div class="texto-tabla-secundario mt-1">
                        Guardá estos datos para entregarlos al empleado.
                    </div>
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Teléfonos</h6>

                <div class="bloque-contacto">
                    <input type="hidden" id="txtTelefonoAnterior" value="" />

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="txtTelefono">Teléfono</label>
                                <input type="text" id="txtTelefono" class="form-control" maxlength="8" autocomplete="off" inputmode="numeric" />
                                <small class="form-text text-muted">Debe contener exactamente 8 números, sin +506, guiones ni espacios.</small>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="cboTipoTelefono">Tipo</label>
                                <select id="cboTipoTelefono" class="form-control">
                                    <option value="0">Seleccione</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboTelefonoPrincipal">Principal</label>
                                <select id="cboTelefonoPrincipal" class="form-control">
                                    <option value="false">No</option>
                                    <option value="true">Sí</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboTelefonoActivo">Estado</label>
                                <select id="cboTelefonoActivo" class="form-control">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-group mb-2 w-100">
                                <button type="button" class="btn btn-primary btn-block" onclick="guardarTelefonoEmpleado()">
                                    Agregar
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-danger mt-2" id="mensajeErrorTelefono" style="display:none;"></div>

                    <div class="table-responsive mt-2">
                        <table class="table table-sm table-bordered tabla-contacto" id="tablaTelefonosEmpleado" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Teléfono</th>
                                    <th>Tipo</th>
                                    <th>Principal</th>
                                    <th>Estado</th>
                                    <th style="width:160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <h6 class="font-weight-bold mb-3">Correos</h6>

                <div class="bloque-contacto">
                    <input type="hidden" id="txtCorreoAnterior" value="" />

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group mb-2">
                                <label for="txtCorreo">Correo</label>
                                <input type="email" id="txtCorreo" class="form-control" maxlength="255" autocomplete="off" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="cboTipoCorreo">Tipo</label>
                                <select id="cboTipoCorreo" class="form-control">
                                    <option value="0">Seleccione</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboCorreoPrincipal">Principal</label>
                                <select id="cboCorreoPrincipal" class="form-control">
                                    <option value="false">No</option>
                                    <option value="true">Sí</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboCorreoActivo">Estado</label>
                                <select id="cboCorreoActivo" class="form-control">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-1 d-flex align-items-end">
                            <div class="form-group mb-2 w-100">
                                <button type="button" class="btn btn-primary btn-block" onclick="guardarCorreoEmpleado()">
                                    +
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-danger mt-2" id="mensajeErrorCorreo" style="display:none;"></div>

                    <div class="table-responsive mt-2">
                        <table class="table table-sm table-bordered tabla-contacto" id="tablaCorreosEmpleado" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Correo</th>
                                    <th>Tipo</th>
                                    <th>Principal</th>
                                    <th>Estado</th>
                                    <th style="width:160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <small class="text-muted mr-auto">
                    Para agregar teléfonos o correos, primero guarde el empleado.
                </small>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarEmpleado()">
                    Guardar empleado
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalClave" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Restablecer contraseña</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="txtIdentificacionClave" value="" />

                <div class="alert alert-danger" id="mensajeErrorClave" style="display:none;"></div>

                <div class="form-group">
                    <label>Empleado</label>
                    <input type="text" id="txtEmpleadoClave" class="form-control" disabled />
                </div>

                <div class="alert alert-info">
                    Se generará automáticamente una nueva contraseña temporal.
                </div>

                <div class="bloque-credenciales" id="bloqueClaveRestablecida">
                    <div class="font-weight-bold mb-1">Nueva credencial temporal</div>
                    <div><strong>Usuario:</strong> <span id="lblUsuarioClaveRestablecida"></span></div>
                    <div><strong>Contraseña temporal:</strong> <span id="lblClaveRestablecida"></span></div>
                    <div class="texto-tabla-secundario mt-1">
                        Guardá estos datos para entregarlos al empleado.
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="restablecerClave()">
                    Generar nueva clave
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaEmpleados = [];
        var tablaEmpleados = null;

        var listaTelefonosEmpleado = [];
        var listaCorreosEmpleado = [];

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarPuestosActivos();
            cargarRolesActivos();
            cargarTiposTelefonoActivos();
            cargarTiposCorreoActivos();
            cargarEmpleados();

            $("#cboProvincia").on("change", function () {
                var codigoProvincia = parseInt($(this).val());

                $("#cboCanton").empty();
                $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

                $("#cboDistrito").empty();
                $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                if (!isNaN(codigoProvincia) && codigoProvincia > 0) {
                    cargarCantonesPorProvincia(codigoProvincia, null);
                }
            });

            $("#cboCanton").on("change", function () {
                var codigoCanton = parseInt($(this).val());

                $("#cboDistrito").empty();
                $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                if (!isNaN(codigoCanton) && codigoCanton > 0) {
                    cargarDistritosPorCanton(codigoCanton, null);
                }
            });

            $("#txtIdentificacion").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 11) {
                    valor = valor.substring(0, 11);
                }

                $(this).val(valor);

                if (valor.length > 0 && valor.length < 8) {
                    mostrarAyudaCampo("txtIdentificacion", "La identificación debe tener entre 8 y 11 números.");
                } else {
                    ocultarAyudaCampo("txtIdentificacion");
                }
            });

            $("#txtNombre, #txtPrimerApellido, #txtSegundoApellido").on("input", function () {
                limpiarTextoPersona(this.id, "Solo se permiten letras y espacios.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo(this.id, "Este campo no puede superar los 45 caracteres.");
                }
            });

            $("#txtDireccion").on("input", function () {
                limpiarTextoDireccion("txtDireccion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 250) {
                    $(this).val($(this).val().substring(0, 250));
                    mostrarAyudaCampo("txtDireccion", "La dirección no puede superar los 250 caracteres.");
                }
            });

            $("#txtTelefono").on("input", function () {
                var valor = $(this).val();
                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 15) {
                    valor = valor.substring(0, 15);
                }

                $(this).val(valor);
            });

            $("#txtCorreo").on("input", function () {
                var valor = $(this).val().trim().toLowerCase();

                if (valor.length > 255) {
                    valor = valor.substring(0, 255);
                }

                $(this).val(valor);
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }

                if ($("#mensajeErrorClave").is(":visible")) {
                    $("#mensajeErrorClave").fadeOut(150);
                }

                if ($("#mensajeErrorTelefono").is(":visible")) {
                    $("#mensajeErrorTelefono").fadeOut(150);
                }

                if ($("#mensajeErrorCorreo").is(":visible")) {
                    $("#mensajeErrorCorreo").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                limpiarErrores();
            });

            $("#ModalClave").on("hidden.bs.modal", function () {
                $("#mensajeErrorClave").hide().text("");
                $("#txtIdentificacionClave").val("");
                $("#txtEmpleadoClave").val("");
                $("#bloqueClaveRestablecida").hide();
                $("#lblUsuarioClaveRestablecida").text("");
                $("#lblClaveRestablecida").text("");
            });
        });

        function cargarEmpleados() {
            $.ajax({
                url: '@Url.Action("ListarEmpleados", "Persona")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaEmpleados = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los empleados.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaEmpleados != null) {
                tablaEmpleados.clear().destroy();
                tablaEmpleados = null;
            }

            var tbody = $("#tablaEmpleados tbody");
            tbody.empty();

            $.each(listaEmpleados, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var codigoEmpleado = item.CodigoEmpleado || "";
                var identificacion = item.Identificacion || "";
                var nombreCompleto = obtenerNombreCompleto(item);
                var puesto = item.PuestoNombre || "-";
                var rol = item.RolNombre || "-";
                var usuario = item.NombreUsuario || "-";

                var ubicacion = "";
                if (item.DistritoNombre && item.CantonNombre && item.ProvinciaNombre) {
                    ubicacion = item.DistritoNombre + ", " + item.CantonNombre + ", " + item.ProvinciaNombre;
                } else {
                    ubicacion = "-";
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var restablecer = item.RestablecerClave
                    ? '<div class="texto-tabla-secundario text-warning">Debe restablecer clave</div>'
                    : '';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1 mb-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonClave = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-warning mr-1 mb-1",
                    text: "Clave"
                }).on("click", function () {
                    abrirModalClave(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger mb-1",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarEmpleado(item.Identificacion);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);
                acciones.append(botonClave);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var celdaEmpleado = $("<td>");
                celdaEmpleado.append($("<div>").text(nombreCompleto));
                celdaEmpleado.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: "Ingreso: " + formatearFechaTexto(item.FechaIngreso)
                }));
                celdaEmpleado.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: "Dirección: " + (item.Direccion || "-")
                }));

                var celdaUsuario = $("<td>");
                celdaUsuario.append($("<div>").text(usuario));
                celdaUsuario.append(restablecer);

                var fila = $("<tr>");
                fila.append($("<td>").text(codigoEmpleado));
                fila.append($("<td>").text(identificacion));
                fila.append(celdaEmpleado);
                fila.append($("<td>").text(puesto));
                fila.append($("<td>").text(rol));
                fila.append(celdaUsuario);
                fila.append($("<td>").text(ubicacion));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaEmpleados = $("#tablaEmpleados").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboProvincia").append($("<option>", {
                            value: item.CodigoProvincia,
                            text: item.Nombre
                        }));
                    });
                },
