        function guardarCorreoEmpleado() {
            var identificacion = $("#txtIdentificacion").val().trim();

            if (identificacion === "") {
                $("#mensajeError").text("Primero debe ingresar la identificación del empleado.").show();
                return;
            }

            var obj = {
                Identificacion: identificacion,
                DireccionCorreo: $("#txtDireccionCorreoEmpleado").val().trim(),
                IdTipoCorreo: parseInt($("#cboTipoCorreoEmpleado").val()),
                EsPrincipal: $("#cboCorreoPrincipalEmpleado").val() === "true",
                Activo: true
            };

            var esNuevo = $("#txtCorreoEsNuevo").val() === "true";
            var correoAnterior = $("#txtCorreoAnterior").val().trim();

            if (obj.DireccionCorreo === "") {
                $("#mensajeError").text("Debe ingresar la dirección de correo.").show();
                return;
            }

            if (obj.DireccionCorreo.length > 255) {
                $("#mensajeError").text("La dirección de correo no puede superar los 255 caracteres.").show();
                return;
            }

            if (!validarFormatoCorreo(obj.DireccionCorreo)) {
                $("#mensajeError").text("Debe ingresar un correo electrónico válido.").show();
                return;
            }

            if (obj.IdTipoCorreo === 0 || isNaN(obj.IdTipoCorreo)) {
                $("#mensajeError").text("Debe seleccionar un tipo de correo.").show();
                return;
            }

            if (!esNuevo && correoAnterior === "") {
                $("#mensajeError").text("Debe seleccionar un correo válido para editar.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCorreoDesdeCliente", "Persona")',
                type: "POST",
                data: JSON.stringify({
                    obj: obj,
                    esNuevo: esNuevo,
                    correoAnterior: correoAnterior
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#mensajeError").hide().text("");
                        limpiarFormularioCorreoEmpleado();
                        cargarCorreosEmpleado(identificacion);
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el correo del empleado.").show();
                }
            });
        }

