        function convertirFechaJson(fechaJson) {
            if (typeof fechaJson !== "string") {
                return "";
            }

            if (fechaJson.indexOf("/Date") === 0) {
                var timestamp = parseInt(fechaJson.replace(/\/Date\((\d+)\)\//, "$1"));
                var fecha = new Date(timestamp);
                return fecha.toISOString().split("T")[0];
            }

            if (fechaJson.indexOf("T") > -1) {
                return fechaJson.split("T")[0];
            }

            return fechaJson;
    }

