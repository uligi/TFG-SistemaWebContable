        function guardarTelefonoEmpleado() {
            var identificacion = $("#txtIdentificacion").val().trim();

            if (identificacion === "") {
                $("#mensajeError").text("Primero debe ingresar la identificación del empleado.").show();
                return;
            }

            var obj = {
                NumeroTelefono: $("#txtNumeroTelefonoEmpleado").val().trim(),
                Identificacion: identificacion,
                IdTipoTelefono: parseInt($("#cboTipoTelefonoEmpleado").val()),
                EsPrincipal: $("#cboTelefonoPrincipalEmpleado").val() === "true",
                Activo: true
            };

            var esNuevo = $("#txtTelefonoEsNuevo").val() === "true";
            var numeroAnterior = $("#txtNumeroTelefonoAnterior").val().trim();

            if (obj.NumeroTelefono === "") {
                $("#mensajeError").text("Debe ingresar el número de teléfono.").show();
                return;
            }

            if (obj.NumeroTelefono.length > 45) {
                $("#mensajeError").text("El número de teléfono no puede superar los 45 caracteres.").show();
                return;
            }

            if (obj.IdTipoTelefono === 0 || isNaN(obj.IdTipoTelefono)) {
                $("#mensajeError").text("Debe seleccionar un tipo de teléfono.").show();
                return;
            }

            if (!esNuevo && numeroAnterior === "") {
                $("#mensajeError").text("Debe seleccionar un teléfono válido para editar.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTelefonoDesdeCliente", "Persona")',
                type: "POST",
                data: JSON.stringify({
                    obj: obj,
                    esNuevo: esNuevo,
                    numeroAnterior: numeroAnterior
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#mensajeError").hide().text("");
                        limpiarFormularioTelefonoEmpleado();
                        cargarTelefonosEmpleado(identificacion);
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el teléfono del empleado.").show();
                }
            });
        }

