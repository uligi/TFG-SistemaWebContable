@{
    ViewBag.Title = "Empleados";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Empleados</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Personas</li>
        <li class="breadcrumb-item active">Empleados</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de empleados</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo empleado
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar por identificación, código, usuario o nombre...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaEmpleados">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Identificación</th>
                        <th>Empleado</th>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Puesto</th>
                        <th>Estado</th>
                        <th style="width:260px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo empleado</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtCodigoEmpleado" value="" />

                <h6 class="font-weight-bold">Datos personales</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtIdentificacion">Identificación</label>
                        <input type="text" id="txtIdentificacion" class="form-control" maxlength="45" autocomplete="off" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtCodigoEmpleadoMostrar">Código de empleado</label>
                        <input type="text" id="txtCodigoEmpleadoMostrar" class="form-control" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtFechaNacimiento">Fecha de nacimiento</label>
                        <input type="date" id="txtFechaNacimiento" class="form-control" />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtNombre">Nombre</label>
                        <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtPrimerApellido">Primer apellido</label>
                        <input type="text" id="txtPrimerApellido" class="form-control" maxlength="45" autocomplete="off" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="txtSegundoApellido">Segundo apellido</label>
                        <input type="text" id="txtSegundoApellido" class="form-control" maxlength="45" autocomplete="off" />
                    </div>

                </div>

                <h6 class="font-weight-bold mt-3">Ubicación</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="cboProvincia">Provincia</label>
                        <select id="cboProvincia" class="form-control">
                            <option value="0">Seleccione una provincia</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboCanton">Cantón</label>
                        <select id="cboCanton" class="form-control">
                            <option value="0">Seleccione un cantón</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboDistrito">Distrito</label>
                        <select id="cboDistrito" class="form-control">
                            <option value="0">Seleccione un distrito</option>
                        </select>
                    </div>

                </div>

                <div class="form-group">
                    <label for="txtDireccion">Dirección exacta</label>
                    <textarea id="txtDireccion" class="form-control" maxlength="250" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 250 caracteres.</small>
                </div>

                <h6 class="font-weight-bold mt-3">Datos de empleado</h6>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtNombreUsuario">Nombre de usuario</label>
                        <input type="text" id="txtNombreUsuario" class="form-control" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboRol">Rol</label>
                        <select id="cboRol" class="form-control">
                            <option value="0">Seleccione un rol</option>
                        </select>
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboPuesto">Puesto</label>
                        <select id="cboPuesto" class="form-control">
                            <option value="0">Seleccione un puesto</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtFechaIngreso">Fecha de ingreso</label>
                        <input type="date" id="txtFechaIngreso" class="form-control" />
                    </div>

                    <div class="form-group col-md-4">
                        <label for="cboActivo">Estado</label>
                        <select id="cboActivo" class="form-control">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="font-weight-bold mb-0">Teléfonos del empleado</h6>
                    <small class="text-muted" id="textoAyudaTelefono">
                        Para agregar teléfonos, primero guarde el empleado.
                    </small>
                </div>

                <div class="form-row mt-3">

                    <div class="form-group col-md-4">
                        <label for="txtNumeroTelefonoEmpleado">Número de teléfono</label>
                        <input type="text" id="txtNumeroTelefonoEmpleado" class="form-control" maxlength="45" autocomplete="off" />
                        <input type="hidden" id="txtNumeroTelefonoAnterior" value="" />
                        <input type="hidden" id="txtTelefonoEsNuevo" value="true" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoTelefonoEmpleado">Tipo de teléfono</label>
                        <select id="cboTipoTelefonoEmpleado" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboTelefonoPrincipalEmpleado">Principal</label>
                        <select id="cboTelefonoPrincipalEmpleado" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label>&nbsp;</label>
                        <div class="btn-group btn-block">
                            <button type="button" class="btn btn-primary" id="btnGuardarTelefono" onclick="guardarTelefonoEmpleado()">
                                Guardar teléfono
                            </button>
                            <button type="button" class="btn btn-secondary" id="btnLimpiarTelefono" onclick="limpiarFormularioTelefonoEmpleado()">
                                Limpiar
                            </button>
                        </div>
                    </div>

                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaTelefonosEmpleado">
                        <thead>
                            <tr>
                                <th>Teléfono</th>
                                <th>Tipo</th>
                                <th>Principal</th>
                                <th>Estado</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="font-weight-bold mb-0">Correos del empleado</h6>
                    <small class="text-muted" id="textoAyudaCorreo">
                        Para agregar correos, primero guarde el empleado.
                    </small>
                </div>

                <div class="form-row mt-3">

                    <div class="form-group col-md-4">
                        <label for="txtDireccionCorreoEmpleado">Correo electrónico</label>
                        <input type="email" id="txtDireccionCorreoEmpleado" class="form-control" maxlength="255" autocomplete="off" />
                        <input type="hidden" id="txtCorreoAnterior" value="" />
                        <input type="hidden" id="txtCorreoEsNuevo" value="true" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="cboTipoCorreoEmpleado">Tipo de correo</label>
                        <select id="cboTipoCorreoEmpleado" class="form-control">
                            <option value="0">Seleccione un tipo</option>
                        </select>
                    </div>

                    <div class="form-group col-md-2">
                        <label for="cboCorreoPrincipalEmpleado">Principal</label>
                        <select id="cboCorreoPrincipalEmpleado" class="form-control">
                            <option value="true">Sí</option>
                            <option value="false">No</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label>&nbsp;</label>
                        <div class="btn-group btn-block">
                            <button type="button" class="btn btn-primary" id="btnGuardarCorreo" onclick="guardarCorreoEmpleado()">
                                Guardar correo
                            </button>
                            <button type="button" class="btn btn-secondary" id="btnLimpiarCorreo" onclick="limpiarFormularioCorreoEmpleado()">
                                Limpiar
                            </button>
                        </div>
                    </div>

                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaCorreosEmpleado">
                        <thead>
                            <tr>
                                <th>Correo</th>
                                <th>Tipo</th>
                                <th>Principal</th>
                                <th>Estado</th>
                                <th style="width:170px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarEmpleado()">
                    Guardar empleado
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalCredenciales" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Credenciales del empleado</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <div class="alert alert-warning">
                    Guarde estas credenciales y entréguelas al empleado. La contraseña temporal no se volverá a mostrar.
                </div>

                <div class="form-group">
                    <label>Usuario</label>
                    <input type="text" id="txtCredencialUsuario" class="form-control" readonly />
                </div>

                <div class="form-group">
                    <label>Contraseña temporal</label>
                    <input type="text" id="txtCredencialClave" class="form-control" readonly />
                </div>

                <small class="text-muted">
                    El empleado deberá cambiar la contraseña al iniciar sesión.
                </small>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaEmpleados = [];
        var listaTelefonosEmpleado = [];
        var listaCorreosEmpleado = [];

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarRoles();
            cargarPuestos();
            cargarTiposTelefonoEmpleado();
            cargarTiposCorreoEmpleado();
            cargarEmpleados();


            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });

            $("#cboProvincia").on("change", function () {
                var idProvincia = parseInt($(this).val());
                cargarCantonesPorProvincia(idProvincia, 0);
                limpiarDistritos();
            });

            $("#cboCanton").on("change", function () {
                var idCanton = parseInt($(this).val());
                cargarDistritosPorCanton(idCanton, 0);
            });
        });

        function cargarEmpleados() {
            $.ajax({
                url: '@Url.Action("ListarEmpleados", "Persona")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaEmpleados = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los empleados.");
                }
            });
        }

        function cargarRoles() {
            $.ajax({
                url: '@Url.Action("ListarRoles", "Seguridad")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboRol").empty();
                    $("#cboRol").append('<option value="0">Seleccione un rol</option>');

                    $.each(respuesta.data, function (i, item) {
                        if (item.Activo) {
                            $("#cboRol").append(
                                $("<option>", {
                                    value: item.IdRol,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    alert("Error al cargar los roles.");
                }
            });
        }
        function cargarPuestos() {
    $.ajax({
        url: '@Url.Action("ListarPuestosActivos", "Catalogos")',
        type: "GET",
        dataType: "json",
        success: function (respuesta) {
            $("#cboPuesto").empty();
            $("#cboPuesto").append('<option value="0">Seleccione un puesto</option>');

            $.each(respuesta.data, function (i, item) {
                $("#cboPuesto").append(
                    $("<option>", {
                        value: item.IdPuesto,
                        text: item.Nombre
                    })
                );
            });
        },
        error: function () {
            alert("Error al cargar los puestos.");
        }
    });
}

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaEmpleados tbody");

            tbody.empty();

            $.each(listaEmpleados, function (i, item) {

                var codigo = item.CodigoEmpleado || "";
                var identificacion = item.Identificacion || "";
                var nombre = item.Nombre || "";
                var primerApellido = item.PrimerApellido || "";
                var segundoApellido = item.SegundoApellido || "";
                var nombreCompleto = (nombre + " " + primerApellido + " " + segundoApellido).trim();
                var usuario = item.NombreUsuario || "";
                var rol = item.RolNombre || "";
                var puesto = item.PuestoNombre || "";

                var texto = (codigo + " " + identificacion + " " + nombreCompleto + " " + usuario + " " + rol + " " + puesto).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var fila = `
                    <tr>
                        <td>${codigo}</td>
                        <td>${identificacion}</td>
                        <td>${nombreCompleto}</td>
                        <td>${usuario}</td>
                        <td>${rol}</td>
                        <td>${puesto}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick='inactivarEmpleado(${JSON.stringify(identificacion)})'>
                                Inactivar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-warning" onclick='restablecerClaveEmpleado(${JSON.stringify(identificacion)})'>
                                Restablecer
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtCodigoEmpleado").val("");
            $("#txtCodigoEmpleadoMostrar").val("");
            $("#txtNombreUsuario").val("");

            $("#txtIdentificacion").val("");
            $("#txtIdentificacion").prop("readonly", false);

            $("#txtNombre").val("");
            $("#txtPrimerApellido").val("");
            $("#txtSegundoApellido").val("");
            $("#txtFechaNacimiento").val("");

            $("#cboProvincia").val(0);
            $("#cboCanton").empty().append('<option value="0">Seleccione un cantón</option>');
            $("#cboDistrito").empty().append('<option value="0">Seleccione un distrito</option>');

            $("#txtDireccion").val("");
            $("#cboPuesto").val(0);
            $("#txtFechaIngreso").val("");
            $("#cboRol").val(0);
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo empleado");

            limpiarFormularioTelefonoEmpleado();
            listaTelefonosEmpleado = [];
            pintarTelefonosEmpleado();
            bloquearTelefonosEmpleado(true);

            limpiarFormularioCorreoEmpleado();
            listaCorreosEmpleado = [];
            pintarCorreosEmpleado();
            bloquearCorreosEmpleado(true);

            if (json != null) {
                $("#txtCodigoEmpleado").val(json.CodigoEmpleado || "");
                $("#txtCodigoEmpleadoMostrar").val(json.CodigoEmpleado || "");
                $("#txtNombreUsuario").val(json.NombreUsuario || "");

                $("#txtIdentificacion").val(json.Identificacion);
                $("#txtIdentificacion").prop("readonly", true);

                $("#txtNombre").val(json.Nombre);
                $("#txtPrimerApellido").val(json.PrimerApellido);
                $("#txtSegundoApellido").val(json.SegundoApellido || "");

                if (json.FechaNacimiento != null) {
                    $("#txtFechaNacimiento").val(convertirFechaJson(json.FechaNacimiento));
                }

                $("#txtDireccion").val(json.Direccion || "");
                $("#cboPuesto").val(json.IdPuesto || 0);

                if (json.FechaIngreso != null) {
                    $("#txtFechaIngreso").val(convertirFechaJson(json.FechaIngreso));
                }

                $("#cboRol").val(json.IdRol);
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar empleado");

                if (json.IdProvincia != null) {
                    $("#cboProvincia").val(json.IdProvincia);
                    cargarCantonesPorProvincia(json.IdProvincia, json.IdCanton);

                    setTimeout(function () {
                        cargarDistritosPorCanton(json.IdCanton, json.IdDistrito);
                    }, 300);
                }

                bloquearTelefonosEmpleado(false);
                cargarTelefonosEmpleado(json.Identificacion);

                bloquearCorreosEmpleado(false);
                cargarCorreosEmpleado(json.Identificacion);
            }

            $("#FormModal").modal("show");
        }

        function guardarEmpleado() {
            var obj = {
                Identificacion: $("#txtIdentificacion").val().trim(),
                CodigoEmpleado: $("#txtCodigoEmpleado").val().trim(),

                Nombre: $("#txtNombre").val().trim(),
                PrimerApellido: $("#txtPrimerApellido").val().trim(),
                SegundoApellido: $("#txtSegundoApellido").val().trim(),
                FechaNacimiento: $("#txtFechaNacimiento").val() === "" ? null : $("#txtFechaNacimiento").val(),
                IdDistrito: parseInt($("#cboDistrito").val()) === 0 ? null : parseInt($("#cboDistrito").val()),
                Direccion: $("#txtDireccion").val().trim(),

                IdPuesto: parseInt($("#cboPuesto").val()) === 0 ? null : parseInt($("#cboPuesto").val()),
                FechaIngreso: $("#txtFechaIngreso").val() === "" ? null : $("#txtFechaIngreso").val(),
                IdRol: parseInt($("#cboRol").val()),
                Activo: $("#cboActivo").val() === "true"
            };

            if (obj.Identificacion === "") {
                $("#mensajeError").text("Debe ingresar la identificación.").show();
                return;
            }

            if (obj.Nombre === "") {
                $("#mensajeError").text("Debe ingresar el nombre.").show();
                return;
            }

            if (obj.PrimerApellido === "") {
                $("#mensajeError").text("Debe ingresar el primer apellido.").show();
                return;
            }

            if (obj.IdRol === 0 || isNaN(obj.IdRol)) {
                $("#mensajeError").text("Debe seleccionar un rol.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarEmpleado", "Persona")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (obj.CodigoEmpleado === "") {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarEmpleados();

                            $("#txtCredencialUsuario").val(respuesta.nombreUsuario);
                            $("#txtCredencialClave").val(respuesta.claveTemporal);
                            $("#ModalCredenciales").modal("show");
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarEmpleados();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el empleado.").show();
                }
            });
        }

        function inactivarEmpleado(identificacion) {
            if (!confirm("¿Desea inactivar este empleado?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarEmpleado", "Persona")',
                type: "POST",
                data: JSON.stringify({ identificacion: identificacion }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarEmpleados();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el empleado.");
                }
            });
        }

        function restablecerClaveEmpleado(identificacion) {
            if (!confirm("¿Desea restablecer la contraseña de este empleado?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("RestablecerClaveEmpleado", "Persona")',
                type: "POST",
                data: JSON.stringify({ identificacion: identificacion }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#txtCredencialUsuario").val(respuesta.nombreUsuario);
                        $("#txtCredencialClave").val(respuesta.claveTemporal);
                        $("#ModalCredenciales").modal("show");
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al restablecer la contraseña.");
                }
