@{
    ViewBag.Title = "Teléfonos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Teléfonos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Personas</li>
        <li class="breadcrumb-item active">Teléfonos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de teléfonos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo teléfono
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar por identificación, persona o teléfono...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaTelefonos">
                <thead>
                    <tr>
                        <th>Identificación</th>
                        <th>Persona</th>
                        <th>Teléfono</th>
                        <th>Tipo</th>
                        <th>Principal</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo teléfono</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtEsNuevo" value="true" />

                <div class="form-group">
                    <label for="txtIdentificacion">Identificación de la persona</label>
                    <input type="text" id="txtIdentificacion" class="form-control" maxlength="45" autocomplete="off" />
                    <small class="form-text text-muted">
                        Debe existir como persona registrada en clientes o empleados.
                    </small>
                </div>

                <div class="form-group">
                    <label for="txtNumeroTelefono">Número de teléfono</label>
                    <input type="text" id="txtNumeroTelefono" class="form-control" maxlength="45" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label for="cboTipoTelefono">Tipo de teléfono</label>
                    <select id="cboTipoTelefono" class="form-control">
                        <option value="0">Seleccione un tipo de teléfono</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="cboEsPrincipal">Teléfono principal</label>
                    <select id="cboEsPrincipal" class="form-control">
                        <option value="false">No</option>
                        <option value="true">Sí</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarTelefono()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaTelefonos = [];

        $(document).ready(function () {
            cargarTiposTelefono();
            cargarTelefonos();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });
        });

        function cargarTelefonos() {
            $.ajax({
                url: '@Url.Action("ListarTelefonos", "Persona")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaTelefonos = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los teléfonos.");
                }
            });
        }

        function cargarTiposTelefono() {
            $.ajax({
                url: '@Url.Action("ListarTipoTelefonos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoTelefono").empty();
                    $("#cboTipoTelefono").append('<option value="0">Seleccione un tipo de teléfono</option>');

                    $.each(respuesta.data, function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoTelefono").append(
                                $("<option>", {
                                    value: item.IdTipoTelefono,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    alert("Error al cargar los tipos de teléfono.");
                }
            });
        }

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaTelefonos tbody");

            tbody.empty();

            $.each(listaTelefonos, function (i, item) {

                var identificacion = item.Identificacion || "";
                var numero = item.NumeroTelefono || "";
                var nombre = item.Nombre || "";
                var primerApellido = item.PrimerApellido || "";
                var segundoApellido = item.SegundoApellido || "";
                var nombreCompleto = (nombre + " " + primerApellido + " " + segundoApellido).trim();
                var tipo = item.TipoTelefonoNombre || "";

                var texto = (identificacion + " " + numero + " " + nombreCompleto + " " + tipo).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var principal = item.EsPrincipal
                    ? '<span class="badge badge-info">Sí</span>'
                    : '<span class="badge badge-light">No</span>';

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var fila = `
                    <tr>
                        <td>${identificacion}</td>
                        <td>${nombreCompleto}</td>
                        <td>${numero}</td>
                        <td>${tipo}</td>
                        <td>${principal}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarTelefono('${numero}', '${identificacion}')">
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtEsNuevo").val("true");

            $("#txtIdentificacion").val("");
            $("#txtIdentificacion").prop("readonly", false);

            $("#txtNumeroTelefono").val("");
            $("#txtNumeroTelefono").prop("readonly", false);

            $("#cboTipoTelefono").val(0);
            $("#cboEsPrincipal").val("false");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo teléfono");

            if (json != null) {
                $("#txtEsNuevo").val("false");

                $("#txtIdentificacion").val(json.Identificacion);
                $("#txtIdentificacion").prop("readonly", true);

                $("#txtNumeroTelefono").val(json.NumeroTelefono);
                $("#txtNumeroTelefono").prop("readonly", true);

                $("#cboTipoTelefono").val(json.IdTipoTelefono);
                $("#cboEsPrincipal").val(json.EsPrincipal ? "true" : "false");
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#tituloModal").text("Editar teléfono");
            }

            $("#FormModal").modal("show");
        }

        function guardarTelefono() {
            var obj = {
                NumeroTelefono: $("#txtNumeroTelefono").val().trim(),
                Identificacion: $("#txtIdentificacion").val().trim(),
                IdTipoTelefono: parseInt($("#cboTipoTelefono").val()),
                EsPrincipal: $("#cboEsPrincipal").val() === "true",
                Activo: $("#cboActivo").val() === "true"
            };

            var esNuevo = $("#txtEsNuevo").val() === "true";

            if (obj.Identificacion === "") {
                $("#mensajeError").text("Debe ingresar la identificación de la persona.").show();
                return;
            }

            if (obj.Identificacion.length > 45) {
                $("#mensajeError").text("La identificación no puede superar los 45 caracteres.").show();
                return;
            }

            if (obj.NumeroTelefono === "") {
                $("#mensajeError").text("Debe ingresar el número de teléfono.").show();
                return;
            }

            if (obj.NumeroTelefono.length > 45) {
                $("#mensajeError").text("El número de teléfono no puede superar los 45 caracteres.").show();
                return;
            }

            if (obj.IdTipoTelefono === 0 || isNaN(obj.IdTipoTelefono)) {
                $("#mensajeError").text("Debe seleccionar un tipo de teléfono.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTelefono", "Persona")',
                type: "POST",
                data: JSON.stringify({ obj: obj, esNuevo: esNuevo }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {

                    if (esNuevo) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarTelefonos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarTelefonos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el teléfono.").show();
                }
            });
        }

        function inactivarTelefono(numeroTelefono, identificacion) {
            if (!confirm("¿Desea inactivar este teléfono?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarTelefono", "Persona")',
                type: "POST",
                data: JSON.stringify({
                    numeroTelefono: numeroTelefono,
                    identificacion: identificacion
                }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarTelefonos();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el teléfono.");
                }
            });
        }
    </script>
}