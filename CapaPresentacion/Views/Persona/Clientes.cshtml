        function guardarTelefonoCliente() {
            $("#mensajeErrorTelefono").hide().text("");

            var identificacion = $("#txtIdentificacion").val().trim();

            if (!validarIdentificacion(identificacion)) {
                $("#mensajeErrorTelefono").text("Primero debe guardar un cliente válido.").show();
                return;
            }

            var obj = {
                Identificacion: identificacion,
                NumeroTelefonoAnterior: $("#txtTelefonoAnterior").val().trim(),
                NumeroTelefono: $("#txtTelefono").val().trim(),
                IdTipoTelefono: parseInt($("#cboTipoTelefono").val()),
                EsPrincipal: $("#cboTelefonoPrincipal").val() === "true",
                Activo: $("#cboTelefonoActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoTelefono)) {
                obj.IdTipoTelefono = 0;
            }

            if (!validarTelefono(obj.NumeroTelefono)) {
                $("#mensajeErrorTelefono").text("El teléfono debe contener exactamente 8 dígitos numéricos, sin prefijo ni caracteres especiales.").show();
                return;
            }

            if (obj.IdTipoTelefono <= 0) {
                $("#mensajeErrorTelefono").text("Debe seleccionar un tipo de teléfono.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarTelefono", "Persona")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        limpiarFormularioTelefono();
                        cargarTelefonosCliente(identificacion);
                    } else {
                        $("#mensajeErrorTelefono").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorTelefono").text("Error al guardar el teléfono.").show();
                }
            });
        }

