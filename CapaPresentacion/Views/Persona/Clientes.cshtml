@{
    ViewBag.Title = "Clientes";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .bloque-contacto {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 12px;
        margin-bottom: 12px;
    }

    .tabla-contacto th,
    .tabla-contacto td {
        vertical-align: middle !important;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Clientes</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Personas</li>
        <li class="breadcrumb-item active">Clientes</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de clientes</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo cliente
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaClientes" style="width:100%;">
                <thead>
                    <tr>
                        <th>Código cliente</th>
                        <th>Identificación</th>
                        <th>Cliente</th>
                        <th>Ubicación</th>
                        <th>Límite crédito</th>
                        <th>Días crédito</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo cliente</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtCodigoCliente" value="" />

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

                <h6 class="font-weight-bold mb-3">Datos personales</h6>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="txtIdentificacion">Identificación</label>
                            <input type="text" id="txtIdentificacion" class="form-control" maxlength="11" autocomplete="off" inputmode="numeric" />
                            <small class="form-text text-muted">Cédula nacional: 9 dígitos. Cédula extranjera: 11 dígitos.</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="txtFechaNacimiento">Fecha de nacimiento</label>
                            <input type="date" id="txtFechaNacimiento" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtNombre">Nombre</label>
                            <input type="text" id="txtNombre" class="form-control" maxlength="45" autocomplete="off" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtPrimerApellido">Primer apellido</label>
                            <input type="text" id="txtPrimerApellido" class="form-control" maxlength="45" autocomplete="off" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtSegundoApellido">Segundo apellido</label>
                            <input type="text" id="txtSegundoApellido" class="form-control" maxlength="45" autocomplete="off" />
                        </div>
                    </div>
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Ubicación</h6>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboProvincia">Provincia</label>
                            <select id="cboProvincia" class="form-control">
                                <option value="0">Seleccione una provincia</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboCanton">Cantón</label>
                            <select id="cboCanton" class="form-control">
                                <option value="0">Seleccione un cantón</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboDistrito">Distrito</label>
                            <select id="cboDistrito" class="form-control">
                                <option value="0">Seleccione un distrito</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="txtDireccion">Dirección exacta</label>
                    <textarea id="txtDireccion" class="form-control" maxlength="250" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 250 caracteres.</small>
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Datos comerciales</h6>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtLimiteCredito">Límite de crédito</label>
                            <input type="number" id="txtLimiteCredito" class="form-control" min="0" step="0.01" autocomplete="off" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="txtDiasCredito">Días de crédito</label>
                            <input type="number" id="txtDiasCredito" class="form-control" min="0" step="1" autocomplete="off" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="cboActivo">Estado</label>
                            <select id="cboActivo" class="form-control">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>

                <hr />

                <h6 class="font-weight-bold mb-3">Teléfonos</h6>

                <div class="bloque-contacto">
                    <input type="hidden" id="txtTelefonoAnterior" value="" />

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="txtTelefono">Teléfono</label>
                                <input type="text" id="txtTelefono" class="form-control" maxlength="8" autocomplete="off" inputmode="numeric" />
                                <small class="form-text text-muted">Debe contener exactamente 8 números, sin +506, guiones ni espacios.</small>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="cboTipoTelefono">Tipo</label>
                                <select id="cboTipoTelefono" class="form-control">
                                    <option value="0">Seleccione</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboTelefonoPrincipal">Principal</label>
                                <select id="cboTelefonoPrincipal" class="form-control">
                                    <option value="false">No</option>
                                    <option value="true">Sí</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboTelefonoActivo">Estado</label>
                                <select id="cboTelefonoActivo" class="form-control">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-group mb-2 w-100">
                                <button type="button" class="btn btn-primary btn-block" onclick="guardarTelefonoCliente()">
                                    Agregar
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-danger mt-2" id="mensajeErrorTelefono" style="display:none;"></div>

                    <div class="table-responsive mt-2">
                        <table class="table table-sm table-bordered tabla-contacto" id="tablaTelefonosCliente" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Teléfono</th>
                                    <th>Tipo</th>
                                    <th>Principal</th>
                                    <th>Estado</th>
                                    <th style="width:160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <h6 class="font-weight-bold mb-3">Correos</h6>

                <div class="bloque-contacto">
                    <input type="hidden" id="txtCorreoAnterior" value="" />

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group mb-2">
                                <label for="txtCorreo">Correo</label>
                                <input type="email" id="txtCorreo" class="form-control" maxlength="255" autocomplete="off" />
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-2">
                                <label for="cboTipoCorreo">Tipo</label>
                                <select id="cboTipoCorreo" class="form-control">
                                    <option value="0">Seleccione</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboCorreoPrincipal">Principal</label>
                                <select id="cboCorreoPrincipal" class="form-control">
                                    <option value="false">No</option>
                                    <option value="true">Sí</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group mb-2">
                                <label for="cboCorreoActivo">Estado</label>
                                <select id="cboCorreoActivo" class="form-control">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-1 d-flex align-items-end">
                            <div class="form-group mb-2 w-100">
                                <button type="button" class="btn btn-primary btn-block" onclick="guardarCorreoCliente()">
                                    +
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-danger mt-2" id="mensajeErrorCorreo" style="display:none;"></div>

                    <div class="table-responsive mt-2">
                        <table class="table table-sm table-bordered tabla-contacto" id="tablaCorreosCliente" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Correo</th>
                                    <th>Tipo</th>
                                    <th>Principal</th>
                                    <th>Estado</th>
                                    <th style="width:160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <small class="text-muted mr-auto">
                    Para agregar teléfonos o correos, primero guarde el cliente.
                </small>

                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarCliente()">
                    Guardar cliente
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaClientes = [];
        var tablaClientes = null;

        var listaTelefonosCliente = [];
        var listaCorreosCliente = [];

        $(document).ready(function () {
            cargarProvinciasActivas();
            cargarTiposTelefonoActivos();
            cargarTiposCorreoActivos();
            cargarClientes();

            $("#cboProvincia").on("change", function () {
                var codigoProvincia = parseInt($(this).val());

                $("#cboCanton").empty();
                $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

                $("#cboDistrito").empty();
                $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                if (!isNaN(codigoProvincia) && codigoProvincia > 0) {
                    cargarCantonesPorProvincia(codigoProvincia, null);
                }
            });

            $("#cboCanton").on("change", function () {
                var codigoCanton = parseInt($(this).val());

                $("#cboDistrito").empty();
                $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                if (!isNaN(codigoCanton) && codigoCanton > 0) {
                    cargarDistritosPorCanton(codigoCanton, null);
                }
            });

            $("#txtIdentificacion").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 11) {
                    valor = valor.substring(0, 11);
                }

                $(this).val(valor);

                if (valor.length > 0 && valor.length < 8) {
                    mostrarAyudaCampo("txtIdentificacion", "La identificación debe tener entre 8 y 11 números.");
                } else {
                    ocultarAyudaCampo("txtIdentificacion");
                }
            });

            $("#txtNombre, #txtPrimerApellido, #txtSegundoApellido").on("input", function () {
                limpiarTextoPersona(this.id, "Solo se permiten letras y espacios.");

                if ($(this).val().length > 45) {
                    $(this).val($(this).val().substring(0, 45));
                    mostrarAyudaCampo(this.id, "Este campo no puede superar los 45 caracteres.");
                }
            });

            $("#txtDireccion").on("input", function () {
                limpiarTextoDireccion("txtDireccion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 250) {
                    $(this).val($(this).val().substring(0, 250));
                    mostrarAyudaCampo("txtDireccion", "La dirección no puede superar los 250 caracteres.");
                }
            });

            $("#txtTelefono").on("input", function () {
                var valor = $(this).val();
                valor = valor.replace(/[^0-9]/g, "");

                if (valor.length > 15) {
                    valor = valor.substring(0, 15);
                }

                $(this).val(valor);
            });

            $("#txtCorreo").on("input", function () {
                var valor = $(this).val().trim().toLowerCase();

                if (valor.length > 255) {
                    valor = valor.substring(0, 255);
                }

                $(this).val(valor);
            });

            $("#txtLimiteCredito").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(",", ".");
                valor = valor.replace(/[^0-9.]/g, "");

                var partes = valor.split(".");
                if (partes.length > 2) {
                    valor = partes[0] + "." + partes[1];
                }

                if (partes.length === 2 && partes[1].length > 2) {
                    valor = partes[0] + "." + partes[1].substring(0, 2);
                }

                $(this).val(valor);
            });

            $("#txtDiasCredito").on("input", function () {
                var valor = $(this).val();
                valor = valor.replace(/[^0-9]/g, "");
                $(this).val(valor);
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }

                if ($("#mensajeErrorTelefono").is(":visible")) {
                    $("#mensajeErrorTelefono").fadeOut(150);
                }

                if ($("#mensajeErrorCorreo").is(":visible")) {
                    $("#mensajeErrorCorreo").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                limpiarErrores();
            });
        });

        function cargarClientes() {
            $.ajax({
                url: '@Url.Action("ListarClientes", "Persona")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaClientes = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los clientes.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaClientes != null) {
                tablaClientes.clear().destroy();
                tablaClientes = null;
            }

            var tbody = $("#tablaClientes tbody");
            tbody.empty();

            $.each(listaClientes, function (i, item) {

                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }

                var codigoCliente = item.CodigoCliente || "";
                var identificacion = item.Identificacion || "";

                var nombreCompleto = obtenerNombreCompleto(item);

                var ubicacion = "";
                if (item.DistritoNombre && item.CantonNombre && item.ProvinciaNombre) {
                    ubicacion = item.DistritoNombre + ", " + item.CantonNombre + ", " + item.ProvinciaNombre;
                } else {
                    ubicacion = "-";
                }

                var limiteCredito = parseFloat(item.LimiteCredito || 0).toFixed(2);
                var diasCredito = item.DiasCredito || 0;

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonInactivar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: "Inactivar"
                }).on("click", function () {
                    inactivarCliente(item.Identificacion);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonInactivar);
                }

                var celdaCliente = $("<td>");
                celdaCliente.append($("<div>").text(nombreCompleto));
                celdaCliente.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: "Dirección: " + (item.Direccion || "-")
                }));

                var fila = $("<tr>");
                fila.append($("<td>").text(codigoCliente));
                fila.append($("<td>").text(identificacion));
                fila.append(celdaCliente);
                fila.append($("<td>").text(ubicacion));
                fila.append($("<td>").text("₡" + limiteCredito));
                fila.append($("<td>").text(diasCredito));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaClientes = $("#tablaClientes").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[0, "desc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function cargarProvinciasActivas() {
            $.ajax({
                url: '@Url.Action("ListarProvinciasActivas", "Ubicacion")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboProvincia").empty();
                    $("#cboProvincia").append('<option value="0">Seleccione una provincia</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboProvincia").append(
                            $("<option>", {
                                value: item.CodigoProvincia,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar las provincias.", "error");
                }
            });
        }

        function cargarCantonesPorProvincia(codigoProvincia, callback) {
            $.ajax({
                url: '@Url.Action("ListarCantonesActivosPorProvincia", "Ubicacion")',
                type: "GET",
                data: { codigoProvincia: codigoProvincia },
                dataType: "json",
                success: function (respuesta) {
                    $("#cboCanton").empty();
                    $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboCanton").append(
                            $("<option>", {
                                value: item.CodigoCanton,
                                text: item.Nombre
                            })
                        );
                    });

                    if (callback != null) {
                        callback();
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los cantones.", "error");
                }
            });
        }

        function cargarDistritosPorCanton(codigoCanton, callback) {
            $.ajax({
                url: '@Url.Action("ListarDistritosActivosPorCanton", "Ubicacion")',
                type: "GET",
                data: { codigoCanton: codigoCanton },
                dataType: "json",
                success: function (respuesta) {
                    $("#cboDistrito").empty();
                    $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboDistrito").append(
                            $("<option>", {
                                value: item.CodigoDistrito,
                                text: item.Nombre
                            })
                        );
                    });

                    if (callback != null) {
                        callback();
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los distritos.", "error");
                }
            });
        }

        function cargarTiposTelefonoActivos() {
            $.ajax({
                url: '@Url.Action("ListarTipoTelefonos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoTelefono").empty();
                    $("#cboTipoTelefono").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoTelefono").append(
                                $("<option>", {
                                    value: item.IdTipoTelefono,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de teléfono.", "error");
                }
            });
        }

        function cargarTiposCorreoActivos() {
            $.ajax({
                url: '@Url.Action("ListarTipoCorreos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoCorreo").empty();
                    $("#cboTipoCorreo").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        if (item.Activo) {
                            $("#cboTipoCorreo").append(
                                $("<option>", {
                                    value: item.IdTipoCorreo,
                                    text: item.Nombre
                                })
                            );
                        }
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de correo.", "error");
                }
            });
        }

        function abrirModal(json) {
            limpiarErrores();

            listaTelefonosCliente = [];
            listaCorreosCliente = [];

            $("#txtCodigoCliente").val("");
            $("#txtIdentificacion").val("");
            $("#txtIdentificacion").prop("disabled", false);

            $("#txtNombre").val("");
            $("#txtPrimerApellido").val("");
            $("#txtSegundoApellido").val("");
            $("#txtFechaNacimiento").val("");

            $("#cboProvincia").val(0);

            $("#cboCanton").empty();
            $("#cboCanton").append('<option value="0">Seleccione un cantón</option>');

            $("#cboDistrito").empty();
            $("#cboDistrito").append('<option value="0">Seleccione un distrito</option>');

            $("#txtDireccion").val("");

            $("#txtLimiteCredito").val("0.00");
            $("#txtDiasCredito").val("0");

            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo cliente");

            limpiarFormularioTelefono();
            limpiarFormularioCorreo();
            pintarTelefonosCliente();
            pintarCorreosCliente();

            if (json != null) {
                $("#txtCodigoCliente").val(json.CodigoCliente || "");
                $("#txtIdentificacion").val(json.Identificacion || "");
                $("#txtIdentificacion").prop("disabled", true);

                $("#txtNombre").val(json.Nombre || "");
                $("#txtPrimerApellido").val(json.PrimerApellido || "");
                $("#txtSegundoApellido").val(json.SegundoApellido || "");
                $("#txtFechaNacimiento").val(formatearFechaInput(json.FechaNacimiento));

                $("#cboProvincia").val(json.CodigoProvincia);

                cargarCantonesPorProvincia(json.CodigoProvincia, function () {
                    $("#cboCanton").val(json.CodigoCanton);

                    cargarDistritosPorCanton(json.CodigoCanton, function () {
                        $("#cboDistrito").val(json.CodigoDistrito);
                    });
                });

                $("#txtDireccion").val(json.Direccion || "");
                $("#txtLimiteCredito").val(parseFloat(json.LimiteCredito || 0).toFixed(2));
                $("#txtDiasCredito").val(json.DiasCredito || 0);

                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar cliente");

                cargarTelefonosCliente(json.Identificacion);
                cargarCorreosCliente(json.Identificacion);
            }

            $("#FormModal").modal("show");
        }

        function guardarCliente() {
            $("#mensajeError").hide().text("");

            var obj = {
                Identificacion: $("#txtIdentificacion").val().trim(),
                CodigoCliente: $("#txtCodigoCliente").val().trim(),

                Nombre: $("#txtNombre").val().trim(),
                PrimerApellido: $("#txtPrimerApellido").val().trim(),
                SegundoApellido: $("#txtSegundoApellido").val().trim(),
                FechaNacimiento: $("#txtFechaNacimiento").val(),

                CodigoDistrito: parseInt($("#cboDistrito").val()),
                Direccion: $("#txtDireccion").val().trim(),

                LimiteCredito: parseFloat($("#txtLimiteCredito").val()),
                DiasCredito: parseInt($("#txtDiasCredito").val()),

                Activo: $("#cboActivo").val() === "true"
            };

            var codigoProvincia = parseInt($("#cboProvincia").val());
            var codigoCanton = parseInt($("#cboCanton").val());

            if (isNaN(obj.CodigoDistrito)) {
                obj.CodigoDistrito = 0;
            }

            if (isNaN(obj.LimiteCredito)) {
                obj.LimiteCredito = 0;
            }

            if (isNaN(obj.DiasCredito)) {
                obj.DiasCredito = 0;
            }

            if (obj.Identificacion === "") {
                mostrarError("Debe ingresar la identificación.", "txtIdentificacion");
                return;
            }

            if (!validarIdentificacion(obj.Identificacion)) {
                mostrarError("La identificación debe contener solo números: 9 dígitos para cédula nacional o 11 dígitos para cédula extranjera.", "txtIdentificacion");
                return;
            }

            if (!validarMayorEdad(obj.FechaNacimiento)) {
                mostrarError("La fecha de nacimiento es obligatoria y debe corresponder a una persona mayor de edad.", "txtFechaNacimiento");
                return;
            }

            if (obj.Nombre === "") {
                mostrarError("Debe ingresar el nombre.", "txtNombre");
                return;
            }

            if (!validarTextoPersona(obj.Nombre)) {
                mostrarError("El nombre solo puede contener letras y espacios.", "txtNombre");
                return;
            }

            if (obj.Nombre.length > 45) {
                mostrarError("El nombre no puede superar los 45 caracteres.", "txtNombre");
                return;
            }

            if (obj.PrimerApellido === "") {
                mostrarError("Debe ingresar el primer apellido.", "txtPrimerApellido");
                return;
            }

            if (!validarTextoPersona(obj.PrimerApellido)) {
                mostrarError("El primer apellido solo puede contener letras y espacios.", "txtPrimerApellido");
                return;
            }

            if (obj.PrimerApellido.length > 45) {
                mostrarError("El primer apellido no puede superar los 45 caracteres.", "txtPrimerApellido");
                return;
            }

            if (obj.SegundoApellido !== "" && !validarTextoPersona(obj.SegundoApellido)) {
                mostrarError("El segundo apellido solo puede contener letras y espacios.", "txtSegundoApellido");
                return;
            }

            if (obj.SegundoApellido.length > 45) {
                mostrarError("El segundo apellido no puede superar los 45 caracteres.", "txtSegundoApellido");
                return;
            }

            if (isNaN(codigoProvincia) || codigoProvincia <= 0) {
                mostrarError("Debe seleccionar una provincia.", "cboProvincia");
                return;
            }

            if (isNaN(codigoCanton) || codigoCanton <= 0) {
                mostrarError("Debe seleccionar un cantón.", "cboCanton");
                return;
            }

            if (obj.CodigoDistrito <= 0) {
                mostrarError("Debe seleccionar un distrito.", "cboDistrito");
                return;
            }

            if (obj.Direccion === "") {
                mostrarError("Debe ingresar la dirección exacta.", "txtDireccion");
                return;
            }

            if (!validarTextoDireccion(obj.Direccion)) {
                mostrarError("La dirección solo puede contener letras, números, espacios y caracteres básicos.", "txtDireccion");
                return;
            }

            if (obj.Direccion.length > 250) {
                mostrarError("La dirección no puede superar los 250 caracteres.", "txtDireccion");
                return;
            }

            if (obj.LimiteCredito < 0) {
                mostrarError("El límite de crédito no puede ser negativo.", "txtLimiteCredito");
                return;
            }

            if (obj.DiasCredito < 0) {
                mostrarError("Los días de crédito no pueden ser negativos.", "txtDiasCredito");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarCliente", "Persona")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#txtCodigoCliente").val($("#txtCodigoCliente").val() || "GENERADO");
                        $("#txtIdentificacion").prop("disabled", true);

                        cargarClientes();

                        mostrarMensajeSistema(
                            "Cliente guardado correctamente. Ya puede agregar teléfonos y correos.",
                            "exito"
                        );
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el cliente.").show();
                }
            });
        }

        function inactivarCliente(identificacion) {
