                    }
                },
                error: function () {
                    alert("Error al inactivar el correo.");
                }
            });
        }

        function validarFormatoCorreo(correo) {
            if (correo === null || correo === undefined) {
                return false;
            }

            correo = correo.trim();

            var arroba = String.fromCharCode(64);

            if (correo.indexOf(arroba) === -1) {
                return false;
            }

            if (correo.indexOf(arroba) !== correo.lastIndexOf(arroba)) {
                return false;
            }

            var partes = correo.split(arroba);

            if (partes.length !== 2) {
                return false;
            }

            var usuario = partes[0];
            var dominio = partes[1];

            if (usuario.length === 0 || dominio.length === 0) {
                return false;
            }

            if (dominio.indexOf(".") === -1) {
                return false;
            }

            if (dominio.startsWith(".") || dominio.endsWith(".")) {
                return false;
            }

            return true;
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function soloNumeros(valor) {
            return /^[0-9]+$/.test(valor);
        }

        function soloTextoNombre(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]+$/.test(valor);
        }

        function validarIdentificacionCostaRica(identificacion) {
            if (identificacion === "") {
                return "Debe ingresar la identificación.";
            }

            if (!soloNumeros(identificacion)) {
                return "La identificación debe contener solo números.";
            }

            if (identificacion.length < 9 || identificacion.length > 12) {
                return "La identificación debe tener entre 9 y 12 dígitos.";
            }

            return "";
        }

        function validarFechaNacimiento(fechaTexto) {
            if (fechaTexto === "") {
                return "";
            }

            var fecha = new Date(fechaTexto + "T00:00:00");
            var hoy = new Date();

            if (isNaN(fecha.getTime())) {
                return "Debe ingresar una fecha de nacimiento válida.";
            }

            if (fecha > hoy) {
                return "La fecha de nacimiento no puede ser futura.";
            }

            var edad = hoy.getFullYear() - fecha.getFullYear();
            var mes = hoy.getMonth() - fecha.getMonth();

            if (mes < 0 || (mes === 0 && hoy.getDate() < fecha.getDate())) {
                edad--;
            }

            if (edad > 120) {
                return "La fecha de nacimiento no es válida.";
            }

            return "";
        }

        function validarMontoNoNegativo(texto, nombreCampo) {
            if (texto === "") {
                return "";
            }

            var numero = parseFloat(texto);

            if (isNaN(numero)) {
                return "Debe ingresar un valor válido para " + nombreCampo + ".";
            }

            if (numero < 0) {
                return nombreCampo + " no puede ser negativo.";
            }

            return "";
        }

        function validarEnteroNoNegativo(texto, nombreCampo) {
            if (texto === "") {
                return "";
            }

            var numero = parseInt(texto);

            if (isNaN(numero) || numero.toString() !== texto) {
                return "Debe ingresar un número entero válido para " + nombreCampo + ".";
            }

            if (numero < 0) {
                return nombreCampo + " no puede ser negativo.";
            }

            return "";
        }

        function validarTelefonoCostaRica(numero) {
            if (numero === "") {
                return "Debe ingresar el número de teléfono.";
            }

            if (!soloNumeros(numero)) {
                return "El teléfono debe contener solo números.";
            }

            if (numero.length !== 8) {
                return "El teléfono debe tener 8 dígitos.";
            }

            return "";
        }
        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarNoNumeros(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarNoLetras(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarNoDecimal(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^0-9.]/g, "");

            var partes = valorLimpio.split(".");
            if (partes.length > 2) {
                valorLimpio = partes[0] + "." + partes.slice(1).join("");
            }

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }
    </script>
}