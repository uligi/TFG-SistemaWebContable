        function obtenerNombreCompleto(item) {
            var partes = [];

            if (item.Nombre) {
                partes.push(item.Nombre);
            }

            if (item.PrimerApellido) {
                partes.push(item.PrimerApellido);
            }

            if (item.SegundoApellido) {
                partes.push(item.SegundoApellido);
            }

            return partes.join(" ");
        }

        function formatearFechaInput(valor) {
            if (valor == null || valor === "") {
                return "";
            }

            if (typeof valor === "string" && valor.indexOf("/Date(") === 0) {
                var ticks = parseInt(valor.replace("/Date(", "").replace(")/", ""));
                var fecha = new Date(ticks);

                var mes = (fecha.getMonth() + 1).toString().padStart(2, "0");
                var dia = fecha.getDate().toString().padStart(2, "0");

                return fecha.getFullYear() + "-" + mes + "-" + dia;
            }

            if (typeof valor === "string" && valor.length >= 10) {
                return valor.substring(0, 10);
            }

            return "";
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarErrores() {
            $("#mensajeError").hide().text("");
            $("#mensajeErrorTelefono").hide().text("");
            $("#mensajeErrorCorreo").hide().text("");

            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function limpiarTextoPersona(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function limpiarTextoDireccion(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoPersona(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]+$/.test(valor);
        }

        function validarIdentificacion(valor) {
            return /^([0-9]{9}|[0-9]{11})$/.test(valor);
        }

        function validarTextoDireccion(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function validarTelefono(valor) {
            return /^[0-9]{8}$/.test(valor);
        }

        function validarMayorEdad(valor) {
            if (!valor) {
                return false;
            }

            var fechaNacimiento = new Date(valor + "T00:00:00");
            var hoy = new Date();

            hoy.setHours(0, 0, 0, 0);

            if (fechaNacimiento >= hoy) {
                return false;
            }

            var fechaMinima = new Date(hoy.getFullYear() - 18, hoy.getMonth(), hoy.getDate());

            return fechaNacimiento <= fechaMinima;
        }

         function validarCorreo(valor) {
                    if (valor == null) {
                        return false;
                    }

                    valor = valor.trim().toLowerCase();

                    var arroba = String.fromCharCode(64);
                    var patron = "^[^\\s" + arroba + "]+"
                        + arroba
                        + "[^\\s" + arroba + "]+\\.[^\\s" + arroba + "]+$";

                    var regexCorreo = new RegExp(patron);
                    return regexCorreo.test(valor);
         }
    </script>
}