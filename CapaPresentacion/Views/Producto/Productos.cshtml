@{
    ViewBag.Title = "Productos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}



<style>
    .campo-ayuda-error {
        display: none;
        color: #d9534f;
        font-size: 12px;
        margin-top: 4px;
    }

    .input-error-suave {
        border-color: #d9534f !important;
    }

    .texto-tabla-secundario {
        font-size: 12px;
        color: #6c757d;
    }

    .codigo-producto {
        font-family: Consolas, monospace;
        font-weight: bold;
    }

    .bloque-importacion {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 12px;
        margin-bottom: 15px;
    }
</style>

<h4 class="font-weight-bold py-3 mb-0">Gestión de Productos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Inventario</li>
        <li class="breadcrumb-item active">Productos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de productos</h6>

        <div>
            <button type="button" class="btn btn-outline-secondary btn-sm mr-1" onclick="abrirModalImportacion()">
                Importar CSV
            </button>

            <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
                Nuevo producto
            </button>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered nowrap" id="tablaProductos" style="width:100%;">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Producto</th>
                        <th>Tipo</th>
                        <th>Impuesto</th>
                        <th>Precio venta</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo producto</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtCodigoProducto" value="" />

                <div class="alert alert-danger mt-2" id="mensajeError" style="display:none;"></div>

                <div class="form-group">
                    <label for="txtCodigoProductoVisible">Código producto</label>
                    <input type="text" id="txtCodigoProductoVisible" class="form-control codigo-producto" disabled />
                    <small class="form-text text-muted">
                        El código se genera automáticamente al guardar.
                    </small>
                </div>

                <div class="form-group">
                    <label for="txtNombreProducto">Nombre producto</label>
                    <input type="text" id="txtNombreProducto" class="form-control" maxlength="150" autocomplete="off" />
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="cboTipoProducto">Tipo de producto</label>
                            <select id="cboTipoProducto" class="form-control">
                                <option value="0">Seleccione</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="cboImpuesto">Impuesto</label>
                            <select id="cboImpuesto" class="form-control">
                                <option value="0">Seleccione</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="250" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 250 caracteres. Puede quedar vacío.</small>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="txtPrecioVenta">Precio venta con IVA incluido</label><input type="text" id="txtPrecioVenta" class="form-control" autocomplete="off" />
                            <small class="form-text text-muted">Use punto para decimales. Ejemplo: 1500.50</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="txtStockActual">Stock actual</label>
                            <input type="text" id="txtStockActual" class="form-control" autocomplete="off" />
                            <small class="form-text text-muted">Use punto para decimales. Ejemplo: 10.00</small>
                        </div>
                    </div>
                </div>

                <div class="form-group" id="grupoActivo">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarProducto()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="ModalImportacion" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Importar productos desde CSV</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="alert alert-danger" id="mensajeErrorImportacion" style="display:none;"></div>
                <div class="alert alert-success" id="mensajeExitoImportacion" style="display:none;"></div>

                <div class="bloque-importacion">
                    <strong>Formato requerido del CSV:</strong>
                    <div class="texto-tabla-secundario mt-2">
                        NombreProducto, TipoProducto, Impuesto, Descripcion, PrecioVenta, StockActual
                    </div>

                    <div class="mt-2">
                        <code>Arroz 80%, Abarrotes, IVA 13%, Bolsa de arroz, 1200.00, 25</code>
                    </div>
                </div>

                <div class="form-group">
                    <label for="archivoCsv">Archivo CSV</label>
                    <input type="file" id="archivoCsv" class="form-control" accept=".csv" />
                </div>

                <div id="detalleImportacion" class="mt-3" style="display:none;">
                    <h6>Detalle de errores</h6>
                    <ul id="listaErroresImportacion"></ul>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="importarProductosCsv()">
                    Importar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaProductos = [];
        var tablaProductos = null;

        $(document).ready(function () {
            cargarTiposProducto();
            cargarImpuestos();
            cargarProductos();

            $("#txtNombreProducto").on("input", function () {
                limpiarTextoGeneral("txtNombreProducto", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 150) {
                    $(this).val($(this).val().substring(0, 150));
                    mostrarAyudaCampo("txtNombreProducto", "El nombre no puede superar los 150 caracteres.");
                }
            });

            $("#txtDescripcion").on("input", function () {
                limpiarTextoGeneral("txtDescripcion", "Solo se permiten letras, números, espacios y caracteres básicos.");

                if ($(this).val().length > 250) {
                    $(this).val($(this).val().substring(0, 250));
                    mostrarAyudaCampo("txtDescripcion", "La descripción no puede superar los 250 caracteres.");
                }
            });

            $("#txtPrecioVenta, #txtStockActual").on("input", function () {
                var valor = $(this).val();

                valor = valor.replace(",", ".");
                valor = valor.replace(/[^0-9.]/g, "");

                var partes = valor.split(".");
                if (partes.length > 2) {
                    valor = partes[0] + "." + partes.slice(1).join("");
                }

                $(this).val(valor);
            });

            $("input, select, textarea").on("change keyup", function () {
                if ($("#mensajeError").is(":visible")) {
                    $("#mensajeError").fadeOut(150);
                }

                if ($("#mensajeErrorImportacion").is(":visible")) {
                    $("#mensajeErrorImportacion").fadeOut(150);
                }

                if ($("#mensajeExitoImportacion").is(":visible")) {
                    $("#mensajeExitoImportacion").fadeOut(150);
                }
            });

            $("#FormModal").on("hidden.bs.modal", function () {
                limpiarErrores();
            });

            $("#ModalImportacion").on("hidden.bs.modal", function () {
                limpiarImportacion();
            });
        });

        function cargarProductos() {
            $.ajax({
                url: '@Url.Action("ListarProductos", "Producto")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaProductos = respuesta.data || [];
                    pintarTabla();
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los productos.", "error");
                }
            });
        }

        function pintarTabla() {
            if (tablaProductos != null) {
                tablaProductos.clear().destroy();
                tablaProductos = null;
            }

            var tbody = $("#tablaProductos tbody");
            tbody.empty();

            $.each(listaProductos, function (i, item) {
                if (window.esAdministradorSistema !== true && item.Activo === false) {
                    return;
                }
                var codigoProducto = item.CodigoProducto || "";
                var nombreProducto = item.NombreProducto || "";
                var tipoProducto = item.TipoProductoNombre || "-";

                var impuesto = (item.ImpuestoNombre || "-") + " (" + formatearNumero(item.PorcentajeImpuesto) + "%)";
                var precio = formatearMoneda(item.PrecioVenta);
                var stock = formatearNumero(item.StockActual);

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var botonEditar = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-primary mr-1",
                    text: "Editar"
                }).on("click", function () {
                    abrirModal(item);
                });

                var botonEstado = $("<button>", {
                    type: "button",
                    class: "btn btn-sm btn-outline-danger",
                    text: obtenerTextoAccionEstado(true)
                }).on("click", function () {
                    inactivarProducto(item.CodigoProducto);
                });

                var acciones = $("<td>");
                acciones.append(botonEditar);

                if (item.Activo) {
                    acciones.append(botonEstado);
                }

                var celdaProducto = $("<td>");
                celdaProducto.append($("<div>").text(nombreProducto));
                celdaProducto.append($("<div>", {
                    class: "texto-tabla-secundario",
                    text: item.Descripcion || "Sin descripción"
                }));

                var fila = $("<tr>");
                fila.append($("<td>", { class: "codigo-producto", text: codigoProducto }));
                fila.append(celdaProducto);
                fila.append($("<td>").text(tipoProducto));
                fila.append($("<td>").text(impuesto));
                fila.append($("<td>").text(precio));
                fila.append($("<td>").text(stock));
                fila.append($("<td>").html(estado));
                fila.append(acciones);

                tbody.append(fila);
            });

            tablaProductos = $("#tablaProductos").DataTable({
                responsive: true,
                pageLength: 10,
                destroy: true,
                order: [[1, "asc"]],
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });
        }

        function cargarTiposProducto() {
            $.ajax({
                url: '@Url.Action("ListarTipoProductosActivos", "Producto")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboTipoProducto").empty();
                    $("#cboTipoProducto").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        $("#cboTipoProducto").append(
                            $("<option>", {
                                value: item.IdTipoProducto,
                                text: item.Nombre
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los tipos de producto.", "error");
                }
            });
        }

        function cargarImpuestos() {
            $.ajax({
                url: '@Url.Action("ListarImpuestos", "Catalogos")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    $("#cboImpuesto").empty();
                    $("#cboImpuesto").append('<option value="0">Seleccione</option>');

                    $.each(respuesta.data || [], function (i, item) {
                        var texto = item.Nombre + " (" + formatearNumero(item.Porcentaje) + "%)";

                        $("#cboImpuesto").append(
                            $("<option>", {
                                value: item.IdImpuesto,
                                text: texto
                            })
                        );
                    });
                },
                error: function () {
                    mostrarMensajeSistema("Error al cargar los impuestos.", "error");
                }
            });
        }

        function abrirModal(json) {
            limpiarErrores();

            $("#txtCodigoProducto").val("");
            $("#txtCodigoProductoVisible").val("Se generará automáticamente");

            $("#txtNombreProducto").val("");
            $("#cboTipoProducto").val("0");
            $("#cboImpuesto").val("0");
            $("#txtDescripcion").val("");
            $("#txtPrecioVenta").val("0.00");
            $("#txtStockActual").val("0.00");
            $("#cboActivo").val("true");

            $("#grupoActivo").hide();
            $("#tituloModal").text("Nuevo producto");

            if (json != null) {
                $("#txtCodigoProducto").val(json.CodigoProducto || "");
                $("#txtCodigoProductoVisible").val(json.CodigoProducto || "");

                $("#txtNombreProducto").val(json.NombreProducto || "");
                $("#cboTipoProducto").val(json.IdTipoProducto);
                $("#cboImpuesto").val(json.IdImpuesto);
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#txtPrecioVenta").val(formatearNumero(json.PrecioVenta));
                $("#txtStockActual").val(formatearNumero(json.StockActual));
                $("#cboActivo").val(json.Activo ? "true" : "false");

                $("#grupoActivo").show();
                $("#tituloModal").text("Editar producto");
            }

            $("#FormModal").modal("show");
        }

        function guardarProducto() {
            $("#mensajeError").hide().text("");

            var obj = {
                CodigoProducto: $("#txtCodigoProducto").val().trim(),
                NombreProducto: $("#txtNombreProducto").val().trim(),
                IdTipoProducto: parseInt($("#cboTipoProducto").val()),
                IdImpuesto: parseInt($("#cboImpuesto").val()),
                Descripcion: $("#txtDescripcion").val().trim(),
                PrecioVenta: parseFloat($("#txtPrecioVenta").val()),
                StockActual: parseFloat($("#txtStockActual").val()),
                Activo: $("#cboActivo").val() === "true"
            };

            if (isNaN(obj.IdTipoProducto)) obj.IdTipoProducto = 0;
            if (isNaN(obj.IdImpuesto)) obj.IdImpuesto = 0;
            if (isNaN(obj.PrecioVenta)) obj.PrecioVenta = -1;
            if (isNaN(obj.StockActual)) obj.StockActual = -1;

            if (obj.NombreProducto === "") {
                mostrarError("Debe ingresar el nombre del producto.", "txtNombreProducto");
                return;
            }

            if (!validarTextoGeneral(obj.NombreProducto)) {
                mostrarError("El nombre del producto solo puede contener letras, números, espacios y caracteres básicos.", "txtNombreProducto");
                return;
            }

            if (obj.NombreProducto.length > 150) {
                mostrarError("El nombre del producto no puede superar los 150 caracteres.", "txtNombreProducto");
                return;
            }

            if (obj.IdTipoProducto <= 0) {
                mostrarError("Debe seleccionar un tipo de producto.", "cboTipoProducto");
                return;
            }

            if (obj.IdImpuesto <= 0) {
                mostrarError("Debe seleccionar un impuesto.", "cboImpuesto");
                return;
            }

            if (obj.Descripcion.length > 250) {
                mostrarError("La descripción no puede superar los 250 caracteres.", "txtDescripcion");
                return;
            }

            if (obj.Descripcion !== "" && !validarTextoGeneral(obj.Descripcion)) {
                mostrarError("La descripción solo puede contener letras, números, espacios y caracteres básicos.", "txtDescripcion");
                return;
            }

            if (obj.PrecioVenta < 0) {
                mostrarError("El precio de venta no puede ser negativo.", "txtPrecioVenta");
                return;
            }

            if (obj.StockActual < 0) {
                mostrarError("El stock actual no puede ser negativo.", "txtStockActual");
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarProducto", "Producto")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado != 0 && respuesta.resultado !== false) {
                        $("#FormModal").modal("hide");
                        cargarProductos();
                        mostrarMensajeSistema("Producto guardado correctamente.", "exito");
                    } else {
                        $("#mensajeError").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el producto.").show();
                }
            });
        }

        function inactivarProducto(codigoProducto) {
            mostrarConfirmacionSistema(
                obtenerTituloAccionEstado(true),
                obtenerMensajeAccionEstado(true, "este producto"),
                function () {
                    ejecutarInactivarProducto(codigoProducto);
                },
                obtenerTextoAccionEstado(true),
                "btn-danger"
            );
        }

        function ejecutarInactivarProducto(codigoProducto) {
            $.ajax({
                url: '@Url.Action("InactivarProducto", "Producto")',
                type: "POST",
                data: JSON.stringify({ codigoProducto: codigoProducto }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarProductos();
                        mostrarMensajeSistema(obtenerMensajeExitoEstado(true, "Producto"), "exito");
                    } else {
                        mostrarMensajeSistema(respuesta.mensaje || "No se pudo procesar el producto.", "error");
                    }
                },
                error: function () {
                    mostrarMensajeSistema("Error al procesar el producto.", "error");
                }
            });
        }

        function abrirModalImportacion() {
            limpiarImportacion();
            $("#ModalImportacion").modal("show");
        }

        function importarProductosCsv() {
            $("#mensajeErrorImportacion").hide().text("");
            $("#mensajeExitoImportacion").hide().text("");
            $("#detalleImportacion").hide();
            $("#listaErroresImportacion").empty();

            var archivo = $("#archivoCsv")[0].files[0];

            if (!archivo) {
                $("#mensajeErrorImportacion").text("Debe seleccionar un archivo CSV.").show();
                return;
            }

            var formData = new FormData();
            formData.append("archivoCsv", archivo);

            $.ajax({
                url: '@Url.Action("ImportarProductosCsv", "Producto")',
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        $("#mensajeExitoImportacion").text(respuesta.mensaje).show();

                        if (respuesta.detalle && respuesta.detalle.length > 0) {
                            $.each(respuesta.detalle, function (i, item) {
                                $("#listaErroresImportacion").append($("<li>").text(item));
                            });

                            $("#detalleImportacion").show();
                        }

                        cargarProductos();
                    } else {
                        $("#mensajeErrorImportacion").text(respuesta.mensaje).show();
                    }
                },
                error: function () {
                    $("#mensajeErrorImportacion").text("Error al importar productos.").show();
                }
            });
        }

        function limpiarImportacion() {
            $("#archivoCsv").val("");
            $("#mensajeErrorImportacion").hide().text("");
            $("#mensajeExitoImportacion").hide().text("");
            $("#detalleImportacion").hide();
            $("#listaErroresImportacion").empty();
        }

        function mostrarError(mensaje, idCampo) {
            $("#mensajeError").text(mensaje).show();

            if (idCampo) {
                mostrarAyudaCampo(idCampo, mensaje);
                $("#" + idCampo).focus();
            }
        }

        function mostrarAyudaCampo(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            if ($("#" + idMensaje).length === 0) {
                campo.after('<small id="' + idMensaje + '" class="campo-ayuda-error"></small>');
            }

            $("#" + idMensaje).text(mensaje).fadeIn(150);
            campo.addClass("input-error-suave");
        }

        function ocultarAyudaCampo(idCampo) {
            var campo = $("#" + idCampo);
            var idMensaje = "msg_" + idCampo;

            $("#" + idMensaje).fadeOut(150);
            campo.removeClass("input-error-suave");
        }

        function limpiarErrores() {
            $("#mensajeError").hide().text("");
            $(".campo-ayuda-error").hide().text("");
            $(".input-error-suave").removeClass("input-error-suave");
        }

        function limpiarTextoGeneral(idCampo, mensaje) {
            var campo = $("#" + idCampo);
            var valorOriginal = campo.val();
            var valorLimpio = valorOriginal.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]/g, "");

            if (valorOriginal !== valorLimpio) {
                campo.val(valorLimpio);
                mostrarAyudaCampo(idCampo, mensaje);
            } else {
                ocultarAyudaCampo(idCampo);
            }
        }

        function validarTextoGeneral(valor) {
            return /^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ0-9\s.,#\-_/&()]+$/.test(valor);
        }

        function formatearNumero(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                return "0.00";
            }

            return numero.toFixed(2);
        }

        function formatearMoneda(valor) {
            var numero = parseFloat(valor);

            if (isNaN(numero)) {
                numero = 0;
            }

            return "₡" + numero.toLocaleString("es-CR", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }
    </script>
}