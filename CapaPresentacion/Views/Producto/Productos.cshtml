@{
    ViewBag.Title = "Productos";
    Layout = "~/Views/Shared/_LayoutMantenimientos.cshtml";
}

<h4 class="font-weight-bold py-3 mb-0">Mantenimiento de Productos</h4>

<div class="text-muted small mt-0 mb-4 d-block breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Mantenimientos")">
                <i class="feather icon-home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Inventario</li>
        <li class="breadcrumb-item active">Productos</li>
    </ol>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Lista de productos</h6>

        <button type="button" class="btn btn-primary btn-sm" onclick="abrirModal(null)">
            Nuevo producto
        </button>
    </div>

    <div class="card-body">

        <div class="form-row mb-3">
            <div class="col-md-5">
                <input type="text" id="txtBuscar" class="form-control" placeholder="Buscar por código, producto o tipo...">
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered" id="tablaProductos">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Producto</th>
                        <th>Tipo</th>
                        <th>Precio venta</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th style="width:170px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal fade" id="FormModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="tituloModal">Nuevo producto</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdProducto" value="0" />

                <div class="form-row">

                    <div class="form-group col-md-4">
                        <label for="txtCodigoProducto">Código del producto</label>
                        <input type="text" id="txtCodigoProducto" class="form-control" maxlength="45" autocomplete="off" readonly placeholder="Se genera automáticamente" />
                    </div>

                    <div class="form-group col-md-8">
                        <label for="txtNombreProducto">Nombre del producto</label>
                        <input type="text" id="txtNombreProducto" class="form-control" maxlength="150" autocomplete="off" />
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group col-md-6">
                        <label for="cboTipoProducto">Tipo de producto</label>
                        <select id="cboTipoProducto" class="form-control">
                            <option value="0">Seleccione un tipo de producto</option>
                        </select>
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtPrecioVenta">Precio venta</label>
                        <input type="number" id="txtPrecioVenta" class="form-control" min="0" step="0.01" />
                    </div>

                    <div class="form-group col-md-3">
                        <label for="txtStockActual">Stock actual</label>
                        <input type="number" id="txtStockActual" class="form-control" min="0" step="0.01" />
                    </div>

                </div>

                <div class="form-group">
                    <label for="txtDescripcion">Descripción</label>
                    <textarea id="txtDescripcion" class="form-control" maxlength="250" rows="3"></textarea>
                    <small class="form-text text-muted">Máximo 250 caracteres.</small>
                </div>

                <div class="form-group">
                    <label for="cboActivo">Estado</label>
                    <select id="cboActivo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="alert alert-danger mt-3" id="mensajeError" style="display:none;"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cerrar
                </button>
                <button type="button" class="btn btn-primary" onclick="guardarProducto()">
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        var listaProductos = [];

        $(document).ready(function () {
            cargarTipoProductosActivos();
            cargarProductos();

            $("#txtBuscar").on("keyup", function () {
                pintarTabla();
            });
        });

        function cargarProductos() {
            $.ajax({
                url: '@Url.Action("ListarProductos", "Producto")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {
                    listaProductos = respuesta.data;
                    pintarTabla();
                },
                error: function () {
                    alert("Error al cargar los productos.");
                }
            });
        }

        function cargarTipoProductosActivos() {
            $.ajax({
                url: '@Url.Action("ListarTipoProductosActivos", "Producto")',
                type: "GET",
                dataType: "json",
                success: function (respuesta) {

                    $("#cboTipoProducto").empty();
                    $("#cboTipoProducto").append('<option value="0">Seleccione un tipo de producto</option>');

                    $.each(respuesta.data, function (i, item) {

                        var nombre = item.Nombre || item.TipoProductoNombre || "";

                        $("#cboTipoProducto").append(
                            $("<option>", {
                                value: item.IdTipoProducto,
                                text: nombre
                            })
                        );
                    });

                    $("#cboTipoProducto").trigger("change");
                },
                error: function () {
                    alert("Error al cargar los tipos de producto.");
                }
            });
        }

        function pintarTabla() {
            var filtro = $("#txtBuscar").val().toLowerCase();
            var tbody = $("#tablaProductos tbody");

            tbody.empty();

            $.each(listaProductos, function (i, item) {

                var codigo = item.CodigoProducto || "";
                var nombre = item.NombreProducto || "";
                var tipo = item.TipoProductoNombre || "";
                var descripcion = item.Descripcion || "";

                var texto = (codigo + " " + nombre + " " + tipo + " " + descripcion).toLowerCase();

                if (texto.indexOf(filtro) === -1) {
                    return;
                }

                var estado = item.Activo
                    ? '<span class="badge badge-success">Activo</span>'
                    : '<span class="badge badge-secondary">Inactivo</span>';

                var precio = parseFloat(item.PrecioVenta || 0).toFixed(2);
                var stock = parseFloat(item.StockActual || 0).toFixed(2);

                var fila = `
                    <tr>
                        <td>${codigo}</td>
                        <td>${nombre}</td>
                        <td>${tipo}</td>
                        <td>₡${precio}</td>
                        <td>${stock}</td>
                        <td>${estado}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick='abrirModal(${JSON.stringify(item)})'>
                                Editar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="inactivarProducto(${item.IdProducto})">
                                Inactivar
                            </button>
                        </td>
                    </tr>
                `;

                tbody.append(fila);
            });
        }

        function abrirModal(json) {
            $("#mensajeError").hide().text("");

            $("#txtIdProducto").val(0);
            $("#txtCodigoProducto").val("");
            $("#txtNombreProducto").val("");
            $("#cboTipoProducto").val(0);
            $("#txtPrecioVenta").val("0.00");
            $("#txtStockActual").val("0.00");
            $("#txtDescripcion").val("");
            $("#cboActivo").val("true");
            $("#tituloModal").text("Nuevo producto");

            if (json != null) {
                $("#txtIdProducto").val(json.IdProducto);
                $("#txtCodigoProducto").val(json.CodigoProducto);
                $("#txtNombreProducto").val(json.NombreProducto);
                $("#cboTipoProducto").val(json.IdTipoProducto);
                $("#txtPrecioVenta").val(parseFloat(json.PrecioVenta || 0).toFixed(2));
                $("#txtStockActual").val(parseFloat(json.StockActual || 0).toFixed(2));
                $("#txtDescripcion").val(json.Descripcion || "");
                $("#cboActivo").val(json.Activo ? "true" : "false");
                $("#tituloModal").text("Editar producto");
            }

            $("#FormModal").modal("show");
        }

        function guardarProducto() {
            var obj = {
                IdProducto: parseInt($("#txtIdProducto").val()),
                CodigoProducto: $("#txtCodigoProducto").val().trim(),
                NombreProducto: $("#txtNombreProducto").val().trim(),
                IdTipoProducto: parseInt($("#cboTipoProducto").val()),
                Descripcion: $("#txtDescripcion").val().trim(),
                PrecioVenta: parseFloat($("#txtPrecioVenta").val()),
                StockActual: parseFloat($("#txtStockActual").val()),
                Activo: $("#cboActivo").val() === "true"
            };

            if (obj.IdProducto !== 0 && obj.CodigoProducto === "") {
                $("#mensajeError").text("El código del producto no puede estar vacío.").show();
                return;
            }

            if (obj.IdProducto !== 0 && obj.CodigoProducto.length > 45) {
                $("#mensajeError").text("El código no puede superar los 45 caracteres.").show();
                return;
            }

            if (obj.NombreProducto === "") {
                $("#mensajeError").text("Debe ingresar el nombre del producto.").show();
                return;
            }

            if (obj.NombreProducto.length > 150) {
                $("#mensajeError").text("El nombre no puede superar los 150 caracteres.").show();
                return;
            }

            if (obj.IdTipoProducto === 0) {
                $("#mensajeError").text("Debe seleccionar un tipo de producto.").show();
                return;
            }

            if (obj.Descripcion.length > 250) {
                $("#mensajeError").text("La descripción no puede superar los 250 caracteres.").show();
                return;
            }

            if (isNaN(obj.PrecioVenta)) {
                $("#mensajeError").text("Debe ingresar un precio de venta válido.").show();
                return;
            }

            if (obj.PrecioVenta < 0) {
                $("#mensajeError").text("El precio de venta no puede ser negativo.").show();
                return;
            }

            if (isNaN(obj.StockActual)) {
                $("#mensajeError").text("Debe ingresar un stock válido.").show();
                return;
            }

            if (obj.StockActual < 0) {
                $("#mensajeError").text("El stock actual no puede ser negativo.").show();
                return;
            }

            $.ajax({
                url: '@Url.Action("GuardarProducto", "Producto")',
                type: "POST",
                data: JSON.stringify({ obj: obj }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {

                    if (obj.IdProducto === 0) {
                        if (respuesta.resultado != 0) {
                            $("#FormModal").modal("hide");
                            cargarProductos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    } else {
                        if (respuesta.resultado) {
                            $("#FormModal").modal("hide");
                            cargarProductos();
                        } else {
                            $("#mensajeError").text(respuesta.mensaje).show();
                        }
                    }
                },
                error: function () {
                    $("#mensajeError").text("Error al guardar el producto.").show();
                }
            });
        }

        function inactivarProducto(id) {
            if (!confirm("¿Desea inactivar este producto?")) {
                return;
            }

            $.ajax({
                url: '@Url.Action("InactivarProducto", "Producto")',
                type: "POST",
                data: JSON.stringify({ id: id }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (respuesta) {
                    if (respuesta.resultado) {
                        cargarProductos();
                    } else {
                        alert(respuesta.mensaje);
                    }
                },
                error: function () {
                    alert("Error al inactivar el producto.");
                }
            });
        }
    </script>
}